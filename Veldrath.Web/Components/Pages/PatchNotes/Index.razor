@page "/patch-notes"
@inject VeldrathApiClient Api
@using Veldrath.Contracts.Editorial
@using Veldrath.Contracts.Foundry

<PageTitle>Patch Notes — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Style="margin-top:32px">
    <MudText Typo="Typo.h4" GutterBottom="true">Patch Notes</MudText>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-4 d-flex justify-center" />
    }
    else if (_result is null || _result.Items.Count == 0)
    {
        <MudText>No patch notes published yet. Check back soon!</MudText>
    }
    else
    {
        @foreach (var item in _result.Items)
        {
            <MudPaper Class="pa-4 mb-3" Outlined="true">
                <MudLink Href="@($"/patch-notes/{item.Slug}")" Typo="Typo.h6">@item.Title</MudLink>
                <MudStack Row="true" Spacing="3" Class="mt-1">
                    <MudText Typo="Typo.caption" Color="Color.Primary">v@item.Version</MudText>
                    @if (item.PublishedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @item.PublishedAt.Value.ToLocalTime().ToString("MMMM d, yyyy")
                        </MudText>
                    }
                </MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@item.Summary</MudText>
            </MudPaper>
        }

        @if (_result.TotalCount > _result.PageSize)
        {
            <MudPagination Selected="_page"
                           Count="@((int)Math.Ceiling((double)_result.TotalCount / _result.PageSize))"
                           Size="Size.Small"
                           Class="mt-4"
                           SelectedChanged="OnPageChanged" />
        }
    }
</MudContainer>

@code {
    private PagedResult<PatchNoteSummaryDto>? _result;
    private bool _loading = true;
    private int _page = 1;

    protected override async Task OnInitializedAsync()
        => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Api.GetPatchNotesAsync(_page);
        _loading = false;
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }
}
