@page "/patch-notes/{Slug}"
@inject VeldrathApiClient Api
@using Markdig
@using Microsoft.AspNetCore.Components
@using Veldrath.Contracts.Editorial

<PageTitle>@(_note?.Title ?? "Patch Note") — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Style="margin-top:32px">
    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8 d-flex justify-center" />
    }
    else if (_note is null)
    {
        <MudText Typo="Typo.h4" GutterBottom="true">Not Found</MudText>
        <MudText Class="mb-4">That patch note doesn't exist or hasn't been published yet.</MudText>
        <MudLink Href="/patch-notes">← Back to Patch Notes</MudLink>
    }
    else
    {
        <MudLink Href="/patch-notes" Typo="Typo.body2" Class="mb-2 d-block">← Patch Notes</MudLink>
        <MudText Typo="Typo.h3" GutterBottom="true">@_note.Title</MudText>
        <MudStack Row="true" Spacing="3" Class="mb-4">
            <MudChip T="string" Color="Color.Primary" Size="Size.Small">v@_note.Version</MudChip>
            @if (_note.PublishedAt.HasValue)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @_note.PublishedAt.Value.ToLocalTime().ToString("MMMM d, yyyy")
                </MudText>
            }
        </MudStack>
        <MudPaper Class="pa-6" Outlined="true">
            <div class="markdown-content">
                @((MarkupString)_html)
            </div>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private PatchNoteDto? _note;
    private string _html = "";
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _note    = await Api.GetPatchNoteAsync(Slug);
        _html    = _note is not null
            ? Markdown.ToHtml(_note.Content, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build())
            : "";
        _loading = false;
    }
}
