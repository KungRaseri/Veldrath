@page "/lore"
@inject VeldrathApiClient Api
@using Veldrath.Contracts.Editorial
@using Veldrath.Contracts.Foundry

<PageTitle>World Lore — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">World Lore</MudText>

    <MudSelect @bind-Value="_category" Label="Category" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4 select-narrow">
        <MudSelectItem Value="@((string?)null)">All Categories</MudSelectItem>
        <MudSelectItem Value="@("History")">History</MudSelectItem>
        <MudSelectItem Value="@("Factions")">Factions</MudSelectItem>
        <MudSelectItem Value="@("Geography")">Geography</MudSelectItem>
        <MudSelectItem Value="@("Mythology")">Mythology</MudSelectItem>
        <MudSelectItem Value="@("Characters")">Characters</MudSelectItem>
    </MudSelect>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-4 d-flex justify-center" />
    }
    else if (_result is null || _result.Items.Count == 0)
    {
        <MudText>No lore articles published yet. The world awaits its history.</MudText>
    }
    else
    {
        @foreach (var item in _result.Items)
        {
            <MudPaper Class="pa-4 mb-3" Outlined="true">
                <MudLink Href="@($"/lore/{item.Slug}")" Typo="Typo.h6">@item.Title</MudLink>
                <MudText Typo="Typo.caption" Color="Color.Primary" Class="mt-1">@item.Category</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@item.Summary</MudText>
            </MudPaper>
        }

        @if (_result.TotalCount > _result.PageSize)
        {
            <MudPagination Selected="_page"
                           Count="@((int)Math.Ceiling((double)_result.TotalCount / _result.PageSize))"
                           Size="Size.Small"
                           Class="mt-4"
                           SelectedChanged="OnPageChanged" />
        }
    }
</MudContainer>

@code {
    private PagedResult<LoreArticleSummaryDto>? _result;
    private bool _loading = true;
    private string? _category;
    private int _page = 1;

    protected override async Task OnInitializedAsync()
        => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Api.GetLoreArticlesAsync(_page, category: _category);
        _loading = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Re-trigger load when category changes via bind
        if (_result is not null)
            await LoadAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }
}
