@page "/lore/{Slug}"
@inject VeldrathApiClient Api
@using Markdig
@using Microsoft.AspNetCore.Components
@using Veldrath.Contracts.Editorial

<PageTitle>@(_article?.Title ?? "Lore") — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8 d-flex justify-center" />
    }
    else if (_article is null)
    {
        <MudText Typo="Typo.h4" GutterBottom="true">Not Found</MudText>
        <MudText Class="mb-4">That article doesn't exist or hasn't been published yet.</MudText>
        <MudLink Href="/lore">← Back to Lore</MudLink>
    }
    else
    {
        <MudLink Href="/lore" Typo="Typo.body2" Class="mb-2 d-block">← World Lore</MudLink>
        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="mb-2">@_article.Category</MudChip>
        <MudText Typo="Typo.h3" GutterBottom="true">@_article.Title</MudText>
        <MudPaper Class="pa-6" Outlined="true">
            <div class="markdown-content text-lore">
                @((MarkupString)_html)
            </div>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private LoreArticleDto? _article;
    private string _html = "";
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading  = true;
        _article  = await Api.GetLoreArticleAsync(Slug);
        _html     = _article is not null
            ? Markdown.ToHtml(_article.Content, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build())
            : "";
        _loading  = false;
    }
}
