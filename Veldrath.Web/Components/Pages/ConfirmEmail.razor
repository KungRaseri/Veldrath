@page "/confirm-email"
@inject VeldrathApiClient Api
@inject NavigationManager Nav

<PageTitle>Confirm Email — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mt-16">
    <MudPaper Class="pa-8" Outlined="true">
        @if (_loading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            <MudText>Confirming your email address…</MudText>
        }
        else if (_done)
        {
            <MudText Color="Color.Success">Your email has been confirmed! <MudLink Href="/">Return to Veldrath</MudLink></MudText>
        }
        else
        {
            <MudText Color="Color.Error">@(_error ?? "Confirmation failed. The link may have expired.")</MudText>
            <MudText Class="mt-4"><MudLink Href="/login">Back to sign in</MudLink></MudText>
        }
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "userId")] private string? UserId { get; set; }
    [SupplyParameterFromQuery(Name = "token")]  private string? Token  { get; set; }

    private bool    _loading = true;
    private bool    _done;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            _error   = "Invalid confirmation link — userId or token is missing.";
            _loading = false;
            return;
        }

        var (ok, error) = await Api.ConfirmEmailAsync(UserId, Token);
        _done    = ok;
        _error   = error;
        _loading = false;
    }
}
