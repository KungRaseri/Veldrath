@page "/reset-password"
@inject VeldrathApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mt-16">
    <MudPaper Class="pa-8" Outlined="true">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Reset Password</MudText>

        @if (_done)
        {
            <MudText Color="Color.Success">
                Your password has been reset. <MudLink Href="/login">Sign in</MudLink>
            </MudText>
        }
        else if (_tokenMissing)
        {
            <MudText Color="Color.Error">
                This reset link is incomplete or has already been used.
                <MudLink Href="/forgot-password">Request a new one</MudLink>.
            </MudText>
        }
        else
        {
            <MudTextField @bind-Value="_password"
                           Label="New password"
                           InputType="InputType.Password"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-3" />
            <MudTextField @bind-Value="_confirm"
                           Label="Confirm new password"
                           InputType="InputType.Password"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-3" />

            @if (_error is not null)
            {
                <MudText Color="Color.Error" Typo="Typo.body2" Class="mb-2">@_error</MudText>
            }

            <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        FullWidth="true"
                        OnClick="SubmitAsync"
                        Disabled="@_submitting">
                @(_submitting ? "Resetting…" : "Set new password")
            </MudButton>
        }
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery] private string? Email { get; set; }
    [SupplyParameterFromQuery] private string? Token { get; set; }

    private string  _password  = string.Empty;
    private string  _confirm   = string.Empty;
    private bool    _submitting;
    private bool    _done;
    private bool    _tokenMissing;
    private string? _error;

    protected override void OnInitialized()
    {
        _tokenMissing = string.IsNullOrWhiteSpace(Token) || string.IsNullOrWhiteSpace(Email);
    }

    private async Task SubmitAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_password)) { _error = "Please enter a new password."; return; }
        if (_password != _confirm) { _error = "Passwords do not match."; return; }

        _submitting = true;
        try
        {
            var (ok, error) = await Api.ResetPasswordAsync(Email!, Token!, _password);
            if (ok)
                _done = true;
            else
                _error = error ?? "Password reset failed. The link may have expired.";
        }
        finally
        {
            _submitting = false;
        }
    }
}
