@page "/Error"
@using Microsoft.AspNetCore.Diagnostics
@using Veldrath.Web.Components.Layout
@inject NavigationManager Nav

<PageTitle>Error — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16">
    <MudPaper Class="pa-8" Outlined="true">
        <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Error" Size="Size.Large" Class="mb-2 icon-3x" />

        @if (IsDevelopment)
        {
            <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Development Error</MudText>
            <MudText Color="Color.Secondary" Align="Align.Center" Class="mb-4">
                An unhandled exception occurred while processing your request.
            </MudText>

            @if (Exception is not null)
            {
                <MudPaper Class="pa-4 mb-4 paper-danger">
                    <MudText Typo="Typo.h6" GutterBottom="true">Exception Details</MudText>
                    <MudText><strong>Type:</strong> <code>@Exception.GetType().FullName</code></MudText>
                    <MudText><strong>Message:</strong> @Exception.Message</MudText>
                    @if (OriginalPath is not null)
                    {
                        <MudText><strong>Original Path:</strong> <code>@OriginalPath@OriginalQueryString</code></MudText>
                    }
                    <MudPaper Class="pa-3 mt-3 paper-code">
                        <pre class="stack-trace">@Exception.StackTrace</pre>
                    </MudPaper>
                </MudPaper>
            }
            else
            {
                <MudText Class="mb-4">The exception details are not available.</MudText>
                @if (OriginalPath is not null)
                {
                    <MudText><strong>Original Path:</strong> <code>@OriginalPath@OriginalQueryString</code></MudText>
                }
            }

            <MudText Color="Color.Secondary" Typo="Typo.body2" Class="mb-4">
                <strong>Tip:</strong> See the browser's developer console and the server logs for more information.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Something went wrong</MudText>
            <MudText Color="Color.Secondary" Align="Align.Center" Class="mb-4">
                An error occurred while processing your request.
                Our team has been notified and we're working to resolve the issue.
            </MudText>
            <MudText Align="Align.Center" Class="mb-4">Please try again in a few moments.</MudText>
        }

        <MudStack Row="true" Justify="Justify.Center" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Return to Home</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="() => Nav.Refresh(forceReload: true)">Try Again</MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>
