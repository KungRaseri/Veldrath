@page "/community"

<PageTitle>Community — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Community</MudText>

    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6">
            <MudPaper Class="pa-6" Outlined="true">
                <MudText Typo="Typo.h6" GutterBottom="true">Discord</MudText>
                <MudText Class="mb-4">Join the conversation, share builds, and connect with other players.</MudText>
                <MudButton Variant="Variant.Filled"
                            Style="background-color: #5865F2; color: #fff;"
                            Href="https://discord.gg/veldrath"
                            Target="_blank"
                            Class="btn-oauth-discord">
                    Join Discord
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudPaper Class="pa-6" Outlined="true">
                <MudText Typo="Typo.h6" GutterBottom="true">RealmFoundry</MudText>
                <MudText Class="mb-4">Submit and curate community content that shapes the world of Veldrath.</MudText>
                <MudButton Variant="Variant.Filled"
                            Href="https://foundry.veldrath.com"
                            Target="_blank">
                    Open RealmFoundry
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
