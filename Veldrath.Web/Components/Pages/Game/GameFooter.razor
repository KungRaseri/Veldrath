@using Veldrath.GameClient.Core.Services
@* Bottom action bar showing zone info, connection status, and embedded ActionBar component. *@

<div class="game-footer">
    <div class="game-footer-left">
        @if (!string.IsNullOrEmpty(GameState.CurrentZoneName))
        {
            <span class="game-footer-zone">📍 @GameState.CurrentZoneName</span>
        }
        else
        {
            <span class="game-footer-zone">No zone</span>
        }
    </div>

    <div class="game-footer-center">
        <ActionBar ShowAttack="GameState.IsInCombat"
                   ShowDefend="GameState.IsInCombat"
                   ShowFlee="GameState.IsInCombat"
                   ShowRespawn="false" />
    </div>

    <div class="game-footer-right">
        <span class="game-footer-status">
            <span class="game-footer-dot @(GameState.IsConnected ? "dot-connected" : "dot-disconnected")"></span>
            @(GameState.IsConnected ? "Connected" : "Disconnected")
        </span>
        @if (!string.IsNullOrEmpty(GameState.ServerConnectionId))
        {
            <span class="game-footer-connid" title="Connection ID">#@GameState.ServerConnectionId[..Math.Min(8, GameState.ServerConnectionId.Length)]</span>
        }
    </div>
</div>

@code {
    /// <summary>The game state service, injected by Blazor.</summary>
    [Inject] private GameStateService GameState { get; set; } = null!;
}
