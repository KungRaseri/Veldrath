@page "/account/profile"
@using Veldrath.Contracts.Account
@inject NavigationManager Nav
@inject IConfiguration Config
@inject VeldrathApiClient Api
@inject AuthStateService AuthState
@implements IDisposable

<PageTitle>My Account — Veldrath</PageTitle>

@if (!AuthState.IsAuthReady)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8 d-flex justify-center" />
}
else if (!AuthState.IsLoggedIn)
{
    <MudText>Checking authentication...</MudText>
}
else if (_profile is null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8 d-flex justify-center" />
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Style="margin-top:32px">
        @if (_successMessage is not null)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@_successMessage</MudAlert>
        }
        @if (_errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
        }

        <!-- Profile -->
        <MudPaper Class="pa-6 mb-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Profile</MudText>

            <MudStack Spacing="3">
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Username</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="8">
                        @if (_editingUsername)
                        {
                            <MudStack Row="true" Spacing="2">
                                <MudTextField @bind-Value="_newUsername" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1" />
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="SaveUsernameAsync" Disabled="@_saving">Save</MudButton>
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="() => _editingUsername = false">Cancel</MudButton>
                            </MudStack>
                            @if (_usernameError is not null)
                            {
                                <MudText Color="Color.Error" Typo="Typo.body2">@_usernameError</MudText>
                            }
                        }
                        else
                        {
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudText>@_profile.Username</MudText>
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="StartEditUsername">Change</MudButton>
                            </MudStack>
                        }
                    </MudItem>
                </MudGrid>

                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Display Name</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="8">
                        @if (_editingProfile)
                        {
                            <MudTextField @bind-Value="_newDisplayName" Placeholder="Optional public name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        }
                        else
                        {
                            <MudText Color="Color.Secondary">@(_profile.DisplayName ?? "—")</MudText>
                        }
                    </MudItem>
                </MudGrid>

                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Bio</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="8">
                        @if (_editingProfile)
                        {
                            <MudTextField @bind-Value="_newBio" Lines="3" Placeholder="Tell the community about yourself" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        }
                        else
                        {
                            <MudText Color="Color.Secondary">@(_profile.Bio ?? "—")</MudText>
                        }
                    </MudItem>
                </MudGrid>
            </MudStack>

            @if (_editingProfile)
            {
                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProfileAsync" Disabled="@_saving">Save</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="CancelEditProfile">Cancel</MudButton>
                </MudStack>
                @if (_profileError is not null)
                {
                    <MudText Color="Color.Error" Typo="Typo.body2" Class="mt-2">@_profileError</MudText>
                }
            }
            else
            {
                <MudButton Variant="Variant.Text" OnClick="StartEditProfile" Class="mt-2">Edit profile</MudButton>
            }
        </MudPaper>

        <!-- Email -->
        <MudPaper Class="pa-6 mb-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Email</MudText>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Address</MudText>
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudText>@(_profile.Email ?? "—")</MudText>
                        @if (_profile.EmailConfirmed)
                        {
                            <span class="chip chip-success">Confirmed</span>
                        }
                        else
                        {
                            <span class="chip chip-warning">Unconfirmed</span>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ResendConfirmationAsync" Disabled="@_saving">Resend confirmation</MudButton>
                        }
                    </MudStack>
                    @if (_emailMessage is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_emailMessage</MudText>
                    }
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- Security -->
        <MudPaper Class="pa-6 mb-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Security</MudText>
            @if (!_profile.HasPassword)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Your account uses OAuth login only. Use <MudLink Href="/forgot-password">Forgot Password</MudLink>
                    to set a password so you can also sign in with email.
                </MudText>
            }
            else
            {
                @if (_changingPassword)
                {
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_currentPassword" Label="Current Password" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_newPassword" Label="New Password" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_confirmPassword" Label="Confirm New Password" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudStack>
                    <MudStack Row="true" Spacing="2" Class="mt-3">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePasswordAsync" Disabled="@_saving">Update password</MudButton>
                        <MudButton Variant="Variant.Outlined" OnClick="CancelChangePassword">Cancel</MudButton>
                    </MudStack>
                    @if (_passwordError is not null)
                    {
                        <MudText Color="Color.Error" Typo="Typo.body2" Class="mt-2">@_passwordError</MudText>
                    }
                }
                else
                {
                    <MudButton Variant="Variant.Text" OnClick="() => _changingPassword = true">Change password</MudButton>
                }
            }
        </MudPaper>

        <!-- Connected Providers -->
        <MudPaper Class="pa-6 mb-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Connected Accounts</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Link a provider to sign in without a password.</MudText>

            @foreach (var row in _providerRows)
            {
                var linked = _profile.LinkedProviders.FirstOrDefault(
                    p => p.ProviderName.Equals(row.Name, StringComparison.OrdinalIgnoreCase));

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="py-2" Style="border-bottom:1px solid var(--vds-border)">
                    <MudText Style="min-width:100px">@row.Label</MudText>
                    @if (linked is not null)
                    {
                        <span class="chip chip-success">Linked @(linked.LinkedAt?.ToLocalTime().ToString("d") ?? "–")</span>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                    OnClick="() => UnlinkAsync(row.Name, linked.ProviderKey)"
                                    Disabled="@_saving">
                            Unlink
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Text" Size="Size.Small" Href="@BuildLinkUrl(row.Name)">Link</MudButton>
                    }
                </MudStack>
            }
            @if (_providerError is not null)
            {
                <MudText Color="Color.Error" Typo="Typo.body2" Class="mt-2">@_providerError</MudText>
            }
        </MudPaper>

        <!-- Active Sessions -->
        <MudPaper Class="pa-6 mb-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Active Sessions</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Each entry represents an active sign-in from a device or browser.</MudText>

            @foreach (var s in _sessions)
            {
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="py-2" Style="border-bottom:1px solid var(--vds-border)">
                    <MudStack Spacing="0" Style="flex:1">
                        <MudText>@s.CreatedByIp</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Started @s.CreatedAt.ToLocalTime().ToString("g") ·
                            Expires @s.ExpiresAt.ToLocalTime().ToString("d")
                        </MudText>
                    </MudStack>
                    @if (s.IsCurrent)
                    {
                        <span class="chip chip-success">Current</span>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                    OnClick="() => RevokeSessionAsync(s.Id)"
                                    Disabled="@_saving">
                            Revoke
                        </MudButton>
                    }
                </MudStack>
            }
            @if (_sessions.Count > 1)
            {
                <MudButton Variant="Variant.Text" Class="mt-3"
                            OnClick="RevokeOtherSessionsAsync"
                            Disabled="@(_saving || AuthState.SessionId is null)">
                    Sign out everywhere else
                </MudButton>
            }
            @if (_sessionError is not null)
            {
                <MudText Color="Color.Error" Typo="Typo.body2" Class="mt-2">@_sessionError</MudText>
            }
        </MudPaper>
    </MudContainer>
}

@code {
    private record ProviderRow(string Name, string Label);

    private static readonly ProviderRow[] _providerRows =
    [
        new("Discord",   "Discord"),
        new("Google",    "Google"),
        new("Microsoft", "Microsoft"),
    ];

    [SupplyParameterFromQuery(Name = "linked")] private string? LinkedParam { get; set; }
    [SupplyParameterFromQuery(Name = "error")]  private string? ErrorParam  { get; set; }

    private AccountProfileDto? _profile;
    private bool  _saving;

    // Profile edit
    private bool    _editingProfile;
    private string? _newDisplayName;
    private string? _newBio;
    private string? _profileError;

    // Username edit
    private bool    _editingUsername;
    private string  _newUsername = string.Empty;
    private string? _usernameError;

    // Password change
    private bool    _changingPassword;
    private string  _currentPassword = string.Empty;
    private string  _newPassword     = string.Empty;
    private string  _confirmPassword = string.Empty;
    private string? _passwordError;

    // Provider management
    private string? _providerError;

    // Session management
    private List<AccountSessionDto> _sessions    = [];
    private string?                 _sessionError;

    // Banners
    private string? _successMessage;
    private string? _errorMessage;
    private string? _emailMessage;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;
    }

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthReady)
            return;

        if (!AuthState.IsLoggedIn)
        {
            Nav.NavigateTo("/login", forceLoad: false);
            return;
        }

        await AuthState.TryRefreshAsync();

        if (LinkedParam == "1")
            _successMessage = "Provider linked successfully.";
        else if (ErrorParam == "link_failed")
            _errorMessage = "Failed to link provider. Please try again.";

        await LoadProfileWithRetryAsync();
        if (_profile is not null)
            await LoadSessionsWithRetryAsync();
    }

    /// <summary>
    /// Loads the profile from the API, retrying once if the initial call fails
    /// (e.g. with a 401 due to a stale Bearer token from a concurrent renew).
    /// </summary>
    private async Task LoadProfileWithRetryAsync()
    {
        await LoadProfileAsync();
        if (_profile is null && AuthState.IsLoggedIn)
        {
            await AuthState.TryRefreshAsync();
            await LoadProfileAsync();
        }
    }

    /// <summary>
    /// Loads the session list from the API, retrying once if the initial call fails.
    /// </summary>
    private async Task LoadSessionsWithRetryAsync()
    {
        await LoadSessionsAsync();
        if (_sessions.Count == 0 && AuthState.IsLoggedIn)
        {
            await AuthState.TryRefreshAsync();
            await LoadSessionsAsync();
        }
    }

    private async void OnAuthStateChanged()
    {
        if (AuthState.IsAuthReady && AuthState.IsLoggedIn && _profile is null)
        {
            await LoadProfileWithRetryAsync();
            if (_profile is not null)
                await LoadSessionsWithRetryAsync();
        }
        await InvokeAsync(StateHasChanged);
    }

    /// <inheritdoc />
    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
    }

    private async Task LoadProfileAsync()
    {
        try
        {
            _profile = await Api.GetMyProfileAsync();
        }
        catch
        {
            _profile = null;
        }
    }

    private async Task LoadSessionsAsync()
    {
        try
        {
            _sessions = (await Api.GetSessionsAsync(AuthState.SessionId)).ToList();
        }
        catch
        {
            _sessions = [];
        }
    }

    // ── Profile edit ──────────────────────────────────────────────────────────

    private void StartEditProfile()
    {
        _newDisplayName = _profile?.DisplayName;
        _newBio         = _profile?.Bio;
        _profileError   = null;
        _editingProfile = true;
    }

    private void CancelEditProfile()
    {
        _editingProfile = false;
        _profileError   = null;
    }

    private async Task SaveProfileAsync()
    {
        _saving = true;
        _profileError = null;
        try
        {
            var (ok, error) = await Api.UpdateProfileAsync(_newDisplayName, _newBio);
            if (ok)
            {
                _editingProfile  = false;
                _successMessage  = "Profile updated.";
                await LoadProfileAsync();
            }
            else
            {
                _profileError = error ?? "Failed to update profile.";
            }
        }
        finally { _saving = false; }
    }

    // ── Username edit ─────────────────────────────────────────────────────────

    private void StartEditUsername()
    {
        _newUsername     = _profile?.Username ?? string.Empty;
        _usernameError   = null;
        _editingUsername = true;
    }

    private async Task SaveUsernameAsync()
    {
        if (string.IsNullOrWhiteSpace(_newUsername)) return;
        _saving = true;
        _usernameError = null;
        try
        {
            var (ok, error) = await Api.ChangeUsernameAsync(_newUsername);
            if (ok)
            {
                _editingUsername = false;
                _successMessage  = "Username updated.";
                await LoadProfileAsync();
            }
            else
            {
                _usernameError = error ?? "Failed to change username.";
            }
        }
        finally { _saving = false; }
    }

    // ── Password change ───────────────────────────────────────────────────────

    private void CancelChangePassword()
    {
        _changingPassword = false;
        _currentPassword  = string.Empty;
        _newPassword      = string.Empty;
        _confirmPassword  = string.Empty;
        _passwordError    = null;
    }

    private async Task SavePasswordAsync()
    {
        if (_newPassword != _confirmPassword)
        {
            _passwordError = "New passwords do not match.";
            return;
        }
        _saving = true;
        _passwordError = null;
        try
        {
            var (ok, error) = await Api.ChangePasswordAsync(_currentPassword, _newPassword);
            if (ok)
            {
                CancelChangePassword();
                _successMessage = "Password updated.";
            }
            else
            {
                _passwordError = error ?? "Failed to update password.";
            }
        }
        finally { _saving = false; }
    }

    // ── Email ─────────────────────────────────────────────────────────────────

    private async Task ResendConfirmationAsync()
    {
        _saving = true;
        _emailMessage = null;
        try
        {
            var (ok, error) = await Api.ResendEmailConfirmationAsync();
            _emailMessage = ok
                ? "Confirmation email sent. Check your inbox."
                : error ?? "Failed to resend confirmation.";
        }
        finally { _saving = false; }
    }

    // ── Provider management ───────────────────────────────────────────────────

    private string BuildLinkUrl(string provider)
    {
        var serverUrl  = (Config["Veldrath:PublicServerUrl"] ?? Config["Veldrath:ServerUrl"])?.TrimEnd('/') ?? "";
        var returnUrl  = Nav.ToAbsoluteUri("account/profile").ToString();
        var accountId  = AuthState.AccountId;
        return $"{serverUrl}/api/auth/external/{provider.ToLowerInvariant()}"
             + $"?mode=link&accountId={accountId}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private async Task UnlinkAsync(string provider, string providerKey)
    {
        _saving = true;
        _providerError = null;
        try
        {
            var (ok, error) = await Api.UnlinkProviderAsync(provider, providerKey);
            if (ok)
            {
                _successMessage = $"{provider} unlinked.";
                await LoadProfileAsync();
            }
            else
            {
                _providerError = error ?? $"Failed to unlink {provider}.";
            }
        }
        finally { _saving = false; }
    }

    // ── Session management ────────────────────────────────────────────────────

    private async Task RevokeSessionAsync(Guid sessionId)
    {
        _saving = true;
        _sessionError = null;
        try
        {
            var ok = await Api.RevokeSessionAsync(sessionId);
            if (ok)
                await LoadSessionsAsync();
            else
                _sessionError = "Failed to revoke session.";
        }
        finally { _saving = false; }
    }

    private async Task RevokeOtherSessionsAsync()
    {
        if (AuthState.SessionId is not { } current) return;
        _saving = true;
        _sessionError = null;
        try
        {
            var ok = await Api.RevokeOtherSessionsAsync(current);
            if (ok)
                await LoadSessionsAsync();
            else
                _sessionError = "Failed to sign out other sessions.";
        }
        finally { _saving = false; }
    }
}
