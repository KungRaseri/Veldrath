@page "/login"
@implements IDisposable
@inject NavigationManager Nav
@inject IConfiguration Config
@inject VeldrathApiClient Api
@inject AuthStateService AuthState
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Sign In — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Style="margin-top:64px">
    <MudPaper Class="pa-8" Outlined="true">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Sign In</MudText>

        @if (PendingLinkParam is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                <strong>One more step!</strong> We've sent a confirmation link to your email address.
                Click it to finish linking your account with this provider, then sign in again.
            </MudAlert>
        }
        @if (ErrorParam is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                <strong>Sign-in failed.</strong> Something went wrong during authentication. Please try again.
            </MudAlert>
        }
        @if (_loginError is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_loginError</MudAlert>
        }

        <MudText Color="Color.Secondary" Class="mb-4">
            Sign in with your Veldrath account or a connected provider.
        </MudText>

        <EditForm Model="this" OnValidSubmit="DoLoginAsync">
            <MudTextField @bind-Value="_email"
                           Label="Email"
                           InputType="InputType.Email"
                           Placeholder="you@example.com"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-3" />
            <MudTextField @bind-Value="_password"
                           Label="Password"
                           InputType="InputType.Password"
                           Placeholder="Your password"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-4" />
            <MudButton ButtonType="ButtonType.Submit"
                        Variant="Variant.Filled"
                        Color="Color.Primary"
                        FullWidth="true"
                        Disabled="@_submitting">
                @(_submitting ? "Signing in…" : "Sign in with email")
            </MudButton>
        </EditForm>

        <MudText Align="Align.Center" Class="mt-2" Typo="Typo.body2">
            No account? <MudLink Href="/register">Create one</MudLink>
            &nbsp;·&nbsp;
            <MudLink Href="/forgot-password">Forgot password?</MudLink>
        </MudText>

        <div class="my-4" style="display:flex;align-items:center;gap:.75rem;color:var(--vds-text-muted);font-size:.85rem">
            <span style="flex:1;border-top:1px solid var(--vds-border)"></span>
            <span>or continue with</span>
            <span style="flex:1;border-top:1px solid var(--vds-border)"></span>
        </div>

        <MudStack Spacing="2">
            <MudButton Href="@_discordUrl"
                        Variant="Variant.Filled"
                        Style="background-color:#5865f2;color:#fff"
                        FullWidth="true">
                Sign in with Discord
            </MudButton>
            <MudButton Href="@_googleUrl"
                        Variant="Variant.Filled"
                        Style="background-color:#4285f4;color:#fff"
                        FullWidth="true">
                Sign in with Google
            </MudButton>
            <MudButton Href="@_msUrl"
                        Variant="Variant.Filled"
                        Style="background-color:#0078d4;color:#fff"
                        FullWidth="true">
                Sign in with Microsoft
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "pending_link")] private string? PendingLinkParam { get; set; }
    [SupplyParameterFromQuery(Name = "error")]        private string? ErrorParam        { get; set; }

    private string  _email     = string.Empty;
    private string  _password  = string.Empty;
    private bool    _submitting;
    private string? _loginError;

    private string _discordUrl   = "#";
    private string _googleUrl    = "#";
    private string _msUrl        = "#";

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;

        var serverUrl = (Config["Veldrath:PublicServerUrl"] ?? Config["Veldrath:ServerUrl"])?.TrimEnd('/') ?? "";
        var callbackBase = $"{serverUrl}/api/auth/session?redirectTo={Uri.EscapeDataString(Nav.BaseUri.TrimEnd('/') + "/")}";

        _discordUrl = $"{serverUrl}/api/auth/external/discord?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _googleUrl  = $"{serverUrl}/api/auth/external/google?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _msUrl      = $"{serverUrl}/api/auth/external/microsoft?returnUrl={Uri.EscapeDataString(callbackBase)}";
    }

    private void OnAuthStateChanged()
    {
        if (AuthState.IsAuthReady && AuthState.IsLoggedIn && HttpContextAccessor.HttpContext is null)
            Nav.NavigateTo("/account/profile", replace: true);
    }

    public void Dispose() => AuthState.OnChange -= OnAuthStateChanged;

    private async Task DoLoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password)) return;

        _submitting = true;
        _loginError = null;
        try
        {
            var serverUrl = (Config["Veldrath:PublicServerUrl"] ?? Config["Veldrath:ServerUrl"])?.TrimEnd('/') ?? "";

            var response = await Api.LoginAsync(_email, _password);
            if (response is null)
            {
                _loginError = "Incorrect email or password. Please try again.";
                return;
            }

            Api.SetBearerToken(response.AccessToken);
            var code = await Api.CreateExchangeCodeAsync();
            if (code is null)
            {
                _loginError = "Sign-in failed. Please try again.";
                return;
            }

            var redirectTo = Uri.EscapeDataString(Nav.BaseUri.TrimEnd('/') + "/");
            var sessionUrl = $"{serverUrl}/api/auth/session?code={Uri.EscapeDataString(code.Code)}&aid={response.AccountId}&redirectTo={redirectTo}";
            Nav.NavigateTo(sessionUrl, forceLoad: true);
        }
        finally
        {
            _submitting = false;
        }
    }
}
