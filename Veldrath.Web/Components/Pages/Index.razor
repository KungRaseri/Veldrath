@page "/"

<PageTitle>Veldrath — An Online RPG</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-16">
    <MudText Typo="Typo.h2" Align="Align.Center" Class="mb-2">Welcome to Veldrath</MudText>
    <MudText Align="Align.Center" Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
        A multiplayer RPG forged from myth and conflict. Your legend begins here.
    </MudText>
    <MudStack AlignItems="AlignItems.Center" Class="mb-8">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/game/play" Size="Size.Large">
            Play the Game
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/community" Size="Size.Large">
            Join the Community
        </MudButton>
    </MudStack>

    <MudGrid Spacing="4">
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-6" Outlined="true">
                <MudText Typo="Typo.h6" GutterBottom="true">Deep Character Building</MudText>
                <MudText>Choose your class, shape your background, and forge a character that is uniquely yours.
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-6" Outlined="true">
                <MudText Typo="Typo.h6" GutterBottom="true">Living World</MudText>
                <MudText>Explore Varenmark and beyond — a world that breathes, changing with your actions.</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-6" Outlined="true">
                <MudText Typo="Typo.h6" GutterBottom="true">Crafted by the Community</MudText>
                <MudText>Content curated and expanded by players through RealmFoundry.</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
