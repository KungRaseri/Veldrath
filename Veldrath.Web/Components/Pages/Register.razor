@page "/register"
@implements IDisposable
@inject NavigationManager Nav
@inject IConfiguration Config
@inject VeldrathApiClient Api
@inject AuthStateService AuthState

<PageTitle>Create Account — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Style="margin-top:64px">
    <MudPaper Class="pa-8" Outlined="true">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Create an Account</MudText>

        @if (_registered)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                <strong>Account created!</strong> Please check your email to confirm your address.
            </MudAlert>
            <MudText Align="Align.Center"><MudLink Href="/login">Back to sign in</MudLink></MudText>
        }
        else
        {
            <MudText Color="Color.Secondary" Class="mb-4">
                Register with your email to track your progress, join the community, and more.
            </MudText>

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            <EditForm Model="this" OnValidSubmit="DoRegisterAsync">
                <MudTextField @bind-Value="_email"
                               Label="Email"
                               InputType="InputType.Email"
                               Placeholder="you@example.com"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="mb-3" />
                <MudTextField @bind-Value="_username"
                               Label="Username"
                               Placeholder="Choose a username"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="mb-3" />
                <MudTextField @bind-Value="_password"
                               Label="Password"
                               InputType="InputType.Password"
                               Placeholder="Create a password"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="mb-3" />
                <MudTextField @bind-Value="_confirmPassword"
                               Label="Confirm Password"
                               InputType="InputType.Password"
                               Placeholder="Repeat your password"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="mb-4" />
                <MudButton ButtonType="ButtonType.Submit"
                            Variant="Variant.Filled"
                            Color="Color.Primary"
                            FullWidth="true"
                            Disabled="@_submitting">
                    @(_submitting ? "Creating account…" : "Create account")
                </MudButton>
            </EditForm>

            <MudText Align="Align.Center" Class="mt-2" Typo="Typo.body2">
                Already have an account? <MudLink Href="/login">Sign in</MudLink>
            </MudText>

            <div class="my-4" style="display:flex;align-items:center;gap:.75rem;color:var(--vds-text-muted);font-size:.85rem">
                <span style="flex:1;border-top:1px solid var(--vds-border)"></span>
                <span>or register with</span>
                <span style="flex:1;border-top:1px solid var(--vds-border)"></span>
            </div>

            <MudStack Spacing="2">
                <MudButton Href="@_discordUrl"
                            Variant="Variant.Filled"
                            Style="background-color:#5865f2;color:#fff"
                            FullWidth="true">
                    Register with Discord
                </MudButton>
                <MudButton Href="@_googleUrl"
                            Variant="Variant.Filled"
                            Style="background-color:#4285f4;color:#fff"
                            FullWidth="true">
                    Register with Google
                </MudButton>
                <MudButton Href="@_msUrl"
                            Variant="Variant.Filled"
                            Style="background-color:#0078d4;color:#fff"
                            FullWidth="true">
                    Register with Microsoft
                </MudButton>
            </MudStack>
        }
    </MudPaper>
</MudContainer>

@code {
    private string  _email           = string.Empty;
    private string  _username        = string.Empty;
    private string  _password        = string.Empty;
    private string  _confirmPassword = string.Empty;
    private bool    _submitting;
    private bool    _registered;
    private string? _error;

    private string _discordUrl = "#";
    private string _googleUrl  = "#";
    private string _msUrl      = "#";

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;

        var serverUrl    = (Config["Veldrath:PublicServerUrl"] ?? Config["Veldrath:ServerUrl"])?.TrimEnd('/') ?? "";
        var callbackBase = $"{serverUrl}/api/auth/session?redirectTo={Uri.EscapeDataString(Nav.BaseUri.TrimEnd('/') + "/")}";

        _discordUrl = $"{serverUrl}/api/auth/external/discord?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _googleUrl  = $"{serverUrl}/api/auth/external/google?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _msUrl      = $"{serverUrl}/api/auth/external/microsoft?returnUrl={Uri.EscapeDataString(callbackBase)}";
    }

    private void OnAuthStateChanged()
    {
        if (AuthState.IsAuthReady && AuthState.IsLoggedIn)
            Nav.NavigateTo("/account/profile", replace: true);
    }

    public void Dispose() => AuthState.OnChange -= OnAuthStateChanged;

    private async Task DoRegisterAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_username) ||
            string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please fill in all fields.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _submitting = true;
        try
        {
            var serverUrl = (Config["Veldrath:PublicServerUrl"] ?? Config["Veldrath:ServerUrl"])?.TrimEnd('/') ?? "";

            var response = await Api.RegisterAsync(_email, _username, _password);
            if (response is null)
            {
                _error = "Registration failed. The email or username may already be in use.";
                return;
            }

            Api.SetBearerToken(response.AccessToken);
            var code = await Api.CreateExchangeCodeAsync();
            if (code is null)
            {
                _registered = true;
                return;
            }

            var redirectTo = Uri.EscapeDataString(Nav.BaseUri.TrimEnd('/') + "/");
            var sessionUrl = $"{serverUrl}/api/auth/session?code={Uri.EscapeDataString(code.Code)}&aid={response.AccountId}&redirectTo={redirectTo}";
            Nav.NavigateTo(sessionUrl, forceLoad: true);
        }
        finally
        {
            _submitting = false;
        }
    }
}
