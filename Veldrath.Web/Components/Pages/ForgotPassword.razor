@page "/forgot-password"
@inject VeldrathApiClient Api
@inject NavigationManager Nav

<PageTitle>Forgot Password — Veldrath</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mt-16">
    <MudPaper Class="pa-8" Outlined="true">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Forgot Password</MudText>

        @if (_sent)
        {
            <MudText Color="Color.Success" Class="mb-4">
                If an account with that email exists, we've sent a password-reset link. Check your inbox.
            </MudText>
            <MudLink Href="/login">Back to sign in</MudLink>
        }
        else
        {
            <MudText Color="Color.Secondary" Class="mb-4">
                Enter your account email and we'll send you a reset link.
            </MudText>

            <MudTextField @bind-Value="_email"
                           Label="Email address"
                           InputType="InputType.Email"
                           Placeholder="you@example.com"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-3" />

            @if (_error is not null)
            {
                <MudText Color="Color.Error" Typo="Typo.body2" Class="mb-2">@_error</MudText>
            }

            <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        FullWidth="true"
                        OnClick="SubmitAsync"
                        Disabled="@_submitting">
                @(_submitting ? "Sending…" : "Send reset link")
            </MudButton>

            <MudText Align="Align.Center" Class="mt-4" Typo="Typo.body2">
                <MudLink Href="/login">Back to sign in</MudLink>
            </MudText>
        }
    </MudPaper>
</MudContainer>

@code {
    private string  _email     = string.Empty;
    private bool    _submitting;
    private bool    _sent;
    private string? _error;

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_email)) { _error = "Please enter your email address."; return; }

        _submitting = true;
        _error      = null;
        try
        {
            await Api.ForgotPasswordAsync(_email);
            _sent = true;
        }
        finally
        {
            _submitting = false;
        }
    }
}
