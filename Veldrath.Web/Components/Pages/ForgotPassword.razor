@page "/forgot-password"
@inject VeldrathApiClient Api
@inject NavigationManager Nav

<PageTitle>Forgot Password — Veldrath</PageTitle>

<div class="auth-card">
    <h1>Forgot Password</h1>

    @if (_sent)
    {
        <p class="info">If an account with that email exists, we've sent a password-reset link. Check your inbox.</p>
        <p style="margin-top:1rem"><a href="/login">Back to sign in</a></p>
    }
    else
    {
        <p class="lead">Enter your account email and we'll send you a reset link.</p>

        <label class="field-label">Email address</label>
        <input type="email" class="field-input" @bind="_email" placeholder="you@example.com" />

        @if (_error is not null)
        {
            <p class="error">@_error</p>
        }

        <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@_submitting" style="margin-top:.75rem;width:100%">
            @(_submitting ? "Sending…" : "Send reset link")
        </button>

        <p style="margin-top:1rem;text-align:center;font-size:.9rem"><a href="/login">Back to sign in</a></p>
    }
</div>

<style>
    .auth-card { max-width: 420px; margin: 4rem auto; padding: 2rem; border: 1px solid var(--vds-border); border-radius: 8px; }
    .lead { color: var(--vds-text-muted); margin-bottom: 1.25rem; }
    .info { color: var(--vds-success, #1a7a3a); margin-bottom: 1rem; }
    .field-label { display: block; font-size: .85rem; color: var(--vds-text-muted); margin-bottom: .35rem; }
    .field-input { width: 100%; padding: .4rem .6rem; border-radius: 4px;
        border: 1px solid var(--vds-border); background: var(--vds-bg-3);
        color: inherit; font-size: .95rem; box-sizing: border-box; }
    .btn-primary { background: var(--vds-accent); color: #fff; border: none; padding: .5rem 1rem;
        border-radius: 4px; cursor: pointer; font-size: .95rem; }
    .btn-primary:disabled { opacity: .6; cursor: not-allowed; }
    .error { color: var(--vds-danger); font-size: .9rem; margin-top: .5rem; }
</style>

@code {
    private string  _email     = string.Empty;
    private bool    _submitting;
    private bool    _sent;
    private string? _error;

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_email)) { _error = "Please enter your email address."; return; }

        _submitting = true;
        _error      = null;
        try
        {
            await Api.ForgotPasswordAsync(_email);
            _sent = true;
        }
        finally
        {
            _submitting = false;
        }
    }
}
