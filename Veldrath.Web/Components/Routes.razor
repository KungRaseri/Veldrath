@using Veldrath.GameClient.Components.Components.Layout
@using Veldrath.Web.Components

@* AuthInitializer runs before the Router so auth state is always ready
   before any page renders, regardless of which layout the page uses.
   Fixes page-refresh-on-game-routes where GameLayout (which contains
   no auth init logic) overrides MainLayout. *@
<AuthInitializer />

<Router AppAssembly="typeof(App).Assembly"
        AdditionalAssemblies="new[] { typeof(GameLayout).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>
