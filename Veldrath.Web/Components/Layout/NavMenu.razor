@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav

<MudStack Row="true" Spacing="0" AlignItems="AlignItems.Stretch" Class="nav-bar">
    <MudNavLink Href="/" Match="NavLinkMatch.All">Home</MudNavLink>
    <MudNavLink Href="/lore" Match="NavLinkMatch.Prefix">World</MudNavLink>
    <MudNavLink Href="/patch-notes" Match="NavLinkMatch.Prefix">Patch Notes</MudNavLink>
    <MudNavLink Href="/community" Match="NavLinkMatch.All">Community</MudNavLink>
    @if (AuthState.IsLoggedIn)
    {
        <MudNavLink Href="/game/characterselect" Match="NavLinkMatch.Prefix" ActiveClass="gold-accent">
            <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Size="Size.Small" Style="margin-right:4px" />
            Play
        </MudNavLink>
        <MudNavLink Href="/account/profile" Match="NavLinkMatch.Prefix">@AuthState.Username</MudNavLink>
        <MudNavLink Href="/auth/sign-out" Match="NavLinkMatch.All" ForceLoad="true">Sign Out</MudNavLink>
    }
    else
    {
        <MudNavLink Href="/login" Match="NavLinkMatch.All">Sign In</MudNavLink>
    }
</MudStack>

@code {
    protected override void OnInitialized()
        => AuthState.OnChange += OnAuthStateChanged;

    private void OnAuthStateChanged()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
        => AuthState.OnChange -= OnAuthStateChanged;
}
