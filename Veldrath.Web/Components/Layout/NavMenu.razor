@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav

<MudButtonGroup Variant="Variant.Filled" Class="d-flex align-stretch">
    <MudButton Href="/">Home</MudButton>
    <MudButton Href="/lore">World</MudButton>
    <MudButton Href="/patch-notes">Patch Notes</MudButton>
    <MudButton Href="/community">Community</MudButton>
    @if (AuthState.IsLoggedIn)
    {
        <MudButton StartIcon="@Icons.Material.Filled.SportsEsports" Href="/game/characterselect">Play</MudButton>
        <MudButton Href="/account/profile">@AuthState.Username</MudButton>
        <MudButton Href="/auth/sign-out">Sign Out</MudButton>
    }
    else
    {
        <MudButton Href="/login">Sign In</MudButton>
    }
</MudButtonGroup>

@code {
    protected override void OnInitialized()
        => AuthState.OnChange += OnAuthStateChanged;

    private void OnAuthStateChanged()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
        => AuthState.OnChange -= OnAuthStateChanged;
}
