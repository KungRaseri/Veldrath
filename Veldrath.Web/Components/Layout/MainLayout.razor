@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject VeldrathApiClient Api
@inject ILogger<MainLayout> Logger
@using Veldrath.Contracts.Editorial
@using Veldrath.Contracts.Foundry

<div class="layout">
    <header class="site-header">
        <a class="brand" href="/">Veldrath</a>
        <NavMenu />
    </header>
    @if (_announcements.Count > 0)
    {
        <div class="announcement-bar">
            @foreach (var a in _announcements)
            {
                @if (!_dismissed.Contains(a.Id))
                {
                    <div class="announcement-banner">
                        <strong>@a.Title</strong> — @a.Body
                        <button class="dismiss-btn" aria-label="Dismiss" @onclick="() => Dismiss(a.Id)">&#x2715;</button>
                    </div>
                }
            }
        </div>
    }
    <main class="site-content">
        @Body
    </main>
    <footer class="site-footer">
        <p>&copy; Veldrath. All rights reserved.</p>
    </footer>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private PersistingComponentStateSubscription _subscription;
    private List<EditorialAnnouncementDto> _announcements = [];
    private readonly HashSet<Guid> _dismissed = [];

    private void Dismiss(Guid id)
    {
        _dismissed.Add(id);
        StateHasChanged();
    }

    protected override void OnInitialized()
        => AuthState.OnChange += OnAuthStateChanged;

    private void OnAuthStateChanged()
        => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        var ctx = HttpContextAccessor.HttpContext;

        if (ctx is not null)
        {
            // SSR prerender pass — HttpContext is available.
            var rt = ctx.Request.Cookies["rt"];
            Logger.LogInformation("SSR pass: rt cookie present: {HasRt}", !string.IsNullOrEmpty(rt));

            if (!string.IsNullOrEmpty(rt))
            {
                var renewed = await Api.RenewJwtAsync(rt);
                Logger.LogInformation("SSR pass: RenewJwtAsync returned null: {IsNull}", renewed is null);

                if (renewed is not null)
                {
                    var authResponse = new Veldrath.Contracts.Auth.AuthResponse(
                        renewed.AccessToken,
                        rt,
                        renewed.AccessTokenExpiry,
                        renewed.AccountId,
                        renewed.Username,
                        renewed.Roles,
                        renewed.Permissions,
                        renewed.IsCurator,
                        renewed.SessionId);

                    _subscription = ApplicationState.RegisterOnPersisting(() =>
                    {
                        ApplicationState.PersistAsJson("rt", rt);
                        Logger.LogInformation("SSR pass: Persisted rt token (len={Len})", rt.Length);
                        return Task.CompletedTask;
                    });

                    await AuthState.SetTokensAsync(authResponse);
                    Logger.LogInformation("SSR pass: SetTokensAsync completed. IsLoggedIn={IsLoggedIn}, AccessToken len={Len}",
                        AuthState.IsLoggedIn, authResponse.AccessToken?.Length ?? 0);
                }
            }

            AuthState.MarkReady();
            Logger.LogInformation("SSR pass: MarkReady called. IsAuthReady={Ready}, IsLoggedIn={In}",
                AuthState.IsAuthReady, AuthState.IsLoggedIn);
            return;
        }

        // Interactive circuit pass.
        var hasRt = ApplicationState.TryTakeFromJson<string>("rt", out var persistedRt);
        Logger.LogInformation("Circuit pass: TryTakeFromJson rt: success={Success}, hasValue={HasValue}",
            hasRt, !string.IsNullOrEmpty(persistedRt));

        if (hasRt && !string.IsNullOrEmpty(persistedRt))
        {
            var renewed = await Api.RenewJwtAsync(persistedRt);
            Logger.LogInformation("Circuit pass: RenewJwtAsync returned null: {IsNull}", renewed is null);

            if (renewed is not null)
            {
                var authResponse = new Veldrath.Contracts.Auth.AuthResponse(
                    renewed.AccessToken,
                    persistedRt,
                    renewed.AccessTokenExpiry,
                    renewed.AccountId,
                    renewed.Username,
                    renewed.Roles,
                    renewed.Permissions,
                    renewed.IsCurator,
                    renewed.SessionId);

                await AuthState.SetTokensAsync(authResponse);
                Logger.LogInformation("Circuit pass: SetTokensAsync completed. IsLoggedIn={In}, AccessToken len={Len}",
                    AuthState.IsLoggedIn, renewed.AccessToken?.Length ?? 0);
            }
        }

        AuthState.MarkReady();
        Logger.LogInformation("Circuit pass: MarkReady called. IsAuthReady={Ready}, IsLoggedIn={In}",
            AuthState.IsAuthReady, AuthState.IsLoggedIn);

        // Fetch published announcements on circuit init (after SSR auth is restored).
        try
        {
            var result = await Api.GetAnnouncementsAsync();
            if (result is not null)
                _announcements = [.. result.Items];
        }
        catch { /* best-effort — missing announcements should never break the layout */ }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(async () =>
        {
            // Proactively refresh the JWT when the user navigates and the token is nearing expiry.
            if (AuthState.IsLoggedIn)
                await AuthState.TryRefreshAsync();
        });

    /// <inheritdoc />
    public void Dispose()
    {
        AuthState.OnChange    -= OnAuthStateChanged;
        Nav.LocationChanged   -= OnLocationChanged;
        _subscription.Dispose();
    }
}
