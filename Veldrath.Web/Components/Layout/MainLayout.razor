@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject VeldrathApiClient Api
@using Veldrath.Contracts.Editorial
@using Veldrath.Contracts.Foundry

<div class="layout">
    <header class="site-header">
        <a class="brand" href="/">Veldrath</a>
        <NavMenu />
    </header>
    @if (_announcements.Count > 0)
    {
        <div class="announcement-bar">
            @foreach (var a in _announcements)
            {
                @if (!_dismissed.Contains(a.Id))
                {
                    <div class="announcement-banner">
                        <strong>@a.Title</strong> — @a.Body
                        <button class="dismiss-btn" aria-label="Dismiss" @onclick="() => Dismiss(a.Id)">&#x2715;</button>
                    </div>
                }
            }
        </div>
    }
    <main class="site-content">
        @Body
    </main>
    <footer class="site-footer">
        <p>&copy; Veldrath. All rights reserved.</p>
    </footer>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private PersistingComponentStateSubscription _subscription;
    private List<EditorialAnnouncementDto> _announcements = [];
    private readonly HashSet<Guid> _dismissed = [];

    private void Dismiss(Guid id)
    {
        _dismissed.Add(id);
        StateHasChanged();
    }

    protected override void OnInitialized()
        => AuthState.OnChange += OnAuthStateChanged;

    private void OnAuthStateChanged()
        => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        var ctx = HttpContextAccessor.HttpContext;

        if (ctx is not null)
        {
            // SSR prerender pass — HttpContext is available.
            // The rt cookie is now scoped to .veldrath.com, so it is visible to both
            // veldrath.com and foundry.veldrath.com without a second login.
            var rt = ctx.Request.Cookies["rt"];
            if (!string.IsNullOrEmpty(rt))
            {
                var renewed = await Api.RenewJwtAsync(rt);
                if (renewed is not null)
                {
                    var authResponse = new Veldrath.Contracts.Auth.AuthResponse(
                        renewed.AccessToken,
                        rt,
                        renewed.AccessTokenExpiry,
                        renewed.AccountId,
                        renewed.Username,
                        renewed.Roles,
                        renewed.Permissions,
                        renewed.IsCurator,
                        renewed.SessionId);

                    _subscription = ApplicationState.RegisterOnPersisting(() =>
                    {
                        ApplicationState.PersistAsJson("auth", authResponse);
                        return Task.CompletedTask;
                    });

                    await AuthState.SetTokensAsync(authResponse);
                }
            }

            AuthState.MarkReady();
            return;
        }

        // Interactive circuit pass — restore auth from the persisted SSR JSON.
        if (ApplicationState.TryTakeFromJson<Veldrath.Contracts.Auth.AuthResponse>("auth", out var persisted)
            && persisted is not null)
        {
            await AuthState.SetTokensAsync(persisted);
        }

        AuthState.MarkReady();

        // Fetch published announcements on circuit init (after SSR auth is restored).
        try
        {
            var result = await Api.GetAnnouncementsAsync();
            if (result is not null)
                _announcements = [.. result.Items];
        }
        catch { /* best-effort — missing announcements should never break the layout */ }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            Nav.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Proactively refresh the JWT when the user navigates and the token is nearing expiry.
        if (AuthState.IsLoggedIn)
            await AuthState.TryRefreshAsync();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        AuthState.OnChange    -= OnAuthStateChanged;
        Nav.LocationChanged   -= OnLocationChanged;
        _subscription.Dispose();
    }
}
