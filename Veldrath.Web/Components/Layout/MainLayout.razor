@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject VeldrathApiClient Api
@inject AuthStateCache AuthCache
@inject ILogger<MainLayout> Logger
@using Veldrath.Contracts.Editorial

<MudLayout Class="d-flex flex-column" Style="min-height: 100vh">
    <MudAppBar Elevation="1">
        <MudImage Src="images/veldrath-text-flat-true-transparent.png" Height="28" Class="mx-2" />
        <MudSpacer />
        <NavMenu />
    </MudAppBar>
    @if (_announcements.Count > 0)
    {
        <div class="announcement-bar">
            @foreach (var a in _announcements)
            {
                @if (!_dismissed.Contains(a.Id))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="rounded-0 ma-0">
                        <strong>@a.Title</strong> — @a.Body
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => Dismiss(a.Id)"
                                       aria-label="Dismiss" />
                    </MudAlert>
                }
            }
        </div>
    }
    <MudMainContent Class="flex-grow-1" Style="overflow-y: auto; min-height: 0">
        @Body
    </MudMainContent>
    <footer class="fat-footer">
        <MudContainer MaxWidth="MaxWidth.Large" class="mb-5">
            <MudGrid Spacing="4">
                @* Column 1: Branding *@
                <MudItem xs="12" sm="6" md="4">
                    <div class="fat-footer-brand">
                        <MudImage Src="images/veldrath-final-horizontal-transparent.png" Height="64" Class="mud-mb-4" />
                        <MudText Typo="Typo.body2" Class="fat-footer-description">
                            A multiplayer RPG built on the RealmEngine framework. Explore, craft, fight, and build your
                            legend in the world of Veldrath.
                        </MudText>
                    </div>
                </MudItem>

                @* Column 2: Quick Links *@
                <MudItem xs="12" sm="6" md="2">
                    <MudText Typo="Typo.subtitle1" Class="fat-footer-heading">Quick Links</MudText>
                    <MudLink Href="/lore" Typo="Typo.body2" Class="fat-footer-link">World & Lore</MudLink>
                    <MudLink Href="/patch-notes" Typo="Typo.body2" Class="fat-footer-link">Patch Notes</MudLink>
                    <MudLink Href="/community" Typo="Typo.body2" Class="fat-footer-link">Community</MudLink>
                    @if (AuthState.IsLoggedIn)
                    {
                        <MudLink Typo="Typo.body2" Class="fat-footer-link" Href="/auth/sign-out">Sign Out</MudLink>
                    }
                    else
                    {
                        <MudLink Typo="Typo.body2" Class="fat-footer-link" Href="/login">Sign In</MudLink>
                    }
                </MudItem>

                @* Column 3: Resources *@
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.subtitle1" Class="fat-footer-heading">Resources</MudText>
                    <MudLink Href="https://kungraseri.github.io/RealmEngine/" Typo="Typo.body2" Class="fat-footer-link"
                             Target="_blank">Documentation</MudLink>
                    <MudLink Href="https://github.com/kungraseri/RealmEngine/wiki" Typo="Typo.body2"
                             Class="fat-footer-link" Target="_blank">Wiki</MudLink>
                    <MudLink Href="/support" Typo="Typo.body2" Class="fat-footer-link">Support</MudLink>
                    <MudLink Href="/api" Typo="Typo.body2" Class="fat-footer-link">API Status</MudLink>
                </MudItem>

                @* Column 4: Community / Social *@
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.subtitle1" Class="fat-footer-heading">Community</MudText>
                    <div class="fat-footer-social">
                        <MudLink Href="https://github.com/kungraseri/RealmEngine" Target="_blank"
                                 Class="fat-footer-social-link">
                            <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Class="mud-mr-1" /> GitHub
                        </MudLink>
                        <MudLink Href="https://discord.gg/veldrath" Target="_blank" Class="fat-footer-social-link">
                            <MudIcon Icon="@Icons.Material.Filled.QuestionAnswer" Size="Size.Small" Class="mud-mr-1" />
                            Discord
                        </MudLink>
                    </div>
                </MudItem>
            </MudGrid>
        </MudContainer>

        <MudDivider Class="fat-footer-divider" />
        <MudContainer MaxWidth="MaxWidth.Large" class="mt-5">
            <div class="fat-footer-bottom">
                <MudText Typo="Typo.caption" Class="fat-footer-copyright">
                    &copy; @DateTime.Now.Year Veldrath. All rights reserved.
                </MudText>
                <div class="fat-footer-bottom-links">
                    <MudLink Href="/privacy" Typo="Typo.caption" Class="fat-footer-link">Privacy Policy</MudLink>
                    <MudLink Href="/terms" Typo="Typo.caption" Class="fat-footer-link">Terms of Service</MudLink>
                    <MudLink Href="/contact" Typo="Typo.caption" Class="fat-footer-link">Contact</MudLink>
                </div>
            </div>
        </MudContainer>
    </footer>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private PersistingComponentStateSubscription _subscription;
    private List<EditorialAnnouncementDto> _announcements = [];
    private readonly HashSet<Guid> _dismissed = [];

    private void Dismiss(Guid id)
    {
        _dismissed.Add(id);
        StateHasChanged();
    }

    protected override void OnInitialized()
        => AuthState.OnChange += OnAuthStateChanged;

    private void OnAuthStateChanged()
        => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        var ctx = HttpContextAccessor.HttpContext;

        if (ctx is not null)
        {
            // SSR prerender pass — HttpContext is available.
            var rt = ctx.Request.Cookies["rt"];
            Logger.LogInformation("SSR pass: rt cookie present: {HasRt}", !string.IsNullOrEmpty(rt));

            if (!string.IsNullOrEmpty(rt))
            {
                var renewed = await Api.RenewJwtAsync(rt);
                Logger.LogInformation("SSR pass: RenewJwtAsync returned null: {IsNull}", renewed is null);

                if (renewed is not null)
                {
                    var authResponse = new Veldrath.Contracts.Auth.AuthResponse(
                        renewed.AccessToken,
                        rt,
                        renewed.AccessTokenExpiry,
                        renewed.AccountId,
                        renewed.Username,
                        renewed.Roles,
                        renewed.Permissions,
                        renewed.IsCurator,
                        renewed.SessionId);

                    // Store the full auth response in the singleton cache and persist
                    // only the GUID key. This avoids silent serialization failures with
                    // PersistentComponentState for complex types like IReadOnlyList,
                    // DateTimeOffset, Guid?, etc.
                    var cacheKey = AuthCache.Store(authResponse);
                    _subscription = ApplicationState.RegisterOnPersisting(() =>
                    {
                        ApplicationState.PersistAsJson("auth-key", cacheKey);
                        Logger.LogInformation("SSR pass: Persisted auth cache key (len={Len})", cacheKey.Length);
                        return Task.CompletedTask;
                    });

                    await AuthState.SetTokensAsync(authResponse);
                    Logger.LogInformation("SSR pass: SetTokensAsync completed. IsLoggedIn={IsLoggedIn}, AccessToken len={Len}",
                        AuthState.IsLoggedIn, authResponse.AccessToken?.Length ?? 0);
                }
            }

            AuthState.MarkReady();
            Logger.LogInformation("SSR pass: MarkReady called. IsAuthReady={Ready}, IsLoggedIn={In}",
                AuthState.IsAuthReady, AuthState.IsLoggedIn);
            return;
        }

        // Interactive circuit pass — restore auth from the cache using the persisted GUID key.
        if (ApplicationState.TryTakeFromJson<string>("auth-key", out var cachedKey)
            && !string.IsNullOrEmpty(cachedKey))
        {
            var cached = AuthCache.Take(cachedKey);
            Logger.LogInformation("Circuit pass: AuthCache.Take success={Success}", cached is not null);

            if (cached is not null)
            {
                await AuthState.SetTokensAsync(cached);
                Logger.LogInformation("Circuit pass: SetTokensAsync completed. IsLoggedIn={In}, AccessToken len={Len}",
                    AuthState.IsLoggedIn, cached.AccessToken?.Length ?? 0);
            }
        }
        else
        {
            // Fallback: try to restore from the raw refresh token (for backward compatibility
            // with previously persisted state before the cache approach).
            if (ApplicationState.TryTakeFromJson<string>("rt", out var persistedRt)
                && !string.IsNullOrEmpty(persistedRt))
            {
                Logger.LogInformation("Circuit pass: Fallback TryTakeFromJson rt succeeded");
                var renewed = await Api.RenewJwtAsync(persistedRt);
                if (renewed is not null)
                {
                    var authResponse = new Veldrath.Contracts.Auth.AuthResponse(
                        renewed.AccessToken,
                        persistedRt,
                        renewed.AccessTokenExpiry,
                        renewed.AccountId,
                        renewed.Username,
                        renewed.Roles,
                        renewed.Permissions,
                        renewed.IsCurator,
                        renewed.SessionId);

                    await AuthState.SetTokensAsync(authResponse);
                    Logger.LogInformation("Circuit pass: Fallback SetTokensAsync completed");
                }
            }
        }

        AuthState.MarkReady();
        Logger.LogInformation("Circuit pass: MarkReady called. IsAuthReady={Ready}, IsLoggedIn={In}",
            AuthState.IsAuthReady, AuthState.IsLoggedIn);

        // Fetch published announcements on circuit init (after SSR auth is restored).
        try
        {
            var result = await Api.GetAnnouncementsAsync();
            if (result is not null)
                _announcements = [.. result.Items];
        }
        catch { /* best-effort — missing announcements should never break the layout */ }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(async () =>
        {
            // Proactively refresh the JWT when the user navigates and the token is nearing expiry.
            if (AuthState.IsLoggedIn)
                await AuthState.TryRefreshAsync();
        });

    /// <inheritdoc />
    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        _subscription.Dispose();
    }
}
