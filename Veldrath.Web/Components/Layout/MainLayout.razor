@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject VeldrathApiClient Api
@inject ILogger<MainLayout> Logger
@using Veldrath.Contracts.Editorial

<MudLayout Class="d-flex flex-column" Style="min-height: 100vh">
    <MudAppBar Elevation="1">
        <MudImage Src="images/veldrath-text-flat-true-transparent.png" Height="28" Class="mx-2" />
        <MudSpacer />
        <NavMenu />
    </MudAppBar>
    @if (_announcements.Count > 0)
    {
        <div class="announcement-bar">
            @foreach (var a in _announcements)
            {
                @if (!_dismissed.Contains(a.Id))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="rounded-0 ma-0">
                        <strong>@a.Title</strong> — @a.Body
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => Dismiss(a.Id)"
                                       aria-label="Dismiss" />
                    </MudAlert>
                }
            }
        </div>
    }
    <MudMainContent Class="flex-grow-1" Style="overflow-y: auto; min-height: 0">
        @Body
    </MudMainContent>
    <Footer />
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private List<EditorialAnnouncementDto> _announcements = [];
    private readonly HashSet<Guid> _dismissed = [];

    private void Dismiss(Guid id)
    {
        _dismissed.Add(id);
        StateHasChanged();
    }

    protected override void OnInitialized()
        => AuthState.OnChange += OnAuthStateChanged;

    private void OnAuthStateChanged()
        => InvokeAsync(StateHasChanged);

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        // Auth initialization has been extracted to <see cref="AuthInitializer"/>
        // which runs above the Router, ensuring MarkReady() is called before any
        // page renders regardless of which layout is active.

        // Fetch published announcements on circuit init.
        try
        {
            var result = await Api.GetAnnouncementsAsync();
            if (result is not null)
                _announcements = [.. result.Items];
        }
        catch { /* best-effort — missing announcements should never break the layout */ }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(async () =>
        {
            // Proactively refresh the JWT when the user navigates and the token is nearing expiry.
            if (AuthState.IsLoggedIn)
                await AuthState.TryRefreshAsync();
        });

    /// <inheritdoc />
    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
