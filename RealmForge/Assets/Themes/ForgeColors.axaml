<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ================================================================
      VELDRATH DESIGN SYSTEM — FORGE COLORS
      Same palette as GameColors.axaml so that RealmForge tooling
      stays visually consistent with the game client.

      Edit this file to change every color in the Forge editor.

      Sections:
        1.  Accent / Brand — Crimson Seal
        1a. Secondary Accent — Emberfall
        2.  Background Layers
        3.  Borders & Dividers
        4.  Text
        5.  Semantic (success / danger / warning / info)
        6.  Interactive States
        7.  FluentAvalonia / WinUI3 token overrides
        8.  Brushes (derived from colors above)
    ================================================================
    -->


    <!-- ============================================================
         1. ACCENT / BRAND COLOR — CRIMSON SEAL
         Primary red used for highlights, selections, active states,
         and interactive accents throughout the Forge editor UI.
    ============================================================ -->

    <Color x:Key="GameAccentColor">#C0392B</Color>
    <Color x:Key="GameAccentLightColor">#E05545</Color>
    <Color x:Key="GameAccentDarkColor">#8C2018</Color>
    <Color x:Key="GameAccentMutedColor">#3D1A16</Color>

    <!-- FluentAvalonia reads these to tint its built-in controls -->
    <Color x:Key="SystemAccentColor">#C0392B</Color>
    <Color x:Key="SystemAccentColorLight1">#CC4030</Color>
    <Color x:Key="SystemAccentColorLight2">#E05545</Color>
    <Color x:Key="SystemAccentColorLight3">#EF7060</Color>
    <Color x:Key="SystemAccentColorDark1">#8C2018</Color>
    <Color x:Key="SystemAccentColorDark2">#6A1610</Color>
    <Color x:Key="SystemAccentColorDark3">#4A0F0A</Color>


    <!-- ============================================================
         1a. SECONDARY ACCENT / EMBERFALL
         Warm orange-red for energy/combat states, secondary CTAs,
         and fire-aspected visual effects.
    ============================================================ -->

    <Color x:Key="GameSecondaryAccentColor">#CC4125</Color>
    <Color x:Key="GameSecondaryAccentLightColor">#E05E35</Color>
    <Color x:Key="GameSecondaryAccentDarkColor">#943018</Color>
    <Color x:Key="GameSecondaryAccentMutedColor">#361A10</Color>


    <!-- ============================================================
         2. BACKGROUND LAYERS
         Layered depth model — lower numbers are deeper/darker.
         Layer 0 is the raw window background behind everything.
         Layer 4 is the most elevated surface (tooltips, popovers).
    ============================================================ -->

    <!-- Layer 0 — window / page background -->
    <Color x:Key="GameBackground0Color">#0C0D13</Color>

    <!-- Layer 1 — primary surfaces: sidebars, nav panels -->
    <Color x:Key="GameBackground1Color">#14151F</Color>

    <!-- Layer 2 — cards, dialogs, secondary panels -->
    <Color x:Key="GameBackground2Color">#1C1D2B</Color>

    <!-- Layer 3 — input fields, pressed/hover surface fills -->
    <Color x:Key="GameBackground3Color">#262736</Color>

    <!-- Layer 4 — tooltips, flyouts, top-level overlays -->
    <Color x:Key="GameBackground4Color">#2E2F42</Color>


    <!-- ============================================================
         3. BORDERS & DIVIDERS
         Three strengths: subtle (barely visible), default, strong.
    ============================================================ -->

    <Color x:Key="GameBorderSubtleColor">#1E1F2D</Color>
    <Color x:Key="GameBorderColor">#2A2B3D</Color>
    <Color x:Key="GameBorderStrongColor">#3D3F58</Color>


    <!-- ============================================================
         4. TEXT
         Slightly warm white for primary — easier on eyes in dark UIs.
    ============================================================ -->

    <Color x:Key="GameTextPrimaryColor">#F0EDE8</Color>
    <Color x:Key="GameTextSecondaryColor">#A8A09A</Color>
    <Color x:Key="GameTextTertiaryColor">#6E6860</Color>
    <Color x:Key="GameTextDisabledColor">#4A4540</Color>


    <!-- ============================================================
         5. SEMANTIC COLORS
         Conveying meaning: buffs, debuffs, quests, errors, info.
    ============================================================ -->

    <!-- Success — valid data, save confirmed, positive outcomes -->
    <Color x:Key="GameSuccessColor">#5CAB7D</Color>
    <Color x:Key="GameSuccessMutedColor">#1F3D2E</Color>

    <!-- Danger — validation errors, destructive actions -->
    <Color x:Key="GameDangerColor">#E05252</Color>
    <Color x:Key="GameDangerMutedColor">#4A1A1A</Color>

    <!-- Warning — unsaved changes, caution states -->
    <Color x:Key="GameWarningColor">#D4964A</Color>
    <Color x:Key="GameWarningMutedColor">#4A3018</Color>

    <!-- Info — tooltips, field descriptions, neutral notifications -->
    <Color x:Key="GameInfoColor">#5A9ED6</Color>
    <Color x:Key="GameInfoMutedColor">#1A3250</Color>


    <!-- ============================================================
         6. INTERACTIVE STATES
         Used for hover and selection overlays on interactive items.
    ============================================================ -->

    <Color x:Key="GameInteractiveHoverColor">#1E2030</Color>
    <Color x:Key="GameInteractivePressedColor">#252639</Color>
    <Color x:Key="GameInteractiveSelectedColor">#252639</Color>


    <!-- ============================================================
         7. FLUENTAVALONIA / WINUI3 TOKEN OVERRIDES
    ============================================================ -->

    <!-- Page / window background -->
    <Color x:Key="ApplicationPageBackgroundThemeColor">#0C0D13</Color>

    <!-- Solid background fills -->
    <Color x:Key="SolidBackgroundFillColorBase">#0C0D13</Color>
    <Color x:Key="SolidBackgroundFillColorSecondary">#14151F</Color>
    <Color x:Key="SolidBackgroundFillColorTertiary">#1C1D2B</Color>
    <Color x:Key="SolidBackgroundFillColorQuarternary">#262736</Color>

    <!-- Layer fills (panels, cards) -->
    <Color x:Key="LayerFillColorDefault">#1C1D2B</Color>
    <Color x:Key="LayerFillColorAlt">#262736</Color>
    <Color x:Key="LayerOnAcrylicFillColorDefault">#14151F</Color>

    <!-- Control fills -->
    <Color x:Key="ControlFillColorDefault">#1C1D2B</Color>
    <Color x:Key="ControlFillColorSecondary">#262736</Color>
    <Color x:Key="ControlFillColorTertiary">#2E2F42</Color>
    <Color x:Key="ControlFillColorDisabled">#14151F</Color>
    <Color x:Key="ControlFillColorTransparent">Transparent</Color>

    <!-- Stroke / border -->
    <Color x:Key="ControlStrokeColorDefault">#2A2B3D</Color>
    <Color x:Key="ControlStrokeColorSecondary">#3D3F58</Color>
    <Color x:Key="ControlStrokeColorOnAccentDefault">#8C2018</Color>

    <!-- Text fills -->
    <Color x:Key="TextFillColorPrimary">#F0EDE8</Color>
    <Color x:Key="TextFillColorSecondary">#A8A09A</Color>
    <Color x:Key="TextFillColorTertiary">#6E6860</Color>
    <Color x:Key="TextFillColorDisabled">#4A4540</Color>
    <Color x:Key="TextOnAccentFillColorPrimary">#0C0D13</Color>


    <!-- ============================================================
         8. BRUSHES
         Derived from the colors above.
    ============================================================ -->

    <SolidColorBrush x:Key="GameAccentBrush"               Color="{StaticResource GameAccentColor}" />
    <SolidColorBrush x:Key="GameAccentLightBrush"           Color="{StaticResource GameAccentLightColor}" />
    <SolidColorBrush x:Key="GameAccentDarkBrush"            Color="{StaticResource GameAccentDarkColor}" />
    <SolidColorBrush x:Key="GameAccentMutedBrush"           Color="{StaticResource GameAccentMutedColor}" />

    <SolidColorBrush x:Key="GameSecondaryAccentBrush"      Color="{StaticResource GameSecondaryAccentColor}" />
    <SolidColorBrush x:Key="GameSecondaryAccentLightBrush" Color="{StaticResource GameSecondaryAccentLightColor}" />
    <SolidColorBrush x:Key="GameSecondaryAccentDarkBrush"  Color="{StaticResource GameSecondaryAccentDarkColor}" />
    <SolidColorBrush x:Key="GameSecondaryAccentMutedBrush" Color="{StaticResource GameSecondaryAccentMutedColor}" />

    <SolidColorBrush x:Key="GameBackground0Brush"          Color="{StaticResource GameBackground0Color}" />
    <SolidColorBrush x:Key="GameBackground1Brush"          Color="{StaticResource GameBackground1Color}" />
    <SolidColorBrush x:Key="GameBackground2Brush"          Color="{StaticResource GameBackground2Color}" />
    <SolidColorBrush x:Key="GameBackground3Brush"          Color="{StaticResource GameBackground3Color}" />
    <SolidColorBrush x:Key="GameBackground4Brush"          Color="{StaticResource GameBackground4Color}" />

    <SolidColorBrush x:Key="GameBorderSubtleBrush"         Color="{StaticResource GameBorderSubtleColor}" />
    <SolidColorBrush x:Key="GameBorderBrush"               Color="{StaticResource GameBorderColor}" />
    <SolidColorBrush x:Key="GameBorderStrongBrush"         Color="{StaticResource GameBorderStrongColor}" />

    <SolidColorBrush x:Key="GameTextPrimaryBrush"          Color="{StaticResource GameTextPrimaryColor}" />
    <SolidColorBrush x:Key="GameTextSecondaryBrush"        Color="{StaticResource GameTextSecondaryColor}" />
    <SolidColorBrush x:Key="GameTextTertiaryBrush"         Color="{StaticResource GameTextTertiaryColor}" />
    <SolidColorBrush x:Key="GameTextDisabledBrush"         Color="{StaticResource GameTextDisabledColor}" />

    <SolidColorBrush x:Key="GameSuccessBrush"              Color="{StaticResource GameSuccessColor}" />
    <SolidColorBrush x:Key="GameSuccessMutedBrush"         Color="{StaticResource GameSuccessMutedColor}" />
    <SolidColorBrush x:Key="GameDangerBrush"               Color="{StaticResource GameDangerColor}" />
    <SolidColorBrush x:Key="GameDangerMutedBrush"          Color="{StaticResource GameDangerMutedColor}" />
    <SolidColorBrush x:Key="GameWarningBrush"              Color="{StaticResource GameWarningColor}" />
    <SolidColorBrush x:Key="GameWarningMutedBrush"         Color="{StaticResource GameWarningMutedColor}" />
    <SolidColorBrush x:Key="GameInfoBrush"                 Color="{StaticResource GameInfoColor}" />
    <SolidColorBrush x:Key="GameInfoMutedBrush"            Color="{StaticResource GameInfoMutedColor}" />

    <SolidColorBrush x:Key="GameInteractiveHoverBrush"     Color="{StaticResource GameInteractiveHoverColor}" />
    <SolidColorBrush x:Key="GameInteractivePressedBrush"   Color="{StaticResource GameInteractivePressedColor}" />
    <SolidColorBrush x:Key="GameInteractiveSelectedBrush"  Color="{StaticResource GameInteractiveSelectedColor}" />

    <!-- FA application page background brush -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource GameBackground0Color}" />

</ResourceDictionary>
