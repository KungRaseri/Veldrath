@page "/"

<PageTitle>RealmForge - JSON Editor</PageTitle>

<div class="home-container">
    <h1>🛠️ RealmForge</h1>
    <p class="lead">JSON Data Editor for RealmEngine</p>
    
    <div class="features">
        <div class="feature-card">
            <h3>📝 Edit JSON Files</h3>
            <p>Browse and edit game data files with syntax highlighting</p>
        </div>
        
        <div class="feature-card">
            <h3>✅ Validate Data</h3>
            <p>Real-time validation against JSON schemas</p>
        </div>
        
        <div class="feature-card">
            <h3>🔍 Browse Catalog</h3>
            <p>Navigate through items, enemies, spells, and more</p>
        </div>
    </div>
    
    <div class="action-buttons">
        <a href="editor" class="btn btn-primary btn-lg">Open JSON Editor</a>
    </div>
</div>

<style>
    .home-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
        text-align: center;
    }
    
    h1 {
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }
    
    .lead {
        font-size: 1.5rem;
        color: #666;
        margin-bottom: 3rem;
    }
    
    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }
    
    .feature-card {
        padding: 2rem;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: #f9f9f9;
    }
    
    .feature-card h3 {
        margin-bottom: 1rem;
    }
    
    .action-buttons {
        margin-top: 2rem;
    }
    
    .btn-lg {
        padding: 12px 30px;
        font-size: 1.2rem;
    }
</style>
