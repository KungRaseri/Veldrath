@page "/editor"
@inject NavigationManager Navigation

<h3>JSON Editor</h3>

<div class="editor-layout">
    <div class="file-tree">
        <h4>Files</h4>
        <button class="btn btn-primary" @onclick="OpenFolder">Open Data
            Folder</button>

        @if (JsonFiles.Any())
        {
            <ul class="tree">
                @foreach (var file in JsonFiles)
                {
                    <li @onclick="() => LoadFile(file)"
                        class="@(file == CurrentFile ? "selected" : "")">
                        📄 @Path.GetFileName(file)
                    </li>
                }
            </ul>
        }
    </div>

    <div class="editor-panel">
        @if (!string.IsNullOrEmpty(CurrentFile))
        {
            <div class="toolbar">
                <span class="file-name">@Path.GetFileName(CurrentFile)</span>
                <button class="btn btn-success" @onclick="SaveFile">Save</button>
                <button class="btn btn-warning"
                    @onclick="ValidateFile">Validate</button>
            </div>

            <textarea class="json-editor" @bind="JsonContent" rows="30"></textarea>

            @if (!string.IsNullOrEmpty(ValidationMessage))
            {
                <div class="alert @(IsValid ? "alert-success" : "alert-danger")">
                    @ValidationMessage
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <p>Select a file from the tree or open a folder to get started</p>
            </div>
        }
    </div>
</div>

@code {
    private List<string> JsonFiles = new();
    private string CurrentFile = string.Empty;
    private string JsonContent = string.Empty;
    private string ValidationMessage = string.Empty;
    private bool IsValid = false;
    private string DataFolderPath = string.Empty;

    private async Task OpenFolder()
    {
        // TODO: Use FolderPicker when implemented
        // For now, hardcode to Data/Json folder
        var projectRoot = Path.GetFullPath(Path.Combine(AppContext.BaseDirectory, "..",
        "..", "..", ".."));
        DataFolderPath = Path.Combine(projectRoot, "RealmEngine.Data", "Data", "Json");

        if (Directory.Exists(DataFolderPath))
        {
            JsonFiles = Directory.GetFiles(DataFolderPath, "*.json",
            SearchOption.AllDirectories).ToList();
            StateHasChanged();
        }
    }

    private async Task LoadFile(string filePath)
    {
        CurrentFile = filePath;
        JsonContent = await File.ReadAllTextAsync(filePath);
        ValidationMessage = string.Empty;
        StateHasChanged();
    }

    private async Task SaveFile()
    {
        if (!string.IsNullOrEmpty(CurrentFile))
        {
            await File.WriteAllTextAsync(CurrentFile, JsonContent);
            ValidationMessage = "✅ File saved successfully";
            IsValid = true;
            StateHasChanged();
        }
    }

    private async Task ValidateFile()
    {
        try
        {
            // Basic JSON validation
            System.Text.Json.JsonDocument.Parse(JsonContent);
            ValidationMessage = "✅ Valid JSON";
            IsValid = true;
        }
        catch (Exception ex)
        {
            ValidationMessage = $"❌ Invalid JSON: {ex.Message}";
            IsValid = false;
        }
        StateHasChanged();
    }
}

<style>
    .editor-layout {
        display: flex;
        gap: 20px;
        height: calc(100vh - 200px);
    }

    .file-tree {
        width: 300px;
        border: 1px solid #ddd;
        padding: 15px;
        overflow-y: auto;
    }

    .file-tree ul.tree {
        list-style: none;
        padding-left: 0;
    }

    .file-tree li {
        padding: 8px;
        cursor: pointer;
        border-radius: 4px;
    }

    .file-tree li:hover {
        background-color: #f0f0f0;
    }

    .file-tree li.selected {
        background-color: #007bff;
        color: white;
    }

    .editor-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .toolbar {
        display: flex;
        gap: 10px;
        align-items: center;
        padding: 10px;
        background-color: #f8f9fa;
        border: 1px solid #ddd;
        border-bottom: none;
    }

    .file-name {
        flex: 1;
        font-weight: bold;
    }

    .json-editor {
        flex: 1;
        font-family: 'Consolas', 'Monaco', monospace;
        padding: 15px;
        border: 1px solid #ddd;
        resize: none;
    }

    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #999;
    }

    .alert {
        margin-top: 10px;
        padding: 10px;
        border-radius: 4px;
    }

    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-danger {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
</style>