@page "/editor"
@using Newtonsoft.Json.Linq
@inject FileManagementService FileService
@inject EditorSettingsService SettingsService
@inject ModelValidationService ValidationService
@inject ILogger<JsonEditor> Logger

<MudGrid>
    <MudItem xs="3">
        <FileTreeView OnFileClick="@LoadFileAsync" RootPath="@_dataFolderPath" />
    </MudItem>
    
    <MudItem xs="9">
        @if (!string.IsNullOrEmpty(_currentFilePath))
        {
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Spacing="3">
                    <!-- Toolbar -->
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">@Path.GetFileName(_currentFilePath)</MudText>
                        
                        <MudStack Row="true" Spacing="2">
                            <MudToggleGroup T="string" @bind-Value="@_editorMode" Color="Color.Primary" CheckMark="true">
                                <MudToggleItem Value="@("Form")">
                                    <MudIcon Icon="@Icons.Material.Filled.ViewList" Size="Size.Small" Class="mr-1" />
                                    Form
                                </MudToggleItem>
                                <MudToggleItem Value="@("JSON")">
                                    <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Class="mr-1" />
                                    JSON
                                </MudToggleItem>
                            </MudToggleGroup>
                            
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Success" 
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveFileAsync">
                                Save
                            </MudButton>
                        </MudStack>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <!-- Editor Area -->
                    @if (_editorMode == "Form")
                    {
                        <MudAlert Severity="Severity.Info">
                            <MudText Typo="Typo.body2">
                                Form mode coming in Phase 4. Use JSON mode for now.
                            </MudText>
                        </MudAlert>
                    }
                    else
                    {
                        <MudTextField @bind-Value="@_jsonContent"
                                      Label="JSON Content"
                                      Variant="Variant.Outlined"
                                      Lines="25"
                                      HelperText="Monaco Editor will replace this in Phase 3" />
                    }
                    
                    <!-- Validation Messages -->
                    @if (!string.IsNullOrEmpty(_validationMessage))
                    {
                        <MudAlert Severity="@(_isValid ? Severity.Success : Severity.Error)">
                            @_validationMessage
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-8" Style="height: 500px;">
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h5" Color="Color.Secondary">No File Selected</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Select a JSON file from the tree to begin editing</MudText>
                </MudStack>
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    private string _dataFolderPath = string.Empty;
    private string _currentFilePath = string.Empty;
    private string _jsonContent = string.Empty;
    private string _editorMode = "Form";
    private string _validationMessage = string.Empty;
    private bool _isValid = false;
    private JObject? _currentJson;

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsService.LoadSettingsAsync();
        _dataFolderPath = settings.DataFolderPath;
        _editorMode = settings.DefaultEditorMode;
        
        Logger.LogInformation("JsonEditor initialized with data path: {Path}", _dataFolderPath);
    }

    private async Task LoadFileAsync(string filePath)
    {
        try
        {
            Logger.LogInformation("Loading file: {File}", filePath);
            
            _currentFilePath = filePath;
            _currentJson = await FileService.LoadJsonFileAsync(filePath);
            
            if (_currentJson != null)
            {
                _jsonContent = _currentJson.ToString(Newtonsoft.Json.Formatting.Indented);
                _validationMessage = string.Empty;
                Logger.LogDebug("File loaded successfully, {Length} characters", _jsonContent.Length);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load file");
            _validationMessage = $"Error loading file: {ex.Message}";
            _isValid = false;
        }
    }

    private async Task SaveFileAsync()
    {
        try
        {
            Logger.LogInformation("Saving file: {File}", _currentFilePath);
            
            // Validate JSON syntax first
            var syntaxValidation = ValidationService.ValidateJsonSyntax(_jsonContent);
            if (!syntaxValidation.IsValid)
            {
                _validationMessage = "Invalid JSON: " + string.Join(", ", syntaxValidation.Errors.Select(e => e.ErrorMessage));
                _isValid = false;
                return;
            }
            
            // Parse and save
            var jsonToSave = JObject.Parse(_jsonContent);
            await FileService.SaveJsonFileAsync(_currentFilePath, jsonToSave);
            
            _validationMessage = "File saved successfully!";
            _isValid = true;
            Logger.LogInformation("File saved successfully");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save file");
            _validationMessage = $"Error saving file: {ex.Message}";
            _isValid = false;
        }
    }
}
            {
                // Unknown type - form mode not available
                CurrentModel = null;
            }
        }
        catch
        {
            // Parsing failed - stick with JSON mode
            CurrentModel = null;
        }
    }

    private void SwitchMode(string mode)
    {
        if (mode == "json" && EditorMode == "form")
        {
            // Switching from form to JSON - serialize current model
            if (CurrentModel != null)
            {
                var options = new JsonSerializerOptions { WriteIndented = true };
                JsonContent = JsonSerializer.Serialize(CurrentModel, CurrentModel.GetType(), options);
            }
        }
        else if (mode == "form" && EditorMode == "json")
        {
            // Switching from JSON to form - parse JSON back to model
            TryParseModel();
        }
        
        EditorMode = mode;
        StateHasChanged();
    }

    private void HandleFormSave(object model)
    {
        CurrentModel = model;
        
        // Serialize to JSON and save
        var options = new JsonSerializerOptions { WriteIndented = true };
        JsonContent = JsonSerializer.Serialize(model, model.GetType(), options);
        
        SaveFile();
    }

    private void SaveFile()
    {
        if (!string.IsNullOrEmpty(CurrentFile))
        {
            File.WriteAllText(CurrentFile, JsonContent);
            ValidationMessage = "✅ File saved successfully";
            IsValid = true;
            StateHasChanged();
        }
    }

    private void ValidateFile()
    {
        try
        {
            // Basic JSON validation
            System.Text.Json.JsonDocument.Parse(JsonContent);
            ValidationMessage = "✅ Valid JSON";
            IsValid = true;
        }
        catch (Exception ex)
        {
            ValidationMessage = $"❌ Invalid JSON: {ex.Message}";
            IsValid = false;
        }
        StateHasChanged();
    }
}

<style>
    .editor-layout {
        display: flex;
        gap: 20px;
        height: calc(100vh - 200px);
    }
    
    .file-tree {
        width: 300px;
        border: 1px solid #ddd;
        padding: 15px;
        overflow-y: auto;
    }
    
    .file-tree ul.tree {
        list-style: none;
        padding-left: 0;
    }
    
    .file-tree li {
        padding: 8px;
        cursor: pointer;
        border-radius: 4px;
    }
    
    .file-tree li:hover {
        background-color: #f0f0f0;
    }
    
    .file-tree li.selected {
        background-color: #007bff;
        color: white;
    }
    
    .editor-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    
    .toolbar {
        display: flex;
        gap: 10px;
        align-items: center;
        padding: 10px;
        background-color: #f8f9fa;
        border: 1px solid #ddd;
        border-bottom: none;
    }
    
    .file-name {
        flex: 1;
        font-weight: bold;
    }
    
    .mode-toggle {
        display: flex;
        gap: 15px;
        padding: 0 15px;
        border-left: 1px solid #ddd;
        border-right: 1px solid #ddd;
    }
    
    .toggle-label {
        display: flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
        font-weight: 500;
    }
    
    .toggle-label input[type="radio"] {
        cursor: pointer;
    }
    
    .form-editor {
        flex: 1;
        overflow-y: auto;
        border: 1px solid #ddd;
        background: white;
    }
    
    .json-editor {
        flex: 1;
        font-family: 'Consolas', 'Monaco', monospace;
        padding: 15px;
        border: 1px solid #ddd;
        resize: none;
    }
    
    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #999;
    }
    
    .alert {
        margin-top: 10px;
        padding: 10px;
        border-radius: 4px;
    }
    
    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    
    .alert-danger {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
    
    .alert-info {
        background-color: #d1ecf1;
        color: #0c5460;
        border: 1px solid #bee5eb;
    }
</style>
