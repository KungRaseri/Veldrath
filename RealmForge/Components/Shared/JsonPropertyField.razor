@using Newtonsoft.Json.Linq
@inject ILogger<JsonPropertyField> Logger

@if (Property != null)
{
    <div class="mb-3">
        @switch (Property.Value.Type)
        {
            case JTokenType.String:
                var stringValue = Property.Value.ToString();
                @if (stringValue.StartsWith("@"))
                {
                    <div style="display: flex; gap: 8px; align-items: flex-end;">
                        <MudTextField T="string" 
                                     Label="@FormatLabel(Property.Name)" 
                                     @bind-Value="@stringValue"
                                     Variant="Variant.Outlined" 
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Link"
                                     ReadOnly="true" />
                        <MudButton Variant="Variant.Filled" 
                                  Color="Color.Primary" 
                                  StartIcon="@Icons.Material.Filled.Search"
                                  Style="min-width: 120px;">
                            Browse
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudTextField T="string" 
                                 Label="@FormatLabel(Property.Name)" 
                                 @bind-Value="@stringValue"
                                 Variant="Variant.Outlined" 
                                 Lines="@(stringValue.Length > 100 ? 3 : 1)" />
                }
                break;
                
            case JTokenType.Integer:
                var intValue = Property.Value.ToObject<long>();
                <MudNumericField T="long" 
                                Label="@FormatLabel(Property.Name)" 
                                @bind-Value="@intValue"
                                Variant="Variant.Outlined" />
                break;
                
            case JTokenType.Float:
                var floatValue = Property.Value.ToObject<double>();
                <MudNumericField T="double" 
                                Label="@FormatLabel(Property.Name)" 
                                @bind-Value="@floatValue"
                                Variant="Variant.Outlined" />
                break;
                
            case JTokenType.Boolean:
                var boolValue = Property.Value.ToObject<bool>();
                <MudSwitch T="bool" 
                          Label="@FormatLabel(Property.Name)" 
                          @bind-Value="@boolValue"
                          Color="Color.Primary" />
                break;
                
            case JTokenType.Array:
                var array = Property.Value as JArray;
                var arrayCount = array?.Count ?? 0;
                
                @if (array?.FirstOrDefault()?.Type == JTokenType.Object)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">
                        @FormatLabel(Property.Name) (@arrayCount)
                    </MudText>
                    <MudStack Spacing="2">
                        @foreach (var item in array)
                        {
                            var itemObj = item as JObject;
                            if (itemObj != null)
                            {
                                <MudCard Elevation="1" Class="mb-2">
                                    <MudCardContent Class="pa-2">
                                        <MudGrid Spacing="1">
                                            @foreach (var prop in itemObj.Properties())
                                            {
                                                <MudItem xs="12" sm="6">
                                                    @RenderCompactField(prop)
                                                </MudItem>
                                            }
                                        </MudGrid>
                                    </MudCardContent>
                                </MudCard>
                            }
                        }
                    </MudStack>
                }
                else if (array?.Any() == true)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">
                        @FormatLabel(Property.Name) (@arrayCount)
                    </MudText>
                    <MudPaper Elevation="1" Class="pa-2" Style="border: 1px solid #e0e0e0;">
                        <MudStack Spacing="1">
                            @foreach (var item in array)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">@item.ToString()</MudChip>
                            }
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    <MudExpansionPanels MultiExpansion="true">
                        <MudExpansionPanel Text="@($"{FormatLabel(Property.Name)} ({arrayCount} items)")">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Empty array
                            </MudText>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
                break;
                
            case JTokenType.Object:
                var nestedObj = Property.Value as JObject;
                var propCount = nestedObj?.Properties()?.Count() ?? 0;
                
                @* Render all objects as cards for consistency *@
                <MudCard Elevation="1" Class="mb-3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">@FormatLabel(Property.Name)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (nestedObj != null && propCount > 0)
                        {
                            <MudGrid Spacing="1">
                                @foreach (var nestedProp in nestedObj.Properties())
                                {
                                    <MudItem xs="12" sm="6">
                                        @RenderCompactField(nestedProp)
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Empty object</MudText>
                        }
                    </MudCardContent>
                </MudCard>
                break;
                
            default:
                <MudTextField T="string" 
                             Label="@FormatLabel(Property.Name)" 
                             Value="@(Property.Value?.ToString() ?? "")"
                             Disabled="true"
                             Variant="Variant.Outlined" />
                break;
        }
    </div>
}

@code {
    [Parameter]
    public JProperty? Property { get; set; }
    
    private RenderFragment RenderCompactField(JProperty prop)
    {
        return builder =>
        {
            switch (prop.Value.Type)
            {
                case JTokenType.String:
                    var stringValue = prop.Value.ToString();
                    builder.OpenComponent<MudTextField<string>>(0);
                    builder.AddAttribute(1, "Label", FormatLabel(prop.Name));
                    builder.AddAttribute(2, "Value", stringValue);
                    builder.AddAttribute(3, "Variant", Variant.Outlined);
                    builder.AddAttribute(4, "Margin", Margin.Dense);
                    builder.AddAttribute(5, "ReadOnly", true);
                    builder.CloseComponent();
                    break;
                    
                case JTokenType.Integer:
                    builder.OpenComponent<MudTextField<string>>(0);
                    builder.AddAttribute(1, "Label", FormatLabel(prop.Name));
                    builder.AddAttribute(2, "Value", prop.Value.ToString());
                    builder.AddAttribute(3, "Variant", Variant.Outlined);
                    builder.AddAttribute(4, "Margin", Margin.Dense);
                    builder.AddAttribute(5, "ReadOnly", true);
                    builder.CloseComponent();
                    break;
                    
                case JTokenType.Float:
                    builder.OpenComponent<MudTextField<string>>(0);
                    builder.AddAttribute(1, "Label", FormatLabel(prop.Name));
                    builder.AddAttribute(2, "Value", prop.Value.ToString());
                    builder.AddAttribute(3, "Variant", Variant.Outlined);
                    builder.AddAttribute(4, "Margin", Margin.Dense);
                    builder.AddAttribute(5, "ReadOnly", true);
                    builder.CloseComponent();
                    break;
                    
                case JTokenType.Boolean:
                    builder.OpenComponent<MudCheckBox<bool>>(0);
                    builder.AddAttribute(1, "Label", FormatLabel(prop.Name));
                    builder.AddAttribute(2, "Value", prop.Value.ToObject<bool>());
                    builder.AddAttribute(3, "ReadOnly", true);
                    builder.AddAttribute(4, "Dense", true);
                    builder.CloseComponent();
                    break;
                    
                case JTokenType.Array:
                var compactArray = prop.Value as JArray;
                var compactArrayCount = compactArray?.Count ?? 0;
                var firstItem = compactArray?.FirstOrDefault();
                
                if (firstItem?.Type == JTokenType.Object)
                {
                    // Render array of objects as nested cards
                    builder.OpenElement(0, "div");
                    builder.AddAttribute(1, "style", "margin-bottom: 8px;");
                    
                    // Label
                    builder.OpenComponent<MudText>(2);
                    builder.AddAttribute(3, "Typo", Typo.subtitle2);
                    builder.AddAttribute(4, "Style", "font-weight: 600; text-transform: uppercase; color: #666; margin-bottom: 4px;");
                    builder.AddAttribute(5, "ChildContent", (RenderFragment)(labelBuilder =>
                    {
                        labelBuilder.AddContent(0, $"{FormatLabel(prop.Name)} ({compactArrayCount})");
                    }));
                    builder.CloseComponent();
                    
                    // Cards stack
                    builder.OpenComponent<MudStack>(6);
                    builder.AddAttribute(7, "Spacing", 1);
                    builder.AddAttribute(8, "ChildContent", (RenderFragment)(stackBuilder =>
                    {
                        foreach (var item in compactArray!)
                        {
                            var itemObj = item as JObject;
                            if (itemObj != null)
                            {
                                stackBuilder.OpenComponent<MudCard>(0);
                                stackBuilder.AddAttribute(1, "Elevation", 1);
                                stackBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(cardBuilder =>
                                {
                                    cardBuilder.OpenComponent<MudCardContent>(0);
                                    cardBuilder.AddAttribute(1, "Class", "pa-1");
                                    cardBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(contentBuilder =>
                                    {
                                        contentBuilder.OpenComponent<MudGrid>(0);
                                        contentBuilder.AddAttribute(1, "Spacing", 1);
                                        contentBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(gridBuilder =>
                                        {
                                            foreach (var itemProp in itemObj.Properties())
                                            {
                                                gridBuilder.OpenComponent<MudItem>(0);
                                                gridBuilder.AddAttribute(1, "xs", 12);
                                                gridBuilder.AddAttribute(2, "sm", 6);
                                                gridBuilder.AddAttribute(3, "ChildContent", (RenderFragment)(_ =>
                                                {
                                                    _.AddContent(0, RenderCompactField(itemProp));
                                                }));
                                                gridBuilder.CloseComponent();
                                            }
                                        }));
                                        contentBuilder.CloseComponent();
                                    }));
                                    cardBuilder.CloseComponent();
                                }));
                                stackBuilder.CloseComponent();
                            }
                        }
                    }));
                    builder.CloseComponent();
                    
                    builder.CloseElement();
                }
                else if (compactArray?.Any() == true)
                {
                    // Render array of primitives as chip list
                    builder.OpenElement(0, "div");
                    builder.AddAttribute(1, "style", "margin-bottom: 8px;");
                    
                    // Label
                    builder.OpenComponent<MudText>(2);
                    builder.AddAttribute(3, "Typo", Typo.subtitle2);
                    builder.AddAttribute(4, "Style", "font-weight: 600; text-transform: uppercase; color: #666; margin-bottom: 4px;");
                    builder.AddAttribute(5, "ChildContent", (RenderFragment)(labelBuilder =>
                    {
                        labelBuilder.AddContent(0, $"{FormatLabel(prop.Name)} ({compactArrayCount})");
                    }));
                    builder.CloseComponent();
                    
                    // Chips
                    builder.OpenComponent<MudPaper>(6);
                    builder.AddAttribute(7, "Elevation", 1);
                    builder.AddAttribute(8, "Class", "pa-2");
                    builder.AddAttribute(9, "Style", "border: 1px solid #e0e0e0;");
                    builder.AddAttribute(10, "ChildContent", (RenderFragment)(paperBuilder =>
                    {
                        paperBuilder.OpenComponent<MudStack>(0);
                        paperBuilder.AddAttribute(1, "Row", true);
                        paperBuilder.AddAttribute(2, "Spacing", 1);
                        paperBuilder.AddAttribute(3, "ChildContent", (RenderFragment)(stackBuilder =>
                        {
                            foreach (var item in compactArray!)
                            {
                                stackBuilder.OpenComponent<MudChip<string>>(0);
                                stackBuilder.AddAttribute(1, "Size", Size.Small);
                                stackBuilder.AddAttribute(2, "Color", Color.Default);
                                stackBuilder.AddAttribute(3, "Text", item.ToString());
                                stackBuilder.CloseComponent();
                            }
                        }));
                        paperBuilder.CloseComponent();
                    }));
                    builder.CloseComponent();
                    
                    builder.CloseElement();
                }
                else
                {
                    // Empty array
                    builder.OpenComponent<MudTextField<string>>(0);
                    builder.AddAttribute(1, "Label", FormatLabel(prop.Name));
                    builder.AddAttribute(2, "Value", "Empty array");
                    builder.AddAttribute(3, "Variant", Variant.Outlined);
                    builder.AddAttribute(4, "Margin", Margin.Dense);
                    builder.AddAttribute(5, "ReadOnly", true);
                    builder.CloseComponent();
                }
                break;
                    
            case JTokenType.Object:
                var nestedObj = prop.Value as JObject;
                if (nestedObj != null && nestedObj.Properties().Any())
                {
                    // Render object as card
                    builder.OpenElement(0, "div");
                    builder.AddAttribute(1, "style", "margin-bottom: 8px;");
                    
                    // Property label
                    builder.OpenComponent<MudText>(2);
                    builder.AddAttribute(3, "Typo", Typo.subtitle2);
                    builder.AddAttribute(4, "Style", "font-weight: 600; text-transform: uppercase; color: #666; margin-bottom: 4px;");
                    builder.AddAttribute(5, "ChildContent", (RenderFragment)(labelBuilder =>
                    {
                        labelBuilder.AddContent(0, FormatLabel(prop.Name));
                    }));
                    builder.CloseComponent();
                    
                    // Card with object properties
                    builder.OpenComponent<MudCard>(6);
                    builder.AddAttribute(7, "Elevation", 1);
                    builder.AddAttribute(8, "ChildContent", (RenderFragment)(cardBuilder =>
                    {
                        cardBuilder.OpenComponent<MudCardContent>(0);
                        cardBuilder.AddAttribute(1, "Class", "pa-2");
                        cardBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(contentBuilder =>
                        {
                            contentBuilder.OpenComponent<MudGrid>(0);
                            contentBuilder.AddAttribute(1, "Spacing", 1);
                            contentBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(gridBuilder =>
                            {
                                foreach (var nestedProp in nestedObj.Properties())
                                {
                                    gridBuilder.OpenComponent<MudItem>(0);
                                    gridBuilder.AddAttribute(1, "xs", 12);
                                    gridBuilder.AddAttribute(2, "sm", 6);
                                    gridBuilder.AddAttribute(3, "ChildContent", (RenderFragment)(_ =>
                                    {
                                        _.AddContent(0, RenderCompactField(nestedProp));
                                    }));
                                    gridBuilder.CloseComponent();
                                }
                            }));
                            contentBuilder.CloseComponent();
                        }));
                        cardBuilder.CloseComponent();
                    }));
                    builder.CloseComponent();
                    
                    builder.CloseElement();
                }
                else
                {
                    builder.OpenComponent<MudTextField<string>>(0);
                    builder.AddAttribute(1, "Label", FormatLabel(prop.Name));
                    builder.AddAttribute(2, "Value", "Empty Object");
                    builder.AddAttribute(3, "Variant", Variant.Outlined);
                    builder.AddAttribute(4, "Margin", Margin.Dense);
                    builder.AddAttribute(5, "ReadOnly", true);
                    builder.CloseComponent();
                }
                break;
                    
                default:
                    builder.OpenComponent<MudTextField<string>>(0);
                    builder.AddAttribute(1, "Label", FormatLabel(prop.Name));
                    builder.AddAttribute(2, "Value", prop.Value?.ToString() ?? "");
                    builder.AddAttribute(3, "Variant", Variant.Outlined);
                    builder.AddAttribute(4, "Margin", Margin.Dense);
                    builder.AddAttribute(5, "ReadOnly", true);
                    builder.CloseComponent();
                    break;
            }
        };
    }
    
    private string FormatLabel(string name)
    {
        if (string.IsNullOrEmpty(name))
            return string.Empty;
            
        // Convert camelCase or snake_case to Title Case
        var result = System.Text.RegularExpressions.Regex.Replace(name, "([a-z])([A-Z])", "$1 $2");
        result = result.Replace("_", " ");
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(result);
    }
}
