@inject FileManagementService FileService
@inject ILogger<FileTreeView> Logger

<MudPaper Elevation="1" Class="pa-2">
    <MudStack Spacing="2">
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Files</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" 
                           Size="Size.Small" 
                           OnClick="RefreshTree"
                           Title="Refresh file tree" />
        </MudStack>
        
        @if (_rootNode != null)
        {
            <div style="max-height: 600px; overflow-y: auto;">
                @RenderTreeNode(_rootNode, 0)
            </div>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                No files found in: @RootPath
            </MudText>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public EventCallback<string> OnFileClick { get; set; }
    
    [Parameter]
    public string RootPath { get; set; } = @"c:\code\console-game\RealmEngine.Data\Data\Json";
    
    private FileTreeNode? _rootNode;

    protected override void OnInitialized()
    {
        try
        {
            BuildFileTree();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize FileTreeView");
        }
    }

    private RenderFragment RenderTreeNode(FileTreeNode node, int level)
    {
        return builder =>
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "style", $"padding-left: {level * 16}px; cursor: pointer;");
            builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, () => OnNodeClick(node)));
            
            // Icon and name
            builder.OpenElement(3, "div");
            builder.AddAttribute(4, "style", "display: flex; align-items: center; padding: 4px 0;");
            
            if (node.IsDirectory)
            {
                builder.OpenComponent<MudIcon>(5);
                builder.AddAttribute(6, "Icon", node.IsExpanded ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder);
                builder.AddAttribute(7, "Size", Size.Small);
                builder.AddAttribute(8, "Style", "margin-right: 8px;");
                builder.CloseComponent();
            }
            else
            {
                builder.OpenComponent<MudIcon>(9);
                builder.AddAttribute(10, "Icon", Icons.Material.Filled.DataObject);
                builder.AddAttribute(11, "Size", Size.Small);
                builder.AddAttribute(12, "Color", Color.Primary);
                builder.AddAttribute(13, "Style", "margin-right: 8px;");
                builder.CloseComponent();
            }
            
            builder.AddContent(14, node.Name);
            builder.CloseElement(); // div
            builder.CloseElement(); // outer div
            
            // Children
            if (node.IsDirectory && node.IsExpanded && node.Children.Any())
            {
                foreach (var child in node.Children)
                {
                    builder.AddContent(15, RenderTreeNode(child, level + 1));
                }
            }
        };
    }

    private void BuildFileTree()
    {
        try
        {
            if (!Directory.Exists(RootPath))
            {
                Logger.LogWarning("Root path does not exist: {Path}", RootPath);
                return;
            }

            _rootNode = new FileTreeNode
            {
                Name = Path.GetFileName(RootPath) ?? "Data",
                FullPath = RootPath,
                IsDirectory = true,
                IsExpanded = true,
                Children = new List<FileTreeNode>()
            };

            BuildTreeRecursive(_rootNode, RootPath);
            Logger.LogDebug("File tree built for: {Name}", _rootNode.Name);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to build file tree");
        }
    }

    private void BuildTreeRecursive(FileTreeNode parentNode, string path)
    {
        try
        {
            // Add directories first
            var directories = Directory.GetDirectories(path).OrderBy(d => d);
            foreach (var dir in directories)
            {
                var dirNode = new FileTreeNode
                {
                    Name = Path.GetFileName(dir),
                    FullPath = dir,
                    IsDirectory = true,
                    Children = new List<FileTreeNode>()
                };
                parentNode.Children.Add(dirNode);
                BuildTreeRecursive(dirNode, dir);
            }

            // Add JSON files
            var files = Directory.GetFiles(path, "*.json").OrderBy(f => f);
            foreach (var file in files)
            {
                var fileNode = new FileTreeNode
                {
                    Name = Path.GetFileName(file),
                    FullPath = file,
                    IsDirectory = false,
                    Children = new List<FileTreeNode>()
                };
                parentNode.Children.Add(fileNode);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to build tree for: {Path}", path);
        }
    }

    private async Task OnNodeClick(FileTreeNode node)
    {
        if (node.IsDirectory)
        {
            node.IsExpanded = !node.IsExpanded;
            StateHasChanged();
        }
        else
        {
            Logger.LogInformation("File selected: {File}", node.Name);
            await OnFileClick.InvokeAsync(node.FullPath);
        }
    }

    private void RefreshTree()
    {
        Logger.LogInformation("Refreshing file tree");
        BuildFileTree();
        StateHasChanged();
    }
}
