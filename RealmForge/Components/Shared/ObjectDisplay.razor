@using Newtonsoft.Json.Linq
@using MudBlazor

<MudCard Elevation="1" Class="mb-3">
    @if (!HideHeader)
    {
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.subtitle1">@FormatLabel(PropertyName)</MudText>
            </CardHeaderContent>
        </MudCardHeader>
    }
    <MudCardContent>
        @if (Object != null && Object.Properties().Any())
        {
            <MudGrid Spacing="1">
                @foreach (var prop in Object.Properties())
                {
                    <MudItem xs="12" sm="6">
                        <PrimitiveField Property="@prop" />
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Empty object</MudText>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public string PropertyName { get; set; } = "";
    
    [Parameter]
    public JObject? Object { get; set; }
    
    [Parameter]
    public bool HideHeader { get; set; } = false;
    
    private string FormatLabel(string label)
    {
        if (string.IsNullOrWhiteSpace(label))
            return label;
            
        // Convert camelCase or PascalCase to Title Case with spaces
        var result = System.Text.RegularExpressions.Regex.Replace(label, "(\\B[A-Z])", " $1");
        return char.ToUpper(result[0]) + result.Substring(1);
    }
}
