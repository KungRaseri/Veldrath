@using Newtonsoft.Json.Linq
@using MudBlazor

<div class="array-display">
    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">
        @FormatLabel(PropertyName) (@ItemCount)
    </MudText>
    
    @if (IsObjectArray)
    {
        <MudStack Spacing="2">
            @foreach (var item in Items)
            {
                var itemObj = item as JObject;
                if (itemObj != null)
                {
                    <MudCard Elevation="1" Class="mb-2">
                        <MudCardContent Class="pa-2">
                            <MudGrid Spacing="1">
                                @foreach (var prop in itemObj.Properties())
                                {
                                    <MudItem xs="12" sm="6">
                                        <PrimitiveField Property="@prop" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                }
            }
        </MudStack>
    }
    else if (Items.Any())
    {
        <MudPaper Elevation="1" Class="pa-2" Style="border: 1px solid #e0e0e0;">
            <MudStack Spacing="1">
                @foreach (var item in Items)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@item.ToString()</MudChip>
                }
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">Empty array</MudText>
    }
</div>

@code {
    [Parameter]
    public string PropertyName { get; set; } = "";
    
    [Parameter]
    public JArray Items { get; set; } = new JArray();
    
    private int ItemCount => Items?.Count ?? 0;
    
    private bool IsObjectArray => Items?.FirstOrDefault()?.Type == JTokenType.Object;
    
    private string FormatLabel(string label)
    {
        if (string.IsNullOrWhiteSpace(label))
            return label;
            
        // Convert camelCase or PascalCase to Title Case with spaces
        var result = System.Text.RegularExpressions.Regex.Replace(label, "(\\B[A-Z])", " $1");
        return char.ToUpper(result[0]) + result.Substring(1);
    }
}
