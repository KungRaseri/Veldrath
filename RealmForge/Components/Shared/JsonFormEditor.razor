@using Newtonsoft.Json.Linq
@using RealmForge.Services
@inject ReferenceResolverService ReferenceResolver
@inject IDialogService DialogService

<MudPaper Elevation="2" Class="pa-4">
    <MudStack Spacing="3">
        @if (_jsonObject != null)
        {
            @RenderJsonObject(_jsonObject, string.Empty)
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public JObject? JsonObject { get; set; }
    
    [Parameter]
    public EventCallback<JObject> OnJsonChanged { get; set; }
    
    private JObject? _jsonObject;
    
    protected override void OnParametersSet()
    {
        _jsonObject = JsonObject;
    }
    
    private RenderFragment RenderJsonObject(JObject obj, string parentPath)
    {
        return builder =>
        {
            int seq = 0;
            
            foreach (var prop in obj.Properties())
            {
                var currentPath = string.IsNullOrEmpty(parentPath) ? prop.Name : $"{parentPath}.{prop.Name}";
                
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "mb-3");
                
                switch (prop.Value.Type)
                {
                    case JTokenType.String:
                        builder.AddContent(seq++, RenderStringField(prop, currentPath));
                        break;
                        
                    case JTokenType.Integer:
                    case JTokenType.Float:
                        builder.AddContent(seq++, RenderNumberField(prop, currentPath));
                        break;
                        
                    case JTokenType.Boolean:
                        builder.AddContent(seq++, RenderBooleanField(prop, currentPath));
                        break;
                        
                    case JTokenType.Array:
                        builder.AddContent(seq++, RenderArrayField(prop, currentPath));
                        break;
                        
                    case JTokenType.Object:
                        builder.AddContent(seq++, RenderNestedObject(prop, currentPath));
                        break;
                        
                    default:
                        builder.AddContent(seq++, RenderGenericField(prop, currentPath));
                        break;
                }
                
                builder.CloseElement();
            }
        };
    }
    
    private RenderFragment RenderStringField(JProperty prop, string path)
    {
        return builder =>
        {
            int seq = 0;
            var value = prop.Value.ToString();
            var isReference = value.StartsWith("@");
            
            if (isReference)
            {
                // Reference field with browse button
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "style", "display: flex; gap: 8px; align-items: flex-end;");
                
                builder.OpenComponent<MudTextField<string>>(seq++);
                builder.AddAttribute(seq++, "Label", FormatLabel(prop.Name));
                builder.AddAttribute(seq++, "Value", value);
                builder.AddAttribute(seq++, "ValueChanged", EventCallback.Factory.Create<string>(this, v => UpdateValue(prop, v)));
                builder.AddAttribute(seq++, "Variant", Variant.Outlined);
                builder.AddAttribute(seq++, "Adornment", Adornment.Start);
                builder.AddAttribute(seq++, "AdornmentIcon", Icons.Material.Filled.Link);
                builder.CloseComponent();
                
                builder.OpenComponent<MudButton>(seq++);
                builder.AddAttribute(seq++, "Variant", Variant.Filled);
                builder.AddAttribute(seq++, "Color", Color.Primary);
                builder.AddAttribute(seq++, "StartIcon", Icons.Material.Filled.Search);
                builder.AddAttribute(seq++, "OnClick", EventCallback.Factory.Create(this, () => OpenReferencePickerAsync(prop)));
                builder.AddAttribute(seq++, "Style", "min-width: 120px;");
                builder.AddContent(seq++, "Browse");
                builder.CloseComponent();
                
                builder.CloseElement();
            }
            else
            {
                // Regular text field
                builder.OpenComponent<MudTextField<string>>(seq++);
                builder.AddAttribute(seq++, "Label", FormatLabel(prop.Name));
                builder.AddAttribute(seq++, "Value", value);
                builder.AddAttribute(seq++, "ValueChanged", EventCallback.Factory.Create<string>(this, v => UpdateValue(prop, v)));
                builder.AddAttribute(seq++, "Variant", Variant.Outlined);
                builder.AddAttribute(seq++, "Lines", value.Length > 100 ? 3 : 1);
                builder.CloseComponent();
            }
        };
    }
    
    private RenderFragment RenderNumberField(JProperty prop, string path)
    {
        return builder =>
        {
            int seq = 0;
            
            if (prop.Value.Type == JTokenType.Integer)
            {
                builder.OpenComponent<MudNumericField<long>>(seq++);
                builder.AddAttribute(seq++, "Label", FormatLabel(prop.Name));
                builder.AddAttribute(seq++, "Value", prop.Value.ToObject<long>());
                builder.AddAttribute(seq++, "ValueChanged", EventCallback.Factory.Create<long>(this, v => UpdateValue(prop, v)));
                builder.AddAttribute(seq++, "Variant", Variant.Outlined);
                builder.CloseComponent();
            }
            else
            {
                builder.OpenComponent<MudNumericField<double>>(seq++);
                builder.AddAttribute(seq++, "Label", FormatLabel(prop.Name));
                builder.AddAttribute(seq++, "Value", prop.Value.ToObject<double>());
                builder.AddAttribute(seq++, "ValueChanged", EventCallback.Factory.Create<double>(this, v => UpdateValue(prop, v)));
                builder.AddAttribute(seq++, "Variant", Variant.Outlined);
                builder.CloseComponent();
            }
        };
    }
    
    private RenderFragment RenderBooleanField(JProperty prop, string path)
    {
        return builder =>
        {
            int seq = 0;
            
            builder.OpenComponent<MudSwitch<bool>>(seq++);
            builder.AddAttribute(seq++, "Label", FormatLabel(prop.Name));
            builder.AddAttribute(seq++, "Checked", prop.Value.ToObject<bool>());
            builder.AddAttribute(seq++, "CheckedChanged", EventCallback.Factory.Create<bool>(this, v => UpdateValue(prop, v)));
            builder.AddAttribute(seq++, "Color", Color.Primary);
            builder.CloseComponent();
        };
    }
    
    private RenderFragment RenderArrayField(JProperty prop, string path)
    {
        return builder =>
        {
            int seq = 0;
            
            builder.OpenComponent<MudExpansionPanels>(seq++);
            builder.AddAttribute(seq++, "MultiExpansion", true);
            
            builder.OpenComponent<MudExpansionPanel>(seq++);
            builder.AddAttribute(seq++, "Text", $"{FormatLabel(prop.Name)} ({(prop.Value as JArray)?.Count ?? 0} items)");
            builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(b2 =>
            {
                b2.OpenComponent<MudText>(0);
                b2.AddAttribute(1, "Typo", Typo.body2);
                b2.AddAttribute(2, "Color", Color.Secondary);
                b2.AddContent(3, "Array editing coming in Phase 6");
                b2.CloseComponent();
            }));
            builder.CloseComponent();
            
            builder.CloseComponent();
        };
    }
    
    private RenderFragment RenderNestedObject(JProperty prop, string path)
    {
        return builder =>
        {
            int seq = 0;
            
            builder.OpenComponent<MudExpansionPanels>(seq++);
            builder.AddAttribute(seq++, "MultiExpansion", true);
            
            builder.OpenComponent<MudExpansionPanel>(seq++);
            builder.AddAttribute(seq++, "Text", FormatLabel(prop.Name));
            builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(b2 =>
            {
                var nestedObj = prop.Value as JObject;
                if (nestedObj != null)
                {
                    b2.AddContent(0, RenderJsonObject(nestedObj, path));
                }
            }));
            builder.CloseComponent();
            
            builder.CloseComponent();
        };
    }
    
    private RenderFragment RenderGenericField(JProperty prop, string path)
    {
        return builder =>
        {
            int seq = 0;
            
            builder.OpenComponent<MudTextField<string>>(seq++);
            builder.AddAttribute(seq++, "Label", FormatLabel(prop.Name));
            builder.AddAttribute(seq++, "Value", prop.Value?.ToString() ?? "");
            builder.AddAttribute(seq++, "Disabled", true);
            builder.AddAttribute(seq++, "Variant", Variant.Outlined);
            builder.CloseComponent();
        };
    }
    
    private async Task OpenReferencePickerAsync(JProperty prop)
    {
        var parameters = new DialogParameters<ReferencePickerDialog>
        {
            { x => x.CurrentReference, prop.Value.ToString() }
        };
        
        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Large, 
            FullWidth = true,
            CloseButton = true
        };
        
        var dialog = await DialogService.ShowAsync<ReferencePickerDialog>("Select Reference", parameters, options);
        var result = await dialog.Result;
        
        if (!result.Canceled && result.Data is string selectedRef)
        {
            UpdateValue(prop, selectedRef);
        }
    }
    
    private void UpdateValue(JProperty prop, object newValue)
    {
        if (newValue is string str)
            prop.Value = str;
        else if (newValue is long l)
            prop.Value = l;
        else if (newValue is double d)
            prop.Value = d;
        else if (newValue is bool b)
            prop.Value = b;
        
        OnJsonChanged.InvokeAsync(_jsonObject);
        StateHasChanged();
    }
    
    private string FormatLabel(string propertyName)
    {
        // Convert camelCase/PascalCase to Title Case
        var result = System.Text.RegularExpressions.Regex.Replace(propertyName, "(\\B[A-Z])", " $1");
        return char.ToUpper(result[0]) + result.Substring(1);
    }
}
