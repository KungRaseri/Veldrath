@using RealmForge.Models
@inject ReferenceResolverService ReferenceService
@inject ILogger<ReferencePickerDialog> Logger

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <!-- Search and Filter Bar -->
            <MudStack Row="true" Spacing="2">
                <MudTextField @bind-Value="_searchQuery"
                             Label="Search"
                             Placeholder="Search by name..."
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.Search"
                             Immediate="true"
                             OnDebounceIntervalElapsed="OnSearchChanged"
                             DebounceInterval="300"
                             Style="flex: 1;" />
                
                <MudSelect @bind-Value="_selectedCategory"
                          Label="Category"
                          AdornmentIcon="@Icons.Material.Filled.Category"
                          Adornment="Adornment.Start"
                          T="string"
                          Style="min-width: 200px;">
                    <MudSelectItem Value="@((string?)null)">All Categories</MudSelectItem>
                    @foreach (var category in _categories)
                    {
                        <MudSelectItem Value="@category.Id">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@category.Icon" Size="Size.Small" />
                                <MudText>@category.DisplayName (@category.Count)</MudText>
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudStack>

            <!-- Results Table -->
            <MudTable Items="@_filteredReferences"
                     Dense="true"
                     Hover="true"
                     @bind-SelectedItem="_selectedReference"
                     SelectOnRowClick="true"
                     Height="400px"
                     FixedHeader="true"
                     Loading="@_isLoading"
                     LoadingProgressColor="Color.Primary">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Category</MudTh>
                    <MudTh>Path</MudTh>
                    <MudTh>Rarity</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@GetItemIcon(context.Domain)" Size="Size.Small" />
                            <MudText>@context.DisplayName</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Category">@context.Category</MudTd>
                    <MudTd DataLabel="Path">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Path</MudText>
                    </MudTd>
                    <MudTd DataLabel="Rarity">
                        @if (context.RarityWeight > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="@GetRarityColor(context.RarityWeight)">
                                @context.RarityWeight
                            </MudChip>
                        }
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No references found. Try adjusting your search or filters.
                    </MudText>
                </NoRecordsContent>
            </MudTable>

            <!-- Selected Reference Preview -->
            @if (_selectedReference != null)
            {
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Selected Reference</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="1">
                            <MudText><strong>Name:</strong> @_selectedReference.DisplayName</MudText>
                            <MudText><strong>Reference:</strong> <code>@_selectedReference.ReferenceString</code></MudText>
                            @if (_selectedReference.Metadata.ContainsKey("description"))
                            {
                                <MudText><strong>Description:</strong> @_selectedReference.Metadata["description"]</MudText>
                            }
                            @if (_selectedReference.Metadata.ContainsKey("level"))
                            {
                                <MudText><strong>Level:</strong> @_selectedReference.Metadata["level"]</MudText>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
        </MudStack>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Select"
                   Disabled="@(_selectedReference == null)">
            Select
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IDialogReference? MudDialog { get; set; }

    [Parameter]
    public string? InitialCategory { get; set; }

    [Parameter]
    public string? CurrentReference { get; set; }

    private string _searchQuery = string.Empty;
    private string? _selectedCategory;
    private List<ReferenceInfo> _filteredReferences = new();
    private List<ReferenceCategory> _categories = new();
    private ReferenceInfo? _selectedReference;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initialize reference catalog if not already done
            if (!ReferenceService.IsInitialized)
            {
                Logger.LogInformation("Initializing reference catalog...");
                var dataPath = @"c:\code\console-game\RealmEngine.Data\Data\Json";
                await ReferenceService.BuildReferenceCatalogAsync(dataPath);
            }

            // Load categories
            _categories = ReferenceService.GetCategories();
            _selectedCategory = InitialCategory;

            // Load initial references
            await LoadReferencesAsync();

            // Pre-select current reference if specified
            if (!string.IsNullOrWhiteSpace(CurrentReference))
            {
                _selectedReference = _filteredReferences
                    .FirstOrDefault(r => r.ReferenceString.Equals(CurrentReference, StringComparison.OrdinalIgnoreCase));
            }

            _isLoading = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize ReferencePickerDialog");
            _isLoading = false;
        }
    }

    private async Task LoadReferencesAsync()
    {
        try
        {
            _isLoading = true;
            _filteredReferences = ReferenceService.SearchReferences(_searchQuery, _selectedCategory);
            Logger.LogDebug("Loaded {Count} references", _filteredReferences.Count);
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load references");
            _filteredReferences = new List<ReferenceInfo>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnSearchChanged()
    {
        await LoadReferencesAsync();
    }

    private async Task OnCategoryChanged()
    {
        await LoadReferencesAsync();
    }

    private string GetItemIcon(string domain)
    {
        return domain.ToLower() switch
        {
            "items" => Icons.Material.Filled.Inventory,
            "enemies" => Icons.Material.Filled.BugReport,
            "npcs" => Icons.Material.Filled.People,
            "abilities" => Icons.Material.Filled.FlashOn,
            "spells" => Icons.Material.Filled.AutoFixHigh,
            "skills" => Icons.Material.Filled.Star,
            "quests" => Icons.Material.Filled.Assignment,
            "classes" => Icons.Material.Filled.School,
            "materials" => Icons.Material.Filled.Layers,
            "recipes" => Icons.Material.Filled.Restaurant,
            "world" => Icons.Material.Filled.Public,
            "organizations" => Icons.Material.Filled.CorporateFare,
            _ => Icons.Material.Filled.Folder
        };
    }

    private Color GetRarityColor(int rarityWeight)
    {
        return rarityWeight switch
        {
            >= 80 => Color.Default,     // Common
            >= 50 => Color.Success,     // Uncommon
            >= 20 => Color.Info,        // Rare
            >= 5 => Color.Warning,      // Epic
            _ => Color.Secondary        // Legendary
        };
    }

    private void Select()
    {
        if (_selectedReference != null && MudDialog != null)
        {
            Logger.LogInformation("Selected reference: {Reference}", _selectedReference.ReferenceString);
            MudDialog.Close(DialogResult.Ok(_selectedReference.ReferenceString));
        }
    }

    private void Cancel()
    {
        Logger.LogDebug("Reference picker cancelled");
        MudDialog?.Close();
    }
}
