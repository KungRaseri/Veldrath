<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmForge.ViewModels"
             x:Class="RealmForge.Views.HomeView">

    <Design.DataContext>
        <vm:HomeViewModel />
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="800" Spacing="24" Margin="40">

            <TextBlock Text="🛠️ RealmForge"
                       FontSize="48" FontWeight="Bold"
                       Foreground="{DynamicResource GameTextPrimaryBrush}"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Content Editor for RealmEngine"
                       FontSize="20" Foreground="{DynamicResource GameTextSecondaryBrush}"
                       HorizontalAlignment="Center" />

            <!-- Feature cards -->
            <ItemsControl>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- Browse Catalog -->
                <Border Background="{DynamicResource GameBackground2Brush}" CornerRadius="8" Padding="24"
                        Width="220" Margin="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="🔍  Browse Catalog" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GameTextPrimaryBrush}" />
                        <TextBlock Text="Navigate items, enemies, spells, and more."
                                   Foreground="{DynamicResource GameTextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Edit Entities -->
                <Border Background="{DynamicResource GameBackground2Brush}" CornerRadius="8" Padding="24"
                        Width="220" Margin="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="✏️  Edit Entities" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GameTextPrimaryBrush}" />
                        <TextBlock Text="Create and modify game content stored in the database."
                                   Foreground="{DynamicResource GameTextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </ItemsControl>

            <TextBlock Text="Select an entity from the tree to start editing, or right-click a category to create a new one."
                       FontSize="14" Foreground="{DynamicResource GameTextTertiaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
