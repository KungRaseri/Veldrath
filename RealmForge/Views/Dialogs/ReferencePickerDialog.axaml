<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RealmForge.ViewModels"
        x:Class="RealmForge.Views.Dialogs.ReferencePickerDialog"
        Title="Browse References"
        Width="800" Height="550"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">

    <Design.DataContext>
        <vm:ReferencePickerViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Search bar -->
        <Border Grid.Row="0" Padding="12,10" Background="#252526"
                BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid ColumnDefinitions="*,12,200">
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText}"
                         Watermark="Search references…"
                         Background="#3c3c3c" Foreground="#e0e0e0"
                         BorderBrush="#555" Padding="8,6"
                         CornerRadius="4" />
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          PlaceholderText="(All categories)"
                          Background="#3c3c3c"
                          HorizontalAlignment="Stretch" />
            </Grid>
        </Border>

        <!-- Result count -->
        <Border Grid.Row="1" Padding="12,4" Background="#252526">
            <TextBlock Text="{Binding FilteredReferences.Count, StringFormat='{}{0} result(s)'}"
                       FontSize="11" Foreground="#666" />
        </Border>

        <!-- Results list -->
        <ScrollViewer Grid.Row="2">
            <ListBox x:Name="ResultsList"
                     ItemsSource="{Binding FilteredReferences}"
                     SelectedItem="{Binding SelectedReference}"
                     Background="#1e1e1e"
                     SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,120" Margin="4,2">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding ReferenceString}"
                                           FontFamily="Consolas,monospace"
                                           FontSize="12" Foreground="#4fc1ff" />
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="11" Foreground="#888" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RarityWeight, StringFormat='weight: {0}'}"
                                       FontSize="11" Foreground="#555"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="3" Padding="12,8" Background="#252526"
                BorderThickness="0,1,0,0" BorderBrush="#333">
            <Grid ColumnDefinitions="*,Auto,4,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding SelectedReference.ReferenceString, FallbackValue=''}"
                           Foreground="#4fc1ff" FontFamily="Consolas,monospace"
                           FontSize="12" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Insert"
                        Click="Insert_Click"
                        IsEnabled="{Binding SelectedReference, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Background="#107c41" Foreground="White"
                        Padding="16,6" CornerRadius="4" />
                <Button Grid.Column="3" Content="Cancel"
                        Click="Cancel_Click"
                        Background="#3c3c3c" Foreground="#ccc"
                        Padding="16,6" CornerRadius="4" />
            </Grid>
        </Border>
    </Grid>
</Window>
