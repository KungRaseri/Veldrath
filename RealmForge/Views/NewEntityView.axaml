<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmForge.ViewModels"
             x:Class="RealmForge.Views.NewEntityView">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource GameBackground1Brush}" Padding="14,10"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GameBorderBrush}">
            <StackPanel Spacing="2">
                <TextBlock Text="New Entity"
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource GameTextPrimaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Table:" Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="12" />
                    <TextBlock Text="{Binding TypeKeyNode.TableName}"
                               Foreground="{DynamicResource GameTextSecondaryBrush}" FontSize="12" />
                    <TextBlock Text="·" Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="12" />
                    <TextBlock Text="Domain:" Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="12" />
                    <TextBlock Text="{Binding TypeKeyNode.Domain}"
                               Foreground="{DynamicResource GameTextSecondaryBrush}" FontSize="12" />
                    <TextBlock Text="·" Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="12" />
                    <TextBlock Text="Type:" Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="12" />
                    <TextBlock Text="{Binding TypeKeyNode.TypeKey}"
                               Foreground="{DynamicResource GameTextSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Form ───────────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1">
            <StackPanel MaxWidth="520" Margin="48,40" Spacing="28" VerticalAlignment="Top">

                <!-- Display Name -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Display Name" Foreground="{DynamicResource GameTextPrimaryBrush}" FontSize="13" />
                    <TextBox Text="{Binding DisplayName}"
                             Watermark="e.g. Iron Longsword" />
                </StackPanel>

                <!-- Slug -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Slug" Foreground="{DynamicResource GameTextPrimaryBrush}" FontSize="13" />
                    <TextBox Text="{Binding Slug}"
                             Watermark="e.g. iron-longsword"
                             FontFamily="{DynamicResource GameFontMono}" />
                    <TextBlock Text="URL-safe identifier, auto-derived from display name. Unique within the type."
                               Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource GameDangerBrush}"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           TextWrapping="Wrap" />

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Classes="ghost"
                            Padding="16,8" CornerRadius="4" />
                    <Button Content="Create Entity"
                            Command="{Binding CreateCommand}"
                            Classes="accent"
                            Padding="20,8" CornerRadius="4"
                            IsEnabled="{Binding !IsCreating}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
