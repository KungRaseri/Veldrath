<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RealmForge.ViewModels"
        xmlns:views="using:RealmForge.Views"
        xmlns:converters="using:RealmForge.Converters"
        x:Class="RealmForge.Views.MainWindow"
        x:Name="mainWindow"
        Title="RealmForge — Content Editor"
        Width="1280" Height="840"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Title Bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource GameBackground1Brush}" Padding="8,6"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GameBorderBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Content="☰"
                            Command="{Binding TogglePaneCommand}"
                            Background="Transparent" Foreground="{DynamicResource GameTextPrimaryBrush}"
                            Padding="8,4" CornerRadius="4" />
                    <TextBlock Text="RealmForge"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource GameTextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="v4.0"
                               FontSize="11" Foreground="{DynamicResource GameTextTertiaryBrush}"
                               VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>

                <Panel Grid.Column="1" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="↺"
                            Command="{Binding RefreshTreeCommand}"
                            Background="Transparent" Foreground="{DynamicResource GameTextSecondaryBrush}"
                            Padding="8,4" CornerRadius="4"
                            ToolTip.Tip="Refresh content tree" />
                    <ToggleButton Content="🌙"
                                  IsChecked="{Binding IsDarkMode}"
                                  Background="Transparent"
                                  Padding="8,4" />
                    <Button Content="…"
                            Command="{Binding ShowAboutCommand}"
                            Background="Transparent" Foreground="{DynamicResource GameTextTertiaryBrush}"
                            Padding="8,4" CornerRadius="4"
                            ToolTip.Tip="About RealmForge" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Main content area ────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="48,*">

            <!-- ── Activity bar ─────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="{DynamicResource GameBackground0Brush}"
                    BorderThickness="0,0,1,0" BorderBrush="{DynamicResource GameBorderSubtleBrush}">
                <ItemsControl ItemsSource="{Binding ActivitySections}"
                              Margin="0,6,0,0" VerticalAlignment="Top">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ActivitySectionViewModel">
                            <Panel Height="48" Width="48">
                                <Rectangle Width="2" HorizontalAlignment="Left" Fill="{DynamicResource GameAccentBrush}"
                                           IsVisible="{Binding IsActive}" />
                                <Button Command="{Binding #mainWindow.DataContext.SelectActivityCommand}"
                                        CommandParameter="{Binding Key}"
                                        Background="Transparent"
                                        Width="48" Height="48"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        CornerRadius="0"
                                        ToolTip.Tip="{Binding Label}">
                                    <Image Width="24" Height="24"
                                           Source="{Binding IconPath, Converter={x:Static converters:AvaresBitmapConverter.Instance}}"
                                           Classes.active="{Binding IsActive}">
                                        <Image.Styles>
                                            <Style Selector="Image"><Setter Property="Opacity" Value="0.4" /></Style>
                                            <Style Selector="Image.active"><Setter Property="Opacity" Value="0.9" /></Style>
                                        </Image.Styles>
                                    </Image>
                                </Button>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── SplitView: sidebar tree + content ──────────────────────── -->
            <SplitView Grid.Column="1"
                       IsPaneOpen="{Binding IsPaneOpen}"
                       DisplayMode="Inline"
                       OpenPaneLength="280"
                       PaneBackground="{DynamicResource GameBackground0Brush}">

            <!-- ── Left pane: content tree ─────────────────────────────── -->
            <SplitView.Pane>
                <Grid RowDefinitions="*,Auto">

                    <!-- Loading indicator -->
                    <TextBlock Grid.Row="0" Text="Loading…"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="13"
                               IsVisible="{Binding IsLoadingTree}" />

                    <!-- Error state (DB unreachable) -->
                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="10" Margin="16,0"
                                IsVisible="{Binding HasTreePaneMessage}">
                        <TextBlock Text="⚠"
                                   Foreground="{DynamicResource GameWarningBrush}" FontSize="20"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding TreePaneMessage}"
                                   Foreground="{DynamicResource GameWarningBrush}" FontSize="12"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <Button Content="Retry"
                                Command="{Binding RefreshTreeCommand}"
                                Background="{DynamicResource GameWarningMutedBrush}" Foreground="{DynamicResource GameWarningBrush}"
                                Padding="14,5" CornerRadius="4"
                                HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Content navigation: domain list with inline chips on selection -->
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding TreeNodes}"
                             SelectedItem="{Binding SelectedDomainGroup, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4,4,4,4"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             IsVisible="{Binding IsTreeVisible}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="CornerRadius" Value="6" />
                            </Style>
                            <Style Selector="ListBoxItem:selected">
                                <Setter Property="Background" Value="{DynamicResource GameInteractiveSelectedBrush}" />
                            </Style>
                            <Style Selector="ListBoxItem:not(:selected):pointerover">
                                <Setter Property="Background" Value="{DynamicResource GameInteractiveHoverBrush}" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:FileTreeNodeViewModel">
                                <StackPanel>
                                    <!-- Domain group header row -->
                                    <Grid ColumnDefinitions="Auto,*" Margin="8,7,8,7">
                                        <Image Grid.Column="0"
                                               Width="18" Height="18"
                                               VerticalAlignment="Center"
                                               Opacity="0.75"
                                               Source="{Binding IconPath, Converter={x:Static converters:AvaresBitmapConverter.Instance}}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="13" Foreground="{DynamicResource GameTextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0" />
                                    </Grid>
                                    <!-- Type key chips — visible only when this row is selected -->
                                    <ItemsControl ItemsSource="{Binding Children}"
                                                  Margin="8,0,8,8"
                                                  IsVisible="{Binding $parent[ListBoxItem].IsSelected}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:FileTreeNodeViewModel">
                                                <StackPanel Orientation="Horizontal" Spacing="1" Margin="0,2,3,0">
                                                    <Button Content="{Binding Name}"
                                                            Command="{Binding #mainWindow.DataContext.OpenTypeKeyCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource GameBackground2Brush}" Foreground="{DynamicResource GameTextSecondaryBrush}"
                                                            FontSize="11" Padding="8,4"
                                                            CornerRadius="10,0,0,10" />
                                                    <Button Content="+"
                                                            Command="{Binding NewEntityCommand}"
                                                            Background="{DynamicResource GameBackground2Brush}" Foreground="{DynamicResource GameTextTertiaryBrush}"
                                                            FontSize="11" Padding="5,4"
                                                            CornerRadius="0,10,10,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Pane footer: DB status -->
                    <Border Grid.Row="1" Background="{DynamicResource GameBackground0Brush}" Padding="10,6"
                            BorderThickness="0,1,0,0" BorderBrush="{DynamicResource GameBorderSubtleBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Green dot when connected -->
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource GameSuccessBrush}"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding DbStatus,
                                         Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <TextBlock Text="{Binding DbStatus}"
                                       Foreground="{DynamicResource GameTextDisabledBrush}" FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </Grid>
            </SplitView.Pane>

            <!-- ── Main content area ──────────────────────────────────── -->
            <ContentControl Content="{Binding CurrentPage}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:HomeViewModel">
                        <views:HomeView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:EntityListViewModel">
                        <views:EntityListView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:EntityEditorViewModel">
                        <views:EntityEditorView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:NewEntityViewModel">
                        <views:NewEntityView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

        </SplitView>

        </Grid>

    </Grid>
</Window>

