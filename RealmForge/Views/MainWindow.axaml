<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RealmForge.ViewModels"
        xmlns:views="using:RealmForge.Views"
        xmlns:converters="using:RealmForge.Converters"
        x:Class="RealmForge.Views.MainWindow"
        x:Name="mainWindow"
        Title="RealmForge — Content Editor"
        Width="1280" Height="840"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Title Bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#252526" Padding="8,6"
                BorderThickness="0,0,0,1" BorderBrush="#333">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Content="☰"
                            Command="{Binding TogglePaneCommand}"
                            Background="Transparent" Foreground="#ccc"
                            Padding="8,4" CornerRadius="4" />
                    <TextBlock Text="RealmForge"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#e0e0e0" VerticalAlignment="Center" />
                    <TextBlock Text="v4.0"
                               FontSize="11" Foreground="#555"
                               VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>

                <Panel Grid.Column="1" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="↺"
                            Command="{Binding RefreshTreeCommand}"
                            Background="Transparent" Foreground="#888"
                            Padding="8,4" CornerRadius="4"
                            ToolTip.Tip="Refresh content tree" />
                    <ToggleButton Content="🌙"
                                  IsChecked="{Binding IsDarkMode}"
                                  Background="Transparent"
                                  Padding="8,4" />
                    <Button Content="…"
                            Command="{Binding ShowAboutCommand}"
                            Background="Transparent" Foreground="#555"
                            Padding="8,4" CornerRadius="4"
                            ToolTip.Tip="About RealmForge" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Main content area ────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="48,*">

            <!-- ── Activity bar ─────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#1b1b1b"
                    BorderThickness="0,0,1,0" BorderBrush="#2d2d2d">
                <ItemsControl ItemsSource="{Binding ActivitySections}"
                              Margin="0,6,0,0" VerticalAlignment="Top">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ActivitySectionViewModel">
                            <Panel Height="48" Width="48">
                                <Rectangle Width="2" HorizontalAlignment="Left" Fill="#6caed8"
                                           IsVisible="{Binding IsActive}" />
                                <Button Command="{Binding #mainWindow.DataContext.SelectActivityCommand}"
                                        CommandParameter="{Binding Key}"
                                        Background="Transparent"
                                        Width="48" Height="48"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        CornerRadius="0"
                                        ToolTip.Tip="{Binding Label}">
                                    <Image Width="24" Height="24"
                                           Source="{Binding IconPath, Converter={x:Static converters:AvaresBitmapConverter.Instance}}"
                                           Classes.active="{Binding IsActive}">
                                        <Image.Styles>
                                            <Style Selector="Image"><Setter Property="Opacity" Value="0.4" /></Style>
                                            <Style Selector="Image.active"><Setter Property="Opacity" Value="0.9" /></Style>
                                        </Image.Styles>
                                    </Image>
                                </Button>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── SplitView: sidebar tree + content ──────────────────────── -->
            <SplitView Grid.Column="1"
                       IsPaneOpen="{Binding IsPaneOpen}"
                       DisplayMode="Inline"
                       OpenPaneLength="280"
                       PaneBackground="#1b1b1b">

            <!-- ── Left pane: content tree ─────────────────────────────── -->
            <SplitView.Pane>
                <Grid RowDefinitions="*,Auto">

                    <!-- Loading indicator -->
                    <TextBlock Grid.Row="0" Text="Loading…"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#555" FontSize="13"
                               IsVisible="{Binding IsLoadingTree}" />

                    <!-- Error state (DB unreachable) -->
                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="10" Margin="16,0"
                                IsVisible="{Binding HasTreePaneMessage}">
                        <TextBlock Text="⚠"
                                   Foreground="#6a4a20" FontSize="20"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding TreePaneMessage}"
                                   Foreground="#6a5a40" FontSize="12"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <Button Content="Retry"
                                Command="{Binding RefreshTreeCommand}"
                                Background="#2a2010" Foreground="#a08040"
                                Padding="14,5" CornerRadius="4"
                                HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Content tree -->
                    <TreeView Grid.Row="0"
                              ItemsSource="{Binding TreeNodes}"
                              SelectedItem="{Binding SelectedNode}"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0,4,0,0"
                              IsVisible="{Binding IsTreeVisible}">

                        <TreeView.Styles>
                            <Style Selector="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Padding" Value="2,3" />
                            </Style>
                            <!-- Replace FluentAvalonia's glyph-based toggle with a path chevron
                                 so it always renders correctly against our dark pane background. -->
                            <Style Selector="TreeViewItem /template/ ToggleButton">
                                <Setter Property="Width" Value="16" />
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <Border Background="Transparent" Width="16"
                                                VerticalAlignment="Stretch">
                                            <Path HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Width="7" Height="5"
                                                  Stretch="Uniform"
                                                  Stroke="#5a5a5a"
                                                  StrokeThickness="1.5"
                                                  StrokeLineCap="Round"
                                                  Fill="Transparent"
                                                  Data="M 0 0 L 5 4 L 10 0"
                                                  RenderTransformOrigin="50%,50%"
                                                  RenderTransform="rotate(-90deg)" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter>
                            </Style>
                            <Style Selector="TreeViewItem /template/ ToggleButton:checked /template/ Path">
                                <Setter Property="Stroke" Value="#909090" />
                                <Setter Property="RenderTransform" Value="rotate(0deg)" />
                            </Style>
                            <Style Selector="TreeViewItem /template/ ToggleButton:pointerover /template/ Path">
                                <Setter Property="Stroke" Value="#cccccc" />
                            </Style>
                        </TreeView.Styles>

                        <TreeView.DataTemplates>
                            <TreeDataTemplate DataType="vm:FileTreeNodeViewModel"
                                             ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="New Entity"
                                                      Command="{Binding NewEntityCommand}"
                                                      IsVisible="{Binding NewEntityCommand, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                            <MenuItem Header="Delete"
                                                      Command="{Binding DeleteCommand}"
                                                      IsVisible="{Binding DeleteCommand, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <!-- Game icon for top-level domain nodes -->
                                    <Image Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Opacity="0.7"
                                           IsVisible="{Binding IconPath, Converter={x:Static ObjectConverters.IsNotNull}}"
                                           Source="{Binding IconPath, Converter={x:Static converters:AvaresBitmapConverter.Instance}}" />
                                    <!-- Fallback glyph for typekey and entity leaf nodes -->
                                    <TextBlock Text="{Binding Icon}"
                                               Foreground="#555" FontSize="10"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IconPath, Converter={x:Static ObjectConverters.IsNull}}" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13" Foreground="#ccc"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.DataTemplates>

                    </TreeView>

                    <!-- Pane footer: DB status -->
                    <Border Grid.Row="1" Background="#161616" Padding="10,6"
                            BorderThickness="0,1,0,0" BorderBrush="#222">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Green dot when connected -->
                            <Ellipse Width="6" Height="6" Fill="#00aa55"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding DbStatus,
                                         Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <TextBlock Text="{Binding DbStatus}"
                                       Foreground="#4a4a4a" FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </Grid>
            </SplitView.Pane>

            <!-- ── Main content area ──────────────────────────────────── -->
            <ContentControl Content="{Binding CurrentPage}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:HomeViewModel">
                        <views:HomeView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:EntityListViewModel">
                        <views:EntityListView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:EntityEditorViewModel">
                        <views:EntityEditorView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:NewEntityViewModel">
                        <views:NewEntityView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

        </SplitView>

        </Grid>

    </Grid>
</Window>

