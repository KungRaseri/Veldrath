<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmForge.ViewModels"
             x:Class="RealmForge.Views.EntityListView">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource GameBackground1Brush}" Padding="16,12"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GameBorderBrush}">
            <Grid ColumnDefinitions="*,Auto">

                <StackPanel Spacing="8">
                    <!-- Breadcrumb + count -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding DomainLabel}"
                                   Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="›"
                                   Foreground="{DynamicResource GameTextDisabledBrush}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TypeKeyLabel}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GameTextPrimaryBrush}" VerticalAlignment="Center" />
                        <Border Background="{DynamicResource GameBackground3Brush}" CornerRadius="8" Padding="8,4"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalCount}"
                                       Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11" />
                        </Border>
                    </StackPanel>

                    <!-- Search -->
                    <TextBox Text="{Binding FilterText}"
                             Watermark="Filter by name or slug…"
                             Background="{DynamicResource GameBackground2Brush}" Foreground="{DynamicResource GameTextPrimaryBrush}"
                             BorderBrush="{DynamicResource GameBorderBrush}" Padding="8,4" CornerRadius="4"
                             MaxWidth="380" HorizontalAlignment="Left" />
                </StackPanel>

                <!-- New Entity button -->
                <Button Grid.Column="1"
                        Content="＋  New Entity"
                        Command="{Binding NewEntityCommand}"
                        Classes="accent"
                        Padding="12,8" CornerRadius="4"
                        VerticalAlignment="Center" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- ── List ───────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <!-- Column header strip -->
            <Border Grid.Row="0" Background="{DynamicResource GameBackground0Brush}" Padding="16,4"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GameBorderSubtleBrush}">
                <Grid ColumnDefinitions="*,160,56,90,124,44">
                    <TextBlock Grid.Column="0" Text="NAME"
                               Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="SLUG"
                               Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="WEIGHT"
                               Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="STATUS"
                               Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="4" Text="UPDATED"
                               Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11" FontWeight="SemiBold" />
                </Grid>
            </Border>

            <!-- Loading indicator -->
            <TextBlock Grid.Row="1" Text="Loading…"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="12"
                       IsVisible="{Binding IsLoading}" />

            <!-- Rows -->
            <ScrollViewer Grid.Row="1" IsVisible="{Binding !IsLoading}">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:EntityListRowViewModel">
                            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GameBorderSubtleBrush}">
                                <Grid ColumnDefinitions="*,44">

                                <!-- Clickable row area (opens editor) -->
                                <Button Grid.Column="0"
                                        Command="{Binding OpenCommand}"
                                        Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="16,8" CornerRadius="0">
                                    <Grid ColumnDefinitions="*,160,56,90,124">

                                        <!-- Name / DisplayName -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   Foreground="{DynamicResource GameTextPrimaryBrush}" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />

                                        <!-- Slug -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Slug}"
                                                   FontFamily="{DynamicResource GameFontMono}"
                                                   Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />

                                        <!-- RarityWeight -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding RarityWeight}"
                                                   Foreground="{DynamicResource GameInfoBrush}" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                                        <!-- IsActive badge -->
                                        <Panel Grid.Column="3" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource GameSuccessMutedBrush}" CornerRadius="4" Padding="8,4"
                                                    HorizontalAlignment="Left"
                                                    IsVisible="{Binding IsActive}">
                                                <TextBlock Text="Active"
                                                           Foreground="{DynamicResource GameSuccessBrush}" FontSize="11" />
                                            </Border>
                                            <Border Background="{DynamicResource GameDangerMutedBrush}" CornerRadius="4" Padding="8,4"
                                                    HorizontalAlignment="Left"
                                                    IsVisible="{Binding !IsActive}">
                                                <TextBlock Text="Inactive"
                                                           Foreground="{DynamicResource GameDangerBrush}" FontSize="11" />
                                            </Border>
                                        </Panel>

                                        <!-- UpdatedAt -->
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding UpdatedText}"
                                                   Foreground="{DynamicResource GameTextTertiaryBrush}" FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Button>

                                <!-- Delete button -->
                                <Button Grid.Column="1"
                                        Command="{Binding RequestDeleteCommand}"
                                        Content="✕"
                                        Background="Transparent" Foreground="{DynamicResource GameDangerMutedBrush}"
                                        FontSize="12" Width="44"
                                        VerticalAlignment="Stretch"
                                        ToolTip.Tip="Delete entity" />
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ── Delete confirmation banner ─────────────────────────────────── -->
        <Border Grid.Row="2" Background="{DynamicResource GameDangerMutedBrush}" Padding="16,8"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource GameDangerBrush}"
                IsVisible="{Binding PendingDelete, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Permanently delete"
                               Foreground="{DynamicResource GameDangerBrush}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding PendingDelete.Label}"
                               Foreground="{DynamicResource GameTextPrimaryBrush}" FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" />
                    <TextBlock Text="? This cannot be undone."
                               Foreground="{DynamicResource GameDangerBrush}" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Delete"
                        Command="{Binding ConfirmDeleteCommand}"
                        Classes="danger"
                        Padding="14,6" CornerRadius="4" Margin="0,0,8,0" />
                <Button Grid.Column="2"
                        Content="Cancel"
                        Command="{Binding CancelDeleteCommand}"
                        Classes="ghost"
                        Padding="14,6" CornerRadius="4" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
