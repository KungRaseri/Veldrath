<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fac="using:FluentAvalonia.Styling"
             x:Class="RealmForge.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <fac:FluentAvaloniaTheme />
        <StyleInclude Source="avares://RealmForge/Assets/Themes/ForgeTheme.axaml" />
    </Application.Styles>
</Application>
