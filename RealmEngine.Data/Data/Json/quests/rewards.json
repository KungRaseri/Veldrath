  "metadata": {
    "version": "4.0",
    "lastUpdated": "2026-01-08",
    "description": "Quest rewards catalog including items, gold, and experience scaling formulas",
    "type": "hierarchical_catalog",
    "notes": "Consolidated from items.json, gold.json, and experience.json. Supports weighted selection and dynamic scaling based on player level and quest difficulty. Item rewards provide equipment/consumables/progression. Gold rewards are tiered by amount. Experience rewards scale with player level to maintain progression balance.",
    "total_item_rewards": 20,
    "total_gold_tiers": 9,
    "total_xp_tiers": 9,
    "usage": "Load via GameDataService.QuestRewards. Use SelectByRarityWeight() for random selection. Scale rewards based on player level using formulas in notes. Match reward tier to quest difficulty (easy=common/uncommon, medium=uncommon/rare, hard=rare/epic, very hard=epic/legendary, epic/legendary=legendary/mythic).",
    "categories": {
      "items": [
        "consumable_rewards",
        "common_equipment",
        "uncommon_equipment",
        "rare_equipment",
        "epic_equipment",
        "legendary_equipment",
        "mythic_equipment",
        "choice_rewards"
      ],
      "gold": [
        "trivial_rewards",
        "low_rewards",
        "medium_rewards",
        "high_rewards",
        "very_high_rewards",
        "epic_rewards",
        "legendary_rewards",
        "mythic_rewards",
        "ancient_rewards"
      ],
      "experience": [
        "trivial_xp",
        "low_xp",
        "medium_xp",
        "high_xp",
        "very_high_xp",
        "epic_xp",
        "legendary_xp",
        "mythic_xp",
        "ancient_xp"
      ]
    },
    "scaling_formulas": {
      "gold": "final_amount = base_amount * (1 + player_level * 0.05)",
      "experience": "final_xp = base_xp * difficulty_multiplier * (1 + player_level * 0.1)",
      "item_level": "item_level = player_level ± 2 (within tier range)"
    },
    "bonus_multipliers": {
      "secondary_objectives": "Add 25-50% bonus XP/gold",
      "hidden_objectives": "Add 50-100% bonus XP/gold, upgrade item tier by 1",
      "first_time_completion": "Add 20% bonus XP",
      "speed_bonus": "Complete within time limit for up to 50% bonus gold/XP",
      "perfect_completion": "All objectives done = 100% bonus XP, upgrade item tier by 1"
    }
  },
