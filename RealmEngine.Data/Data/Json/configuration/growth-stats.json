{
  "metadata": {
    "description": "Character stat growth and progression configuration",
    "version": "4.0",
    "lastUpdated": "2026-01-23",
    "type": "growth_stats_config",
    "notes": [
      "Stat growth is defined per class using JSON references to @classes domain",
      "Base values pulled from class catalog, growth rates defined here for global tuning",
      "Derived stats (HP, mana, damage) calculated from primary stats",
      "Stat caps prevent infinite scaling and maintain balance",
      "Growth multipliers allow per-class customization without hardcoding"
    ]
  },
  "derivedStats": {
    "health": {
      "formula": "base + (constitution * 10) + (level * classHealthGrowth)",
      "description": "Total HP calculated from constitution and class growth"
    },
    "mana": {
      "formula": "base + (intelligence * 5) + (wisdom * 5) + (level * classManaGrowth)",
      "description": "Total mana calculated from intelligence, wisdom, and class growth"
    },
    "physicalDamage": {
      "formula": "strength * 0.5 + weaponDamage",
      "description": "Physical damage bonus from strength"
    },
    "magicalDamage": {
      "formula": "intelligence * 0.5 + spellPower",
      "description": "Magical damage bonus from intelligence"
    },
    "criticalChance": {
      "formula": "0.05 + (dexterity * 0.001)",
      "description": "Base 5% + 0.1% per dexterity point"
    },
    "criticalDamage": {
      "formula": "1.5 + (strength * 0.002)",
      "description": "Base 150% + 0.2% per strength point"
    },
    "armor": {
      "formula": "constitution * 2 + equipmentArmor",
      "description": "Physical damage reduction"
    },
    "magicResist": {
      "formula": "wisdom * 2 + equipmentResist",
      "description": "Magical damage reduction"
    },
    "dodge": {
      "formula": "0.05 + (dexterity * 0.001)",
      "description": "Base 5% + 0.1% per dexterity point"
    },
    "block": {
      "formula": "0.05 + (constitution * 0.0005)",
      "description": "Base 5% + 0.05% per constitution point"
    }
  },
  "statCaps": {
    "softCaps": {
      "description": "Stats experience diminishing returns after these values",
      "strength": 100,
      "dexterity": 100,
      "constitution": 100,
      "intelligence": 100,
      "wisdom": 100,
      "charisma": 100,
      "diminishingFactor": 0.5
    },
    "hardCaps": {
      "description": "Stats cannot exceed these values",
      "strength": 200,
      "dexterity": 200,
      "constitution": 200,
      "intelligence": 200,
      "wisdom": 200,
      "charisma": 200
    }
  },
