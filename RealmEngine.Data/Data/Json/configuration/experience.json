{
  "metadata": {
    "description": "Experience and leveling system configuration",
    "version": "4.0",
    "lastUpdated": "2026-01-23",
    "type": "experience_config",
    "notes": [
      "XP requirements use exponential curve for natural progression",
      "Activity bonuses are multipliers applied to base XP gains",
      "Level difference penalties/bonuses encourage appropriate challenge levels",
      "Prestige system allows restarting with permanent bonuses"
    ]
  },
  "levelCurve": {
    "formula": "exponential",
    "baseXP": 100,
    "exponent": 1.5,
    "maxLevel": 100,
    "description": "XP = baseXP * (level ^ exponent)"
  },
  "xpSources": {
    "combat": {
      "baseXP": 50,
      "description": "Base XP for defeating enemies",
      "levelDifferenceModifiers": {
        "-5": 0.1,
        "-4": 0.25,
        "-3": 0.5,
        "-2": 0.75,
        "-1": 0.9,
        "0": 1.0,
        "1": 1.1,
        "2": 1.25,
        "3": 1.5,
        "4": 1.75,
        "5": 2.0,
        "6+": 2.5
      },
      "enemyTypeMultipliers": {
        "normal": 1.0,
        "elite": 2.0,
        "boss": 5.0,
        "worldBoss": 10.0,
        "raidBoss": 20.0
      }
    },
    "questCompletion": {
      "baseXP": 500,
      "description": "XP for completing quests",
      "difficultyMultipliers": {
        "trivial": 0.5,
        "easy": 0.75,
        "normal": 1.0,
        "hard": 1.5,
        "epic": 2.0,
        "legendary": 3.0
      }
    },
    "exploration": {
      "newLocationXP": 100,
      "discoveryXP": 50,
      "landmarkXP": 200,
      "description": "XP for discovering new areas"
    },
    "crafting": {
      "baseXP": 25,
      "description": "XP for crafting items",
      "rarityMultipliers": {
        "common": 0.5,
        "uncommon": 1.0,
        "rare": 2.0,
        "epic": 4.0,
        "legendary": 8.0
      },
      "firstTimeBonus": 2.0
    },
    "gathering": {
      "baseXP": 10,
      "description": "XP for harvesting resources",
      "rarityMultipliers": {
        "common": 0.5,
        "uncommon": 1.0,
        "rare": 2.0,
        "epic": 4.0,
        "legendary": 8.0
      }
    }
  },
  "bonuses": {
    "restBonus": {
      "enabled": true,
      "maxBonusXP": 150,
      "bonusMultiplier": 2.0,
      "description": "Double XP while rested bonus is active"
    },
    "groupBonus": {
      "enabled": true,
      "bonusPerMember": 0.1,
      "maxBonus": 0.5,
      "description": "10% bonus XP per party member (max 50%)"
    },
    "guildBonus": {
      "enabled": true,
      "bonusMultiplier": 1.15,
      "description": "15% bonus XP for guild members"
    },
    "eventBonus": {
      "enabled": true,
      "bonusMultiplier": 2.0,
      "description": "Double XP during special events"
    }
  },
  "prestige": {
    "enabled": true,
    "minimumLevel": 100,
    "resetLevel": 1,
    "permanentBonusPerPrestige": 0.05,
    "maxPrestige": 10,
    "prestigeRewards": {
      "1": {
        "title": "Reborn",
        "statBonus": 5,
        "description": "+5% to all stats permanently"
      },
      "3": {
        "title": "Ascended",
        "statBonus": 15,
        "description": "+15% to all stats permanently"
      },
      "5": {
        "title": "Transcendent",
        "statBonus": 30,
        "description": "+30% to all stats permanently"
      },
      "10": {
        "title": "Eternal",
        "statBonus": 50,
        "description": "+50% to all stats permanently"
      }
    }
  },
  "penalties": {
    "death": {
      "xpLoss": 0.05,
      "description": "Lose 5% of current level XP on death",
      "canLoseLevel": false
    }
  }
}
