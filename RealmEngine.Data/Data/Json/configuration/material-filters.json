{
  "metadata": {
    "description": "Item type material compatibility - defines which materials can be used for which item types",
    "version": "5.2",
    "lastUpdated": "2026-01-22",
    "type": "material_filter_config",
    "notes": [
      "Filters define valid material categories for item categories and types",
      "Supports property-based matching (e.g., armorClass, blockChance)",
      "Lookup order: item.allowedMaterials → propertyMatches → category → defaults"
    ]
  },
  "defaults": {
    "unknown": {
      "description": "Fallback for unknown item types (no materials)",
      "allowedMaterials": []
    }
  },
  "categories": {
    "weapons": {
      "description": "Weapon category - most use metals, some use woods",
      "defaultMaterials": [
        "metals"
      ],
      "types": {
        "heavy-blades": {
          "description": "Swords, longswords, greatswords",
          "allowedMaterials": [
            "metals"
          ]
        },
        "light-blades": {
          "description": "Daggers, rapiers, shortswords",
          "allowedMaterials": [
            "metals"
          ]
        },
        "axes": {
          "description": "Axes, battleaxes, greataxes",
          "allowedMaterials": [
            "metals"
          ]
        },
        "blunt": {
          "description": "Maces, warhammers, clubs",
          "allowedMaterials": [
            "metals",
            "woods",
            "stones"
          ]
        },
        "polearms": {
          "description": "Spears, halberds, pikes",
          "allowedMaterials": [
            "metals"
          ]
        },
        "bows": {
          "description": "Bows, longbows, crossbows",
          "allowedMaterials": [
            "woods"
          ]
        },
        "staves": {
          "description": "Staves, quarterstaffs",
          "allowedMaterials": [
            "woods",
            "metals"
          ]
        }
      }
    },
    "armor": {
      "description": "Armor category - materials depend on armor class",
      "defaultMaterials": [
        "metals"
      ],
      "propertyMatches": [
        {
          "property": "blockChance",
          "condition": "exists",
          "description": "Shields use woods and metals",
          "allowedMaterials": [
            "woods",
            "metals"
          ]
        },
        {
          "property": "armorClass",
          "value": "light",
          "description": "Light armor uses fabrics",
          "allowedMaterials": [
            "fabrics"
          ]
        },
        {
          "property": "armorClass",
          "value": "medium",
          "description": "Medium armor uses leathers",
          "allowedMaterials": [
            "leathers"
          ]
        },
        {
          "property": "armorClass",
          "value": "heavy",
          "description": "Heavy armor uses metals",
          "allowedMaterials": [
            "metals"
          ]
        }
      ],
      "types": {
        "light-armor": {
          "description": "Cloth, robes, padded armor",
          "allowedMaterials": [
            "fabrics"
          ]
        },
        "medium-armor": {
          "description": "Leather, hide, studded leather",
          "allowedMaterials": [
            "leathers"
          ]
        },
        "heavy-armor": {
          "description": "Chainmail, plate, scale mail",
          "allowedMaterials": [
            "metals"
          ]
        },
        "shields": {
          "description": "Bucklers, shields, tower shields",
          "allowedMaterials": [
            "woods",
            "metals"
          ]
        }
      }
    },
    "clothing": {
      "description": "Clothing items use fabrics",
      "defaultMaterials": [
        "fabrics"
      ],
      "types": {}
    },
    "accessories": {
      "description": "Jewelry and accessories use gems and metals",
      "defaultMaterials": [
        "gems",
        "metals"
      ],
      "types": {
        "rings": {
          "description": "Rings and bands",
          "allowedMaterials": [
            "metals",
            "gems"
          ]
        },
        "amulets": {
          "description": "Necklaces and amulets",
          "allowedMaterials": [
            "metals",
            "gems"
          ]
        },
        "trinkets": {
          "description": "Magical trinkets",
          "allowedMaterials": [
            "gems",
            "crystals",
            "bones"
          ]
        }
      }
    },
    "consumables": {
      "description": "Consumable items don't use materials",
      "defaultMaterials": [],
      "types": {}
    },
    "potions": {
      "description": "Potions don't use materials",
      "defaultMaterials": [],
      "types": {}
    },
    "scrolls": {
      "description": "Scrolls don't use materials",
      "defaultMaterials": [],
      "types": {}
    },
    "materials": {
      "description": "Material items themselves don't use materials",
      "defaultMaterials": [],
      "types": {}
    },
    "reagents": {
      "description": "Reagents don't use materials",
      "defaultMaterials": [],
      "types": {}
    }
  }
}