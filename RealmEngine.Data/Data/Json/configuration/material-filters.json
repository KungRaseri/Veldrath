{
  "metadata": {
    "description": "Item type material compatibility - defines which materials can be used for which item types",
    "version": "5.1",
    "lastUpdated": "2026-01-21",
    "type": "material_filter_config",
    "notes": [
      "Filters define valid material categories for each item type",
      "defaults section provides base allowed materials for item types",
      "Individual items can override defaults with allowedMaterials field",
      "Lookup order: item.allowedMaterials → defaults[itemType] → fail"
    ]
  },
  "defaults": {
    "weapon": {
      "description": "Default materials for weapons",
      "allowedMaterials": [
        "@items/materials/ingot",
        "@items/materials/wood"
      ]
    },
    "armor": {
      "description": "Default materials for armor (all types allowed, items override for specifics)",
      "allowedMaterials": [
        "@items/materials/ingot",
        "@items/materials/leather",
        "@items/materials/fabric"
      ]
    },
    "accessory": {
      "description": "Default materials for accessories",
      "allowedMaterials": [
        "@items/materials/ingot",
        "@items/materials/gem"
      ]
    }
  },
  "filters": {
    "weapon": {
      "description": "Materials usable in weapon crafting",
      "allowedMaterials": [
        "@items/materials/ingot",
        "@items/materials/wood"
      ]
    },
    "armor": {
      "description": "Materials usable in armor crafting",
      "allowedMaterials": [
        "@items/materials/ingot",
        "@items/materials/leather"
      ]
    },
    "accessory": {
      "description": "Materials usable in accessory crafting",
      "allowedMaterials": [
        "@items/materials/ingot"
      ]
    }
  }
}