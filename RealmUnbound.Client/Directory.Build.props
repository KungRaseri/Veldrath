<Project>
  <!-- Chain to root Directory.Build.props for shared settings -->
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
  <!-- Client version (RealmUnbound.Client Avalonia desktop app) -->
  <Import Project="$(MSBuildThisFileDirectory)../versions/client.props" />
</Project>
