<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmUnbound.Client.ViewModels"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RealmUnbound.Client.Views.RegisterView"
             x:DataType="vm:RegisterViewModel">

    <Grid RowDefinitions="*,Auto,*">

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Width="360"
                    Spacing="12">

            <TextBlock Text="Create Account"
                       Classes="title-large"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24" />

            <!-- Email -->
            <TextBlock Text="Email" Classes="muted" />
            <TextBox Text="{Binding Email}"
                     Watermark="Enter your email"
                     Height="40" />

            <!-- Username -->
            <TextBlock Text="Username" Classes="muted" Margin="0,8,0,0" />
            <TextBox Text="{Binding Username}"
                     Watermark="Choose a username"
                     Height="40" />

            <!-- Password -->
            <TextBlock Text="Password" Classes="muted" Margin="0,8,0,0" />
            <TextBox Text="{Binding Password}"
                     Watermark="Choose a password"
                     PasswordChar="•"
                     Height="40" />

            <!-- Confirm Password -->
            <TextBlock Text="Confirm Password" Classes="muted" Margin="0,8,0,0" />
            <TextBox Text="{Binding ConfirmPassword}"
                     Watermark="Confirm your password"
                     PasswordChar="•"
                     Height="40" />

            <!-- Error feedback -->
            <ui:InfoBar Title="Registration Failed"
                        Message="{Binding ErrorMessage}"
                        Severity="Error"
                        IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        IsClosable="False"
                        Margin="0,4,0,0" />

            <!-- Register -->
            <Button Content="Register"
                    Classes="accent"
                    Command="{Binding RegisterCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="44"
                    FontSize="16"
                    Margin="0,8,0,0" />

            <!-- Back -->
            <Button Content="Back"
                    Classes="ghost"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="40"
                    FontSize="14" />

            <!-- Busy indicator -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsBusy}"
                         Height="4" />

        </StackPanel>

    </Grid>

</UserControl>
