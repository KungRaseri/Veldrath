<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmUnbound.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RealmUnbound.Client.Views.MainMenuView"
             x:DataType="vm:MainMenuViewModel">

    <Grid RowDefinitions="*,Auto,*">
        <Grid.Background>
            <ImageBrush Source="{DynamicResource UiBg1}" Stretch="UniformToFill" Opacity="0.4" />
        </Grid.Background>

        <!-- Title block -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Spacing="12">

            <TextBlock Text="{Binding Title}"
                       Classes="title-large"
                       FontSize="72"
                       LetterSpacing="6"
                       HorizontalAlignment="Center" />

            <TextBlock Text="{Binding Subtitle}"
                       Classes="subtitle"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,48" />

            <!-- Guest buttons: shown when NOT logged in -->
            <Button Content="Register"
                    Classes="accent"
                    Command="{Binding RegisterCommand}"
                    IsVisible="{Binding !IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <Button Content="Login"
                    Command="{Binding LoginCommand}"
                    IsVisible="{Binding !IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <!-- Authenticated buttons: shown when logged in -->
            <Button Content="Select Character"
                    Classes="accent"
                    Command="{Binding SelectCharacterCommand}"
                    IsVisible="{Binding IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <Button Content="Logout"
                    Classes="danger"
                    Command="{Binding LogoutCommand}"
                    IsVisible="{Binding IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <!-- Always visible -->
            <Button Content="Settings"
                    Classes="ghost"
                    Command="{Binding SettingsCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <Button Content="Exit"
                    Classes="danger"
                    Command="{Binding ExitCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />
        </StackPanel>

    </Grid>

</UserControl>
