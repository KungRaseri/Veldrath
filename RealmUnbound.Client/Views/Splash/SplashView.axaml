<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Veldrath.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Veldrath.Client.Views.SplashView"
             x:DataType="vm:SplashViewModel"
             Background="#0a0a0f">

    <Grid RowDefinitions="*,Auto">

        <!-- Centred title block -->
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="16">

            <TextBlock Text="{Binding Title}"
                       Classes="title-large"
                       FontSize="96"
                       LetterSpacing="8"
                       HorizontalAlignment="Center" />

            <TextBlock Text="{Binding Subtitle}"
                       Classes="subtitle"
                       FontSize="20"
                       LetterSpacing="3"
                       HorizontalAlignment="Center" />

        </StackPanel>

        <!-- Bottom loading bar -->
        <StackPanel Grid.Row="1" Margin="80,0,80,48" Spacing="10">

            <TextBlock Text="{Binding StatusText}"
                       Classes="muted"
                       FontSize="13"
                       HorizontalAlignment="Left" />

            <ProgressBar Value="{Binding Progress}"
                         Minimum="0"
                         Maximum="100"
                         Height="3"
                         Foreground="{DynamicResource GameAccentBrush}"
                         Background="{DynamicResource GameBackground2Brush}" />

        </StackPanel>

    </Grid>

</UserControl>
