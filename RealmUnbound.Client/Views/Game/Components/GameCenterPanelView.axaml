<UserControl
    x:Class="RealmUnbound.Client.Views.GameCenterPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:RealmUnbound.Client.Controls"
    xmlns:vm="using:RealmUnbound.Client.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="800"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <Border Background="{DynamicResource GameBackground0Brush}">
        <controls:TilemapControl ViewModel="{Binding Tilemap}" />
    </Border>

</UserControl>
