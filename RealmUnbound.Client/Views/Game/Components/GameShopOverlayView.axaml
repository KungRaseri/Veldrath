<UserControl
    x:Class="Veldrath.Client.Views.GameShopOverlayView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Veldrath.Client.ViewModels"
    d:DesignHeight="520"
    d:DesignWidth="640"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <Border Background="#B2000000" IsVisible="{Binding IsShopOpen}">
        <Border
            MaxWidth="640"
            MaxHeight="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource GameBackground1Brush}"
            BorderBrush="{DynamicResource GameBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <DockPanel>

                <!--  Header  -->
                <Border
                    Padding="16,10"
                    Background="{DynamicResource GameBackground2Brush}"
                    BorderBrush="{DynamicResource GameBorderBrush}"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="Shop" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Classes="muted"
                                FontSize="14"
                                Text="{Binding ShopZoneName}" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Classes="ghost icon"
                            Command="{Binding CloseShopCommand}"
                            Content="✕" />
                    </Grid>
                </Border>

                <!--  Buy / Sell tabs  -->
                <TabControl Margin="8">

                    <!--  Buy tab  -->
                    <TabItem Header="Buy">
                        <ScrollViewer MaxHeight="360">
                            <Panel>
                                <TextBlock
                                    Margin="0,32"
                                    HorizontalAlignment="Center"
                                    Classes="muted"
                                    IsVisible="{Binding !ShopItems.Count}"
                                    Text="Nothing for sale here." />
                                <ItemsControl IsVisible="{Binding ShopItems.Count}" ItemsSource="{Binding ShopItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ShopItemViewModel">
                                            <Border
                                                Padding="4,8"
                                                BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Text="{Binding DisplayName}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="12,0"
                                                        VerticalAlignment="Center"
                                                        Classes="accent"
                                                        Text="{Binding BuyPriceText}" />
                                                    <Button
                                                        Grid.Column="2"
                                                        Height="28"
                                                        Classes="accent"
                                                        Command="{Binding BuyCommand}"
                                                        Content="Buy"
                                                        FontSize="12" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Panel>
                        </ScrollViewer>
                    </TabItem>

                    <!--  Sell tab  -->
                    <TabItem Header="Sell">
                        <ScrollViewer MaxHeight="360">
                            <Panel>
                                <TextBlock
                                    Margin="0,32"
                                    HorizontalAlignment="Center"
                                    Classes="muted"
                                    IsVisible="{Binding !ShopItems.Count}"
                                    Text="Nothing available to sell." />
                                <ItemsControl IsVisible="{Binding ShopItems.Count}" ItemsSource="{Binding ShopItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ShopItemViewModel">
                                            <Border
                                                Padding="4,8"
                                                BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Text="{Binding DisplayName}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="12,0"
                                                        VerticalAlignment="Center"
                                                        Classes="muted"
                                                        Text="{Binding SellPriceText}" />
                                                    <Button
                                                        Grid.Column="2"
                                                        Height="28"
                                                        Classes="ghost"
                                                        Command="{Binding SellCommand}"
                                                        Content="Sell"
                                                        FontSize="12" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Panel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>

            </DockPanel>
        </Border>
    </Border>

</UserControl>
