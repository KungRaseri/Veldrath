<UserControl
    x:Class="RealmUnbound.Client.Views.GameFooterView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:RealmUnbound.Client.ViewModels"
    d:DesignHeight="48"
    d:DesignWidth="1280"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <Border Classes="panel-statusbar">
        <Grid VerticalAlignment="Center" ColumnDefinitions="Auto,*,Auto">

            <!--  Left: inventory + combat actions  -->
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Height="34"
                    Classes="ghost"
                    Classes.accent="{Binding IsInventoryOpen}"
                    Command="{Binding ToggleInventoryCommand}"
                    Content="Inventory"
                    FontSize="13" />
                <StackPanel
                    IsVisible="{Binding IsInCombat}"
                    Orientation="Horizontal"
                    Spacing="4">
                    <Button
                        Height="34"
                        Classes="accent"
                        Command="{Binding AttackEnemyCommand}"
                        Content="⚔ Attack"
                        FontSize="13" />
                    <Button
                        Height="34"
                        Classes="ghost"
                        Command="{Binding DefendActionCommand}"
                        Content="🛡 Defend"
                        FontSize="13" />
                    <Button
                        Height="34"
                        Classes="danger ghost"
                        Command="{Binding FleeFromCombatCommand}"
                        Content="🏃 Flee"
                        FontSize="13" />
                </StackPanel>
            </StackPanel>

            <!--  Center: ability hotbar — 6 always-visible slots  -->
            <ItemsControl
                Grid.Column="1"
                HorizontalAlignment="Center"
                ItemsSource="{Binding HotbarSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:HotbarSlotViewModel">
                        <Button
                            Height="34"
                            MinWidth="80"
                            Padding="6,0"
                            Classes="ghost"
                            Classes.muted="{Binding IsEmpty}"
                            Command="{Binding UseCommand}"
                            Content="{Binding DisplayLabel}"
                            FontSize="12" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Right: utility actions  -->
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Height="34"
                    Classes="ghost"
                    Command="{Binding OpenJournalCommand}"
                    Content="Journal"
                    FontSize="13" />
            </StackPanel>

        </Grid>
    </Border>

</UserControl>
