<UserControl
    x:Class="RealmUnbound.Client.Views.GameView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:RealmUnbound.Client.ViewModels"
    xmlns:views="using:RealmUnbound.Client.Views"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <!--
        ══════════════════════════════════════════════════════════════════════
        GAME VIEW — thin layout shell; all content lives in extracted components
        Row 0: Header  (Auto)
        Row 1: Content — Left|Center|Right  (*)
        Row 2: Action bar  (Auto)
        ══════════════════════════════════════════════════════════════════════
    -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!--  ── ROW 0: HEADER ────────────────────────────────────────────────  -->
        <views:GameHeaderView Grid.Row="0" />

        <!--  ── ROW 1: 3-COLUMN CONTENT ─────────────────────────────────────  -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">

            <!--  ── LEFT PANEL (collapsible) ────────────────────────────────  -->
            <views:GameLeftPanelView Grid.Column="0" />

            <!--  ── CENTER PANEL (Zone / Region / World views) ─────────────  -->
            <views:GameCenterPanelView Grid.Column="1" />

            <!--  ── RIGHT PANEL (action log + social) ───────────────────────  -->
            <views:GameRightPanelView Grid.Column="2" />

        </Grid>

        <!--  ── INVENTORY OVERLAY ───────────────────────────────────────────  -->
        <!--  Spans center + right columns so the left stats panel stays visible  -->
        <views:GameInventoryOverlayView
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2" />

        <!--  ── SHOP OVERLAY ────────────────────────────────────────────────  -->
        <views:GameShopOverlayView
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2" />

        <!--  ── JOURNAL OVERLAY ──────────────────────────────────────────────  -->
        <views:GameJournalOverlayView
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2" />

        <!--  ── ROW 2: HOTBAR + CONTEXT-SENSITIVE ACTION BAR ────────────────  -->
        <views:GameFooterView Grid.Row="2" />

        <!--  ── ATTRIBUTE ALLOCATION OVERLAY ────────────────────────────────  -->
        <views:GameAttributeAllocationOverlayView
            Grid.Row="0"
            Grid.RowSpan="3"
            ZIndex="100" />

        <!--  ── STATUS MESSAGE BANNER ───────────────────────────────────────  -->
        <!--  Full-width overlay anchored to the top; ZIndex 200 puts it above all other content  -->
        <views:GameStatusBannerView
            Grid.Row="0"
            Grid.RowSpan="3"
            ZIndex="200" />

    </Grid>

</UserControl>