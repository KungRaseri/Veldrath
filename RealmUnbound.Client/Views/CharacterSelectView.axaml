<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmUnbound.Client.ViewModels"
             xmlns:svc="using:RealmUnbound.Client.Services"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RealmUnbound.Client.Views.CharacterSelectView"
             x:DataType="vm:CharacterSelectViewModel">

    <Grid>

        <!-- ===== LIST PANEL (IsCreating = false) ===== -->
        <Grid RowDefinitions="Auto,*,Auto"
              IsVisible="{Binding !IsCreating}">

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="Select Your Character"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#c8a96e"
                       HorizontalAlignment="Center"
                       Margin="0,32,0,24" />

            <!-- Character list -->
            <ScrollViewer Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" Spacing="0">

                    <!-- Error message -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#c05050"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding Characters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="svc:CharacterDto">
                                <Border Background="#1e1e2e"
                                        BorderBrush="#3a3a5a"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="16"
                                        Margin="0,0,0,8"
                                        Width="480">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#e0e0f0" />
                                            <TextBlock Foreground="#8a8a9a" FontSize="13">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}Slot {0}  ·  {1}  ·  Level {2}">
                                                        <Binding Path="SlotIndex" />
                                                        <Binding Path="ClassName" />
                                                        <Binding Path="Level" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Play"
                                                Command="{Binding $parent[UserControl].DataContext.SelectCommand}"
                                                CommandParameter="{Binding}"
                                                Height="36"
                                                Margin="8,0" />

                                        <Button Grid.Column="2"
                                                Content="Delete"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}"
                                                Height="36"
                                                Foreground="#c05050" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- New Character button -->
            <Button Grid.Row="2"
                    Content="+ New Character"
                    Command="{Binding ShowCreateCommand}"
                    HorizontalAlignment="Center"
                    Width="480"
                    Height="44"
                    FontSize="15"
                    Margin="0,0,0,32" />

        </Grid>

        <!-- ===== CREATE PANEL (IsCreating = true) ===== -->
        <Grid RowDefinitions="Auto,*,Auto"
              IsVisible="{Binding IsCreating}">

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="New Character"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#c8a96e"
                       HorizontalAlignment="Center"
                       Margin="0,32,0,48" />

            <!-- Create form -->
            <StackPanel Grid.Row="1"
                        Width="480"
                        HorizontalAlignment="Center"
                        Spacing="8">

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#c05050"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Margin="0,0,0,8" />

                <TextBlock Text="Character Name" Foreground="#8a8a9a" />
                <TextBox Text="{Binding NewCharacterName}"
                         Watermark="Enter a name for your character"
                         Height="44"
                         FontSize="15" />

                <Button Content="Create Character"
                        Command="{Binding CreateCommand}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        FontSize="15"
                        Margin="0,16,0,0" />

                <Button Content="Cancel"
                        Command="{Binding CancelCreateCommand}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        FontSize="15" />

            </StackPanel>

        </Grid>

        <!-- Busy overlay (covers both panels) -->
        <Grid IsVisible="{Binding IsBusy}"
              Background="#80000000">
            <ProgressBar IsIndeterminate="True"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Width="200" />
        </Grid>

    </Grid>

</UserControl>
