<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmUnbound.Client.ViewModels"
             xmlns:svc="using:RealmUnbound.Client.Services"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RealmUnbound.Client.Views.CharacterSelectView"
             x:DataType="vm:CharacterSelectViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource GameBackground1Brush}"
                BorderBrush="{DynamicResource GameBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding PanelTitle}"
                           Classes="title"
                           FontSize="22"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Logout"
                        Classes="danger ghost"
                        Command="{Binding LogoutCommand}"
                        Height="32"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">

        <!-- ===== LIST PANEL (IsCreating = false) ===== -->
        <Grid RowDefinitions="*,Auto"
              IsVisible="{Binding !IsCreating}">

            <!-- Character list -->
            <ScrollViewer Grid.Row="0">
                <StackPanel HorizontalAlignment="Center" Spacing="0" Margin="0,24,0,0">

                    <!-- Error feedback -->
                    <ui:InfoBar Title="Error"
                                Message="{Binding ErrorMessage}"
                                Severity="Error"
                                IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                IsClosable="False"
                                Width="480"
                                Margin="0,0,0,4" />

                    <Expander Header="Details"
                              IsVisible="{Binding ErrorDetails, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                              IsExpanded="False"
                              Width="480"
                              Margin="0,0,0,4">
                        <TextBlock Text="{Binding ErrorDetails}"
                                   Classes="muted"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </Expander>

                    <ItemsControl ItemsSource="{Binding Characters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="svc:CharacterDto">
                                <Border Classes="card"
                                        Margin="0,0,0,8"
                                        Width="480">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}"
                                                       Classes="title"
                                                       FontSize="18" />
                                            <TextBlock Classes="muted" FontSize="13">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}Slot {0}  Â·  {1}  Â·  Level {2}">
                                                        <Binding Path="SlotIndex" />
                                                        <Binding Path="ClassName" />
                                                        <Binding Path="Level" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Play"
                                                Classes="accent"
                                                Command="{Binding $parent[UserControl].DataContext.SelectCommand}"
                                                CommandParameter="{Binding}"
                                                Height="36"
                                                Margin="8,0" />

                                        <Button Grid.Column="2"
                                                Content="Delete"
                                                Classes="danger"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}"
                                                Height="36" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- New Character button -->
            <Button Grid.Row="1"
                    Content="+ New Character"
                    Classes="accent"
                    Command="{Binding ShowCreateCommand}"
                    HorizontalAlignment="Center"
                    Width="480"
                    Height="44"
                    FontSize="15"
                    Margin="0,12,0,32" />

        </Grid>

        <!-- ===== CREATE PANEL (IsCreating = true) ===== -->
        <Grid RowDefinitions="Auto,*"
              IsVisible="{Binding IsCreating}">

            <!-- Create form -->
            <StackPanel Grid.Row="0"
                        Width="480"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="0,32,0,0">

                <!-- Error feedback -->
                <ui:InfoBar Title="Error"
                            Message="{Binding ErrorMessage}"
                            Severity="Error"
                            IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            IsClosable="False"
                            Margin="0,0,0,4" />

                <Expander Header="Details"
                          IsVisible="{Binding ErrorDetails, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          IsExpanded="False"
                          Margin="0,0,0,4">
                    <TextBlock Text="{Binding ErrorDetails}"
                               Classes="muted"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </Expander>

                <TextBlock Text="Character Name" Classes="muted" />
                <TextBox Text="{Binding NewCharacterName}"
                         Watermark="Enter a name for your character"
                         Height="44"
                         FontSize="15" />

                <Button Content="Create Character"
                        Classes="accent"
                        Command="{Binding CreateCommand}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        FontSize="15"
                        Margin="0,16,0,0" />

                <Button Content="Cancel"
                        Classes="ghost"
                        Command="{Binding CancelCreateCommand}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        FontSize="15" />
            </StackPanel>
        </Grid>

        </Grid>

    </Grid>

</UserControl>
