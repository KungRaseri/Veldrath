<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmUnbound.Client.ViewModels"
             xmlns:svc="using:RealmUnbound.Contracts.Characters"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RealmUnbound.Client.Views.CharacterSelectView"
             x:DataType="vm:CharacterSelectViewModel">

    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <ImageBrush Source="{DynamicResource UiBg1}" Stretch="UniformToFill" Opacity="0.3" />
        </Grid.Background>

        <!-- Top bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource GameBackground1Brush}"
                BorderBrush="{DynamicResource GameBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding PanelTitle}"
                           Classes="title"
                           FontSize="22"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Logout"
                        Classes="danger ghost"
                        Command="{Binding LogoutCommand}"
                        Height="32"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">

        <!-- ===== LIST PANEL (IsCreating = false) ===== -->
        <Grid RowDefinitions="*,Auto"
              IsVisible="{Binding !IsCreating}">

            <!-- Character list -->
            <ScrollViewer Grid.Row="0">
                <StackPanel HorizontalAlignment="Center" Spacing="0" Margin="0,24,0,0">

                    <!-- Error feedback -->
                    <ui:InfoBar Title="Error"
                                Message="{Binding ErrorMessage}"
                                Severity="Error"
                                IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                IsClosable="False"
                                Width="480"
                                Margin="0,0,0,4" />

                    <Expander Header="Details"
                              IsVisible="{Binding ErrorDetails, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                              IsExpanded="False"
                              Width="480"
                              Margin="0,0,0,4">
                        <TextBlock Text="{Binding ErrorDetails}"
                                   Classes="muted"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </Expander>

                    <ItemsControl ItemsSource="{Binding Characters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CharacterEntryViewModel">
                                <Border Classes="card"
                                        Margin="0,0,0,8"
                                        Width="480">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto">

                                        <!-- Character info with class icon -->
                                        <StackPanel Grid.Row="0" Grid.Column="0"
                                                    Orientation="Horizontal" Spacing="10">
                                            <Image Source="{Binding ClassIcon}"
                                                   Width="40" Height="40"
                                                   Stretch="Uniform"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding ClassIcon,
                                                       Converter={x:Static ObjectConverters.IsNotNull}}" />
                                            <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Character.Name}"
                                                           Classes="title"
                                                           FontSize="18" />
                                                <!-- In Game badge — only visible when character is online -->
                                                <Border Background="{DynamicResource SystemAccentColorDark2}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding IsOnline}">
                                                    <TextBlock Text="In Game"
                                                               Foreground="White"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <!-- HC badge — only visible for hardcore characters -->
                                                <Border Background="#8B0000"
                                                        CornerRadius="4"
                                                        Padding="4,2"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding IsHardcore}">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <Image Source="{Binding HardcoreIcon}"
                                                               Width="14" Height="14"
                                                               Stretch="Uniform"
                                                               IsVisible="{Binding HardcoreIcon,
                                                                   Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                        <TextBlock Text="HC"
                                                                   Foreground="White"
                                                                   FontSize="11"
                                                                   FontWeight="Bold" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Classes="muted" FontSize="13">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}Slot {0}  ·  {1}  ·  Level {2}">
                                                        <Binding Path="Character.SlotIndex" />
                                                        <Binding Path="Character.ClassName" />
                                                        <Binding Path="Character.Level" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Row="0" Grid.Column="1"
                                                Content="Play"
                                                Classes="accent"
                                                Command="{Binding $parent[UserControl].DataContext.SelectCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding !IsOnline}"
                                                Height="36"
                                                Margin="8,0" />

                                        <Button Grid.Row="0" Grid.Column="2"
                                                Content="Delete"
                                                Classes="danger"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding !IsOnline}"
                                                Height="36" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- New Character button -->
            <Button Grid.Row="1"
                    Content="+ New Character"
                    Classes="accent"
                    Command="{Binding ShowCreateCommand}"
                    HorizontalAlignment="Center"
                    Width="480"
                    Height="44"
                    FontSize="15"
                    Margin="0,12,0,32" />

        </Grid>

        <!-- ===== CREATE PANEL (IsCreating = true) ===== -->
        <Grid RowDefinitions="Auto,*"
              IsVisible="{Binding IsCreating}">

            <!-- Create form -->
            <StackPanel Grid.Row="0"
                        Width="480"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="0,32,0,0">

                <!-- Error feedback -->
                <ui:InfoBar Title="Error"
                            Message="{Binding ErrorMessage}"
                            Severity="Error"
                            IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            IsClosable="False"
                            Margin="0,0,0,4" />

                <Expander Header="Details"
                          IsVisible="{Binding ErrorDetails, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          IsExpanded="False"
                          Margin="0,0,0,4">
                    <TextBlock Text="{Binding ErrorDetails}"
                               Classes="muted"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </Expander>

                <TextBlock Text="Character Name" Classes="muted" />
                <TextBox Text="{Binding NewCharacterName}"
                         Watermark="Enter a name for your character"
                         Height="44"
                         FontSize="15" />

                <TextBlock Text="Class" Classes="muted" />
                <ComboBox ItemsSource="{Binding AvailableClasses}"
                          SelectedItem="{Binding SelectedClass}"
                          PlaceholderText="Select a class"
                          HorizontalAlignment="Stretch"
                          Height="44"
                          FontSize="15" />

                <TextBlock Text="Difficulty" Classes="muted" />
                <CheckBox Content="Hardcore Mode"
                          IsChecked="{Binding IsHardcoreCreate}"
                          FontSize="15" />
                <ui:InfoBar Title="Permadeath Warning"
                            Message="Hardcore characters are permanently deleted on death. This cannot be undone."
                            Severity="Warning"
                            IsOpen="{Binding IsHardcoreCreate}"
                            IsClosable="False"
                            Margin="0,0,0,4" />

                <Image Source="{Binding SelectedClassIcon}"
                       Width="72" Height="72"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"
                       IsVisible="{Binding SelectedClassIcon,
                           Converter={x:Static ObjectConverters.IsNotNull}}" />

                <Button Content="Create Character"
                        Classes="accent"
                        Command="{Binding CreateCommand}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        FontSize="15"
                        Margin="0,16,0,0" />

                <Button Content="Cancel"
                        Classes="ghost"
                        Command="{Binding CancelCreateCommand}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        FontSize="15" />
            </StackPanel>
        </Grid>

        </Grid>

    </Grid>

</UserControl>
