<UserControl
    x:Class="RealmUnbound.Client.Views.GameView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:RealmUnbound.Client.ViewModels"
    xmlns:views="using:RealmUnbound.Client.Views"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <!--
        ══════════════════════════════════════════════════════════════════════
        GAME VIEW — 3-column layout with collapsible left panel
        Row 0: Header  (Auto)
        Row 1: Content — Left|Center|Right  (*)
        Row 2: Action bar  (Auto)
        ══════════════════════════════════════════════════════════════════════
    -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!--  ── ROW 0: HEADER ────────────────────────────────────────────────  -->
        <views:GameHeaderView Grid.Row="0" />

        <!--  ── ROW 1: 3-COLUMN CONTENT ─────────────────────────────────────  -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">

            <!--  ── LEFT PANEL (collapsible) ────────────────────────────────  -->
            <views:GameLeftPanelView Grid.Column="0" />

            <!--  ── CENTER PANEL (Zone / Region / World views) ─────────────  -->
            <Border
                Grid.Column="1"
                Padding="24"
                Background="{DynamicResource GameBackground0Brush}">
                <DockPanel>

                    <!--  Header: zone description + view selector tabs  -->
                    <DockPanel Margin="0,0,0,16" DockPanel.Dock="Top">

                        <!--  View tabs (right-aligned)  -->
                        <StackPanel
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="2">
                            <Button
                                Height="28"
                                Classes="ghost"
                                Classes.accent="{Binding IsZoneViewActive}"
                                Command="{Binding ShowZoneViewCommand}"
                                Content="Zone"
                                FontSize="12" />
                            <Button
                                Height="28"
                                Classes="ghost"
                                Classes.accent="{Binding IsRegionViewActive}"
                                Command="{Binding ShowRegionViewCommand}"
                                Content="Region"
                                FontSize="12" />
                            <Button
                                Height="28"
                                Classes="ghost"
                                Classes.accent="{Binding IsWorldViewActive}"
                                Command="{Binding ShowWorldViewCommand}"
                                Content="World"
                                FontSize="12" />
                        </StackPanel>

                        <!--  Zone description (fills remaining width)  -->
                        <TextBlock
                            VerticalAlignment="Center"
                            Classes="muted"
                            FontStyle="Italic"
                            Text="{Binding ZoneDescription}"
                            TextWrapping="Wrap" />
                    </DockPanel>

                    <!--  Three panels stacked — only the active one is visible  -->
                    <Grid>

                        <!--
                            ══════════════════════════════════════════════════
                            ZONE PANEL — current zone details + mini region list
                            ══════════════════════════════════════════════════
                        -->
                        <ScrollViewer IsVisible="{Binding IsZoneViewActive}" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!--  Feature badges (Inn / Merchant)  -->
                                <StackPanel
                                    Margin="0,4,0,0"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Border
                                        Padding="10,5"
                                        Background="{DynamicResource GameSuccessMutedBrush}"
                                        BorderBrush="{DynamicResource GameSuccessBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        IsVisible="{Binding HasInn}">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource GameSuccessBrush}"
                                            Text="Inn" />
                                    </Border>
                                    <Border
                                        Padding="10,5"
                                        Background="{DynamicResource GameInfoMutedBrush}"
                                        BorderBrush="{DynamicResource GameInfoBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        IsVisible="{Binding HasMerchant}">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource GameInfoBrush}"
                                            Text="Merchant" />
                                    </Border>
                                </StackPanel>

                                <!--  Region breadcrumb + min level  -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Classes="caption"
                                            Text="Region:" />
                                        <Button
                                            Height="24"
                                            Padding="4,0"
                                            VerticalAlignment="Center"
                                            Classes="ghost"
                                            Command="{Binding ShowRegionViewCommand}"
                                            Content="{Binding RegionName}"
                                            FontSize="13" />
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="4">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Classes="caption"
                                            Text="Min level" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Classes="accent"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Text="{Binding ZoneMinLevel}" />
                                    </StackPanel>
                                </Grid>

                                <Border Classes="separator" />

                                <!--  Mini zone list for current region  -->
                                <TextBlock Classes="caption" Text="Zones in this region" />
                                <ItemsControl ItemsSource="{Binding RegionZones}">
                                    <ItemsControl.Styles>
                                        <Style Selector="Border.active">
                                            <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                                            <Setter Property="Background" Value="{DynamicResource GameBackground3Brush}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ZoneNodeViewModel">
                                            <Border
                                                MinWidth="120"
                                                Margin="0,0,8,8"
                                                Padding="10,7"
                                                Background="{DynamicResource GameBackground2Brush}"
                                                BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="1"
                                                Classes.active="{Binding IsCurrentZone}"
                                                CornerRadius="4">
                                                <StackPanel Spacing="3">
                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock
                                                            Classes="caption"
                                                            FontSize="10"
                                                            Text="{Binding Type}" />
                                                        <TextBlock Classes="caption" FontSize="10">
                                                            <Run Text="Lv." /><Run Text="{Binding MinLevel}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Button
                                                        Height="22"
                                                        Padding="6,0"
                                                        Classes="ghost"
                                                        Command="{Binding TravelCommand}"
                                                        Content="Travel →"
                                                        FontSize="10"
                                                        IsVisible="{Binding CanTravel}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Classes="separator" />

                                <!--  Locations in this zone  -->
                                <TextBlock Classes="caption" Text="Locations" />
                                <ItemsControl ItemsSource="{Binding ZoneLocations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ZoneLocationItemViewModel">
                                            <Border
                                                Margin="0,0,0,6"
                                                Padding="10,7"
                                                Background="{DynamicResource GameBackground2Brush}"
                                                BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                            <TextBlock
                                                                FontSize="12"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding DisplayName}" />
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock
                                                                    Classes="caption"
                                                                    FontSize="10"
                                                                    Text="{Binding LocationType}" />
                                                                <TextBlock
                                                                    Classes="caption"
                                                                    FontSize="10"
                                                                    IsVisible="{Binding MinLevel, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                                    <Run Text="Lv." /><Run Text="{Binding MinLevel}" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button
                                                            Grid.Column="1"
                                                            Height="22"
                                                            Padding="6,0"
                                                            VerticalAlignment="Center"
                                                            Classes="ghost"
                                                            Command="{Binding NavigateCommand}"
                                                            Content="Go →"
                                                            FontSize="10"
                                                            IsVisible="{Binding CanNavigate}" />
                                                    </Grid>
                                                    <!--  Outgoing connection buttons — only shown when this is the current location  -->
                                                    <ItemsControl IsVisible="{Binding IsCurrent}" ItemsSource="{Binding $parent[Window].DataContext.CurrentLocationConnections, FallbackValue={}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:ZoneConnectionLinkViewModel">
                                                                <Button
                                                                    Height="22"
                                                                    Margin="0,2,4,0"
                                                                    Padding="6,0"
                                                                    Classes="ghost"
                                                                    Command="{Binding TraverseCommand}"
                                                                    Content="{Binding Label}"
                                                                    FontSize="10" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!--  ── ENEMY ROSTER ────────────────────────────────────  -->
                                <!--  Visible only when at a zone location that has enemies  -->
                                <StackPanel IsVisible="{Binding HasSpawnedEnemies}" Spacing="8">
                                    <Border Classes="separator" />
                                    <TextBlock Classes="caption" Text="Enemies" />
                                    <ItemsControl ItemsSource="{Binding SpawnedEnemies}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SpawnedEnemyItemViewModel">
                                                <Border
                                                    Margin="0,0,0,5"
                                                    Padding="8,6"
                                                    Background="{DynamicResource GameBackground2Brush}"
                                                    BorderBrush="{DynamicResource GameBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock
                                                                    FontSize="12"
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding Name}" />
                                                                <TextBlock Classes="caption" FontSize="10">
                                                                    <Run Text="Lv." /><Run Text="{Binding Level}" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <ProgressBar
                                                                Height="4"
                                                                Classes="health"
                                                                Maximum="{Binding MaxHealth}"
                                                                Minimum="0"
                                                                Value="{Binding CurrentHealth}" />
                                                            <TextBlock Classes="caption" FontSize="10">
                                                                <Run Text="{Binding CurrentHealth}" /><Run Text=" / " /><Run Text="{Binding MaxHealth}" /><Run Text=" HP" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Button
                                                            Grid.Column="1"
                                                            Height="26"
                                                            Padding="8,0"
                                                            VerticalAlignment="Center"
                                                            Classes="accent"
                                                            Command="{Binding $parent[UserControl].DataContext.EngageEnemyCommand}"
                                                            CommandParameter="{Binding Id}"
                                                            Content="Engage"
                                                            FontSize="10"
                                                            IsVisible="{Binding IsAlive}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!--  ── COMBAT HUD ──────────────────────────────────────  -->
                                <!--  Overlays the zone panel while IsInCombat is true  -->
                                <Border
                                    Padding="14"
                                    Background="{DynamicResource GameBackground2Brush}"
                                    BorderBrush="{DynamicResource GameDangerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    IsVisible="{Binding IsInCombat}">
                                    <StackPanel Spacing="10">
                                        <!--  Enemy stats  -->
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock
                                                    Grid.Column="0"
                                                    FontSize="15"
                                                    FontWeight="Bold"
                                                    Text="{Binding CombatEnemyName}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Classes="caption">
                                                    <Run Text="Lv." /><Run Text="{Binding CombatEnemyLevel}" />
                                                </TextBlock>
                                            </Grid>
                                            <ProgressBar
                                                Height="8"
                                                Classes="health"
                                                Maximum="{Binding CombatEnemyMaxHealth}"
                                                Minimum="0"
                                                Value="{Binding CombatEnemyCurrentHealth}" />
                                            <TextBlock Classes="caption">
                                                <Run Text="{Binding CombatEnemyCurrentHealth}" /><Run Text=" / " /><Run Text="{Binding CombatEnemyMaxHealth}" /><Run Text=" HP" />
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Classes="separator" />

                                        <!--  Combat action buttons  -->
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button
                                                Height="32"
                                                Classes="accent"
                                                Command="{Binding AttackEnemyCommand}"
                                                Content="⚔ Attack"
                                                FontSize="13" />
                                            <Button
                                                Height="32"
                                                Classes="ghost"
                                                Command="{Binding DefendActionCommand}"
                                                Content="🛡 Defend"
                                                FontSize="13" />
                                            <Button
                                                Height="32"
                                                Classes="danger ghost"
                                                Command="{Binding FleeFromCombatCommand}"
                                                Content="🏃 Flee"
                                                FontSize="13" />
                                        </StackPanel>

                                        <!--  Learned ability buttons (dynamic from LearnedAbilities)  -->
                                        <ItemsControl IsVisible="{Binding LearnedAbilities.Count, Converter={x:Static ObjectConverters.IsNotNull}}" ItemsSource="{Binding LearnedAbilities}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        Height="30"
                                                        Margin="0,0,6,6"
                                                        Classes="ghost"
                                                        Command="{Binding $parent[UserControl].DataContext.UseAbilityInCombatCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="{Binding}"
                                                        FontSize="12" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!--  Enemy known abilities caption  -->
                                        <StackPanel IsVisible="{Binding EnemyAbilityNames.Count, Converter={x:Static ObjectConverters.IsNotNull}}" Spacing="2">
                                            <TextBlock
                                                Classes="caption"
                                                FontSize="11"
                                                Text="Enemy abilities:" />
                                            <ItemsControl ItemsSource="{Binding EnemyAbilityNames}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            Margin="0,0,8,0"
                                                            Classes="muted"
                                                            FontSize="11"
                                                            Text="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!--  ── DEATH OVERLAY ────────────────────────────────────  -->
                                <!--  Shown when the player is dead  -->
                                <Border
                                    Padding="14"
                                    Background="{DynamicResource GameBackground2Brush}"
                                    BorderBrush="{DynamicResource GameDangerBrush}"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    IsVisible="{Binding IsPlayerDead}">
                                    <StackPanel HorizontalAlignment="Center" Spacing="10">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            Classes="danger"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Text="You have fallen…" />

                                        <!--  Normal-mode: Respawn  -->
                                        <Button
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            Classes="accent"
                                            Command="{Binding RespawnCommand}"
                                            Content="Respawn"
                                            FontSize="14"
                                            IsVisible="{Binding IsHardcoreDeath, Converter={x:Static BoolConverters.Not}}" />

                                        <!--  Hardcore-mode: return to character select  -->
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            IsVisible="{Binding IsHardcoreDeath}"
                                            Spacing="6">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                Classes="muted"
                                                FontSize="12"
                                                Text="Your hardcore character is gone." />
                                            <Button
                                                Height="36"
                                                HorizontalAlignment="Center"
                                                Classes="danger"
                                                Command="{Binding LogoutCommand}"
                                                Content="Return to Character Select"
                                                FontSize="14" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!--
                            ══════════════════════════════════════════════════
                            REGION PANEL — region info + full zone card grid
                            ══════════════════════════════════════════════════
                        -->
                        <ScrollViewer IsVisible="{Binding IsRegionViewActive}" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!--  Region header  -->
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Text="{Binding RegionName}" />
                                        <Border
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource GameBackground3Brush}"
                                            BorderBrush="{DynamicResource GameBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            IsVisible="{Binding RegionType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Classes="caption" Text="{Binding RegionType}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Classes="muted" FontSize="13">
                                        <Run Text="Levels " /><Run Text="{Binding RegionMinLevel}" /><Run Text="–" /><Run Text="{Binding RegionMaxLevel}" />
                                    </TextBlock>
                                    <TextBlock
                                        Classes="muted"
                                        FontStyle="Italic"
                                        Text="{Binding RegionDescription}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Classes="separator" />

                                <TextBlock Classes="caption" Text="Zones" />
                                <ItemsControl ItemsSource="{Binding RegionZones}">
                                    <ItemsControl.Styles>
                                        <Style Selector="Border.active">
                                            <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                                            <Setter Property="Background" Value="{DynamicResource GameBackground3Brush}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ZoneNodeViewModel">
                                            <Border
                                                MinWidth="160"
                                                Margin="0,0,12,12"
                                                Padding="14,10"
                                                Background="{DynamicResource GameBackground2Brush}"
                                                BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="1"
                                                Classes.active="{Binding IsCurrentZone}"
                                                CornerRadius="6">
                                                <StackPanel Spacing="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            Classes="accent"
                                                            FontSize="11"
                                                            IsVisible="{Binding IsCurrentZone}"
                                                            Text="★" />
                                                    </StackPanel>
                                                    <Border
                                                        Padding="5,2"
                                                        HorizontalAlignment="Left"
                                                        Background="{DynamicResource GameBackground4Brush}"
                                                        CornerRadius="3">
                                                        <TextBlock
                                                            Classes="caption"
                                                            FontSize="10"
                                                            Text="{Binding Type}" />
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock FontSize="11">
                                                            <Run Text="Lv." /><Run Text="{Binding MinLevel}" />
                                                        </TextBlock>
                                                        <TextBlock
                                                            Classes="muted"
                                                            FontSize="10"
                                                            IsVisible="{Binding HasInn}"
                                                            Text="Inn" />
                                                        <TextBlock
                                                            Classes="muted"
                                                            FontSize="10"
                                                            IsVisible="{Binding HasMerchant}"
                                                            Text="Shop" />
                                                    </StackPanel>
                                                    <Button
                                                        Height="26"
                                                        Classes="ghost"
                                                        Command="{Binding TravelCommand}"
                                                        Content="Travel here"
                                                        FontSize="11"
                                                        IsVisible="{Binding CanTravel}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>

                        <!--
                            ══════════════════════════════════════════════════
                            WORLD PANEL — world header + region card grid
                            ══════════════════════════════════════════════════
                        -->
                        <ScrollViewer IsVisible="{Binding IsWorldViewActive}" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!--  World header  -->
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Text="{Binding WorldName}" />
                                    <TextBlock
                                        Classes="muted"
                                        FontStyle="Italic"
                                        Text="{Binding WorldEra}" />
                                </StackPanel>

                                <Border Classes="separator" />

                                <TextBlock Classes="caption" Text="Regions" />
                                <ItemsControl ItemsSource="{Binding WorldRegions}">
                                    <ItemsControl.Styles>
                                        <Style Selector="Border.active">
                                            <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RegionCardViewModel">
                                            <Border
                                                MinWidth="200"
                                                Margin="0,0,16,16"
                                                Padding="16,12"
                                                Background="{DynamicResource GameBackground2Brush}"
                                                BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="1"
                                                Classes.active="{Binding IsCurrentRegion}"
                                                CornerRadius="6">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock
                                                            FontSize="15"
                                                            FontWeight="Bold"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            Classes="accent"
                                                            FontSize="10"
                                                            IsVisible="{Binding IsCurrentRegion}"
                                                            Text="You are here" />
                                                    </StackPanel>
                                                    <Border
                                                        Padding="6,2"
                                                        HorizontalAlignment="Left"
                                                        Background="{DynamicResource GameBackground3Brush}"
                                                        CornerRadius="3">
                                                        <TextBlock
                                                            Classes="caption"
                                                            FontSize="11"
                                                            Text="{Binding Type}" />
                                                    </Border>
                                                    <TextBlock Classes="muted" FontSize="12">
                                                        <Run Text="Levels " /><Run Text="{Binding MinLevel}" /><Run Text="–" /><Run Text="{Binding MaxLevel}" />
                                                    </TextBlock>
                                                    <Button
                                                        Height="26"
                                                        Classes="ghost"
                                                        Command="{Binding ExploreCommand}"
                                                        Content="Explore →"
                                                        FontSize="11" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                </DockPanel>
            </Border>

            <!--  ── RIGHT PANEL (action log + social) ───────────────────────  -->
            <views:GameRightPanelView Grid.Column="2" />

        </Grid>

        <!--  ── INVENTORY OVERLAY ───────────────────────────────────────────  -->
        <!--  Spans center + right columns so the left stats panel stays visible  -->
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Background="#B2000000"
            IsVisible="{Binding IsInventoryOpen}">
            <Border
                MaxWidth="640"
                MaxHeight="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource GameBackground1Brush}"
                BorderBrush="{DynamicResource GameBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <DockPanel>

                    <!--  Header  -->
                    <Border
                        Padding="16,10"
                        Background="{DynamicResource GameBackground2Brush}"
                        BorderBrush="{DynamicResource GameBorderBrush}"
                        BorderThickness="0,0,0,1"
                        DockPanel.Dock="Top">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="Inventory" />
                            <Button
                                Grid.Column="1"
                                Width="32"
                                Height="32"
                                Classes="ghost icon"
                                Command="{Binding ToggleInventoryCommand}"
                                Content="✕" />
                        </Grid>
                    </Border>

                    <!--  Item list  -->
                    <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                        <Panel>
                            <!--  Empty state  -->
                            <TextBlock
                                Margin="0,32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Classes="muted"
                                IsVisible="{Binding !InventoryItems.Count}"
                                Text="Your inventory is empty." />

                            <!--  Item rows  -->
                            <ItemsControl IsVisible="{Binding InventoryItems.Count}" ItemsSource="{Binding InventoryItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InventoryItemViewModel">
                                        <Border
                                            Padding="4,8"
                                            BorderBrush="{DynamicResource GameBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding DisplayName}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="8,0"
                                                    VerticalAlignment="Center"
                                                    Classes="caption"
                                                    IsVisible="{Binding HasDurability}"
                                                    Text="{Binding DurabilityText}" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Margin="8,0"
                                                    VerticalAlignment="Center"
                                                    Classes="accent"
                                                    Text="{Binding QuantityText}" />
                                                <Button
                                                    Grid.Column="3"
                                                    Height="28"
                                                    Margin="4,0,0,0"
                                                    Classes="ghost"
                                                    Command="{Binding EquipCommand}"
                                                    CommandParameter="MainHand"
                                                    Content="Equip"
                                                    FontSize="12" />
                                                <Button
                                                    Grid.Column="4"
                                                    Height="28"
                                                    Margin="4,0,0,0"
                                                    Classes="ghost"
                                                    Command="{Binding DropCommand}"
                                                    Content="Drop"
                                                    FontSize="12" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Panel>
                    </ScrollViewer>

                </DockPanel>
            </Border>
        </Border>

        <!--  ── SHOP OVERLAY ────────────────────────────────────────────────  -->
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Background="#B2000000"
            IsVisible="{Binding IsShopOpen}">
            <Border
                MaxWidth="640"
                MaxHeight="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource GameBackground1Brush}"
                BorderBrush="{DynamicResource GameBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <DockPanel>

                    <!--  Header  -->
                    <Border
                        Padding="16,10"
                        Background="{DynamicResource GameBackground2Brush}"
                        BorderBrush="{DynamicResource GameBorderBrush}"
                        BorderThickness="0,0,0,1"
                        DockPanel.Dock="Top">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="Shop" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Classes="muted"
                                    FontSize="14"
                                    Text="{Binding ShopZoneName}" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Width="32"
                                Height="32"
                                Classes="ghost icon"
                                Command="{Binding CloseShopCommand}"
                                Content="✕" />
                        </Grid>
                    </Border>

                    <!--  Shop content: Buy / Sell tabs  -->
                    <TabControl Margin="8">

                        <!--  Buy tab  -->
                        <TabItem Header="Buy">
                            <ScrollViewer MaxHeight="360">
                                <Panel>
                                    <TextBlock
                                        Margin="0,32"
                                        HorizontalAlignment="Center"
                                        Classes="muted"
                                        IsVisible="{Binding !ShopItems.Count}"
                                        Text="Nothing for sale here." />
                                    <ItemsControl IsVisible="{Binding ShopItems.Count}" ItemsSource="{Binding ShopItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ShopItemViewModel">
                                                <Border
                                                    Padding="4,8"
                                                    BorderBrush="{DynamicResource GameBorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            Text="{Binding DisplayName}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Margin="12,0"
                                                            VerticalAlignment="Center"
                                                            Classes="accent"
                                                            Text="{Binding BuyPriceText}" />
                                                        <Button
                                                            Grid.Column="2"
                                                            Height="28"
                                                            Classes="accent"
                                                            Command="{Binding BuyCommand}"
                                                            Content="Buy"
                                                            FontSize="12" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Panel>
                            </ScrollViewer>
                        </TabItem>

                        <!--  Sell tab  -->
                        <TabItem Header="Sell">
                            <ScrollViewer MaxHeight="360">
                                <Panel>
                                    <TextBlock
                                        Margin="0,32"
                                        HorizontalAlignment="Center"
                                        Classes="muted"
                                        IsVisible="{Binding !ShopItems.Count}"
                                        Text="Nothing available to sell." />
                                    <ItemsControl IsVisible="{Binding ShopItems.Count}" ItemsSource="{Binding ShopItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ShopItemViewModel">
                                                <Border
                                                    Padding="4,8"
                                                    BorderBrush="{DynamicResource GameBorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            Text="{Binding DisplayName}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Margin="12,0"
                                                            VerticalAlignment="Center"
                                                            Classes="muted"
                                                            Text="{Binding SellPriceText}" />
                                                        <Button
                                                            Grid.Column="2"
                                                            Height="28"
                                                            Classes="ghost"
                                                            Command="{Binding SellCommand}"
                                                            Content="Sell"
                                                            FontSize="12" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Panel>
                            </ScrollViewer>
                        </TabItem>

                    </TabControl>

                </DockPanel>
            </Border>
        </Border>

        <!--  ── ROW 2: HOTBAR + CONTEXT-SENSITIVE ACTION BAR ────────────────  -->
        <views:GameFooterView Grid.Row="2" />

        <!--  ── ATTRIBUTE ALLOCATION OVERLAY ────────────────────────────────  -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="#CC000000"
            IsVisible="{Binding IsAttributeAllocationOpen}"
            ZIndex="100">
            <Border
                Width="420"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Classes="panel">
                <StackPanel DataContext="{Binding AttributeAllocation}" Spacing="12">

                    <TextBlock
                        Classes="accent"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Allocate Attribute Points" />

                    <TextBlock FontSize="12">
                        <Run Text="Points remaining: " /><Run Classes="accent" Text="{Binding PointsToAllocate}" />
                    </TextBlock>

                    <!--  Attribute rows  -->
                    <ItemsControl ItemsSource="{Binding Attributes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AttributeDraftViewModel">
                                <Grid Margin="0,3" ColumnDefinitions="*,Auto,Auto,Auto">
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Text="{Binding Name}" />
                                    <Button
                                        Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        Margin="0,0,4,0"
                                        Padding="0"
                                        Command="{Binding DecrementCommand}"
                                        Content="−" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Width="36"
                                        VerticalAlignment="Center"
                                        Classes="accent"
                                        FontSize="13"
                                        Text="{Binding DisplayValue}"
                                        TextAlignment="Center" />
                                    <Button
                                        Grid.Column="3"
                                        Width="28"
                                        Height="28"
                                        Margin="4,0,0,0"
                                        Padding="0"
                                        Command="{Binding IncrementCommand}"
                                        Content="+" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button Command="{Binding CancelCommand}" Content="Cancel" />
                        <Button
                            Classes="accent"
                            Command="{Binding ConfirmCommand}"
                            Content="Confirm" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>

        <!--  ── STATUS MESSAGE BANNER ───────────────────────────────────────  -->
        <!--  Full-width overlay anchored to the top; ZIndex 200 puts it above all other content  -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="3"
            Padding="16,10"
            VerticalAlignment="Top"
            Background="{DynamicResource GameBackground2Brush}"
            BorderBrush="{DynamicResource GameWarningBrush}"
            BorderThickness="0,0,0,2"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            ZIndex="200">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="{Binding StatusMessage}"
                    TextWrapping="Wrap" />
                <Button
                    Grid.Column="1"
                    Width="32"
                    Height="32"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Classes="ghost icon"
                    Command="{Binding DismissStatusMessageCommand}"
                    Content="✕"
                    IsVisible="{Binding IsStatusMessageDismissable}" />
            </Grid>
        </Border>

    </Grid>

</UserControl>
