<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmUnbound.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RealmUnbound.Client.Views.GameView"
             x:DataType="vm:GameViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource GameBackground1Brush}"
                BorderBrush="{DynamicResource GameBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding CharacterName}"
                               Classes="accent"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="→"
                               Foreground="{DynamicResource GameTextTertiaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ZoneName}"
                               Classes="muted"
                               FontSize="14"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Classes="muted"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <Button Grid.Column="2"
                        Content="Logout"
                        Classes="danger ghost"
                        Command="{Binding LogoutCommand}"
                        Height="32"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="*,220">

            <!-- Action log -->
            <Border Grid.Column="0"
                    Background="{DynamicResource GameBackground0Brush}"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding ZoneDescription}"
                               Classes="muted"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding ActionLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="13"
                                               Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Online players panel -->
            <Border Grid.Column="1"
                    Background="{DynamicResource GameBackground1Brush}"
                    BorderBrush="{DynamicResource GameBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Online in Zone"
                               Classes="caption"
                               Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding OnlinePlayers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource GameSuccessBrush}" />
                                    <TextBlock Text="{Binding}"
                                               FontSize="13" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </Grid>

    </Grid>

</UserControl>
