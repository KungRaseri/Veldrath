<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RealmUnbound.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RealmUnbound.Client.Views.GameView"
             x:DataType="vm:GameViewModel">

    <!-- ══════════════════════════════════════════════════════════════════════
         GAME VIEW — 3-column layout with collapsible left panel
         Row 0: Header  (Auto)
         Row 1: Content — Left|Center|Right  (*)
         Row 2: Action bar  (Auto)
    ══════════════════════════════════════════════════════════════════════ -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── ROW 0: HEADER ──────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Classes="panel-topbar">
            <Grid ColumnDefinitions="*,Auto,Auto">

                <!-- Left: character name → zone name + zone type badge -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding CharacterName}"
                               Classes="accent"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="→"
                               Foreground="{DynamicResource GameTextTertiaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ZoneName}"
                               FontSize="14"
                               VerticalAlignment="Center" />
                    <Border Background="{DynamicResource GameBackground3Brush}"
                            BorderBrush="{DynamicResource GameBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ZoneType,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ZoneType}"
                                   Classes="caption" />
                    </Border>
                </StackPanel>

                <!-- Centre: status message -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Classes="muted"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <!-- Right: logout -->
                <Button Grid.Column="2"
                        Content="Logout"
                        Classes="danger ghost"
                        Command="{Binding LogoutCommand}"
                        Height="32"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- ── ROW 1: 3-COLUMN CONTENT ───────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,220">

            <!-- ── LEFT PANEL (collapsible) ──────────────────────────────── -->
            <!-- DockPanel auto-sizes the column: 224px open, 28px collapsed -->
            <DockPanel Grid.Column="0"
                       Background="{DynamicResource GameBackground1Brush}"
                       LastChildFill="False">

                <!-- Toggle button — always visible, pinned to right edge -->
                <Button DockPanel.Dock="Right"
                        Classes="icon ghost"
                        Content="{Binding LeftPanelToggleIcon}"
                        Command="{Binding ToggleLeftPanelCommand}"
                        Width="28"
                        VerticalAlignment="Top"
                        Margin="0,10,2,0"
                        ToolTip.Tip="Toggle stats panel" />

                <!-- Collapsible content panel -->
                <Border DockPanel.Dock="Left"
                        IsVisible="{Binding IsLeftPanelOpen}"
                        Width="196"
                        BorderBrush="{DynamicResource GameBorderBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="12,12,8,12">
                    <DockPanel>

                        <!-- HP / MP bars — docked to top -->
                        <StackPanel DockPanel.Dock="Top"
                                    Spacing="10"
                                    Margin="0,0,0,12">

                            <!-- HP bar -->
                            <StackPanel Spacing="3">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="HP"
                                               Classes="caption"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="caption"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding CurrentHealth}" /><Run Text=" / " /><Run Text="{Binding MaxHealth}" />
                                    </TextBlock>
                                </Grid>
                                <ProgressBar Classes="health"
                                             Minimum="0"
                                             Maximum="{Binding MaxHealth}"
                                             Value="{Binding CurrentHealth}"
                                             Height="8" />
                            </StackPanel>

                            <!-- MP bar -->
                            <StackPanel Spacing="3">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="MP"
                                               Classes="caption"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="caption"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding CurrentMana}" /><Run Text=" / " /><Run Text="{Binding MaxMana}" />
                                    </TextBlock>
                                </Grid>
                                <ProgressBar Classes="mana"
                                             Minimum="0"
                                             Maximum="{Binding MaxMana}"
                                             Value="{Binding CurrentMana}"
                                             Height="8" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Divider -->
                        <Border DockPanel.Dock="Top"
                                Classes="separator"
                                Margin="0,0,0,10" />

                        <!-- Log label -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Action Log"
                                   Classes="caption"
                                   Margin="0,0,0,6" />

                        <!-- Scrolling log -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ActionLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </DockPanel>

            <!-- ── CENTER PANEL (Zone / Region / World views) ───────────── -->
            <Border Grid.Column="1"
                    Background="{DynamicResource GameBackground0Brush}"
                    Padding="24">
                <DockPanel>

                    <!-- Header: zone description + view selector tabs -->
                    <DockPanel DockPanel.Dock="Top"
                               Margin="0,0,0,16">

                        <!-- View tabs (right-aligned) -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                            <Button Content="Zone"
                                    Classes="ghost"
                                    Classes.accent="{Binding IsZoneViewActive}"
                                    Command="{Binding ShowZoneViewCommand}"
                                    Height="28"
                                    FontSize="12" />
                            <Button Content="Region"
                                    Classes="ghost"
                                    Classes.accent="{Binding IsRegionViewActive}"
                                    Command="{Binding ShowRegionViewCommand}"
                                    Height="28"
                                    FontSize="12" />
                            <Button Content="World"
                                    Classes="ghost"
                                    Classes.accent="{Binding IsWorldViewActive}"
                                    Command="{Binding ShowWorldViewCommand}"
                                    Height="28"
                                    FontSize="12" />
                        </StackPanel>

                        <!-- Zone description (fills remaining width) -->
                        <TextBlock Text="{Binding ZoneDescription}"
                                   Classes="muted"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Three panels stacked — only the active one is visible -->
                    <Grid>

                        <!-- ══════════════════════════════════════════════════
                             ZONE PANEL — current zone details + mini region list
                        ══════════════════════════════════════════════════ -->
                        <ScrollViewer IsVisible="{Binding IsZoneViewActive}"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!-- Feature badges (Inn / Merchant) -->
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            Margin="0,4,0,0">
                                    <Border Background="{DynamicResource GameSuccessMutedBrush}"
                                            BorderBrush="{DynamicResource GameSuccessBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,5"
                                            IsVisible="{Binding HasInn}">
                                        <TextBlock Text="Inn"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource GameSuccessBrush}" />
                                    </Border>
                                    <Border Background="{DynamicResource GameInfoMutedBrush}"
                                            BorderBrush="{DynamicResource GameInfoBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,5"
                                            IsVisible="{Binding HasMerchant}">
                                        <TextBlock Text="Merchant"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource GameInfoBrush}" />
                                    </Border>
                                </StackPanel>

                                <!-- Region breadcrumb + min level -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Region:"
                                                   Classes="caption"
                                                   VerticalAlignment="Center" />
                                        <Button Content="{Binding RegionName}"
                                                Command="{Binding ShowRegionViewCommand}"
                                                Classes="ghost"
                                                FontSize="13"
                                                Height="24"
                                                Padding="4,0"
                                                VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="4"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Min level"
                                                   Classes="caption"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ZoneMinLevel}"
                                                   Classes="accent"
                                                   FontWeight="Bold"
                                                   FontSize="15"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <Border Classes="separator" />

                                <!-- Mini zone list for current region -->
                                <TextBlock Text="Zones in this region"
                                           Classes="caption" />
                                <ItemsControl ItemsSource="{Binding RegionZones}">
                                    <ItemsControl.Styles>
                                        <Style Selector="Border.active">
                                            <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                                            <Setter Property="Background" Value="{DynamicResource GameBackground3Brush}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ZoneNodeViewModel">
                                            <Border Margin="0,0,8,8"
                                                    Padding="10,7"
                                                    CornerRadius="4"
                                                    Background="{DynamicResource GameBackground2Brush}"
                                                    BorderBrush="{DynamicResource GameBorderBrush}"
                                                    BorderThickness="1"
                                                    MinWidth="120"
                                                    Classes.active="{Binding IsCurrentZone}">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6">
                                                        <TextBlock Text="{Binding Type}"
                                                                   FontSize="10"
                                                                   Classes="caption" />
                                                        <TextBlock FontSize="10"
                                                                   Classes="caption">
                                                            <Run Text="Lv." /><Run Text="{Binding MinLevel}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Button Content="Travel →"
                                                            Classes="ghost"
                                                            FontSize="10"
                                                            Height="22"
                                                            Padding="6,0"
                                                            IsVisible="{Binding CanTravel}"
                                                            Command="{Binding TravelCommand}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ══════════════════════════════════════════════════
                             REGION PANEL — region info + full zone card grid
                        ══════════════════════════════════════════════════ -->
                        <ScrollViewer IsVisible="{Binding IsRegionViewActive}"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!-- Region header -->
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="10">
                                        <TextBlock Text="{Binding RegionName}"
                                                   FontSize="20"
                                                   FontWeight="Bold" />
                                        <Border Background="{DynamicResource GameBackground3Brush}"
                                                BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding RegionType,
                                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding RegionType}"
                                                       Classes="caption" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Classes="muted"
                                               FontSize="13">
                                        <Run Text="Levels " /><Run Text="{Binding RegionMinLevel}" /><Run Text="–" /><Run Text="{Binding RegionMaxLevel}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding RegionDescription}"
                                               Classes="muted"
                                               FontStyle="Italic"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Classes="separator" />

                                <TextBlock Text="Zones"
                                           Classes="caption" />
                                <ItemsControl ItemsSource="{Binding RegionZones}">
                                    <ItemsControl.Styles>
                                        <Style Selector="Border.active">
                                            <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                                            <Setter Property="Background" Value="{DynamicResource GameBackground3Brush}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ZoneNodeViewModel">
                                            <Border Margin="0,0,12,12"
                                                    Padding="14,10"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource GameBackground2Brush}"
                                                    BorderBrush="{DynamicResource GameBorderBrush}"
                                                    BorderThickness="1"
                                                    MinWidth="160"
                                                    Classes.active="{Binding IsCurrentZone}">
                                                <StackPanel Spacing="6">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="★"
                                                                   Classes="accent"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsCurrentZone}" />
                                                    </StackPanel>
                                                    <Border CornerRadius="3"
                                                            Padding="5,2"
                                                            Background="{DynamicResource GameBackground4Brush}"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Type}"
                                                                   FontSize="10"
                                                                   Classes="caption" />
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8">
                                                        <TextBlock FontSize="11">
                                                            <Run Text="Lv." /><Run Text="{Binding MinLevel}" />
                                                        </TextBlock>
                                                        <TextBlock Text="Inn"
                                                                   FontSize="10"
                                                                   Classes="muted"
                                                                   IsVisible="{Binding HasInn}" />
                                                        <TextBlock Text="Shop"
                                                                   FontSize="10"
                                                                   Classes="muted"
                                                                   IsVisible="{Binding HasMerchant}" />
                                                    </StackPanel>
                                                    <Button Content="Travel here"
                                                            Classes="ghost"
                                                            FontSize="11"
                                                            Height="26"
                                                            IsVisible="{Binding CanTravel}"
                                                            Command="{Binding TravelCommand}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ══════════════════════════════════════════════════
                             WORLD PANEL — world header + region card grid
                        ══════════════════════════════════════════════════ -->
                        <ScrollViewer IsVisible="{Binding IsWorldViewActive}"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!-- World header -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding WorldName}"
                                               FontSize="22"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding WorldEra}"
                                               Classes="muted"
                                               FontStyle="Italic" />
                                </StackPanel>

                                <Border Classes="separator" />

                                <TextBlock Text="Regions"
                                           Classes="caption" />
                                <ItemsControl ItemsSource="{Binding WorldRegions}">
                                    <ItemsControl.Styles>
                                        <Style Selector="Border.active">
                                            <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RegionCardViewModel">
                                            <Border Margin="0,0,16,16"
                                                    Padding="16,12"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource GameBackground2Brush}"
                                                    BorderBrush="{DynamicResource GameBorderBrush}"
                                                    BorderThickness="1"
                                                    MinWidth="200"
                                                    Classes.active="{Binding IsCurrentRegion}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="15"
                                                                   FontWeight="Bold" />
                                                        <TextBlock Text="You are here"
                                                                   FontSize="10"
                                                                   Classes="accent"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsCurrentRegion}" />
                                                    </StackPanel>
                                                    <Border CornerRadius="3"
                                                            Padding="6,2"
                                                            Background="{DynamicResource GameBackground3Brush}"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Type}"
                                                                   FontSize="11"
                                                                   Classes="caption" />
                                                    </Border>
                                                    <TextBlock FontSize="12"
                                                               Classes="muted">
                                                        <Run Text="Levels " /><Run Text="{Binding MinLevel}" /><Run Text="–" /><Run Text="{Binding MaxLevel}" />
                                                    </TextBlock>
                                                    <Button Content="Explore →"
                                                            Classes="ghost"
                                                            FontSize="11"
                                                            Height="26"
                                                            Command="{Binding ExploreCommand}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                </DockPanel>
            </Border>

            <!-- ── RIGHT PANEL (character stats + online players) ────────── -->
            <Border Grid.Column="2"
                    Background="{DynamicResource GameBackground1Brush}"
                    BorderBrush="{DynamicResource GameBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="0">

                        <!-- Character stats header -->
                        <TextBlock Text="Character"
                                   Classes="caption"
                                   Margin="0,0,0,10" />

                        <!-- Level -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                            <TextBlock Text="Level"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Level}"
                                       Classes="accent"
                                       FontWeight="Bold"
                                       FontSize="14" />
                        </Grid>

                        <!-- XP bar -->
                        <StackPanel Spacing="2" Margin="0,0,0,8">
                            <ProgressBar Classes="xp"
                                         Minimum="0"
                                         Maximum="{Binding ExperienceToNextLevel}"
                                         Value="{Binding Experience}"
                                         Height="4" />
                            <TextBlock Classes="caption"
                                       HorizontalAlignment="Right">
                                <Run Text="{Binding Experience}" /><Run Text=" / " /><Run Text="{Binding ExperienceToNextLevel}" /><Run Text=" XP" />
                            </TextBlock>
                        </StackPanel>

                        <!-- Gold -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                            <TextBlock Text="Gold"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Gold}"
                                       Classes="accent"
                                       FontSize="13" />
                        </Grid>

                        <!-- Unspent AP badge (only when > 0) -->
                        <Border IsVisible="{Binding HasUnspentPoints}"
                                Background="{DynamicResource GameWarningMutedBrush}"
                                BorderBrush="{DynamicResource GameWarningBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,3"
                                Margin="0,6,0,0">
                            <TextBlock Classes="warning" FontSize="11">
                                <Run Text="{Binding UnspentAttributePoints}" /><Run Text=" unspent attribute points" />
                            </TextBlock>
                        </Border>

                        <!-- Divider -->
                        <Border Classes="separator" Margin="0,10" />

                        <!-- Equipment slots -->
                        <TextBlock Text="Equipment"
                                   Classes="caption"
                                   Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding EquipmentSlots}">
                            <ItemsControl.Styles>
                                <Style Selector="Border.equipped">
                                    <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                                    <Setter Property="Background" Value="{DynamicResource GameBackground3Brush}" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EquipmentSlotViewModel">
                                    <Border Width="44" Height="52"
                                            Margin="2"
                                            Background="{DynamicResource GameBackground2Brush}"
                                            BorderBrush="{DynamicResource GameBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            ToolTip.Tip="{Binding Label}"
                                            Classes.equipped="{Binding IsOccupied}">
                                        <StackPanel>
                                            <Panel Width="36" Height="36" Margin="4,4,4,0">
                                                <Image Source="{Binding DisplayIcon}"
                                                       Width="36" Height="36"
                                                       Stretch="Uniform"
                                                       IsVisible="{Binding IsOccupied}"
                                                       VerticalAlignment="Top" />
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="7"
                                                           Classes="caption"
                                                           IsVisible="{Binding IsEmpty}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center" />
                                            </Panel>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="6"
                                                       Classes="caption"
                                                       IsVisible="{Binding IsOccupied}"
                                                       HorizontalAlignment="Center"
                                                       Margin="2,1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Divider -->
                        <Border Classes="separator" Margin="0,12" />

                        <!-- Online players -->
                        <TextBlock Text="Online in Zone"
                                   Classes="caption"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding OnlinePlayers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6"
                                                Margin="0,2">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{DynamicResource GameSuccessBrush}"
                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding}" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Divider -->
                        <Border Classes="separator" Margin="0,12" />

                        <!-- Dev Tools expander (debug helpers during development) -->
                        <Expander Header="Dev Tools"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <StackPanel Spacing="4" Margin="0,6,0,0">
                                <Button Content="Gain 100 XP"
                                        Classes="ghost"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding DevGainXpCommand}" />
                                <Button Content="+50 Gold"
                                        Classes="ghost"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding DevAddGoldCommand}" />
                                <Button Content="Take 10 Damage"
                                        Classes="ghost"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding DevTakeDamageCommand}" />
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- ── INVENTORY OVERLAY ─────────────────────────────────────────── -->
        <!-- Spans center + right columns so the left stats panel stays visible -->
        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                IsVisible="{Binding IsInventoryOpen}"
                Background="#B2000000">
            <Border MaxWidth="640"
                    MaxHeight="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource GameBackground1Brush}"
                    BorderBrush="{DynamicResource GameBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>

                    <!-- Header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource GameBackground2Brush}"
                            BorderBrush="{DynamicResource GameBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Inventory"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Classes="ghost icon"
                                    Command="{Binding ToggleInventoryCommand}"
                                    Width="32" Height="32" />
                        </Grid>
                    </Border>

                    <!-- Item list -->
                    <ScrollViewer Padding="16"
                                  VerticalScrollBarVisibility="Auto">
                        <Panel>
                            <!-- Empty state -->
                            <TextBlock Text="Your inventory is empty."
                                       Classes="muted"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,32"
                                       IsVisible="{Binding !InventoryItems.Count}" />

                            <!-- Item rows -->
                            <ItemsControl ItemsSource="{Binding InventoryItems}"
                                          IsVisible="{Binding InventoryItems.Count}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InventoryItemViewModel">
                                        <Border BorderBrush="{DynamicResource GameBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="4,8">
                                            <Grid ColumnDefinitions="*,Auto,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DisplayName}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DurabilityText}"
                                                           Classes="caption"
                                                           IsVisible="{Binding HasDurability}"
                                                           Margin="8,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding QuantityText}"
                                                           Classes="accent"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Panel>
                    </ScrollViewer>

                </DockPanel>
            </Border>
        </Border>

        <!-- ── SHOP OVERLAY ──────────────────────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                IsVisible="{Binding IsShopOpen}"
                Background="#B2000000">
            <Border MaxWidth="640"
                    MaxHeight="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource GameBackground1Brush}"
                    BorderBrush="{DynamicResource GameBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>

                    <!-- Header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource GameBackground2Brush}"
                            BorderBrush="{DynamicResource GameBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Shop"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ShopZoneName}"
                                           Classes="muted"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Classes="ghost icon"
                                    Command="{Binding CloseShopCommand}"
                                    Width="32" Height="32" />
                        </Grid>
                    </Border>

                    <!-- Shop placeholder content -->
                    <StackPanel Margin="16" Spacing="12">
                        <TextBlock Text="Browse the merchant's wares. Purchasing and selling will be available soon."
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                </DockPanel>
            </Border>
        </Border>

        <!-- ── ROW 2: CONTEXT-SENSITIVE ACTION BAR ───────────────────────── -->
        <Border Grid.Row="2"
                Classes="panel-statusbar">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">

                <!-- Context: only in zones with an inn -->
                <Button Content="Rest at Inn"
                        Classes="accent"
                        IsVisible="{Binding HasInn}"
                        Command="{Binding RestAtLocationCommand}"
                        Height="36"
                        FontSize="13" />

                <!-- Context: only in zones with a merchant -->
                <Button Content="Shop"
                        Classes="ghost"
                        IsVisible="{Binding HasMerchant}"
                        Command="{Binding VisitShopCommand}"
                        Height="36"
                        FontSize="13" />

                <!-- Always available -->
                <Button Content="Inventory"
                        Classes="ghost"
                        Command="{Binding ToggleInventoryCommand}"
                        Classes.accent="{Binding IsInventoryOpen}"
                        Height="36"
                        FontSize="13" />
                <Button Content="Craft Item"
                        Classes="ghost"
                        Command="{Binding CraftItemCommand}"
                        CommandParameter="basic-sword"
                        Height="36"
                        FontSize="13" />
                <Button Content="Use Ability"
                        Classes="ghost"
                        Command="{Binding UseAbilityCommand}"
                        CommandParameter="fireball"
                        Height="36"
                        FontSize="13" />

            </StackPanel>
        </Border>

    </Grid>

</UserControl>
