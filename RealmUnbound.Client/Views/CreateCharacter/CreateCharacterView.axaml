<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Veldrath.Client.ViewModels"
             xmlns:views="using:Veldrath.Client.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Veldrath.Client.Views.CreateCharacterView"
             x:DataType="vm:CreateCharacterViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Top bar -->
        <Border Grid.Row="0"
                Background="#2c1010"
                Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="New Character"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StepLabel}"
                           FontSize="14"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Opacity="0.75" />
            </Grid>
        </Border>

        <!-- Main: left form + right preview -->
        <Grid Grid.Row="1" ColumnDefinitions="480,*">
            <views:CreateCharacterStepFormView Grid.Column="0" />
            <views:CreateCharacterPreviewView  Grid.Column="1" />
        </Grid>
    </Grid>

</UserControl>