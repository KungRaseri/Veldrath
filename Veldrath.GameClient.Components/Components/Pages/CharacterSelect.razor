@page "/Game/CharacterSelect"
@using Veldrath.GameClient.Core.Payloads
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.Contracts.Characters
@using Veldrath.Contracts.Connection
@using Veldrath.Auth.Blazor
@inject IGameHubConnectionService Hub
@inject IGameStateService GameState
@inject NavigationManager Navigation
@inject IGameApiClient Api
@inject AuthStateServiceBase Auth
@inject IConfiguration Configuration
@inject ILogger<CharacterSelect> Logger

@if (_isLoading)
{
    <div class="cs-loading">
        <p>Connecting to game server...</p>
        <div class="spinner"></div>
    </div>
}
else if (_isWaitingForAuth)
{
    <div class="cs-error">
        <p>Waiting for authentication... The server may be starting up.</p>
        <button class="btn btn-primary" @onclick="ConnectAndLoadCharacters">Retry</button>
        <a href="/" class="btn btn-secondary">Back to Home</a>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="cs-error">
        <p>@_errorMessage</p>
        <button class="btn btn-primary" @onclick="ConnectAndLoadCharacters">Retry</button>
        <a href="/" class="btn btn-secondary">Back to Home</a>
    </div>
}
else
{
    <div class="cs-container">
        <h1>Select Your Character</h1>

        @if (_characters.Count == 0)
        {
            <div class="cs-empty">
                <p>You have no characters yet.</p>
                <a href="/Game/CreateCharacter" class="btn btn-primary">Create New Character</a>
            </div>
        }
        else
        {
            <div class="cs-list">
                @foreach (var character in _characters)
                {
                    <div class="cs-card @(_selectedCharacterId == character.Id.ToString() ? "cs-card-selected" : "")">
                        <div class="cs-card-info">
                            <h3>@character.Name</h3>
                            <p>@character.ClassName · Level @character.Level</p>
                            <p>⛁ @character.Experience XP</p>
                            <p class="cs-card-last-played">Last played: @character.LastPlayedAt.ToLocalTime().ToString("g")</p>
                        </div>
                        <div class="cs-card-actions">
                            <button class="btn btn-primary"
                                    @onclick="() => SelectCharacter(character.Id)"
                                    disabled="@(_selectedCharacterId == character.Id.ToString())">
                                @(_selectedCharacterId == character.Id.ToString() ? "Selecting..." : "Select")
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="cs-footer">
                <a href="/Game/CreateCharacter" class="btn btn-secondary">Create New Character</a>
                <a href="/" class="btn btn-secondary">Back to Home</a>
            </div>
        }
    </div>
}

@code {
    private List<CharacterDto> _characters = [];
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _selectedCharacterId;
    private bool _isWaitingForAuth;
    private CancellationTokenSource? _authTimeoutCts;
    private bool _hasLoadedCharacters;
    private readonly List<IDisposable> _hubSubscriptions = [];

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        Auth.OnChange += OnAuthStateChanged;
    }

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthReady)
        {
            _isLoading = false;
            _isWaitingForAuth = true;
            StartAuthTimeout();
            return;
        }

        if (!Auth.IsLoggedIn)
        {
            try { Navigation.NavigateTo("/login"); } catch (InvalidOperationException) { }
            return;
        }

        await ConnectAndLoadCharacters();
    }

    /// <summary>Starts a 10-second countdown; if auth is still not ready when it fires,
    /// sets <see cref="_errorMessage"/> so the error UI with Retry button appears.</summary>
    private async void StartAuthTimeout()
    {
        _authTimeoutCts?.Cancel();
        _authTimeoutCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(10), _authTimeoutCts.Token);
            if (!Auth.IsAuthReady)
            {
                _isWaitingForAuth = false;
                _errorMessage = "Authentication is taking longer than expected. The server may be starting up.";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
            // Timeout was cancelled — auth became ready or component disposed.
        }
    }

    /// <summary>Reacts to auth state changes. Cancels any pending auth timeout and triggers
    /// character load when auth becomes ready after prerendering.</summary>
    private void OnAuthStateChanged()
    {
        if (!Auth.IsAuthReady)
            return;

        // Cancel any pending auth timeout since auth is now ready.
        _authTimeoutCts?.Cancel();

        if (!_hasLoadedCharacters && Auth.IsLoggedIn)
        {
            _isWaitingForAuth = false;
            _hasLoadedCharacters = true;
            InvokeAsync(async () =>
            {
                await ConnectAndLoadCharacters();
                StateHasChanged();
            });
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task ConnectAndLoadCharacters()
    {
        _isLoading = true;
        _isWaitingForAuth = false;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            // Ensure the JWT is still fresh before connecting.
            var tokenValid = await Auth.TryRefreshAsync();
            if (!tokenValid || Auth.AccessToken is null)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            var serverUrl = Configuration["Veldrath:ServerUrl"];
            if (string.IsNullOrWhiteSpace(serverUrl))
                throw new InvalidOperationException(
                    "Veldrath:ServerUrl is not configured. Set it in appsettings.json, " +
                    "appsettings.{Environment}.json, or the Veldrath__ServerUrl environment variable.");

            // Register handler for ServerInfo — sets IsConnected = true on the GameState.
            _hubSubscriptions.Add(Hub.On<ServerInfoPayload>("ServerInfo", async payload =>
            {
                GameState.ApplyServerInfo(payload.ConnectionId);
                await InvokeAsync(StateHasChanged);
            }));

            // Register handler for CharacterSelected event BEFORE connecting.
            _hubSubscriptions.Add(Hub.On<CharacterSelectedPayload>("CharacterSelected", async payload =>
            {
                GameState.ApplyCharacterSelected(payload);
                await InvokeAsync(() => Navigation.NavigateTo("/Game/Play"));
            }));

            // Register handler for CharacterAlreadyActive before connecting.
            _hubSubscriptions.Add(Hub.On<string>("CharacterAlreadyActive", async error =>
            {
                Logger.LogWarning("CharacterAlreadyActive: {Error}", error);
                await InvokeAsync(() =>
                {
                    _errorMessage = "This character is already logged in elsewhere. Please wait or log out from that session.";
                    _selectedCharacterId = null;
                    StateHasChanged();
                });
            }));

            // Register handler for errors.
            _hubSubscriptions.Add(Hub.On<string>("Error", async error =>
            {
                Logger.LogWarning("Hub error: {Error}", error);
                await InvokeAsync(() =>
                {
                    _errorMessage = error;
                    StateHasChanged();
                });
            }));

            await Hub.ConnectAsync(serverUrl, Auth.AccessToken);

            // Load characters from REST API.
            _characters = await Api.GetCharactersAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to connect or load characters: {ExceptionType}: {ExceptionMessage}",
                ex.GetType().Name, ex.Message);
            _errorMessage = "Failed to connect to the game server. Please try again.";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SelectCharacter(Guid characterId)
    {
        _selectedCharacterId = characterId.ToString();
        StateHasChanged();

        try
        {
            await Hub.SendAsync("SelectCharacter", characterId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to select character {CharacterId}.", characterId);
            _errorMessage = "Failed to select character. Please try again.";
            _selectedCharacterId = null;
            StateHasChanged();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        Auth.OnChange -= OnAuthStateChanged;
        _authTimeoutCts?.Cancel();
        _authTimeoutCts?.Dispose();

        foreach (var sub in _hubSubscriptions)
        {
            sub.Dispose();
        }
        _hubSubscriptions.Clear();
    }
}
