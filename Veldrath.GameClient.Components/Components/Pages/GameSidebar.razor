@using Veldrath.GameClient.Core.Abstractions
@using Microsoft.Extensions.Logging
@using MudBlazor
@* Sidebar panel showing player info, stats, zone occupants/enemies, and navigation buttons. *@
@inject IGameStateService GameState
@inject NavigationManager Navigation
@inject IGameHubConnectionService Hub
@inject ILogger<GameSidebar> Logger
@inject IGameApiClient Api

<div class="game-sidebar">
    @if (GameState.CurrentCharacterInfo is { } character)
    {
        <div class="sidebar-section sidebar-character">
            <h3>@character.Name</h3>
            <p>@character.ClassName · Level @character.Level</p>
            <p>◎ @character.Gold gold</p>
        </div>

        <div class="sidebar-section sidebar-attrs">
            <h4>Attributes</h4>
            <p>HP: @character.CurrentHealth / @character.MaxHealth</p>
            <p>MP: @character.CurrentMana / @character.MaxMana</p>
            <p>XP: @character.Experience / @character.EffectiveExperienceToNextLevel</p>
        </div>
    }

    <div class="sidebar-section sidebar-occupants">
        <h4>Nearby Players (@(!string.IsNullOrEmpty(GameState.CurrentZoneId) ? GameState.ZoneOccupants.Count.ToString() : "0"))</h4>
        @if (GameState.ZoneOccupants.Count == 0)
        {
            <p class="sidebar-empty">No other players nearby.</p>
        }
        else
        {
            <ul class="sidebar-list">
                @foreach (var occupant in GameState.ZoneOccupants)
                {
                    <li class="sidebar-list-item" title="@($"Entered {occupant.EnteredAt.ToLocalTime():g}")">
                        @occupant.CharacterName
                    </li>
                }
            </ul>
        }
    </div>

    <div class="sidebar-section sidebar-enemies">
        <h4>Nearby Enemies (@GameState.ZoneEnemies.Count)</h4>
        @if (GameState.ZoneEnemies.Count == 0)
        {
            <p class="sidebar-empty">No enemies nearby.</p>
        }
        else
        {
            <ul class="sidebar-list">
                @foreach (var enemy in GameState.ZoneEnemies)
                {
                    <li class="sidebar-list-item">
                        @enemy.EnemyName (Lv. @enemy.Level) — HP: @enemy.CurrentHealth/@enemy.MaxHealth
                    </li>
                }
            </ul>
        }
    </div>

    @* Known Locations — discovered locations for fast travel *@
    @if (GameState.KnownLocations.Count > 0)
    {
        <div class="sidebar-section sidebar-known-locations">
            <h4>Known Locations (@GameState.KnownLocations.Count)</h4>
            <ul class="sidebar-list">
                @foreach (var loc in GameState.KnownLocations)
                {
                    <li class="sidebar-list-item">
                        @{
                            var isHere = loc.Slug == GameState.CurrentZoneLocationSlug;
                        }
                        <MudButton Variant="Variant.Text"
                                   Size="Size.Small"
                                   OnClick="() => NavigateToLocationAsync(loc.Slug)"
                                   Disabled="@(!Hub.IsConnected || isHere)"
                                   Class="@(isHere ? "sidebar-nav-btn mud-text-secondary" : "sidebar-nav-btn")"
                                   title="@(isHere ? "You are here" : $"Fast travel to {loc.DisplayName}")">
                            📍 @loc.DisplayName @(isHere ? "(here)" : "")
                        </MudButton>
                    </li>
                }
            </ul>
        </div>
    }

    @* G81: NavigateToLocation — show available location connections in the zone *@
    @if (GameState.CurrentLocationConnections.Count > 0)
    {
        <div class="sidebar-section sidebar-navigation">
            <h4>Locations (@GameState.CurrentLocationConnections.Count)</h4>
            <ul class="sidebar-list">
                @foreach (var conn in GameState.CurrentLocationConnections)
                {
                    <li class="sidebar-list-item">
                        <MudButton Variant="Variant.Text"
                                   Size="Size.Small"
                                   OnClick="() => NavigateToLocationAsync(conn.Slug)"
                                   Disabled="@(!Hub.IsConnected)"
                                   Class="sidebar-nav-btn"
                                   title="@($"Navigate to {conn.TargetZoneId}")">
                            @conn.Slug @(conn.IsCrossZone ? "(Zone Transition)" : "")
                        </MudButton>
                    </li>
                }
            </ul>
        </div>
    }

    <div class="sidebar-section sidebar-actions mud-d-flex flex-column gap-2" style="padding-top: 16px;">
        <MudButton Variant="Variant.Outlined"
                   FullWidth="true"
                   OnClick="() => OnOpenOverlay.InvokeAsync(GameOverlay.OverlayKind.Inventory)"
                   Class="sidebar-btn">
            Inventory
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   FullWidth="true"
                   OnClick="() => OnOpenOverlay.InvokeAsync(GameOverlay.OverlayKind.Shop)"
                   Class="sidebar-btn">
            Shop
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   FullWidth="true"
                   OnClick="() => OnOpenOverlay.InvokeAsync(GameOverlay.OverlayKind.Journal)"
                   Class="sidebar-btn">
            Journal
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   FullWidth="true"
                   Href="/Game/Map"
                   Class="sidebar-btn">
            Map
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   FullWidth="true"
                   Href="/Game/Settings"
                   Class="sidebar-btn">
            Settings
        </MudButton>

        @* G68: Visit Shop — conditional on zone having a merchant *@
        @if (GameState.CurrentZone.HasMerchant)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="VisitShopAsync"
                       Disabled="@(!Hub.IsConnected)"
                       Class="sidebar-btn">
                Visit Shop
            </MudButton>
        }

        @* G75: Rest at Inn — conditional on zone having an inn *@
        @if (GameState.CurrentZone.HasInn)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="RestAtLocationAsync"
                       Disabled="@(!Hub.IsConnected)"
                       Class="sidebar-btn">
                Rest
            </MudButton>
        }

        @* G76: Allocate Attribute Points — conditional on having unspent points *@
        @if (GameState.CurrentCharacter.UnspentAttributePoints > 0)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Tertiary"
                       FullWidth="true"
                       OnClick="AllocateStrengthAsync"
                       Disabled="@(!Hub.IsConnected)"
                       Class="sidebar-btn"
                       title="@($"Unspent: {GameState.CurrentCharacter.UnspentAttributePoints}")">
                Attributes (+STR)
            </MudButton>
        }

        @* G70: Search Area *@
        <MudButton Variant="Variant.Outlined"
                   FullWidth="true"
                   OnClick="SearchAreaAsync"
                   Disabled="@(!Hub.IsConnected)"
                   Class="sidebar-btn">
            Search Area
        </MudButton>

        @* G74: Exit Zone *@
        <MudButton Variant="Variant.Outlined"
                   FullWidth="true"
                   OnClick="ExitZoneAsync"
                   Disabled="@(!Hub.IsConnected)"
                   Class="sidebar-btn">
            Exit Zone
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   FullWidth="true"
                   OnClick="Logout"
                   Class="sidebar-btn">
            Logout
        </MudButton>
    </div>
</div>

@code {
    /// <summary>Callback invoked when the player wants to open an overlay panel.</summary>
    [Parameter] public EventCallback<GameOverlay.OverlayKind> OnOpenOverlay { get; set; }

    /// <summary>G68: Sends the VisitShop hub command to open the merchant interface.</summary>
    private async Task VisitShopAsync()
    {
        try
        {
            if (Hub.IsConnected)
                await Hub.SendAsync("VisitShop");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to visit shop.");
        }
    }

    /// <summary>G70: Sends the SearchArea hub command to search the current tile.</summary>
    private async Task SearchAreaAsync()
    {
        try
        {
            if (Hub.IsConnected)
                await Hub.SendAsync("SearchArea");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to search area.");
        }
    }

    /// <summary>G74: Sends the ExitZone hub command to leave the current zone.</summary>
    private async Task ExitZoneAsync()
    {
        try
        {
            if (Hub.IsConnected)
                await Hub.SendAsync("ExitZone");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to exit zone.");
        }
    }

    /// <summary>G75: Sends the RestAtLocation hub command to rest at an inn.</summary>
    private async Task RestAtLocationAsync()
    {
        try
        {
            if (Hub.IsConnected)
                await Hub.SendAsync("RestAtLocation");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to rest.");
        }
    }

    /// <summary>G76: Sends the AllocateAttributePoints hub command with a default Strength allocation.</summary>
    private async Task AllocateStrengthAsync()
    {
        try
        {
            if (Hub.IsConnected)
            {
                var allocation = new Dictionary<string, int>
                {
                    { "Strength", 1 },
                };
                await Hub.SendAsync("AllocateAttributePoints", allocation);
                Logger.LogInformation("Allocated 1 point to Strength.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to allocate attribute points.");
        }
    }

    /// <summary>G81: Sends the NavigateToLocation hub command to move to a zone location.</summary>
    /// <param name="slug">The target location slug.</param>
    private async Task NavigateToLocationAsync(string slug)
    {
        if (string.IsNullOrEmpty(slug))
            return;

        try
        {
            if (Hub.IsConnected)
            {
                await Hub.SendAsync("NavigateToLocation", slug);
                Logger.LogInformation("Navigating to location: {LocationSlug}", slug);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to navigate to location {LocationSlug}.", slug);
        }
    }

    private async Task Logout()
    {
        try
        {
            await Hub.DisconnectAsync();
        }
        catch
        {
            // Best-effort disconnect.
        }

        // Clear server-side session so the routing guard won't show "Resume" on next login.
        try
        {
            await Api.DeleteLastSessionAsync();
        }
        catch
        {
            // Best-effort.
        }

        GameState.Reset();
        Navigation.NavigateTo("/");
    }
}
