@page "/Game/Settings"
@implements IDisposable
@using Microsoft.Extensions.Logging
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.Auth.Blazor
@using MudBlazor
@inject IGameHubConnectionService Hub
@inject IGameStateService GameState
@inject NavigationManager Navigation
@inject AuthStateServiceBase Auth
@inject ILogger<GameSettings> Logger

@* Settings page for audio, display, and accessibility options. Rebuilt with MudBlazor components per CSS audit (plans/css-audit-game-client-components.md). *@

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-4">
    <MudStack Spacing="4">
        @* Header *@
        <div class="d-flex align-items-center gap-3" style="padding-bottom: 12px; border-bottom: 1px solid var(--vds-border, #2A2B3D);">
            <MudText Typo="Typo.h5" Class="mud-text-primary">Settings</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined"
                       Size="Size.Small"
                       OnClick="GoBack"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Back
            </MudButton>
        </div>

        @* Audio section *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3" Style="padding-bottom: 8px; border-bottom: 1px solid var(--vds-border-subtle, #1E1F2D);">Audio</MudText>
            <MudStack Spacing="2">
                <div class="d-flex align-items-center gap-3" style="padding: 8px 0; border-bottom: 1px solid var(--vds-border-subtle, #1E1F2D);">
                    <MudText Typo="Typo.body1" Class="mud-text-primary" Style="min-width: 130px;">Music Volume</MudText>
                    <MudSlider @bind-Value="_musicVolume"
                               Min="0" Max="100" Step="1"
                               Class="flex-1 mx-0"
                               Style="max-width: 200px;"
                               Color="Color.Primary"
                               Immediate="true" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="min-width: 48px; text-align: right;">@_musicVolume%</MudText>
                </div>
                <div class="d-flex align-items-center gap-3" style="padding: 8px 0; border-bottom: 1px solid var(--vds-border-subtle, #1E1F2D);">
                    <MudText Typo="Typo.body1" Class="mud-text-primary" Style="min-width: 130px;">SFX Volume</MudText>
                    <MudSlider @bind-Value="_sfxVolume"
                               Min="0" Max="100" Step="1"
                               Class="flex-1 mx-0"
                               Style="max-width: 200px;"
                               Color="Color.Primary"
                               Immediate="true" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="min-width: 48px; text-align: right;">@_sfxVolume%</MudText>
                </div>
                <div class="d-flex align-items-center gap-3" style="padding: 8px 0;">
                    <MudText Typo="Typo.body1" Class="mud-text-primary" Style="min-width: 130px;">Mute All</MudText>
                    <MudSwitch @bind-Value="_isMuted" Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="min-width: 48px; text-align: right;">@(_isMuted ? "Muted" : "Enabled")</MudText>
                </div>
            </MudStack>
        </MudPaper>

        @* Display section *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3" Style="padding-bottom: 8px; border-bottom: 1px solid var(--vds-border-subtle, #1E1F2D);">Display</MudText>
            <MudStack Spacing="2">
                <div class="d-flex align-items-center gap-3" style="padding: 8px 0; border-bottom: 1px solid var(--vds-border-subtle, #1E1F2D);">
                    <MudText Typo="Typo.body1" Class="mud-text-primary" Style="min-width: 130px;">UI Scale</MudText>
                    <MudSelect @bind-Value="_uiScale"
                               Variant="Variant.Outlined"
                               FullWidth="true" Style="max-width: 200px;"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value="75">75%</MudSelectItem>
                        <MudSelectItem Value="90">90%</MudSelectItem>
                        <MudSelectItem Value="100">100%</MudSelectItem>
                        <MudSelectItem Value="110">110%</MudSelectItem>
                        <MudSelectItem Value="125">125%</MudSelectItem>
                        <MudSelectItem Value="150">150%</MudSelectItem>
                    </MudSelect>
                </div>
                <div class="d-flex align-items-center gap-3" style="padding: 8px 0;">
                    <MudText Typo="Typo.body1" Class="mud-text-primary" Style="min-width: 130px;">Theme</MudText>
                    <MudSelect @bind-Value="_theme"
                               Variant="Variant.Outlined"
                               FullWidth="true" Style="max-width: 200px;"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value="@("dark")">Dark</MudSelectItem>
                        <MudSelectItem Value="@("light")">Light</MudSelectItem>
                        <MudSelectItem Value="@("sepia")">Sepia</MudSelectItem>
                    </MudSelect>
                </div>
            </MudStack>
        </MudPaper>

        @* Accessibility section *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3" Style="padding-bottom: 8px; border-bottom: 1px solid var(--vds-border-subtle, #1E1F2D);">Accessibility</MudText>
            <MudStack Spacing="2">
                <div class="d-flex align-items-center gap-3" style="padding: 8px 0; border-bottom: 1px solid var(--vds-border-subtle, #1E1F2D);">
                    <MudText Typo="Typo.body1" Class="mud-text-primary" Style="min-width: 130px;">Font Size</MudText>
                    <MudSelect @bind-Value="_fontSize"
                               Variant="Variant.Outlined"
                               FullWidth="true" Style="max-width: 200px;"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value="@("small")">Small</MudSelectItem>
                        <MudSelectItem Value="@("medium")">Medium</MudSelectItem>
                        <MudSelectItem Value="@("large")">Large</MudSelectItem>
                        <MudSelectItem Value="@("x-large")">Extra Large</MudSelectItem>
                    </MudSelect>
                </div>
                <div class="d-flex align-items-center gap-3" style="padding: 8px 0;">
                    <MudText Typo="Typo.body1" Class="mud-text-primary" Style="min-width: 130px;">Reduced Motion</MudText>
                    <MudSwitch @bind-Value="_reducedMotion" Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="min-width: 48px; text-align: right;">@(_reducedMotion ? "On" : "Off")</MudText>
                </div>
            </MudStack>
        </MudPaper>

        @* Footer *@
        <div class="d-flex gap-3 justify-center" style="padding: 16px 0; border-top: 1px solid var(--vds-border, #2A2B3D); margin-top: 16px;">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveSettings">
                Save Settings
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       OnClick="ResetDefaults">
                Reset to Defaults
            </MudButton>
        </div>

        @* Status message *@
        @if (_statusMessage is not null)
        {
            <MudAlert Severity="@(_statusIsError ? Severity.Error : Severity.Success)"
                      Class="mt-2"
                      Dense="true">
                @_statusMessage
            </MudAlert>
        }
    </MudStack>
</MudContainer>

@code {
    private int _musicVolume;
    private int _sfxVolume;
    private bool _isMuted;
    private int _uiScale;
    private string _theme = "dark";
    private string _fontSize = "medium";
    private bool _reducedMotion;
    private string? _statusMessage;
    private bool _statusIsError;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        Auth.OnChange += OnAuthStateChanged;

        if (!Auth.IsAuthReady)
            return;

        if (!Auth.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        LoadSettings();
    }

    private void OnAuthStateChanged()
    {
        if (Auth.IsAuthReady)
            InvokeAsync(StateHasChanged);
    }

    /// <inheritdoc />
    public void Dispose()
    {
        Auth.OnChange -= OnAuthStateChanged;
    }

    private void LoadSettings()
    {
        // Read current settings from GameState (persisted across page re-entry for the session).
        var s = GameState.Settings;
        _musicVolume = s.MusicVolume;
        _sfxVolume = s.SfxVolume;
        _isMuted = s.IsMuted;
        _uiScale = s.UiScale;
        _theme = s.Theme;
        _fontSize = s.FontSize;
        _reducedMotion = s.ReducedMotion;
    }

    private async Task SaveSettings()
    {
        try
        {
            var settings = new GameSettingsState(
                _musicVolume,
                _sfxVolume,
                _isMuted,
                _uiScale,
                _theme,
                _fontSize,
                _reducedMotion);

            // Persist in GameState for session-level persistence
            GameState.ApplySettings(settings);

            // Also send to server for cross-session persistence (if supported)
            if (Hub.IsConnected)
            {
                await Hub.SendAsync("SaveSettings", settings);
            }

            _statusMessage = "Settings saved.";
            _statusIsError = false;
            Logger.LogInformation("Settings saved: {Settings}", settings);
        }
        catch (Exception ex)
        {
            _statusMessage = "Failed to save settings.";
            _statusIsError = true;
            Logger.LogWarning(ex, "Failed to save settings.");
        }
    }

    private void ResetDefaults()
    {
        var defaults = new GameSettingsState();
        _musicVolume = defaults.MusicVolume;
        _sfxVolume = defaults.SfxVolume;
        _isMuted = defaults.IsMuted;
        _uiScale = defaults.UiScale;
        _theme = defaults.Theme;
        _fontSize = defaults.FontSize;
        _reducedMotion = defaults.ReducedMotion;
        _statusMessage = "Settings reset to defaults (not saved).";
        _statusIsError = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/Game/Play");
    }
}
