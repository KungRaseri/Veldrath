@page "/Game/Settings"
@attribute [Authorize]
@using Microsoft.Extensions.Logging
@inject IGameHubConnectionService Hub
@inject NavigationManager Navigation
@inject ILogger<GameSettings> Logger

@* Settings page for audio, display, and accessibility options. *@

<div class="game-settings-page">
    <div class="game-settings-header">
        <h2 class="game-settings-title">Settings</h2>
        <button class="btn btn-sm btn-secondary game-settings-close"
                @onclick="GoBack">
            Back
        </button>
    </div>

    <div class="game-settings-sections">
        @* Audio section *@
        <div class="game-settings-section">
            <h3>Audio</h3>
            <div class="settings-row">
                <label class="settings-label">Music Volume</label>
                <div class="settings-control">
                    <input type="range" class="settings-slider"
                           min="0" max="100" step="1"
                           @bind="_musicVolume"
                           @bind:event="oninput" />
                    <span class="settings-value">@_musicVolume%</span>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">SFX Volume</label>
                <div class="settings-control">
                    <input type="range" class="settings-slider"
                           min="0" max="100" step="1"
                           @bind="_sfxVolume"
                           @bind:event="oninput" />
                    <span class="settings-value">@_sfxVolume%</span>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">Mute All</label>
                <div class="settings-control">
                    <label class="settings-toggle">
                        <input type="checkbox" @bind="_isMuted" />
                        <span class="settings-toggle-slider"></span>
                    </label>
                    <span class="settings-value">@(_isMuted ? "Muted" : "Enabled")</span>
                </div>
            </div>
        </div>

        @* Display section *@
        <div class="game-settings-section">
            <h3>Display</h3>
            <div class="settings-row">
                <label class="settings-label">UI Scale</label>
                <div class="settings-control">
                    <select class="settings-select" @bind="_uiScale">
                        <option value="75">75%</option>
                        <option value="90">90%</option>
                        <option value="100" selected>100%</option>
                        <option value="110">110%</option>
                        <option value="125">125%</option>
                        <option value="150">150%</option>
                    </select>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">Theme</label>
                <div class="settings-control">
                    <select class="settings-select" @bind="_theme">
                        <option value="dark">Dark</option>
                        <option value="light">Light</option>
                        <option value="sepia">Sepia</option>
                    </select>
                </div>
            </div>
        </div>

        @* Accessibility section *@
        <div class="game-settings-section">
            <h3>Accessibility</h3>
            <div class="settings-row">
                <label class="settings-label">Font Size</label>
                <div class="settings-control">
                    <select class="settings-select" @bind="_fontSize">
                        <option value="small">Small</option>
                        <option value="medium" selected>Medium</option>
                        <option value="large">Large</option>
                        <option value="x-large">Extra Large</option>
                    </select>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">Reduced Motion</label>
                <div class="settings-control">
                    <label class="settings-toggle">
                        <input type="checkbox" @bind="_reducedMotion" />
                        <span class="settings-toggle-slider"></span>
                    </label>
                    <span class="settings-value">@(_reducedMotion ? "On" : "Off")</span>
                </div>
            </div>
        </div>
    </div>

    <div class="game-settings-footer">
        <button class="btn btn-primary" @onclick="SaveSettings">
            Save Settings
        </button>
        <button class="btn btn-secondary" @onclick="ResetDefaults">
            Reset to Defaults
        </button>
    </div>

    @if (_statusMessage is not null)
    {
        <div class="game-settings-status @(_statusIsError ? "status-error" : "status-success")">
            @_statusMessage
        </div>
    }
</div>

@code {
    private int _musicVolume = 80;
    private int _sfxVolume = 80;
    private bool _isMuted;
    private int _uiScale = 100;
    private string _theme = "dark";
    private string _fontSize = "medium";
    private bool _reducedMotion;
    private string? _statusMessage;
    private bool _statusIsError;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        LoadSettings();
    }

    private void LoadSettings()
    {
        // In a full implementation these would be loaded from a settings service
        // or from the hub.  For now we use sensible defaults.
        _musicVolume = 80;
        _sfxVolume = 80;
        _isMuted = false;
        _uiScale = 100;
        _theme = "dark";
        _fontSize = "medium";
        _reducedMotion = false;
    }

    private async Task SaveSettings()
    {
        try
        {
            // Build settings payload and send via hub or persist locally.
            var settings = new
            {
                MusicVolume = _musicVolume,
                SfxVolume = _sfxVolume,
                IsMuted = _isMuted,
                UiScale = _uiScale,
                Theme = _theme,
                FontSize = _fontSize,
                ReducedMotion = _reducedMotion
            };

            if (Hub.IsConnected)
            {
                await Hub.SendAsync("SaveSettings", settings);
            }

            _statusMessage = "Settings saved.";
            _statusIsError = false;
            Logger.LogInformation("Settings saved: {Settings}", settings);
        }
        catch (Exception ex)
        {
            _statusMessage = "Failed to save settings.";
            _statusIsError = true;
            Logger.LogWarning(ex, "Failed to save settings.");
        }
    }

    private void ResetDefaults()
    {
        _musicVolume = 80;
        _sfxVolume = 80;
        _isMuted = false;
        _uiScale = 100;
        _theme = "dark";
        _fontSize = "medium";
        _reducedMotion = false;
        _statusMessage = "Settings reset to defaults (not saved).";
        _statusIsError = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/Game/Play");
    }
}
