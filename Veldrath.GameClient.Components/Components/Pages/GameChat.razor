@* Chat panel showing message history with channel pills, input field, and send button. *@

<div class="game-chat">
    <div class="game-chat-pills">
        @foreach (var channel in ChannelNames)
        {
            <button class="game-chat-pill @(ActiveChannel == channel ? "game-chat-pill-active" : "")"
                    @onclick="() => SetActiveChannel(channel)"
                    type="button">
                @channel
            </button>
        }
    </div>

    <div class="game-chat-messages">
        @if (FilteredMessages.Any())
        {
            @foreach (var msg in FilteredMessages)
            {
                <div class="game-chat-message @msg.ChannelClass">
                    <span class="game-chat-timestamp">@msg.TimestampFormatted</span>
                    <span class="game-chat-channel">[@msg.Channel]</span>
                    <span class="game-chat-sender">@msg.Sender:</span>
                    <span class="game-chat-text">@msg.Message</span>
                </div>
            }
        }
        else
        {
            <div class="game-chat-empty">No messages in this channel.</div>
        }
    </div>

    <div class="game-chat-input">
        <input type="text"
               class="game-chat-input-field"
               @bind="_inputText"
               @bind:event="oninput"
               @onkeydown="HandleKeyDown"
               placeholder="@WhisperPlaceholder"
               disabled="@(!GameState.IsConnected)" />
        <button class="game-chat-send-btn"
                @onclick="SendMessage"
                disabled="@(string.IsNullOrWhiteSpace(_inputText) || !GameState.IsConnected)">
            @(IsWhisperActive ? "Whisper" : "Send")
        </button>
    </div>
</div>
