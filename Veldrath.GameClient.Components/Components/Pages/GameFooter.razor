@* Bottom action bar showing zone info, connection status with ping, degraded detection,
    and embedded ActionBar component. The reconnecting banner is shown above the footer
    when the hub connection enters the Reconnecting state. *@

<MudAppBar Bottom="true" Fixed="true">
    @* Reconnecting banner (absolute positioned above footer) *@
    @if (ShowReconnectingBanner)
    {
        <div class="game-footer-reconnecting-banner d-flex align-center justify-center gap-2">
            <div class="spinner-small"></div>
            <span>Reconnecting to game server...</span>
        </div>
    }

    <div class="game-footer-left d-flex align-items-center gap-2">
        @if (!string.IsNullOrEmpty(GameState.CurrentZoneName))
        {
            <span class="game-footer-zone">📍 @GameState.CurrentZoneName</span>
        }
        else
        {
            <span class="game-footer-zone">No zone</span>
        }
        @if (PlayerCount > 0)
        {
            <span class="game-footer-connid" title="Players online">👥 @PlayerCount</span>
        }
    </div>

    <div class="game-footer-center flex-1 d-flex justify-center">
        @if (GameState.IsInCombat)
        {
            <ActionBar ShowAttack="true" ShowDefend="true" ShowFlee="true"
                       ShowRespawn="GameState.CurrentCharacter.IsDead" />
        }
        else
        {
            <ActionBar ShowSearch="!GameState.IsInCombat" ShowRest="GameState.CurrentZone.HasInn" OnSearch="SearchAsync"
                       OnRest="RestAsync" />
        }
    </div>

    <div class="game-footer-right d-flex align-items-center gap-2 ml-auto">
        <span class="game-footer-status d-flex align-center gap-1">
            <span class="game-footer-dot @DotClass"></span>
            @StatusText
        </span>
        @if (PingMs > 0 && Status != StatusIndicator.Reconnecting)
        {
            <span class="game-footer-ping" title="Round-trip time">@PingMs ms</span>
        }
        @if (!string.IsNullOrEmpty(GameState.ServerConnectionId))
        {
            <span class="game-footer-connid" title="Connection ID">#@GameState.ServerConnectionId[..Math.Min(8,
                                                                                            GameState.ServerConnectionId.Length)]</span>
            }
        </div>
    </MudAppBar>