@* Bottom action bar showing zone info, connection status with ping, degraded detection,
    and embedded ActionBar component. The reconnecting banner is shown above the footer
    when the hub connection enters the Reconnecting state. *@

<div class="game-footer mud-d-flex align-items-center gap-3 mud-px-4 mud-py-2 flex-shrink-0 position-relative" style="min-height: 40px;">
    @* Reconnecting banner (absolute positioned above footer) *@
    @if (ShowReconnectingBanner)
    {
        <div class="game-footer-reconnecting-banner">
            <div class="spinner-small"></div>
            <span>Reconnecting to game server...</span>
        </div>
    }

    <div class="game-footer-left mud-d-flex align-items-center gap-2">
        @if (!string.IsNullOrEmpty(GameState.CurrentZoneName))
        {
            <span class="game-footer-zone">📍 @GameState.CurrentZoneName</span>
        }
        else
        {
            <span class="game-footer-zone">No zone</span>
        }
        @if (PlayerCount > 0)
        {
            <span class="game-footer-connid" title="Players online">👥 @PlayerCount</span>
        }
    </div>

    <div class="game-footer-center flex-1 mud-d-flex justify-center">
        <ActionBar ShowAttack="GameState.IsInCombat"
                   ShowDefend="GameState.IsInCombat"
                   ShowFlee="GameState.IsInCombat"
                   ShowRespawn="false" />
    </div>

    <div class="game-footer-right mud-d-flex align-items-center gap-2 ml-auto">
        <span class="game-footer-status">
            <span class="game-footer-dot @DotClass"></span>
            @StatusText
        </span>
        @if (PingMs > 0 && Status != StatusIndicator.Reconnecting)
        {
            <span class="game-footer-ping" title="Round-trip time">@PingMs ms</span>
        }
        @if (!string.IsNullOrEmpty(GameState.ServerConnectionId))
        {
            <span class="game-footer-connid" title="Connection ID">#@GameState.ServerConnectionId[..Math.Min(8, GameState.ServerConnectionId.Length)]</span>
        }
    </div>
</div>
