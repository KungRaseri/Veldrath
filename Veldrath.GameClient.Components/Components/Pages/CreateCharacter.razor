@page "/Game/CreateCharacter"
@attribute [Authorize]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Web
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.Contracts.Characters
@using Veldrath.Contracts.Content
@using Veldrath.Auth.Blazor
@inject NavigationManager Navigation
@inject IGameApiClient Api
@inject AuthStateServiceBase Auth
@inject ILogger<CreateCharacter> Logger

<div class="cc-container">
    <h1>Create Character</h1>

    @* Screen reader live region for announcements *@
    <div class="visually-hidden" aria-live="polite" aria-atomic="true">
        @_srAnnouncement
    </div>

    @if (_isInitializing)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted">Loading character creation...</p>
        </div>
    }
    else if (_loadError is not null)
    {
        <div class="cc-error">
            <div class="alert alert-danger">
                <h5>Failed to load character creation</h5>
                <p>@_loadError</p>
            </div>
            <button class="btn btn-primary" @onclick="LoadDataAsync">Retry</button>
            <a href="/Game/CharacterSelect" class="btn btn-secondary">Back to Character Select</a>
        </div>
    }
    else
    {
        <div class="cc-wizard">
            <!-- Step indicator -->
            <nav class="cc-steps flex-wrap" role="navigation" aria-label="Character creation steps">
                <span class="cc-step @(_currentStep >= 1 ? "cc-step-active" : "")" aria-current="@(_currentStep == 1 ? "step" : null)">1. Class</span>
                <span class="cc-step @(_currentStep >= 2 ? "cc-step-active" : "")" aria-current="@(_currentStep == 2 ? "step" : null)">2. Species</span>
                <span class="cc-step @(_currentStep >= 3 ? "cc-step-active" : "")" aria-current="@(_currentStep == 3 ? "step" : null)">3. Background</span>
                <span class="cc-step @(_currentStep >= 4 ? "cc-step-active" : "")" aria-current="@(_currentStep == 4 ? "step" : null)">4. Attributes</span>
                <span class="cc-step @(_currentStep >= 5 ? "cc-step-active" : "")" aria-current="@(_currentStep == 5 ? "step" : null)">5. Equipment</span>
                <span class="cc-step @(_currentStep >= 6 ? "cc-step-active" : "")" aria-current="@(_currentStep == 6 ? "step" : null)">6. Name</span>
                <span class="cc-step @(_currentStep >= 7 ? "cc-step-active" : "")" aria-current="@(_currentStep == 7 ? "step" : null)">7. Confirm</span>
            </nav>

            <!-- Step 1: Class Selection -->
            @if (_currentStep == 1)
            {
                <div class="cc-step-content">
                    <h2 @ref="_stepHeadingRef" tabindex="-1">Choose a Class</h2>
                    <div class="row" role="listbox" aria-label="Available classes">
                        @foreach (var cls in _availableClasses)
                        {
                            var isSelected = _selectedClass?.Slug == cls.Slug;
                            <div class="col-12 col-sm-6 col-md-4 mb-3">
                                <div class="cc-class-card h-100 @(isSelected ? "cc-class-card-selected" : "")"
                                     role="option"
                                     aria-selected="@(isSelected ? "true" : "false")"
                                     tabindex="0"
                                     @onclick="() => SelectClass(cls)"
                                     @onkeydown="(e) => OnCardKeyDownAsync(e, () => SelectClass(cls))">
                                    <h3>@cls.DisplayName</h3>
                                    <p>Hit Die: d@(cls.HitDie)</p>
                                    <p>Primary: @cls.PrimaryStat</p>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="cc-nav">
                        <a href="/Game/CharacterSelect" class="btn btn-secondary w-100 w-md-auto">Back</a>
                        <button class="btn btn-primary w-100 w-md-auto" @onclick="GoToStep2Async" disabled="@(_selectedClass is null)">Next</button>
                    </div>
                </div>
            }

            <!-- Step 2: Species Selection -->
            @if (_currentStep == 2)
            {
                <div class="cc-step-content">
                    <h2 @ref="_stepHeadingRef" tabindex="-1">Choose a Species</h2>
                    <div class="row" role="listbox" aria-label="Available species">
                        @foreach (var species in _availableSpecies)
                        {
                            var isSelected = _selectedSpecies?.Slug == species.Slug;
                            <div class="col-12 col-sm-6 col-md-4 mb-3">
                                <div class="cc-class-card h-100 @(isSelected ? "cc-class-card-selected" : "")"
                                     role="option"
                                     aria-selected="@(isSelected ? "true" : "false")"
                                     tabindex="0"
                                     @onclick="() => SelectSpecies(species)"
                                     @onkeydown="(e) => OnCardKeyDownAsync(e, () => SelectSpecies(species))">
                                    <h3>@species.DisplayName</h3>
                                    @if (!string.IsNullOrWhiteSpace(species.Description))
                                    {
                                        <p>@species.Description</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="cc-nav">
                        <button class="btn btn-secondary w-100 w-md-auto" @onclick="GoToStep1Async">Back</button>
                        <button class="btn btn-primary w-100 w-md-auto" @onclick="GoToStep3Async" disabled="@(_selectedSpecies is null)">Next</button>
                    </div>
                </div>
            }

            <!-- Step 3: Background Selection -->
            @if (_currentStep == 3)
            {
                <div class="cc-step-content">
                    <h2 @ref="_stepHeadingRef" tabindex="-1">Choose a Background</h2>
                    <div class="row" role="listbox" aria-label="Available backgrounds">
                        @foreach (var bg in _availableBackgrounds)
                        {
                            var isSelected = _selectedBackground?.Slug == bg.Slug;
                            <div class="col-12 col-sm-6 col-md-4 mb-3">
                                <div class="cc-class-card h-100 @(isSelected ? "cc-class-card-selected" : "")"
                                     role="option"
                                     aria-selected="@(isSelected ? "true" : "false")"
                                     tabindex="0"
                                     @onclick="() => SelectBackground(bg)"
                                     @onkeydown="(e) => OnCardKeyDownAsync(e, () => SelectBackground(bg))">
                                    <h3>@bg.DisplayName</h3>
                                    @if (!string.IsNullOrWhiteSpace(bg.Description))
                                    {
                                        <p>@bg.Description</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="cc-nav">
                        <button class="btn btn-secondary w-100 w-md-auto" @onclick="GoToStep2Async">Back</button>
                        <button class="btn btn-primary w-100 w-md-auto" @onclick="GoToStep4Async" disabled="@(_selectedBackground is null)">Next</button>
                    </div>
                </div>
            }

            <!-- Step 4: Attributes -->
            @if (_currentStep == 4)
            {
                <div class="cc-step-content">
                    <h2 @ref="_stepHeadingRef" tabindex="-1">Allocate Attributes</h2>
                    <p class="text-muted mb-3">Distribute 27 points across your six attributes. Click + to increase, − to decrease.</p>

                    <div class="alert @(RemainingPoints == 0 ? "alert-success" : "alert-warning") mb-4" role="status">
                        <strong>Points Remaining: @RemainingPoints / @TotalBudget</strong>
                    </div>

                    <div class="row justify-content-center">
                        <div class="col-md-8 col-lg-6">
                            @foreach (var stat in _statAllocations)
                            {
                                var cost = StatCosts[stat.Value];
                                var nextValue = stat.Value + 1;
                                var canIncrease = stat.Value < MaxStat && StatCosts.TryGetValue(nextValue, out var nextCost) && (PointsSpent - cost + nextCost) <= TotalBudget;
                                var canDecrease = stat.Value > MinStat;

                                <div class="cc-attrs-row d-flex align-items-center justify-content-between mb-3 p-3 border rounded">
                                    <span class="cc-attrs-label fw-bold">@StatDisplayNames[stat.Key]</span>
                                    <button class="btn btn-outline-secondary btn-lg cc-attrs-btn"
                                            disabled="@(!canDecrease)"
                                            @onclick="() => DecreaseStatAsync(stat.Key)"
                                            aria-label="Decrease @StatDisplayNames[stat.Key]"
                                            title="Decrease @StatDisplayNames[stat.Key]">
                                        −
                                    </button>
                                    <span class="cc-attrs-value fs-4 fw-bold mx-3">@stat.Value</span>
                                    <button class="btn btn-outline-primary btn-lg cc-attrs-btn"
                                            disabled="@(!canIncrease)"
                                            @onclick="() => IncreaseStatAsync(stat.Key)"
                                            aria-label="Increase @StatDisplayNames[stat.Key]"
                                            title="Increase @StatDisplayNames[stat.Key]">
                                        +
                                    </button>
                                    <span class="cc-attrs-cost text-muted ms-3">Cost: @cost</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="cc-nav">
                        <button class="btn btn-secondary w-100 w-md-auto" @onclick="GoToStep3Async">Back</button>
                        <button class="btn btn-primary w-100 w-md-auto"
                                @onclick="GoToStep5Async"
                                disabled="@(RemainingPoints != 0 || _isSavingAttributes)"
                                title="@(RemainingPoints != 0 ? "Spend all 27 points to continue" : "")">
                            @(_isSavingAttributes ? "Saving..." : "Next")
                        </button>
                    </div>
                </div>
            }

            <!-- Step 5: Equipment Preferences -->
            @if (_currentStep == 5)
            {
                <div class="cc-step-content">
                    <h2 @ref="_stepHeadingRef" tabindex="-1">Equipment Preferences</h2>
                    <p class="text-muted mb-4">Optional — your class determines default gear. Customize if you prefer a specific playstyle.</p>

                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="armorType">Preferred Armor Type</label>
                                <select id="armorType" class="form-select" @bind="_selectedArmorType">
                                    <option value="">(Class Default)</option>
                                    @foreach (var armor in ArmorTypes.Where(a => !string.IsNullOrEmpty(a)))
                                    {
                                        <option value="@armor.ToLowerInvariant().Replace(" ", "-")">@armor</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="weaponType">Preferred Weapon Type</label>
                                <select id="weaponType" class="form-select" @bind="_selectedWeaponType">
                                    <option value="">(Class Default)</option>
                                    @foreach (var weapon in WeaponTypes.Where(w => !string.IsNullOrEmpty(w)))
                                    {
                                        <option value="@weapon.ToLowerInvariant()">@weapon</option>
                                    }
                                </select>
                            </div>
                            <div class="form-check mb-3">
                                <input type="checkbox" class="form-check-input" @bind="_includeShield" id="shieldCheck" />
                                <label class="form-check-label" for="shieldCheck">Include a Shield</label>
                            </div>
                        </div>
                    </div>

                    <div class="cc-nav">
                        <button class="btn btn-secondary w-100 w-md-auto" @onclick="GoToStep4Async">Back</button>
                        <button class="btn btn-primary w-100 w-md-auto"
                                @onclick="GoToStep6SaveEquipmentAsync"
                                disabled="@(_isSavingEquipment)">
                            @(_isSavingEquipment ? "Saving..." : "Next")
                        </button>
                    </div>
                </div>
            }

            <!-- Step 6: Name Input -->
            @if (_currentStep == 6)
            {
                <div class="cc-step-content">
                    <h2 @ref="_stepHeadingRef" tabindex="-1">Name Your Character</h2>
                    <div class="cc-name-input">
                        <label for="characterName">Character Name:</label>
                        <input id="characterName"
                               type="text"
                               class="form-control @(_nameError is not null ? "is-invalid" : "") @(_nameAvailable == true ? "is-valid" : "")"
                               @bind="_characterName"
                               @bind:after="OnNameChanged"
                               maxlength="20"
                               placeholder="Enter a name (2-20 characters, letters and spaces only)"
                               aria-describedby="cc-name-feedback" />
                        <div id="cc-name-feedback">
                            @if (_nameError is not null)
                            {
                                <p class="cc-name-error invalid-feedback d-block">@_nameError</p>
                            }
                            else if (_nameChecking)
                            {
                                <p class="cc-name-checking">Checking availability...</p>
                            }
                            else if (_nameAvailable == true)
                            {
                                <p class="cc-name-available valid-feedback d-block">Name is available!</p>
                            }
                        </div>
                    </div>
                    <div class="cc-nav">
                        <button class="btn btn-secondary w-100 w-md-auto" @onclick="GoToStep5Async">Back</button>
                        <button class="btn btn-primary w-100 w-md-auto" @onclick="GoToStep7Async"
                                disabled="@(string.IsNullOrWhiteSpace(_characterName) || _nameAvailable != true)">Next</button>
                    </div>
                </div>
            }

            <!-- Step 7: Review & Create -->
            @if (_currentStep == 7)
            {
                <div class="cc-step-content">
                    <h2 @ref="_stepHeadingRef" tabindex="-1">Review & Create</h2>
                    <p class="text-muted mb-4">Review your character before venturing into Veldrath.</p>

                    @* Character Preview Panel *@
                    @if (_characterPreview != null)
                    {
                        <div class="card mb-4 border-primary">
                            <div class="card-header bg-primary text-white">
                                <h3 class="h5 mb-0">Character Preview</h3>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-12 col-md-6">
                                        <p><strong>Class:</strong> @_characterPreview.ClassName</p>
                                        <p><strong>Species:</strong> @_characterPreview.SpeciesName</p>
                                        <p><strong>Background:</strong> @_characterPreview.BackgroundName</p>
                                        <hr />
                                        <p><strong>Health:</strong> <span class="text-danger fw-bold">@_characterPreview.Health</span></p>
                                        <p><strong>Mana:</strong> <span class="text-primary fw-bold">@_characterPreview.Mana</span></p>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <h3 class="h6">Attributes</h3>
                                        <div class="d-flex justify-content-between"><span>Strength</span> <strong>@_characterPreview.Strength</strong></div>
                                        <div class="d-flex justify-content-between"><span>Dexterity</span> <strong>@_characterPreview.Dexterity</strong></div>
                                        <div class="d-flex justify-content-between"><span>Constitution</span> <strong>@_characterPreview.Constitution</strong></div>
                                        <div class="d-flex justify-content-between"><span>Intelligence</span> <strong>@_characterPreview.Intelligence</strong></div>
                                        <div class="d-flex justify-content-between"><span>Wisdom</span> <strong>@_characterPreview.Wisdom</strong></div>
                                        <div class="d-flex justify-content-between"><span>Charisma</span> <strong>@_characterPreview.Charisma</strong></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else if (_isLoadingPreview)
                    {
                        <div class="card mb-4">
                            <div class="card-body text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading preview...</span>
                                </div>
                                <p class="mt-2 text-muted">Calculating character stats...</p>
                            </div>
                        </div>
                    }

                    @* Choices Summary *@
                    <div class="card mb-4">
                        <div class="card-header"><h3 class="h5 mb-0">Your Choices</h3></div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-12 col-sm-4">Name</dt>
                                <dd class="col-12 col-sm-8 fw-bold">@_characterName</dd>

                                <dt class="col-12 col-sm-4">Class</dt>
                                <dd class="col-12 col-sm-8">@(_selectedClass?.DisplayName ?? "—")</dd>

                                <dt class="col-12 col-sm-4">Species</dt>
                                <dd class="col-12 col-sm-8">@(_selectedSpecies?.DisplayName ?? "—")</dd>

                                <dt class="col-12 col-sm-4">Background</dt>
                                <dd class="col-12 col-sm-8">@(_selectedBackground?.DisplayName ?? "—")</dd>

                                <dt class="col-12 col-sm-4">Attributes</dt>
                                <dd class="col-12 col-sm-8">
                                    @foreach (var stat in _statAllocations)
                                    {
                                        <span class="me-3">@StatDisplayNames[stat.Key].Split(' ')[0]: <strong>@stat.Value</strong></span>
                                    }
                                </dd>

                                <dt class="col-12 col-sm-4">Equipment</dt>
                                <dd class="col-12 col-sm-8">
                                    @if (!string.IsNullOrEmpty(_selectedArmorType) || !string.IsNullOrEmpty(_selectedWeaponType) || _includeShield)
                                    {
                                        <span>@(string.IsNullOrEmpty(_selectedArmorType) ? "Class Default" : _selectedArmorType)</span>
                                        <span class="mx-1">/</span>
                                        <span>@(string.IsNullOrEmpty(_selectedWeaponType) ? "Class Default" : _selectedWeaponType)</span>
                                        @if (_includeShield)
                                        {
                                            <span class="ms-1">+ Shield</span>
                                        }
                                    }
                                    else
                                    {
                                        <span>Class Defaults</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>

                    @* Difficulty Mode *@
                    <div class="card mb-4">
                        <div class="card-header"><h3 class="h5 mb-0">Difficulty</h3></div>
                        <div class="card-body">
                            <div class="form-check">
                                <input type="radio" class="form-check-input" name="difficulty" value="normal" id="diffNormal"
                                       checked="@(_difficultyMode == "normal")"
                                       @onchange="SetNormalDifficulty" />
                                <label class="form-check-label" for="diffNormal">Normal — Standard gameplay, death is recoverable</label>
                            </div>
                            <div class="form-check">
                                <input type="radio" class="form-check-input" name="difficulty" value="hardcore" id="diffHardcore"
                                       checked="@(_difficultyMode == "hardcore")"
                                       @onchange="SetHardcoreDifficulty" />
                                <label class="form-check-label" for="diffHardcore">Hardcore — Permadeath. Character is permanently lost upon death.</label>
                            </div>
                        </div>
                    </div>

                    @if (IsHardcore)
                    {
                        <div class="alert alert-danger" role="alert">
                            <strong>⚠️ Hardcore Mode:</strong> If your character dies, they are permanently lost.
                            This cannot be undone. Are you sure?
                        </div>
                    }

                    @* Create Button *@
                    <div class="d-flex justify-content-between flex-wrap gap-2">
                        <button class="btn btn-outline-secondary w-100 w-md-auto" @onclick="GoToStep6Async" disabled="@(_isCreating)">
                            ← Back
                        </button>
                        <button class="btn btn-success btn-lg w-100 w-md-auto" @onclick="ConfirmCreate" disabled="@(_isCreating)">
                            @(_isCreating ? "Creating..." : "Create Character")
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ActorClassDto> _availableClasses = [];
    private ActorClassDto? _selectedClass;
    private List<SpeciesDto> _availableSpecies = [];
    private SpeciesDto? _selectedSpecies;
    private List<BackgroundDto> _availableBackgrounds = [];
    private BackgroundDto? _selectedBackground;
    private string _characterName = string.Empty;
    private string? _nameError;
    private bool _nameChecking;
    private bool? _nameAvailable;
    private bool _isInitializing = true;
    private bool _isCreating;
    private string? _loadError;
    private int _currentStep = 1;
    private Guid? _sessionId;
    private bool _isSavingAttributes;
    private bool _isSavingEquipment;

    // Character preview
    private CharacterPreviewDto? _characterPreview;
    private bool _isLoadingPreview;

    // Screen reader announcement text
    private string _srAnnouncement = string.Empty;

    // Focus management
    private ElementReference _stepHeadingRef;

    // Point-buy constants
    private static readonly Dictionary<int, int> StatCosts = new()
    {
        { 8, 0 }, { 9, 1 }, { 10, 2 }, { 11, 3 }, { 12, 4 }, { 13, 5 }, { 14, 7 }, { 15, 9 }
    };
    private const int MinStat = 8;
    private const int MaxStat = 15;
    private const int TotalBudget = 27;

    private Dictionary<string, int> _statAllocations = new()
    {
        { "strength", 8 }, { "dexterity", 8 }, { "constitution", 8 },
        { "intelligence", 8 }, { "wisdom", 8 }, { "charisma", 8 }
    };

    private int PointsSpent => _statAllocations.Sum(kvp => StatCosts[kvp.Value]);
    private int RemainingPoints => TotalBudget - PointsSpent;

    private static readonly Dictionary<string, string> StatDisplayNames = new()
    {
        { "strength", "Strength (STR)" },
        { "dexterity", "Dexterity (DEX)" },
        { "constitution", "Constitution (CON)" },
        { "intelligence", "Intelligence (INT)" },
        { "wisdom", "Wisdom (WIS)" },
        { "charisma", "Charisma (CHA)" }
    };

    // Equipment preferences
    private static readonly List<string> ArmorTypes = new() { "", "Light Armor", "Medium Armor", "Heavy Armor", "Unarmored" };
    private static readonly List<string> WeaponTypes = new() { "", "Sword", "Axe", "Dagger", "Staff", "Bow", "Mace" };
    private string _selectedArmorType = "";
    private string _selectedWeaponType = "";
    private bool _includeShield = false;

    // Difficulty mode
    private string _difficultyMode = "normal";
    private bool IsHardcore => _difficultyMode == "hardcore";

    /// <summary>Gets a human-readable summary of the selected equipment preferences.</summary>
    private string EquipmentSummary
    {
        get
        {
            var parts = new List<string>();

            if (!string.IsNullOrEmpty(_selectedArmorType))
            {
                var display = ArmorTypes.FirstOrDefault(a =>
                    !string.IsNullOrEmpty(a) &&
                    a.ToLowerInvariant().Replace(" ", "-") == _selectedArmorType) ?? _selectedArmorType;
                parts.Add(display);
            }

            if (!string.IsNullOrEmpty(_selectedWeaponType))
            {
                var display = WeaponTypes.FirstOrDefault(w =>
                    !string.IsNullOrEmpty(w) &&
                    w.ToLowerInvariant() == _selectedWeaponType) ?? _selectedWeaponType;
                parts.Add(display);
            }

            if (_includeShield)
                parts.Add("Shield");

            return parts.Count > 0 ? string.Join(", ", parts) : "Class Defaults";
        }
    }

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Navigation.NavigateTo("/Login");
            return;
        }

        await LoadDataAsync();
    }

    /// <summary>Fetches all reference data (classes, species, backgrounds) and begins a creation session.</summary>
    private async Task LoadDataAsync()
    {
        _isInitializing = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            // Fetch classes
            List<ActorClassDto>? classes = null;
            try
            {
                classes = await Api.GetClassesAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load available classes");
                _loadError = "Could not load available classes. Please check your connection and try again.";
                return;
            }

            // Fetch species
            List<SpeciesDto>? speciesList = null;
            try
            {
                speciesList = await Api.GetSpeciesAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load available species");
                _loadError = "Could not load available species. Please check your connection and try again.";
                return;
            }

            // Fetch backgrounds
            List<BackgroundDto>? backgrounds = null;
            try
            {
                backgrounds = await Api.GetBackgroundsAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load available backgrounds");
                _loadError = "Could not load available backgrounds. Please check your connection and try again.";
                return;
            }

            _availableClasses = classes!;
            _availableSpecies = speciesList!;
            _availableBackgrounds = backgrounds!;

            // Begin a creation session so the server tracks wizard state.
            try
            {
                var sessionResult = await Api.BeginCreationSessionAsync();
                if (sessionResult is { Success: true })
                {
                    _sessionId = sessionResult.SessionId;
                }
                else
                {
                    Logger.LogWarning("BeginCreationSessionAsync returned null or failed; proceeding without session tracking.");
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to begin creation session; proceeding without session tracking.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during character creation initialization");
            _loadError = "An unexpected error occurred while loading character creation. Please try again.";
        }
        finally
        {
            _isInitializing = false;
            StateHasChanged();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (_sessionId.HasValue)
        {
            try
            {
                await Api.AbandonCreationSessionAsync(_sessionId.Value);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to abandon creation session {SessionId}", _sessionId);
            }
        }
    }

    /// <summary>Moves focus to the current step heading for screen reader accessibility.</summary>
    private async Task FocusStepHeadingAsync()
    {
        await Task.Delay(50); // Allow DOM to update after step change
        if (_stepHeadingRef.Context != null)
        {
            await _stepHeadingRef.FocusAsync();
        }
    }

    /// <summary>Navigates to the specified step and moves focus to its heading.</summary>
    /// <param name="step">The step number (1–7) to navigate to.</param>
    private async Task NavigateToStepAsync(int step)
    {
        _currentStep = step;
        await FocusStepHeadingAsync();
    }

    /// <summary>Handles keyboard navigation on selection cards (Enter or Space to select).</summary>
    /// <param name="e">The keyboard event arguments.</param>
    /// <param name="action">The selection action to invoke.</param>
    private async Task OnCardKeyDownAsync(KeyboardEventArgs e, Func<Task> action)
    {
        if (e.Key is "Enter" or " ")
        {
            await action();
        }
    }

