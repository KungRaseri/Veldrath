@page "/Game/CreateCharacter"
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Web
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.Contracts.Characters
@using Veldrath.Contracts.Content
@using Veldrath.Auth.Blazor
@inject NavigationManager Navigation
@inject IGameApiClient Api
@inject AuthStateServiceBase Auth
@inject ILogger<CreateCharacter> Logger
@inject IJSRuntime JsRuntime

<MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
    <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-6">Create Character</MudText>

    @* Screen reader live region for announcements *@
    <div class="visually-hidden" aria-live="polite" aria-atomic="true">
        @_srAnnouncement
    </div>

    @if (_isInitializing)
    {
        <MudStack Row="false" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 60vh;">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" Class="mb-3" />
            <MudText Typo="Typo.body2" Color="Color.Dark">Loading character creation...</MudText>
        </MudStack>
    }
    else if (_loadError is not null)
    {
        <MudStack Row="false" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 60vh;" Spacing="4">
            <MudAlert Severity="Severity.Error" Class="mb-4">
                <MudText Typo="Typo.h6">Failed to load character creation</MudText>
                <MudText>@_loadError</MudText>
            </MudAlert>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDataAsync">Retry</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/Game/CharacterSelect">Back to Character
                    Select</MudButton>
                </MudStack>
            </MudStack>
        }
    else if (_sessionExpired)
        {
            <MudStack Row="false" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 60vh;" Spacing="4">
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    <MudText Typo="Typo.h6">Session Expired</MudText>
                    <MudText>Your character creation session has expired. Please start over.</MudText>
                </MudAlert>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResetWizard">Start Over</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/Game/CharacterSelect">Back to Character
                        Select</MudButton>
                    </MudStack>
                </MudStack>
            }
    else
            {
                @* Per-step error banner (M4) *@
                @if (_stepError is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">@_stepError</MudAlert>
                }

                @* Session timeout warning banner *@
                var minutesRemaining = SessionMinutesRemaining;
                @if (_sessionCreatedAt != default && minutesRemaining <= 5 && minutesRemaining > 0)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-3 pa-2">Session expires in @minutesRemaining minute(s). Please
                        complete your character soon.</MudAlert>
                    }
        else if (_sessionCreatedAt != default && minutesRemaining <= 0)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3 pa-2">Session expired. Please start over.</MudAlert>
                    }

                    @* Step indicator header *@
                    <MudStack Row="true" Justify="Justify.Center" Spacing="1" Class="mb-6">
                        @{
                            var stepLabels = new[] { "1. Name", "2. Class", "3. Species", "4. Background", "5. Attributes", "6. Equipment",
      "7. Review" };
                            for (int i = 0; i < stepLabels.Length; i++)
                            {
                                var stepNum = i + 1;
                                var isActive = _currentStep == stepNum;
                                var isCompleted = _currentStep > stepNum;
                                <MudChip T="string" Text="@stepLabels[i]"
                                         Color="@(isActive ? Color.Tertiary : (isCompleted ? Color.Primary : Color.Secondary))"
                                         Variant="@(isActive ? Variant.Filled : Variant.Text)" Size="Size.Small" />
                            }
                        }
                    </MudStack>

                    @* Step content with scroll management *@
                    <div style="overflow-y: auto; max-height: calc(100vh - 250px);">

                        @* Step 1: Name Input *@
                        @if (_currentStep == 1)
                        {
                            <h2 @ref="_stepHeadingRef" tabindex="-1" class="mud-typography mud-typography-h5 mb-4">Name Your Character</h2>
                            <MudTextField @bind-Value="_characterName" Label="Character Name" Variant="Variant.Outlined" MaxLength="20"
                                          Placeholder="Enter a name (2-20 characters, letters only)" HelperText="@GetNameHelperText()"
                                          Immediate="true" Adornment="@GetNameAdornment()" AdornmentIcon="@GetNameAdornmentIcon()"
                                          AdornmentColor="@GetNameAdornmentColor()" OnBlur="OnNameChangedAsync" />
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelWizard" Disabled="@(_isCreating)">
                                    Cancel
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep2Async"
                                           Disabled="@(string.IsNullOrWhiteSpace(_characterName) || _nameAvailable != true)">Next</MudButton>
                            </MudStack>
                        }

                        @* Step 2: Class Selection *@
                        @if (_currentStep == 2)
                        {
                            <h2 @ref="_stepHeadingRef" tabindex="-1" class="mud-typography mud-typography-h5 mb-4">Choose a Class</h2>
                            <MudGrid>
                                @foreach (var cls in _availableClasses)
                                {
                                    var isSelected = _selectedClass?.Slug == cls.Slug;
                                    <MudItem xs="12" sm="6" md="4">
                                        <div @onclick="() => SelectClass(cls)" @onkeydown="(e) => OnCardKeyDownAsync(e, () => SelectClass(cls))"
                                             tabindex="0" role="option" aria-selected="@(isSelected ? "true" : "false")"
                                             style="cursor: pointer;">
                                            <MudCard Elevation="@(isSelected ? 5 : 1)"
                                                     Style="@(isSelected ? "border: 2px solid var(--mud-palette-primary);" : "")">
                                                <MudCardContent>
                                                    <MudText Typo="Typo.h6">@cls.DisplayName</MudText>
                                                    <MudText Typo="Typo.body2" Color="Color.Dark">Hit Die: d@(cls.HitDie)</MudText>
                                                    <MudText Typo="Typo.body2" Color="Color.Dark">Primary: @cls.PrimaryStat</MudText>
                                                </MudCardContent>
                                            </MudCard>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GoToStep1Async">Back</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelWizard" Disabled="@(_isCreating)">
                                    Cancel
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep3Async"
                                           Disabled="@(_selectedClass is null)">Next</MudButton>
                            </MudStack>
                        }

                        @* Step 3: Species Selection *@
                        @if (_currentStep == 3)
                        {
                            <h2 @ref="_stepHeadingRef" tabindex="-1" class="mud-typography mud-typography-h5 mb-4">Choose a Species</h2>
                            <MudGrid>
                                @foreach (var species in _availableSpecies)
                                {
                                    var isSelected = _selectedSpecies?.Slug == species.Slug;
                                    <MudItem xs="12" sm="6" md="4">
                                        <div @onclick="() => SelectSpecies(species)"
                                             @onkeydown="(e) => OnCardKeyDownAsync(e, () => SelectSpecies(species))" tabindex="0" role="option"
                                             aria-selected="@(isSelected ? "true" : "false")" style="cursor: pointer;">
                                            <MudCard Elevation="@(isSelected ? 5 : 1)"
                                                     Style="@(isSelected ? "border: 2px solid var(--mud-palette-primary);" : "")">
                                                <MudCardContent>
                                                    <MudText Typo="Typo.h6">@species.DisplayName</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(species.Description))
                                                    {
                                                        <MudText Typo="Typo.body2" Color="Color.Dark">@species.Description</MudText>
                                                    }
                                                </MudCardContent>
                                            </MudCard>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GoToStep2Async">Back</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelWizard" Disabled="@(_isCreating)">
                                    Cancel
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep4Async"
                                           Disabled="@(_selectedSpecies is null)">Next</MudButton>
                            </MudStack>
                        }

                        @* Step 4: Background Selection *@
                        @if (_currentStep == 4)
                        {
                            <h2 @ref="_stepHeadingRef" tabindex="-1" class="mud-typography mud-typography-h5 mb-4">Choose a Background</h2>
                            <MudGrid>
                                @foreach (var bg in _availableBackgrounds)
                                {
                                    var isSelected = _selectedBackground?.Slug == bg.Slug;
                                    <MudItem xs="12" sm="6" md="4">
                                        <div @onclick="() => SelectBackground(bg)"
                                             @onkeydown="(e) => OnCardKeyDownAsync(e, () => SelectBackground(bg))" tabindex="0" role="option"
                                             aria-selected="@(isSelected ? "true" : "false")" style="cursor: pointer;">
                                            <MudCard Elevation="@(isSelected ? 5 : 1)"
                                                     Style="@(isSelected ? "border: 2px solid var(--mud-palette-primary);" : "")">
                                                <MudCardContent>
                                                    <MudText Typo="Typo.h6">@bg.DisplayName</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(bg.Description))
                                                    {
                                                        <MudText Typo="Typo.body2" Color="Color.Dark">@bg.Description</MudText>
                                                    }
                                                </MudCardContent>
                                            </MudCard>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GoToStep3Async">Back</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelWizard" Disabled="@(_isCreating)">
                                    Cancel
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep5Async"
                                           Disabled="@(_selectedBackground is null)">Next</MudButton>
                            </MudStack>
                        }

                        @* Step 5: Attributes *@
                        @if (_currentStep == 5)
                        {
                            <h2 @ref="_stepHeadingRef" tabindex="-1" class="mud-typography mud-typography-h5 mb-4">Allocate Attributes</h2>
                            <MudText Typo="Typo.body2" Color="Color.Dark" Class="mb-4">Distribute @TotalBudget points across your six
                                attributes. Click + to increase, − to decrease.</MudText>

                                <MudProgressLinear Value="@(TotalBudget - RemainingPoints)" Min="0" Max="@TotalBudget"
                                                   Color="@(RemainingPoints == 0 ? Color.Success : Color.Warning)" Class="mb-2" />
                                <MudText Typo="Typo.body1" Class="mb-4">
                                    <strong>Points Remaining: @RemainingPoints / @TotalBudget</strong>
                                </MudText>

                                <MudStack Row="false" Spacing="2">
                                    @foreach (var stat in _statAllocations)
                                    {
                                        var cost = StatCosts[stat.Value];
                                        var nextValue = stat.Value + 1;
                                        var canIncrease = stat.Value < MaxStat && StatCosts.TryGetValue(nextValue, out var nextCost) && (PointsSpent
                            - cost + nextCost) <= TotalBudget;
                                        var canDecrease = stat.Value > MinStat;
                                        var decreaseLabel = $"Decrease {StatDisplayNames[stat.Key]}";
                                        var increaseLabel = $"Increase {StatDisplayNames[stat.Key]}";

                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                                                  Class="pa-3 mud-border rounded-lg">
                                            <MudText Typo="Typo.body1" Style="min-width: 180px;">@StatDisplayNames[stat.Key]</MudText>
                                            <MudIconButton Icon="@Icons.Material.Filled.Remove" Disabled="@(!canDecrease)"
                                                           OnClick="() => DecreaseStatAsync(stat.Key)" aria-label="@decreaseLabel" />
                                            <MudText Typo="Typo.h6" Class="mx-3" Style="min-width: 40px; text-align: center;">@stat.Value</MudText>
                                            <MudIconButton Icon="@Icons.Material.Filled.Add" Disabled="@(!canIncrease)"
                                                           OnClick="() => IncreaseStatAsync(stat.Key)" aria-label="@increaseLabel" />
                                            <MudText Typo="Typo.body2" Color="Color.Dark" Style="min-width: 80px; text-align: right;">Cost: @cost
                                            </MudText>
                                        </MudStack>
                                    }
                                </MudStack>

                                <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GoToStep4Async">Back</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelWizard" Disabled="@(_isCreating)">
                                        Cancel
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep6Async"
                                               Disabled="@(RemainingPoints != 0 || _isSavingAttributes)">
                                        @(_isSavingAttributes ? "Saving..." : "Next")
                                    </MudButton>
                                </MudStack>
                            }

                            @* Step 6: Equipment Preferences *@
                            @if (_currentStep == 6)
                            {
                                <h2 @ref="_stepHeadingRef" tabindex="-1" class="mud-typography mud-typography-h5 mb-4">Equipment Preferences
                                </h2>
                                <MudText Typo="Typo.body2" Color="Color.Dark" Class="mb-4">Optional — your class determines default gear.
                                    Customize if you prefer a specific playstyle.</MudText>

                                    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-0">
                                        <MudSelect @bind-Value="_selectedArmorType" T="string" Label="Preferred Armor Type"
                                                   Variant="Variant.Outlined" Class="mb-3">
                                            <MudSelectItem Value="@((string?)null)">(Class Default)</MudSelectItem>
                                            @foreach (var armor in ArmorTypes.Where(a => !string.IsNullOrEmpty(a)))
                                            {
                                                <MudSelectItem Value="@armor.ToLowerInvariant().Replace(" ", "-")">@armor</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudSelect @bind-Value="_selectedWeaponType" T="string" Label="Preferred Weapon Type"
                                                   Variant="Variant.Outlined" Class="mb-3">
                                            <MudSelectItem Value="@((string?)null)">(Class Default)</MudSelectItem>
                                            @foreach (var weapon in WeaponTypes.Where(w => !string.IsNullOrEmpty(w)))
                                            {
                                                <MudSelectItem Value="@weapon.ToLowerInvariant().Replace(" ", "-")">@weapon</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudCheckBox @bind-Value="_includeShield" T="bool" Label="Include a Shield" Class="mb-3" />
                                    </MudContainer>

                                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GoToStep5Async">Back</MudButton>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelWizard" Disabled="@(_isCreating)">
                                            Cancel
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToStep7SaveEquipmentAsync"
                                                   Disabled="@(_isSavingEquipment)">
                                            @(_isSavingEquipment ? "Saving..." : "Next")
                                        </MudButton>
                                    </MudStack>
                                }

                                @* Step 7: Review & Create *@
                                @if (_currentStep == 7)
                                {
                                    <h2 @ref="_stepHeadingRef" tabindex="-1" class="mud-typography mud-typography-h5 mb-4">Review & Create</h2>
                                    <MudText Typo="Typo.body2" Color="Color.Dark" Class="mb-4">Review your character before venturing into Veldrath.
                                    </MudText>

                                    @* Character Preview Panel *@
                                    @if (_characterPreview != null)
                                    {
                                        <MudCard Elevation="3" Class="mb-4">
                                            <MudCardHeader>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h5">Character Preview</MudText>
                                                </CardHeaderContent>
                                            </MudCardHeader>
                                            <MudCardContent>
                                                <MudGrid>
                                                    <MudItem xs="12" md="6">
                                                        <MudStack Row="false" Spacing="2">
                                                            <MudChip T="string" Text="@_characterPreview.ClassName" Color="Color.Primary"
                                                                     Size="Size.Small" />
                                                            <MudChip T="string" Text="@_characterPreview.SpeciesName" Color="Color.Secondary"
                                                                     Size="Size.Small" />
                                                            <MudChip T="string" Text="@_characterPreview.BackgroundName" Color="Color.Tertiary"
                                                                     Size="Size.Small" />
                                                            <MudDivider Class="my-2" />
                                                            <MudText Typo="Typo.body1">
                                                                <strong>Health:</strong> <span
                                                                class="mud-text-error"><strong>@_characterPreview.Health</strong></span>
                                                            </MudText>
                                                            <MudText Typo="Typo.body1">
                                                                <strong>Mana:</strong> <span
                                                                class="mud-text-primary"><strong>@_characterPreview.Mana</strong></span>
                                                            </MudText>
                                                        </MudStack>
                                                    </MudItem>
                                                    <MudItem xs="12" md="6">
                                                        <MudText Typo="Typo.h6">Attributes</MudText>
                                                        <div class="d-flex justify-space-between"><span>Strength</span>
                                                            <strong>@_characterPreview.Strength</strong></div>
                                                            <div class="d-flex justify-space-between"><span>Dexterity</span>
                                                                <strong>@_characterPreview.Dexterity</strong></div>
                                                                <div class="d-flex justify-space-between"><span>Constitution</span>
                                                                    <strong>@_characterPreview.Constitution</strong></div>
                                                                    <div class="d-flex justify-space-between"><span>Intelligence</span>
                                                                        <strong>@_characterPreview.Intelligence</strong></div>
                                                                        <div class="d-flex justify-space-between"><span>Wisdom</span>
                                                                            <strong>@_characterPreview.Wisdom</strong></div>
                                                                            <div class="d-flex justify-space-between"><span>Charisma</span>
                                                                                <strong>@_characterPreview.Charisma</strong></div>
                                                                            </MudItem>
                                                                        </MudGrid>
                                                                    </MudCardContent>
                                                                </MudCard>
                                                            }
                else if (_isLoadingPreview)
                                                            {
                                                                <MudCard Elevation="1" Class="mb-4">
                                                                    <MudCardContent Class="text-center py-4">
                                                                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-2" />
                                                                        <MudText Typo="Typo.body2" Color="Color.Dark">Calculating character stats...</MudText>
                                                                    </MudCardContent>
                                                                </MudCard>
                                                            }

                                                            @* Choices Summary *@
                                                            <MudCard Elevation="1" Class="mb-4">
                                                                <MudCardHeader>
                                                                    <CardHeaderContent>
                                                                        <MudText Typo="Typo.h5">Your Choices</MudText>
                                                                    </CardHeaderContent>
                                                                </MudCardHeader>
                                                                <MudCardContent>
                                                                    <MudStack Row="false" Spacing="2">
                                                                        <MudText Typo="Typo.body1"><strong>Name:</strong> @_characterName</MudText>
                                                                        <MudText Typo="Typo.body1"><strong>Class:</strong> @(_selectedClass?.DisplayName ?? "—")</MudText>
                                                                        <MudText Typo="Typo.body1"><strong>Species:</strong> @(_selectedSpecies?.DisplayName ?? "—")
                                                                        </MudText>
                                                                        <MudText Typo="Typo.body1"><strong>Background:</strong> @(_selectedBackground?.DisplayName ?? "—")
                                                                        </MudText>
                                                                        <MudText Typo="Typo.body1">
                                                                            <strong>Attributes:</strong>
                                                                            @foreach (var stat in _statAllocations)
                                                                            {
                                                                                <span class="mr-3">@StatDisplayNames[stat.Key].Split(' ')[0]:
                                                                                    <strong>@stat.Value</strong></span>
                                                                                }
                                                                            </MudText>
                                                                            <MudText Typo="Typo.body1"><strong>Equipment:</strong> @EquipmentSummary</MudText>
                                                                        </MudStack>
                                                                    </MudCardContent>
                                                                </MudCard>

                                                                @* Difficulty Mode *@
                                                                <MudCard Elevation="1" Class="mb-4">
                                                                    <MudCardHeader>
                                                                        <CardHeaderContent>
                                                                            <MudText Typo="Typo.h5">Difficulty</MudText>
                                                                        </CardHeaderContent>
                                                                    </MudCardHeader>
                                                                    <MudCardContent>
                                                                        <MudRadioGroup @bind-Value="_difficultyMode" T="string">
                                                                            <MudRadio T="string" Value="@("normal")" Color="Color.Success">Normal — Standard gameplay, death is
                                                                                recoverable</MudRadio>
                                                                                <MudRadio T="string" Value="@("hardcore")" Color="Color.Error">Hardcore — Permadeath. Character is
                                                                                    permanently lost upon death.</MudRadio>
                                                                                </MudRadioGroup>
                                                                            </MudCardContent>
                                                                        </MudCard>

                                                                        @if (IsHardcore)
                                                                        {
                                                                            <MudAlert Severity="Severity.Error" Class="mb-4">
                                                                                <strong>⚠️ Hardcore Mode:</strong> If your character dies, they are permanently lost.
                                                                                This cannot be undone. Are you sure?
                                                                            </MudAlert>
                                                                        }

                                                                        @* Create Button *@
                                                                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                                                                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GoToStep6Async"
                                                                                       Disabled="@(_isCreating)">
                                                                                ← Back
                                                                            </MudButton>
                                                                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelWizard" Disabled="@(_isCreating)">
                                                                                Cancel
                                                                            </MudButton>
                                                                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" OnClick="ConfirmCreate"
                                                                                       Disabled="@(_isCreating)">
                                                                                @(_isCreating ? "Creating..." : "Create Character")
                                                                            </MudButton>
                                                                        </MudStack>
                                                                    }
                                                                </div>
                                                            }
                                                        </MudContainer>

@code {
    private List<ActorClassDto> _availableClasses = [];
    private ActorClassDto? _selectedClass;
    private List<SpeciesDto> _availableSpecies = [];
    private SpeciesDto? _selectedSpecies;
    private List<BackgroundDto> _availableBackgrounds = [];
    private BackgroundDto? _selectedBackground;
    private string _characterName = string.Empty;
    private string? _nameError;
    private bool _nameChecking;
    private bool? _nameAvailable;
    private bool _isInitializing = true;
    private bool _isCreating;
    private string? _loadError;
    private int _currentStep = 1;
    private Guid? _sessionId;
    private DateTime _sessionCreatedAt;
    private bool _sessionExpired;
    private bool _isSavingAttributes;
    private bool _isSavingEquipment;

    // Per-step error display (M4)
    private string? _stepError;

    // Character preview
    private CharacterPreviewDto? _characterPreview;
    private bool _isLoadingPreview;

    // Screen reader announcement text
    private string _srAnnouncement = string.Empty;

    // Focus management
    private ElementReference _stepHeadingRef;

    // Name check debounce (C6)
    private CancellationTokenSource? _nameCheckCts;

    // Point-buy constants
    private static readonly Dictionary<int, int> StatCosts = new()
    {
        { 8, 0 }, { 9, 1 }, { 10, 2 }, { 11, 3 }, { 12, 4 }, { 13, 5 }, { 14, 7 }, { 15, 9 }
    };
    private const int MinStat = 8;
    private const int MaxStat = 15;
    private const int TotalBudget = 27;

    // C5: Stat keys use PascalCase to match desktop
    private Dictionary<string, int> _statAllocations = new()
    {
        { "Strength", 8 }, { "Dexterity", 8 }, { "Constitution", 8 },
        { "Intelligence", 8 }, { "Wisdom", 8 }, { "Charisma", 8 }
    };

    private int PointsSpent => _statAllocations.Sum(kvp => StatCosts[kvp.Value]);
    private int RemainingPoints => TotalBudget - PointsSpent;

    // C5: StatDisplayNames use PascalCase keys
    private static readonly Dictionary<string, string> StatDisplayNames = new()
    {
        { "Strength", "Strength (STR)" },
        { "Dexterity", "Dexterity (DEX)" },
        { "Constitution", "Constitution (CON)" },
        { "Intelligence", "Intelligence (INT)" },
        { "Wisdom", "Wisdom (WIS)" },
        { "Charisma", "Charisma (CHA)" }
    };

    // Equipment preferences
    private static readonly List<string> ArmorTypes = new() { "", "Light Armor", "Medium Armor", "Heavy Armor", "Unarmored" };
    private static readonly List<string> WeaponTypes = new() { "", "Sword", "Axe", "Dagger", "Staff", "Bow", "Mace" };
    private string _selectedArmorType = "";
    private string _selectedWeaponType = "";
    private bool _includeShield = false;

    // Difficulty mode
    private string _difficultyMode = "normal";
    private bool IsHardcore => _difficultyMode == "hardcore";

    /// <summary>Gets the number of minutes remaining before the creation session expires.
    /// Computed from <see cref="_sessionCreatedAt"/> and the server-side session idle timeout (30 minutes).</summary>
    private int SessionMinutesRemaining => _sessionCreatedAt == default
        ? 30
        : 30 - (int)(DateTime.UtcNow - _sessionCreatedAt).TotalMinutes;

    /// <summary>Gets a human-readable summary of the selected equipment preferences.</summary>
    private string EquipmentSummary
    {
        get
        {
            var parts = new List<string>();

            if (!string.IsNullOrEmpty(_selectedArmorType))
            {
                var display = ArmorTypes.FirstOrDefault(a =>
                    !string.IsNullOrEmpty(a) &&
                    a.ToLowerInvariant().Replace(" ", "-") == _selectedArmorType) ?? _selectedArmorType;
                parts.Add(display);
            }

            if (!string.IsNullOrEmpty(_selectedWeaponType))
            {
                // M6: weapon slugs now use .Replace(" ", "-") consistently
                var display = WeaponTypes.FirstOrDefault(w =>
                    !string.IsNullOrEmpty(w) &&
                    w.ToLowerInvariant().Replace(" ", "-") == _selectedWeaponType) ?? _selectedWeaponType;
                parts.Add(display);
            }

            if (_includeShield)
                parts.Add("Shield");

            return parts.Count > 0 ? string.Join(", ", parts) : "Class Defaults";
        }
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        Auth.OnChange += OnAuthStateChanged;
    }

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthReady)
            return;

        if (!Auth.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        Navigation.LocationChanged += OnLocationChanged;

        await LoadDataAsync();
    }

    private void OnAuthStateChanged()
    {
        if (Auth.IsAuthReady)
            InvokeAsync(StateHasChanged);
    }

    /// <summary>Fetches all reference data (classes, species, backgrounds) in parallel and begins a creation session.</summary>
    private async Task LoadDataAsync()
    {
        _isInitializing = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            // Ensure the JWT is fresh before making API calls.
            await Auth.TryRefreshAsync();

            // M5: Parallelize content loading with Task.WhenAll
            var classesTask = Api.GetClassesAsync();
            var speciesTask = Api.GetSpeciesAsync();
            var backgroundsTask = Api.GetBackgroundsAsync();
            var sessionTask = Api.BeginCreationSessionAsync();

            await Task.WhenAll(classesTask, speciesTask, backgroundsTask, sessionTask);

            // Process results individually with error handling per task
            List<ActorClassDto>? classes = null;
            try
            {
                classes = await classesTask;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load available classes");
                _loadError = "Could not load available classes. Please check your connection and try again.";
                return;
            }

            List<SpeciesDto>? speciesList = null;
            try
            {
                speciesList = await speciesTask;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load available species");
                _loadError = "Could not load available species. Please check your connection and try again.";
                return;
            }

            List<BackgroundDto>? backgrounds = null;
            try
            {
                backgrounds = await backgroundsTask;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load available backgrounds");
                _loadError = "Could not load available backgrounds. Please check your connection and try again.";
                return;
            }

            _availableClasses = classes!;
            _availableSpecies = speciesList!;
            _availableBackgrounds = backgrounds!;

            // M1: Auto-select first item in each list
            if (_availableClasses.Count > 0)
            {
                _selectedClass = _availableClasses[0];
            }

            if (_availableSpecies.Count > 0)
            {
                _selectedSpecies = _availableSpecies[0];
            }

            if (_availableBackgrounds.Count > 0)
            {
                _selectedBackground = _availableBackgrounds[0];
            }

            // Process session creation result
            try
            {
                var sessionResult = await sessionTask;
                if (sessionResult is { Success: true })
                {
                    _sessionId = sessionResult.SessionId;
                    _sessionCreatedAt = DateTime.UtcNow;
                }
                else
                {
                    Logger.LogWarning("BeginCreationSessionAsync returned null or failed; proceeding without session tracking.");
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to begin creation session; proceeding without session tracking.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during character creation initialization");
            _loadError = "An unexpected error occurred while loading character creation. Please try again.";
        }
        finally
        {
            _isInitializing = false;
            StateHasChanged();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        Auth.OnChange -= OnAuthStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        _nameCheckCts?.Cancel();
        _nameCheckCts?.Dispose();

        await DisableBeforeUnloadAsync();

        if (_sessionId.HasValue)
        {
            try
            {
                await Api.AbandonCreationSessionAsync(_sessionId.Value);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to abandon creation session {SessionId}", _sessionId);
            }
        }
    }

    /// <summary>Handles in-app navigation away from the wizard by abandoning the creation session.</summary>
    /// <param name="sender">The event source.</param>
    /// <param name="e">The location changed event arguments.</param>
    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (!e.Location.Contains("/Game/CreateCharacter", StringComparison.OrdinalIgnoreCase))
        {
            await AbandonSessionIfNeeded();
        }
    }

    /// <summary>Best-effort session abandonment for circuit disconnect or navigation away scenarios.
    /// Does not throw — failures are silently logged.</summary>
    private async Task AbandonSessionIfNeeded()
    {
        if (_sessionId.HasValue)
        {
            try
            {
                await Api.AbandonCreationSessionAsync(_sessionId.Value);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to abandon creation session {SessionId} on navigation", _sessionId);
            }
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("characterCreation.enableBeforeUnload");
        }
    }

    /// <summary>Removes the browser beforeunload listener that warns users about unsaved progress.</summary>
    private async Task DisableBeforeUnloadAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("characterCreation.disableBeforeUnload");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to disable beforeunload listener");
        }
    }

    /// <summary>Moves focus to the current step heading for screen reader accessibility.</summary>
    private async Task FocusStepHeadingAsync()
    {
        await Task.Delay(50); // Allow DOM to update after step change
        if (_stepHeadingRef.Context != null)
        {
            await _stepHeadingRef.FocusAsync();
        }
    }

    /// <summary>Navigates to the specified step, clears any step error, and moves focus to its heading. (M4)</summary>
    /// <param name="step">The step number (1–7) to navigate to.</param>
    private async Task NavigateToStepAsync(int step)
    {
        _stepError = null;
        _currentStep = step;
        await FocusStepHeadingAsync();
    }

    /// <summary>Handles keyboard navigation on selection cards (Enter or Space to select).</summary>
    /// <param name="e">The keyboard event arguments.</param>
    /// <param name="action">The selection action to invoke.</param>
    private async Task OnCardKeyDownAsync(KeyboardEventArgs e, Func<Task> action)
    {
        if (e.Key is "Enter" or " ")
        {
            await action();
        }
    }

