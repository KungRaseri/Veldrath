@using Veldrath.GameClient.Core.Abstractions
@using Microsoft.Extensions.Logging
@using MudBlazor
@* Sidebar panel showing player info, stats, zone occupants/enemies, and navigation buttons. *@
@inject NavigationManager Navigation
@inject ILogger<Sidebars> Logger
@inject IGameApiClient Api

<MudDrawerContainer>
    <MudDrawer @bind-Open="@_isLeftSidebarOpen" Anchor="Anchor.Left">
        <MudNavLink OnClick="() => OnOpenOverlay.InvokeAsync(GameOverlay.OverlayKind.CharacterSheet)">
            👤 Character Sheet
        </MudNavLink>
        <MudNavLink OnClick="() => OnOpenOverlay.InvokeAsync(GameOverlay.OverlayKind.Inventory)">
            🎒 Inventory
        </MudNavLink>
        <MudNavLink Href="/Game/Map">
            🗺 Map
        </MudNavLink>
        <MudNavLink OnClick="() => OnOpenOverlay.InvokeAsync(GameOverlay.OverlayKind.Journal)">
            📜 Journal
        </MudNavLink>
        <div class="sidebar-section sidebar-occupants">
            <h4>Nearby Players (@(!string.IsNullOrEmpty(GameState.CurrentZoneId) ?
                                                                                                                                                                GameState.ZoneOccupants.Count.ToString() : "0"))</h4>
                @if (GameState.ZoneOccupants.Count == 0)
                {
                    <p class="sidebar-empty">No other players nearby.</p>
                }
                else
                {
                    <ul class="sidebar-list">
                        @foreach (var occupant in GameState.ZoneOccupants)
                        {
                            <li class="sidebar-list-item" title="@($"Entered {occupant.EnteredAt.ToLocalTime():g}")">
                                @occupant.CharacterName
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="sidebar-section sidebar-enemies">
                <h4>Nearby Enemies (@GameState.ZoneEnemies.Count)</h4>
                @if (GameState.ZoneEnemies.Count == 0)
                {
                    <p class="sidebar-empty">No enemies nearby.</p>
                }
                else
                {
                    <ul class="sidebar-list">
                        @foreach (var enemy in GameState.ZoneEnemies)
                        {
                            <li class="sidebar-list-item">
                                @enemy.EnemyName (Lv. @enemy.Level) — HP: @enemy.CurrentHealth/@enemy.MaxHealth
                            </li>
                        }
                    </ul>
                }
            </div>

            @* Known Locations — discovered locations for fast travel *@
            @if (GameState.KnownLocations.Count > 0)
            {
                <div class="sidebar-section sidebar-known-locations">
                    <h4>Known Locations (@GameState.KnownLocations.Count)</h4>
                    <ul class="sidebar-list">
                        @foreach (var loc in GameState.KnownLocations)
                        {
                            <li class="sidebar-list-item">
                                @{
                                    var isHere = loc.Slug == GameState.CurrentZoneLocationSlug;
                                }
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                           OnClick="() => NavigateToLocationAsync(loc.Slug)" Disabled="@(!Hub.IsConnected || isHere)"
                                           Class="@(isHere ? "sidebar-nav-btn" : "sidebar-nav-btn")"
                                           title="@(isHere ? "You are here" : $"Fast travel to {loc.DisplayName}")">
                                    📍 @loc.DisplayName @(isHere ? "(here)" : "")
                                </MudButton>
                            </li>
                        }
                    </ul>
                </div>
            }

            @* G81: NavigateToLocation — show available location connections in the zone *@
            @if (GameState.CurrentLocationConnections.Count > 0)
            {
                <div class="sidebar-section sidebar-navigation">
                    <h4>Locations (@GameState.CurrentLocationConnections.Count)</h4>
                    <ul class="sidebar-list">
                        @foreach (var conn in GameState.CurrentLocationConnections)
                        {
                            <li class="sidebar-list-item">
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                           OnClick="() => NavigateToLocationAsync(conn.Slug)" Disabled="@(!Hub.IsConnected)"
                                           Class="sidebar-nav-btn" title="@($"Navigate to {conn.TargetZoneId}")">
                                    @conn.Slug @(conn.IsCrossZone ? "(Zone Transition)" : "")
                                </MudButton>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="sidebar-section sidebar-actions d-flex flex-column gap-2" style="padding-top: 16px;">

                @* G68: Visit Shop — conditional on zone having a merchant *@
                @if (GameState.CurrentZone.HasMerchant)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="VisitShopAsync"
                               Disabled="@(!Hub.IsConnected)" Class="sidebar-btn">
                        Visit Shop
                    </MudButton>
                }

                @* G75: Rest at Inn — conditional on zone having an inn *@
                @if (GameState.CurrentZone.HasInn)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="RestAtLocationAsync"
                               Disabled="@(!Hub.IsConnected)" Class="sidebar-btn">
                        Rest
                    </MudButton>
                }

                @* G76: Allocate Attribute Points — conditional on having unspent points *@
                @if (GameState.CurrentCharacter.UnspentAttributePoints > 0)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" FullWidth="true" OnClick="AllocateStrengthAsync"
                               Disabled="@(!Hub.IsConnected)" Class="sidebar-btn"
                               title="@($"Unspent: {GameState.CurrentCharacter.UnspentAttributePoints}")">
                        Attributes (+STR)
                    </MudButton>
                }

                @* G70: Search Area *@
                <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick="SearchAreaAsync"
                           Disabled="@(!Hub.IsConnected)" Class="sidebar-btn">
                    Search Area
                </MudButton>

                @* G74: Exit Zone *@
                <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick="ExitZoneAsync"
                           Disabled="@(!Hub.IsConnected)" Class="sidebar-btn">
                    Exit Zone
                </MudButton>
            </div>
        </MudDrawer>
        <MudDrawer @bind-Open="@_isRightSidebarOpen"  Anchor="Anchor.Right">
            <div class="game-chat-pills d-flex gap-0 flex-shrink-0">
                @foreach (var channel in ChannelNames)
                {
                    <button class="game-chat-pill @(ActiveChannel == channel ? "game-chat-pill-active" : "")"
                            @onclick="() => SetActiveChannel(channel)" type="button">
                        @channel
                    </button>
                }
            </div>

            <div class="game-chat-messages d-flex flex-column flex-1 overflow-y-auto">
                @if (FilteredMessages.Any())
                {
                    @foreach (var msg in FilteredMessages)
                    {
                        <div class="game-chat-message d-flex align-baseline gap-1 @msg.ChannelClass">
                            <span class="game-chat-timestamp">@msg.TimestampFormatted</span>
                            <span class="game-chat-channel">[@msg.Channel]</span>
                            <span class="game-chat-sender">@msg.Sender:</span>
                            <span class="game-chat-text">@msg.Message</span>
                        </div>
                    }
                }
                else
                {
                    <div class="game-chat-empty">No messages in this channel.</div>
                }
            </div>

            <div class="game-chat-input d-flex align-center gap-2">
                <input type="text" class="game-chat-input-field flex-1" @bind="_inputText" @bind:event="oninput"
                       @onkeydown="HandleKeyDown" placeholder="@WhisperPlaceholder" disabled="@(!GameState.IsConnected)" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="SendMessage"
                           Disabled="@(string.IsNullOrWhiteSpace(_inputText) || !GameState.IsConnected)">
                    @(IsWhisperActive ? "Whisper" : "Send")
                </MudButton>
            </div>
        </MudDrawer>
    </MudDrawerContainer>