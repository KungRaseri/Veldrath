@using Veldrath.GameClient.Core.Abstractions
@using MudBlazor
@* Combat UI shown when GameState.IsInCombat is true. Displays enemy info, action buttons, and combat log. *@
@inject IGameHubConnectionService Hub
@inject IGameStateService GameState

@if (GameState.CombatEnemy is { } enemy)
{
    <div class="game-combat flex-1 mud-d-flex flex-column align-items-center justify-center">
        <div class="game-combat-enemy">
            <h2>@enemy.EnemyName</h2>
            <p>Level @enemy.Level</p>
            <StatusBar Label="HP" Current="enemy.CurrentHealth" Max="enemy.MaxHealth" Color="#e53935" />
        </div>

        <div class="game-combat-log mud-d-flex align-items-center justify-center mud-text-center">
            @if (!string.IsNullOrEmpty(GameState.LastCombatActionResult))
            {
                <p class="game-combat-result">@GameState.LastCombatActionResult</p>
            }
        </div>

        <div class="game-combat-actions mud-d-flex gap-3">
            <ActionBar ShowAttack="true"
                       ShowDefend="true"
                       ShowFlee="true"
                       ShowRespawn="@PlayerIsDead"
                       Disabled="@_actionInProgress"
                       OnAttack="PerformAttack"
                       OnDefend="PerformDefend"
                       OnFlee="PerformFlee"
                       OnRespawn="PerformRespawn" />
        </div>

        @if (_showVictory)
        {
            <div class="game-combat-victory">
                <h2>Victory!</h2>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="DismissVictory">
                    Continue
                </MudButton>
            </div>
        }
    </div>
}
else
{
    <div class="game-combat-empty">
        <p>No enemy engaged.</p>
    </div>
}

@code {
    private bool _actionInProgress;
    private bool _showVictory;
    private IDisposable? _stateSubscription;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        _stateSubscription = GameState.OnStateChanged(() => InvokeAsync(StateHasChanged));
    }

    private bool PlayerIsDead => GameState.CurrentCharacterInfo?.CurrentHealth <= 0;

    private async Task PerformAttack()
    {
        _actionInProgress = true;
        try { await Hub.SendAsync("AttackEnemy"); }
        finally { _actionInProgress = false; }
    }

    private async Task PerformDefend()
    {
        _actionInProgress = true;
        try { await Hub.SendAsync("DefendAction"); }
        finally { _actionInProgress = false; }
    }

    private async Task PerformFlee()
    {
        _actionInProgress = true;
        try { await Hub.SendAsync("FleeFromCombat"); }
        finally { _actionInProgress = false; }
    }

    private async Task PerformRespawn()
    {
        _actionInProgress = true;
        try { await Hub.SendAsync("Respawn"); }
        finally { _actionInProgress = false; }
    }

    private void DismissVictory()
    {
        _showVictory = false;
    }
}
