@page "/Game/Play"
@inherits GamePageBase
@using Veldrath.GameClient.Core.Payloads
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.Auth.Blazor
@using Veldrath.Contracts.Connection
@using Veldrath.Contracts.Tilemap
@inject IGameHubConnectionService Hub
@inject IGameStateService GameState
@inject IGameApiClient Api
@inject IConfiguration Configuration

<CascadingValue Value="GameState">
    <GameHeader />

    <Sidebars OnOpenOverlay="HandleOpenOverlay" />
    <MudContainer Gutters="false" Fixed="true">
        @if (_isRestoringSession)
        {
            <div class="game-loading-zone">
                <p>Restoring your game session...</p>
                <div class="spinner"></div>
            </div>
        }
        else if (GameState.IsInCombat)
        {
            <GameCombat />
        }
        else if (GameState.ZoneTileMap is not null)
        {
            <GameTilemap />
            @if (GameState.IsAtLocation)
            {
                <ZoneLocationPanel />
            }
        }
        else
        {
            <div class="game-loading-zone">
                <p>Loading zone...</p>
                <div class="spinner"></div>
            </div>
        }
    </MudContainer>

    <GameFooter />
    <GameOverlay Visible="_showOverlay" OverlayType="_activeOverlay" OnClose="HandleCloseOverlay" />
</CascadingValue>

@* <div class="d-flex flex-column overflow-hidden flex-1">
</div> *@

@* Reconnect overlay shown when the SignalR circuit drops during gameplay.
    OnReconnected triggers session restoration via the hub state subscription. *@
<ReconnectOverlay OnReturnToMenu="HandleReturnToMenu" OnReconnected="HandleReconnected" />

@code {
    private readonly List<IDisposable> _hubSubscriptions = [];
    private IDisposable? _stateSubscription;
    private IDisposable? _hubStateSubscription;
    private bool _hubConnected;
    private bool _isRestoringSession;
    private CancellationTokenSource? _claimRetryCts;
    private bool _showOverlay;
    private GameOverlay.OverlayKind _activeOverlay;
    private ILogger<Game> _logger = null!;

    /// <summary>Gets or sets the logger, injected by DI.</summary>
    [Inject]
    private ILogger<Game> Logger
    {
        get => _logger;
        set => _logger = value;
    }

    /// <summary>
    /// Called by <see cref="ReconnectOverlay"/> when the user chooses to return to the main menu.
    /// </summary>
    private async Task HandleReturnToMenu()
    {
        GameState.ApplySystemMessage("Returning to main menu...");
        SafeNavigate("/");
    }

    /// <summary>
    /// Called by <see cref="ReconnectOverlay"/> after a successful reconnection.
    /// Forces a re-render so the hub state subscription can detect the transition
    /// and restore the game session state.
    /// </summary>
    private void HandleReconnected()
    {
        StateHasChanged();
    }

    /// <inheritdoc />
    protected override async Task OnGameInitializedAsync()
    {
        // Subscribe to hub state changes so we can detect when a reconnection
        // succeeds and restore the game session (re-send SelectCharacter, EnterZone, etc.).
        _hubStateSubscription ??= SubscribeToHubState();

        await ConnectAndRegisterHandlers();

        // ── Auto-restore on fresh circuit (page refresh) ──
        if (_hubConnected && GameState.CurrentCharacterId is null)
        {
            await RestoreSessionFromServerAsync();
        }
    }

    /// <summary>
    /// Subscribes to <see cref="IGameHubConnectionService.StateChanged"/> so the game page
    /// can reinitialize its session when the hub reconnects after a transient failure.
    /// </summary>
    private IDisposable SubscribeToHubState()
    {
        void Handler(object? s, ConnectionState state)
        {
            _ = InvokeAsync(async () =>
            {
                // Only act on reconnection (when _hubConnected was already true before the drop).
                if (_hubConnected && state == ConnectionState.Connected
                    && GameState.CurrentCharacterId is not null)
                {
                    Logger.LogInformation(
                        "Hub reconnected — restoring game session for character {CharId}.",
                        GameState.CurrentCharacterId);
                    await EnterZoneAfterConnectAsync();
                }
            });
        }

        Hub.StateChanged += Handler;
        return new HubStateSubscription(() => Hub.StateChanged -= Handler);
    }

    private async Task ConnectAndRegisterHandlers()
    {
        try
        {
            var tokenValid = await Auth.TryRefreshAsync();
            if (!tokenValid || Auth.AccessToken is null)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            var serverUrl = Configuration["Veldrath:ServerUrl"]
                ?? throw new InvalidOperationException("Veldrath:ServerUrl is not configured.");

            RegisterHubHandlers();

            _stateSubscription ??= GameState.OnStateChanged(() => InvokeAsync(StateHasChanged));

            if (!Hub.IsConnected)
            {
                await Hub.ConnectAsync(serverUrl, Auth.AccessToken);
            }

            _hubConnected = Hub.IsConnected;

            if (_hubConnected && GameState.CurrentCharacterId is not null)
            {
                await EnterZoneAfterConnectAsync();
            }
        }
        catch (ObjectDisposedException)
        {
            // Expected during SSR prerender — the DI scope is disposed after HTML is generated.
            // The interactive circuit will retry connection via OnGameInitializedAsync.
            Logger.LogDebug("Hub connection skipped during SSR prerender.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to connect to game hub.");
            GameState.ApplySystemMessage("Failed to connect to game server.");
        }
    }

    /// <summary>
    /// Attempts to reclaim a character by sending <c>SelectCharacter</c> to the hub
    /// with a polling retry loop that covers the server's 30-second grace period.
    /// Returns <c>true</c> when the <c>CharacterSelected</c> hub handler has populated
    /// <see cref="IGameStateService.CurrentCharacterId"/>; <c>false</c> if all
    /// retries are exhausted or the operation is cancelled.
    /// </summary>
    /// <param name="characterId">The character ID to reclaim.</param>
    /// <param name="ct">Cancellation token tied to the retry lifecycle.</param>
    /// <returns><c>true</c> if the character was reclaimed successfully; <c>false</c> otherwise.</returns>
    private async Task<bool> ReclaimCharacterAsync(Guid characterId, CancellationToken ct)
    {
        // Retry delays: 3s, 6s, 10s, 15s — total ~34s to cover the 30s grace period.
        int[] retryDelays = [3000, 6000, 10000, 15000];

        for (int attempt = 0; attempt < retryDelays.Length; attempt++)
        {
            if (ct.IsCancellationRequested)
                return false;

            Logger.LogInformation(
                "ReclaimCharacterAsync attempt {Attempt}/{Max} for character {CharId}...",
                attempt + 1, retryDelays.Length, characterId);

            try
            {
                await Hub.SendAsync("SelectCharacter", characterId);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "SelectCharacter send failed on attempt {Attempt} for {CharId}", attempt + 1, characterId);
                // Network-level error — not retryable in this loop; let caller decide.
                return false;
            }

            // Wait for the backoff period to give the server time to respond.
            // The CharacterSelected or CharacterAlreadyActive hub callback may fire
            // during this window.
            try
            {
                await Task.Delay(retryDelays[attempt], ct);
            }
            catch (OperationCanceledException)
            {
                Logger.LogInformation("ReclaimCharacterAsync cancelled for {CharId}.", characterId);
                return false;
            }

            // Check whether CharacterSelected handler has populated the state.
            if (GameState.CurrentCharacterId == characterId.ToString())
            {
                Logger.LogInformation(
                    "Character {CharId} successfully reclaimed on attempt {Attempt}.",
                    characterId, attempt + 1);
                GameState.ApplySystemMessage("Session restored successfully.");
                return true;
            }

            Logger.LogInformation(
                "Character {CharId} not yet reclaimed after attempt {Attempt}/{Max} — will retry.",
                characterId, attempt + 1, retryDelays.Length);
        }

        Logger.LogWarning(
            "Failed to reclaim character {CharId} after {Max} attempts — grace period may have expired or character is stuck.",
            characterId, retryDelays.Length);
        return false;
    }

    private async Task EnterZoneAfterConnectAsync()
    {
        if (GameState.ZoneTileMap is not null)
            return;

        var zoneId = GameState.CurrentZoneId;

        if (string.IsNullOrEmpty(zoneId))
        {
            Logger.LogInformation(
                "No zone ID known yet — re-selecting character to obtain zone info.");

            var charId = GameState.CurrentCharacterId;
            if (charId is not null && Guid.TryParse(charId, out var guid))
            {
                // Cancel any in-flight claim retry and start a fresh one.
                _claimRetryCts?.Cancel();
                _claimRetryCts?.Dispose();
                _claimRetryCts = new CancellationTokenSource();

                var reclaimed = await ReclaimCharacterAsync(guid, _claimRetryCts.Token);
                if (!reclaimed)
                {
                    Logger.LogWarning("Failed to reclaim character {CharId} during reconnection.", guid);
                    GameState.ApplySystemMessage("Failed to restore game session after reconnection.");
                }
            }
            return;
        }

        await EnterZoneAsync(zoneId);
    }

    private async Task EnterZoneAsync(string zoneId)
    {
        Logger.LogInformation("Entering zone {ZoneId}...", zoneId);

        try
        {
            await Hub.SendAsync("EnterZone", zoneId);
            await Hub.SendAsync("GetZoneTileMap");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to enter zone {ZoneId}.", zoneId);
            GameState.ApplySystemMessage("Failed to enter zone.");
        }
    }

    /// <summary>
    /// Queries the server for the account's last active session and restores it
    /// using a polling retry loop that covers the server's 30-second claim grace period.
    /// Called on a fresh circuit (after page refresh) where no character is selected.
    /// On success, the existing <c>CharacterSelected</c> hub handler populates
    /// <see cref="IGameStateService"/> and auto-enters the zone.
    /// On failure, redirects to the character select screen.
    /// </summary>
    private async Task RestoreSessionFromServerAsync()
    {
        _isRestoringSession = true;
        StateHasChanged();

        try
        {
            var session = await Api.GetLastSessionAsync();
            if (session is null)
            {
                // No prior session — redirect to character select.
                Navigation.NavigateTo("/Game/CharacterSelect");
                return;
            }

            // Cancel any in-flight claim retry and start a fresh one.
            _claimRetryCts?.Cancel();
            _claimRetryCts?.Dispose();
            _claimRetryCts = new CancellationTokenSource();

            var reclaimed = await ReclaimCharacterAsync(session.CharacterId, _claimRetryCts.Token);

            if (!reclaimed)
            {
                Logger.LogWarning("Unable to reclaim character {CharId} after all retries.", session.CharacterId);
                GameState.ApplySystemMessage("Unable to reconnect to your character. Please select a character manually.");
                Navigation.NavigateTo("/Game/CharacterSelect");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to restore session from server");
            GameState.ApplySystemMessage("Failed to restore your game session. Please select a character manually.");
            Navigation.NavigateTo("/Game/CharacterSelect");
        }
        finally
        {
            _isRestoringSession = false;
            StateHasChanged();
        }
    }

    private void HandleOpenOverlay(GameOverlay.OverlayKind kind)
    {
        _activeOverlay = kind;
        _showOverlay = true;
        StateHasChanged();
    }

    private void HandleCloseOverlay()
    {
        _showOverlay = false;
        StateHasChanged();
    }

    private void RegisterHubHandlers()
    {
        _hubSubscriptions.Add(Hub.On<ServerInfoPayload>("ServerInfo", async payload =>
        {
            GameState.ApplyServerInfo(payload.ConnectionId);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CharacterSelectedPayload>("CharacterSelected", async payload =>
        {
            Logger.LogInformation(
                "CharacterSelected received: {Name} Lv.{Level} {Class} in zone {Zone}",
                payload.Name, payload.Level, payload.ClassName, payload.CurrentZoneId);
            GameState.ApplyCharacterSelected(payload);
            Logger.LogInformation(
                "ApplyCharacterSelected done. CurrentCharacter={Char}, CurrentCharacterInfo={Info}",
                GameState.CurrentCharacterInfo?.Name ?? "null",
                ((IGameStateService)GameState).CurrentCharacterInfo?.Name ?? "null");

            if (!string.IsNullOrEmpty(payload.CurrentZoneId) && GameState.ZoneTileMap is null)
            {
                await EnterZoneAsync(payload.CurrentZoneId);
            }

            await InvokeAsync(StateHasChanged);
            Logger.LogInformation("StateHasChanged invoked after CharacterSelected.");
        }));

        // ── Handle CharacterAlreadyActive during session restore ──
        // Sent by GameHub.SelectCharacter when TryClaim fails because the
        // character is still claimed (within the 30-second grace period).
        // The actual retry logic lives in ReclaimCharacterAsync; this handler
        // only logs when a retry loop is active, or shows a fallback error if not.
        _hubSubscriptions.Add(Hub.On<Guid>("CharacterAlreadyActive", async characterId =>
        {
            // If a claim retry loop is active, the loop handles retries — just log.
            if (_claimRetryCts is not null && !_claimRetryCts.IsCancellationRequested)
            {
                Logger.LogInformation(
                    "Character {CharId} is still claimed by old circuit — retry loop will continue.",
                    characterId);
                return;
            }

            // No active retry loop — show generic error as fallback.
            Logger.LogWarning(
                "CharacterAlreadyActive received for {CharId} with no active retry loop.",
                characterId);
            GameState.ApplySystemMessage("This character is already active in another session.");
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<ZoneEnteredPayload>("ZoneEntered", async payload =>
        {
            GameState.ApplyZoneEntered(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<TileMapDto>("ZoneTileMap", async dto =>
        {
            var tiles = ConvertTileMap(dto);
            GameState.ApplyZoneTileMap(tiles);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<Veldrath.Contracts.Tilemap.CharacterMovedPayload>("CharacterMoved", async payload =>
        {
            GameState.ApplyCharacterMoved(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<PlayerEnteredPayload>("PlayerEntered", async payload =>
        {
            GameState.ApplyPlayerEntered(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<PlayerLeftPayload>("PlayerLeft", async payload =>
        {
            GameState.ApplyPlayerLeft(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CombatStartedPayload>("CombatStarted", async payload =>
        {
            GameState.ApplyCombatStarted(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CombatTurnPayload>("CombatTurn", async payload =>
        {
            GameState.ApplyCombatTurn(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CombatEndedPayload>("CombatEnded", async payload =>
        {
            GameState.ApplyCombatEnded(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<EnemyDefeatedPayload>("EnemyDefeated", async payload =>
        {
            GameState.ApplyEnemyDefeated(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CharacterRespawnedPayload>("CharacterRespawned", async payload =>
        {
            GameState.ApplyCharacterRespawned();
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<ChatMessageHubDto>("ReceiveChatMessage", async payload =>
        {
            GameState.ApplyChatMessage(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<string>("SystemMessage", async message =>
        {
            GameState.ApplySystemMessage(message);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<string>("Error", async error =>
        {
            Logger.LogWarning("Hub error: {Error}", error);
            GameState.ApplySystemMessage($"Error: {error}");
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<Veldrath.Contracts.Tilemap.ZoneEntitiesSnapshotPayload>("ZoneEntitiesSnapshot", async
payload =>
        {
            GameState.ApplyZoneEntitiesSnapshot(payload);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G18: OnKicked ──────────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<Veldrath.Contracts.Connection.KickedPayload>("OnKicked", async payload =>
        {
            GameState.ApplyKicked(payload.Reason);
            await InvokeAsync(StateHasChanged);
            Navigation.NavigateTo("/");
        }));

        // ── G19: ExperienceGained ──────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ExperienceGainedPayload>("ExperienceGained", async payload =>
        {
            GameState.ApplyExperienceGained(payload.NewLevel, payload.NewXP, payload.LeveledUpTo);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G20: GoldChanged ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<GoldChangedPayload>("GoldChanged", async payload =>
        {
            GameState.ApplyGoldChanged(payload.GoldAdded, payload.NewGoldTotal);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G21: DamageTaken ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<DamageTakenPayload>("DamageTaken", async payload =>
        {
            GameState.ApplyDamageTaken(payload.Damage, payload.CurrentHP, payload.MaxHP, payload.IsDead);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G22: ItemEquipped ──────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemEquippedPayload>("ItemEquipped", async payload =>
        {
            foreach (var (slot, item) in payload.Equipped)
            {
                GameState.ApplyEquipmentChanged(slot, item);
            }
            GameState.ApplySystemMessage($"Equipped {payload.ItemRef}.");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G23: ShopVisited ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ShopVisitedPayload>("ShopVisited", async payload =>
        {
            GameState.ApplyShopVisited(payload.ZoneId, payload.ZoneName);
            _activeOverlay = GameOverlay.OverlayKind.Shop;
            _showOverlay = true;
            await InvokeAsync(StateHasChanged);
        }));

        // ── G24: ShopCatalog ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ShopCatalogPayload>("ShopCatalog", async payload =>
        {
            GameState.ApplyShopCatalogUpdated(payload.Catalog);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G25: ItemPurchased ─────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemPurchasedPayload>("ItemPurchased", async payload =>
        {
            GameState.ApplyItemTransacted(payload.Name, payload.GoldSpent, payload.Inventory);
            GameState.ApplySystemMessage($"Purchased {payload.Name}.");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G26: ItemSold ──────────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemSoldPayload>("ItemSold", async payload =>
        {
            GameState.ApplyItemTransacted(payload.Name, payload.GoldReceived, payload.Inventory);
            GameState.ApplySystemMessage($"Sold {payload.Name}.");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G27: ItemDropped ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemDroppedPayload>("ItemDropped", async payload =>
        {
            GameState.ApplyItemTransacted(payload.ItemRef, GameState.CurrentCharacterGold, payload.Inventory);
            GameState.ApplySystemMessage($"Dropped {payload.ItemRef}.");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G28: InventoryLoaded ───────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<InventoryLoadedPayload>("InventoryLoaded", async payload =>
        {
            GameState.ApplyInventoryUpdated(payload.Items, GameState.EquippedItems);
            _activeOverlay = GameOverlay.OverlayKind.Inventory;
            _showOverlay = true;
            await InvokeAsync(StateHasChanged);
        }));

        // ── G29: QuestLogReceived ──────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<QuestLogReceivedPayload>("QuestLogReceived", async payload =>
        {
            GameState.ApplyQuestLogUpdated(payload.Active, payload.Completed);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G30: AttributePointsAllocated ──────────────────────────────────
        _hubSubscriptions.Add(Hub.On<AttributePointsAllocatedPayload>("AttributePointsAllocated", async payload =>
        {
            GameState.ApplyAttributePointsAllocated(payload.RemainingPoints, payload.Attrs);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G31: CharacterRested ───────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<CharacterRestedPayload>("CharacterRested", async payload =>
        {
            GameState.ApplyCharacterRested(payload.HP, payload.MaxHP, payload.MP, payload.MaxMP, payload.Gold);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G32: AbilityUsed ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<AbilityUsedPayload>("AbilityUsed", async payload =>
        {
            GameState.ApplyAbilityUsed(payload.AbilityId, payload.RemainingMana, payload.HPRestored);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G33: SkillXpGained ─────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<SkillXpGainedPayload>("SkillXpGained", async payload =>
        {
            GameState.ApplySkillXpGained(payload.SkillId, payload.XpGained, payload.NewRank, payload.RankedUp);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G34: ItemCrafted ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemCraftedPayload>("ItemCrafted", async payload =>
        {
            GameState.ApplyItemCrafted(payload.RecipeName, payload.GoldSpent, payload.RemainingGold);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G35: DungeonEntered ────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<DungeonEnteredPayload>("DungeonEntered", async payload =>
        {
            GameState.ApplyDungeonEntered(payload.DungeonId);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G36: ZoneLeft ──────────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<string>("ZoneLeft", async _ =>
        {
            GameState.ApplySystemMessage("You left the zone.");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G37: ZoneExited ─────────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ZoneExitedPayload>("ZoneExited", async payload =>
        {
            GameState.ApplyZoneExited(payload.RegionId, payload.TileX, payload.TileY);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G38: RegionMapData ──────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<RegionMapDto>("RegionMapData", async dto =>
        {
            var region = new RegionState
            {
                RegionId = dto.RegionId,
                TileWidth = dto.Width,
                TileHeight = dto.Height,
            };
            GameState.ApplyRegionMapReceived(region);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G39: RegionChanged ──────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<RegionChangedPayload>("RegionChanged", async payload =>
        {
            GameState.ApplyRegionChanged(payload.RegionId, payload.TileX, payload.TileY);
            GameState.ApplySystemMessage($"Entering {payload.RegionId}...");
            try { await Hub.SendAsync("GetRegionMap"); } catch { }
            await InvokeAsync(StateHasChanged);
        }));

        // ── G40: RegionPlayerMoved ──────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<RegionPlayerMovedPayload>("RegionPlayerMoved", async payload =>
        {
            GameState.ApplyRegionPlayerMoved(
                payload.CharacterId.ToString(), payload.TileX, payload.TileY, payload.Direction);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G41: ZoneEntryTriggered ─────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ZoneEntryTriggeredPayload>("ZoneEntryTriggered", async payload =>
        {
            GameState.ApplySystemMessage($"Enter {payload.Name}?");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G42: RegionExitTriggered ────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<RegionExitTriggeredPayload>("RegionExitTriggered", async payload =>
        {
            GameState.ApplySystemMessage($"Cross border into {payload.TargetRegion}?");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G43: TileExitTriggered ──────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<TileExitTriggeredPayload>("TileExitTriggered", async payload =>
        {
            GameState.ApplySystemMessage($"Transitioning to zone {payload.ToZoneId}...");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G44: LocationEntered ────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<LocationEnteredPayload>("LocationEntered", async payload =>
        {
            GameState.ApplyLocationEntered(payload);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G45: ZoneLocationUnlocked ───────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ZoneLocationUnlockedPayload>("ZoneLocationUnlocked", async payload =>
        {
            GameState.ApplyZoneLocationUnlocked(payload.Slug, payload.Name, payload.Type);
            GameState.ApplySystemMessage($"Discovered {payload.Name} ({payload.Type})!");
            await InvokeAsync(StateHasChanged);
        }));

        // ── G46: AreaSearched ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<AreaSearchedPayload>("AreaSearched", async payload =>
        {
            var msg = payload.AnyFound
                ? "You found something!"
                : "You found nothing.";
            GameState.ApplySystemMessage(msg);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G47: ConnectionTraversed ────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ConnectionTraversedPayload>("ConnectionTraversed", async payload =>
        {
            GameState.ApplyConnectionTraversed(
                payload.Slug, payload.ZoneId, payload.IsCrossZone, payload.Connections);
            await InvokeAsync(StateHasChanged);
        }));
    }

    private static Veldrath.GameClient.Core.Abstractions.Tile[,] ConvertTileMap(TileMapDto dto)
    {
        var width = dto.Width;
        var height = dto.Height;
        var tiles = new Veldrath.GameClient.Core.Abstractions.Tile[height, width];

        var groundLayer = dto.Layers.FirstOrDefault();

        for (var y = 0; y < height; y++)
        {
            for (var x = 0; x < width; x++)
            {
                var idx = y * width + x;
                var tileType = groundLayer is not null && idx < groundLayer.Data.Length
                    ? groundLayer.Data[idx]
                    : 0;
                var isBlocked = dto.CollisionMask is not null && idx < dto.CollisionMask.Length && dto.CollisionMask[idx];

                var simplifiedType = tileType switch
                {
                    -1 => -1,
                    0 => 0,
                    1 => 1,
                    2 => 2,
                    3 => 3,
                    _ when isBlocked => 1,
                    _ => 0
                };

                tiles[y, x] = new Veldrath.GameClient.Core.Abstractions.Tile(x, y, simplifiedType, isBlocked);
            }
        }

        return tiles;
    }

    /// <summary>
    /// Simple disposable that runs an action on dispose, used to unsubscribe from
    /// <see cref="IGameHubConnectionService.StateChanged"/>.
    /// </summary>
    private sealed class HubStateSubscription(Action onDispose) : IDisposable
    {
        /// <inheritdoc />
        public void Dispose() => onDispose();
    }

    /// <inheritdoc />
    public override async ValueTask DisposeAsync()
    {
        await base.DisposeAsync();

        _claimRetryCts?.Cancel();
        _claimRetryCts?.Dispose();

        _stateSubscription?.Dispose();
        _hubStateSubscription?.Dispose();

        foreach (var sub in _hubSubscriptions)
        {
            sub.Dispose();
        }
        _hubSubscriptions.Clear();

        if (_hubConnected)
        {
            try { await Hub.DisconnectAsync(); }
            catch (Exception ex) { Logger.LogWarning(ex, "Error disconnecting hub."); }
        }
    }
}
