@page "/Game/Play"
@attribute [Authorize]
@using Veldrath.GameClient.Core.Services
@using Veldrath.GameClient.Core.Payloads
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.Auth.Blazor
@using Veldrath.Contracts.Connection
@using Veldrath.Contracts.Tilemap
@inject IGameHubConnectionService Hub
@inject IGameStateService GameState
@inject NavigationManager Navigation
@inject AuthStateServiceBase Auth
@inject IConfiguration Configuration
@inject ILogger<Game> Logger

<div class="game-container">
    <GameHeader />

    <div class="game-main">
        <div class="game-sidebar">
            <GameSidebar OnOpenOverlay="HandleOpenOverlay" />
            <GameChat />
        </div>

        <div class="game-center">
            @if (GameState.IsInCombat)
            {
                <GameCombat />
            }
            else if (GameState.ZoneTileMap is not null)
            {
                <GameTilemap />
            }
            else
            {
                <div class="game-loading-zone">
                    <p>Loading zone...</p>
                    <div class="spinner"></div>
                </div>
            }
        </div>
    </div>

    <GameFooter />
    <GameOverlay Visible="_showOverlay"
                 OverlayType="_activeOverlay"
                 OnClose="HandleCloseOverlay" />
</div>

@code {
    private readonly List<IDisposable> _hubSubscriptions = [];
    private IDisposable? _stateSubscription;
    private bool _hubConnected;
    private bool _showOverlay;
    private GameOverlay.OverlayKind _activeOverlay;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Navigation.NavigateTo("/Login");
            return;
        }

        await ConnectAndRegisterHandlers();
    }

    private async Task ConnectAndRegisterHandlers()
    {
        try
        {
            var tokenValid = await Auth.TryRefreshAsync();
            if (!tokenValid || Auth.AccessToken is null)
            {
                Navigation.NavigateTo("/Login");
                return;
            }

            var serverUrl = Configuration["Veldrath:ServerUrl"]
                ?? throw new InvalidOperationException("Veldrath:ServerUrl is not configured.");

            RegisterHubHandlers();

            if (GameState is GameStateService gs)
            {
                _stateSubscription ??= gs.OnStateChanged(() => InvokeAsync(StateHasChanged));
            }

            if (!Hub.IsConnected)
            {
                await Hub.ConnectAsync(serverUrl, Auth.AccessToken);
            }

            _hubConnected = Hub.IsConnected;

            if (_hubConnected && GameState.CurrentCharacterId is not null)
            {
                await EnterZoneAfterConnectAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to connect to game hub.");
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage("Failed to connect to game server.");
            }
        }
    }

    private async Task EnterZoneAfterConnectAsync()
    {
        if (GameState.ZoneTileMap is not null)
            return;

        var zoneId = GameState.CurrentZoneId;

        if (string.IsNullOrEmpty(zoneId))
        {
            Logger.LogInformation(
                "No zone ID known yet — re-selecting character to obtain zone info.");

            try
            {
                var charId = GameState.CurrentCharacterId;
                if (charId is not null && Guid.TryParse(charId, out var guid))
                {
                    await Hub.SendAsync("SelectCharacter", guid);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to re-select character after connecting.");
                if (GameState is GameStateService gs)
                {
                    gs.ApplySystemMessage("Failed to restore game session.");
                }
            }
            return;
        }

        await EnterZoneAsync(zoneId);
    }

    private async Task EnterZoneAsync(string zoneId)
    {
        Logger.LogInformation("Entering zone {ZoneId}...", zoneId);

        try
        {
            await Hub.SendAsync("EnterZone", zoneId);
            await Hub.SendAsync("GetZoneTileMap");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to enter zone {ZoneId}.", zoneId);
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage("Failed to enter zone.");
            }
        }
    }

    private void HandleOpenOverlay(GameOverlay.OverlayKind kind)
    {
        _activeOverlay = kind;
        _showOverlay = true;
        StateHasChanged();
    }

    private void HandleCloseOverlay()
    {
        _showOverlay = false;
        StateHasChanged();
    }

    private void RegisterHubHandlers()
    {
        _hubSubscriptions.Add(Hub.On<ServerInfoPayload>("ServerInfo", async payload =>
        {
            if (GameState is GameStateService gs)
            {
                gs.ApplyServerInfo(payload.ConnectionId);
            }
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CharacterSelectedPayload>("CharacterSelected", async payload =>
        {
            GameState.ApplyCharacterSelected(payload);

            if (!string.IsNullOrEmpty(payload.CurrentZoneId) && GameState.ZoneTileMap is null)
            {
                await EnterZoneAsync(payload.CurrentZoneId);
            }

            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<ZoneEnteredPayload>("ZoneEntered", async payload =>
        {
            GameState.ApplyZoneEntered(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<TileMapDto>("ZoneTileMap", async dto =>
        {
            var tiles = ConvertTileMap(dto);
            if (GameState is GameStateService gs)
            {
                gs.ApplyZoneTileMap(tiles);
            }
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<Veldrath.Contracts.Tilemap.CharacterMovedPayload>("CharacterMoved", async payload =>
        {
            GameState.ApplyCharacterMoved(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<PlayerEnteredPayload>("PlayerEntered", async payload =>
        {
            GameState.ApplyPlayerEntered(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<PlayerLeftPayload>("PlayerLeft", async payload =>
        {
            GameState.ApplyPlayerLeft(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CombatStartedPayload>("CombatStarted", async payload =>
        {
            GameState.ApplyCombatStarted(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CombatTurnPayload>("CombatTurn", async payload =>
        {
            GameState.ApplyCombatTurn(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CombatEndedPayload>("CombatEnded", async payload =>
        {
            GameState.ApplyCombatEnded(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<EnemyDefeatedPayload>("EnemyDefeated", async payload =>
        {
            GameState.ApplyEnemyDefeated(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<CharacterRespawnedPayload>("CharacterRespawned", async payload =>
        {
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage("You have respawned.");
            }
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<ChatMessageHubDto>("ReceiveChatMessage", async payload =>
        {
            GameState.ApplyChatMessage(payload);
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<string>("SystemMessage", async message =>
        {
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage(message);
            }
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<string>("Error", async error =>
        {
            Logger.LogWarning("Hub error: {Error}", error);
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage($"Error: {error}");
            }
            await InvokeAsync(StateHasChanged);
        }));

        _hubSubscriptions.Add(Hub.On<Veldrath.Contracts.Tilemap.ZoneEntitiesSnapshotPayload>("ZoneEntitiesSnapshot", async payload =>
        {
            GameState.ApplyZoneEntitiesSnapshot(payload);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G18: OnKicked ──────────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<Veldrath.Contracts.Connection.KickedPayload>("OnKicked", async payload =>
        {
            GameState.ApplyKicked(payload.Reason);
            await InvokeAsync(StateHasChanged);
            Navigation.NavigateTo("/");
        }));

        // ── G19: ExperienceGained ──────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ExperienceGainedPayload>("ExperienceGained", async payload =>
        {
            GameState.ApplyExperienceGained(payload.NewLevel, payload.NewXP, payload.LeveledUpTo);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G20: GoldChanged ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<GoldChangedPayload>("GoldChanged", async payload =>
        {
            GameState.ApplyGoldChanged(payload.GoldAdded, payload.NewGoldTotal);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G21: DamageTaken ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<DamageTakenPayload>("DamageTaken", async payload =>
        {
            GameState.ApplyDamageTaken(payload.Damage, payload.CurrentHP, payload.MaxHP, payload.IsDead);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G22: ItemEquipped ──────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemEquippedPayload>("ItemEquipped", async payload =>
        {
            foreach (var (slot, item) in payload.Equipped)
            {
                GameState.ApplyEquipmentChanged(slot, item);
            }
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage($"Equipped {payload.ItemRef}.");
            }
            await InvokeAsync(StateHasChanged);
        }));

        // ── G23: ShopVisited ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ShopVisitedPayload>("ShopVisited", async payload =>
        {
            GameState.ApplyShopVisited(payload.ZoneId, payload.ZoneName);
            _activeOverlay = GameOverlay.OverlayKind.Shop;
            _showOverlay = true;
            await InvokeAsync(StateHasChanged);
        }));

        // ── G24: ShopCatalog ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ShopCatalogPayload>("ShopCatalog", async payload =>
        {
            GameState.ApplyShopCatalogUpdated(payload.Catalog);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G25: ItemPurchased ─────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemPurchasedPayload>("ItemPurchased", async payload =>
        {
            GameState.ApplyItemTransacted(payload.Name, payload.GoldSpent, payload.Inventory);
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage($"Purchased {payload.Name}.");
            }
            await InvokeAsync(StateHasChanged);
        }));

        // ── G26: ItemSold ──────────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemSoldPayload>("ItemSold", async payload =>
        {
            GameState.ApplyItemTransacted(payload.Name, payload.GoldReceived, payload.Inventory);
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage($"Sold {payload.Name}.");
            }
            await InvokeAsync(StateHasChanged);
        }));

        // ── G27: ItemDropped ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemDroppedPayload>("ItemDropped", async payload =>
        {
            GameState.ApplyItemTransacted(payload.ItemRef, GameState.CurrentCharacterGold, payload.Inventory);
            if (GameState is GameStateService gs)
            {
                gs.ApplySystemMessage($"Dropped {payload.ItemRef}.");
            }
            await InvokeAsync(StateHasChanged);
        }));

        // ── G28: InventoryLoaded ───────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<InventoryLoadedPayload>("InventoryLoaded", async payload =>
        {
            GameState.ApplyInventoryUpdated(payload.Items, GameState.EquippedItems);
            _activeOverlay = GameOverlay.OverlayKind.Inventory;
            _showOverlay = true;
            await InvokeAsync(StateHasChanged);
        }));

        // ── G29: QuestLogReceived ──────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<QuestLogReceivedPayload>("QuestLogReceived", async payload =>
        {
            GameState.ApplyQuestLogUpdated(payload.Active, payload.Completed);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G30: AttributePointsAllocated ──────────────────────────────────
        _hubSubscriptions.Add(Hub.On<AttributePointsAllocatedPayload>("AttributePointsAllocated", async payload =>
        {
            GameState.ApplyAttributePointsAllocated(payload.RemainingPoints, payload.Attrs);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G31: CharacterRested ───────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<CharacterRestedPayload>("CharacterRested", async payload =>
        {
            GameState.ApplyCharacterRested(payload.HP, payload.MaxHP, payload.MP, payload.MaxMP, payload.Gold);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G32: AbilityUsed ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<AbilityUsedPayload>("AbilityUsed", async payload =>
        {
            GameState.ApplyAbilityUsed(payload.AbilityId, payload.RemainingMana, payload.HPRestored);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G33: SkillXpGained ─────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<SkillXpGainedPayload>("SkillXpGained", async payload =>
        {
            GameState.ApplySkillXpGained(payload.SkillId, payload.XpGained, payload.NewRank, payload.RankedUp);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G34: ItemCrafted ───────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<ItemCraftedPayload>("ItemCrafted", async payload =>
        {
            GameState.ApplyItemCrafted(payload.RecipeName, payload.GoldSpent, payload.RemainingGold);
            await InvokeAsync(StateHasChanged);
        }));

        // ── G35: DungeonEntered ────────────────────────────────────────────
        _hubSubscriptions.Add(Hub.On<DungeonEnteredPayload>("DungeonEntered", async payload =>
        {
            GameState.ApplyDungeonEntered(payload.DungeonId);
            await InvokeAsync(StateHasChanged);
        }));
    }

    private static Veldrath.GameClient.Core.Services.Tile[,] ConvertTileMap(TileMapDto dto)
    {
        var width = dto.Width;
        var height = dto.Height;
        var tiles = new Veldrath.GameClient.Core.Services.Tile[height, width];

        var groundLayer = dto.Layers.FirstOrDefault();

        for (var y = 0; y < height; y++)
        {
            for (var x = 0; x < width; x++)
            {
                var idx = y * width + x;
                var tileType = groundLayer is not null && idx < groundLayer.Data.Length
                    ? groundLayer.Data[idx]
                    : 0;
                var isBlocked = dto.CollisionMask is not null && idx < dto.CollisionMask.Length && dto.CollisionMask[idx];

                var simplifiedType = tileType switch
                {
                    -1 => -1,
                    0 => 0,
                    1 => 1,
                    2 => 2,
                    3 => 3,
                    _ when isBlocked => 1,
                    _ => 0
                };

                tiles[y, x] = new Veldrath.GameClient.Core.Services.Tile(x, y, simplifiedType, isBlocked);
            }
        }

        return tiles;
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        _stateSubscription?.Dispose();

        foreach (var sub in _hubSubscriptions)
        {
            sub.Dispose();
        }
        _hubSubscriptions.Clear();

        if (_hubConnected)
        {
            try { await Hub.DisconnectAsync(); }
            catch (Exception ex) { Logger.LogWarning(ex, "Error disconnecting hub."); }
        }
    }
}
