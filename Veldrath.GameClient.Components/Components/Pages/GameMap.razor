@page "/Game/Map"
@using Veldrath.GameClient.Core.Services
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.GameClient.Components.Models
@using Veldrath.Contracts.Tilemap
@using MudBlazor

@* Region map page showing zones as interactive cards. *@

<div class="game-map-page flex-1 d-flex flex-column overflow-y-auto">
    <div class="game-map-header d-flex align-center gap-3">
        <h2 class="game-map-title">Region Map</h2>
        <span class="game-map-region-name">@RegionName</span>
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   OnClick="GoBack"
                   Class="game-map-close ml-auto">
            Back
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <div class="game-map-loading flex-1 d-flex flex-column align-center justify-center gap-4">
            <div class="spinner"></div>
            <p>Loading region map...</p>
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="game-map-error flex-1 d-flex flex-column align-center justify-center gap-4">
            <p>@_errorMessage</p>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="LoadRegionMap">
                Retry
            </MudButton>
        </div>
    }
    else if (_zones.Count == 0)
    {
        <div class="game-map-empty flex-1 d-flex flex-column align-center justify-center gap-4">
            <p>No zones available for this region.</p>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="LoadRegionMap">
                Refresh
            </MudButton>
        </div>
    }
    else
    {
        <div class="game-map-zones gap-3">
            @foreach (var zone in _zones)
            {
                <button class="game-map-zone-card d-flex flex-column align-center gap-1 @GetZoneCardClass(zone)"
                        @onclick="() => NavigateToZone(zone.Id)"
                        disabled="@(!zone.IsClickable)"
                        title="@(zone.IsDiscovered ? $"{zone.Name} (Lv.{zone.MinLevel}+)" : "Undiscovered")">
                    <span class="game-map-zone-name">@zone.DisplayLabel</span>
                    @if (zone.IsDiscovered)
                    {
                        <span class="game-map-zone-type @zone.TypeClass">@zone.Type</span>
                        <span class="game-map-zone-level">Lv. @zone.MinLevel+</span>
                    }
                    @if (zone.IsCurrent)
                    {
                        <span class="game-map-zone-current-badge">You are here</span>
                    }
                </button>
            }
        </div>

        @if (_showLegend)
        {
            <div class="game-map-legend d-flex gap-4 justify-center flex-wrap">
                <span class="legend-item d-flex align-center gap-1"><span class="legend-dot dot-current"></span> Current Zone</span>
                <span class="legend-item d-flex align-center gap-1"><span class="legend-dot dot-available"></span> Available</span>
                <span class="legend-item d-flex align-center gap-1"><span class="legend-dot dot-locked"></span> Undiscovered</span>
            </div>
        }

        @* G73: Change Region — allow entering a new region by ID *@
        <div class="game-map-region-nav">
            <h5>Change Region</h5>
            <div class="game-map-region-input-group">
                <input type="text"
                       class="game-map-region-input"
                       @bind="_targetRegionId"
                       @bind:event="oninput"
                       placeholder="Target region ID..."
                       disabled="@(!Hub.IsConnected)" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="ChangeRegionAsync"
                           Disabled="@(string.IsNullOrWhiteSpace(_targetRegionId) || !Hub.IsConnected)">
                    Travel
                </MudButton>
            </div>
        </div>
    }
</div>
