@using Veldrath.GameClient.Core.Abstractions
@* Single tile renderer for the zone tilemap viewport. Renders a <div> with the appropriate CSS class,
   entity overlays, and hover/mouseleave events for the info card. *@

<div class="game-tile @GetTileClass()"
     @onclick="() => OnClick.InvokeAsync((X, Y))"
     @onmouseenter="() => OnHover.InvokeAsync((X, Y))"
     @onmouseleave="() => OnHover.InvokeAsync((-1, -1))"
     title="@($"({X}, {Y})")">
    @if (IsPlayerHere)
    {
        <div class="tile-indicator tile-indicator-player" title="You are here"></div>
    }
    @if (Occupant is not null)
    {
        <div class="tile-indicator tile-indicator-occupant" title="@Occupant.CharacterName"></div>
    }
    @if (Enemy is not null)
    {
        <div class="tile-indicator tile-indicator-enemy" title="@Enemy.EnemyName (Lv. @Enemy.Level)"></div>
    }
</div>

@code {
    /// <summary>The tile data to render.</summary>
    [Parameter] public Veldrath.GameClient.Core.Abstractions.Tile TileData { get; set; } = null!;

    /// <summary>The map column position of this tile.</summary>
    [Parameter] public int X { get; set; }

    /// <summary>The map row position of this tile.</summary>
    [Parameter] public int Y { get; set; }

    /// <summary>Callback when the tile is clicked. Receives the tile's map coordinates.</summary>
    [Parameter] public EventCallback<(int X, int Y)> OnClick { get; set; }

    /// <summary>
    /// Callback when the mouse enters or leaves the tile.
    /// Receives the tile's map coordinates, or (-1, -1) on mouse leave.
    /// </summary>
    [Parameter] public EventCallback<(int X, int Y)> OnHover { get; set; }

    /// <summary>Whether the player is currently on this tile.</summary>
    [Parameter] public bool IsPlayerHere { get; set; }

    /// <summary>An occupant (other player) on this tile, if any.</summary>
    [Parameter] public OccupantInfo? Occupant { get; set; }

    /// <summary>An enemy on this tile, if any.</summary>
    [Parameter] public EnemyInfo? Enemy { get; set; }

    private string GetTileClass() => TileData.Type switch
    {
        0 => "tile-grass",
        1 => "tile-wall",
        2 => "tile-water",
        3 => "tile-door",
        4 => "tile-path",
        5 => "tile-dirt",
        -1 => "tile-void",
        _ => "tile-empty"
    };
}
