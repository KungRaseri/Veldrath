@* Journal / Quest Log overlay showing active and completed quests. *@
@using Microsoft.Extensions.Logging
@using Veldrath.GameClient.Core.Abstractions
@inject IGameHubConnectionService Hub
@inject IGameStateService GameState
@inject ILogger<JournalOverlay> Logger
@implements IAsyncDisposable

<div class="journal-overlay d-flex flex-column gap-4">
    <div class="journal-quest-list">
        <h4>Active Quests (@GameState.QuestLog.Count)</h4>
        @if (GameState.QuestLog.Count == 0)
        {
            <p class="journal-empty">No active quests. Find an NPC in town to get started!</p>
        }
        else
        {
            @foreach (var quest in GameState.QuestLog)
            {
                <div class="journal-quest d-flex align-center gap-2 @(_selectedQuest == quest ? "journal-quest-selected" : "")"
                     @onclick="() => SelectQuest(quest)">
                    <span class="journal-quest-title flex-1">@quest.Title</span>
                    <span class="journal-quest-progress">@quest.Progress / @quest.Total</span>
                    @if (quest.IsComplete)
                    {
                        <span class="journal-quest-complete-badge">✓</span>
                    }
                </div>
            }
        }
    </div>

    @if (_selectedQuest is not null)
    {
        <div class="journal-quest-detail d-flex flex-column gap-2">
            <h4>@_selectedQuest.Title</h4>
            @if (!string.IsNullOrEmpty(_selectedQuest.Description))
            {
                <p class="journal-quest-desc">@_selectedQuest.Description</p>
            }
            <div class="journal-quest-objectives">
                <h5>Objectives</h5>
                @if (_selectedQuest.Objectives.Count == 0)
                {
                    <p class="journal-empty">No specific objectives listed.</p>
                }
                else
                {
                    <ul>
                        @foreach (var (objName, required) in _selectedQuest.Objectives)
                        {
                            var progress = _selectedQuest.ProgressData.GetValueOrDefault(objName, 0);
                            var done = progress >= required;
                            <li class="@(done ? "objective-done" : "objective-pending")">
                                @if (done) { <span class="objective-check">✓</span> }
                                @objName: @progress / @required
                            </li>
                        }
                    </ul>
                }
            </div>
            <div class="journal-quest-rewards">
                <h5>Rewards</h5>
                <p>@_selectedQuest.XpReward XP · @_selectedQuest.GoldReward gold</p>
            </div>
        </div>
    }

    @if (GameState.CompletedQuests.Count > 0)
    {
        <div class="journal-completed">
            <h4>Completed Quests (@GameState.CompletedQuests.Count)</h4>
            <div class="journal-completed-list d-flex flex-column">
                @foreach (var quest in GameState.CompletedQuests)
                {
                    <div class="journal-completed-item">@quest.Title</div>
                }
            </div>
        </div>
    }
</div>

@code {
    private QuestLogEntry? _selectedQuest;
    private IDisposable? _questLogSubscription;

    /// <summary>
    /// Hub event payload received when the quest log is sent from the server.
    /// </summary>
    /// <param name="Active">The currently active quests.</param>
    /// <param name="Completed">The completed quests.</param>
    public sealed record QuestLogPayload(
        IReadOnlyList<QuestLogEntry> Active,
        IReadOnlyList<QuestLogEntry> Completed);

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        // Subscribe to hub event for quest log updates
        _questLogSubscription = Hub.On<QuestLogPayload>("QuestLogReceived", payload =>
        {
            GameState.ApplyQuestLogUpdated(payload.Active, payload.Completed);
            _ = InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        });

        // Request current quest log from the server
        _ = RequestQuestLogAsync();
    }

    private async Task RequestQuestLogAsync()
    {
        try
        {
            if (Hub.IsConnected)
                await Hub.SendAsync("GetQuestLog");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to request quest log from server.");
        }
    }

    private void SelectQuest(QuestLogEntry quest)
    {
        _selectedQuest = quest;
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        _questLogSubscription?.Dispose();
        await Task.CompletedTask;
    }
}
