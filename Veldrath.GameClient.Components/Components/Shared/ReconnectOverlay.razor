@using Microsoft.Extensions.Configuration
@using Veldrath.GameClient.Core.Abstractions
@using Veldrath.GameClient.Core.Models
@using Veldrath.Auth.Blazor
@using MudBlazor
@* Full-screen overlay shown when the SignalR hub connection is lost or reconnecting.
    Displays a countdown timer with auto-retry and manual reconnect/return-to-menu options. *@

@if (_visible)
{
    <div class="reconnect-overlay d-flex flex-column align-center justify-center gap-6">
        <div class="reconnect-overlay-card d-flex flex-column align-center gap-4">
            <div class="reconnect-overlay-icon">⚠</div>
            <h2 class="reconnect-overlay-title">Connection Lost</h2>
            <p class="reconnect-overlay-message">
                @_statusMessage
            </p>

            @if (_showCountdown)
            {
                <div class="reconnect-overlay-countdown">@_countdownSeconds</div>
                <p class="reconnect-overlay-message">
                    Auto-retry in @_countdownSeconds seconds...
                </p>
            }

            <div class="reconnect-overlay-actions d-flex gap-3 justify-center">
                @if (!_isReconnecting)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ReconnectNow"
                               Disabled="@_isBusy"
                               Size="Size.Small">
                        @(_isBusy ? "Reconnecting..." : "Reconnect Now")
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined"
                           OnClick="ReturnToMenu"
                           Disabled="@_isBusy"
                           Size="Size.Small">
                    Return to Menu
                </MudButton>
            </div>
        </div>
    </div>
}

@* Brief toast notification when reconnection succeeds. *@
@if (_showReconnectedToast)
{
    <div class="reconnect-toast">
        <span>✓</span>
        <span>Reconnected successfully</span>
    </div>
}

@code {
    private bool _visible;
    private bool _showCountdown;
    private bool _isReconnecting;
    private bool _isBusy;
    private bool _showReconnectedToast;
    private int _countdownSeconds;
    private string _statusMessage = "The connection to the game server was lost.";
    private CancellationTokenSource? _retryCts;
    private IDisposable? _hubStateSubscription;

    /// <summary>
    /// Callback invoked when the user chooses to return to the main menu.
    /// The hosting component should handle navigation.
    /// </summary>
    [Parameter]
    public EventCallback OnReturnToMenu { get; set; }

    /// <summary>
    /// Callback invoked when the user clicks "Reconnect Now" or an auto-retry succeeds.
    /// </summary>
    [Parameter]
    public EventCallback OnReconnected { get; set; }

    [Inject]
    private IGameHubConnectionService Hub { get; set; } = null!;

    [Inject]
    private IConfiguration Configuration { get; set; } = null!;

    [Inject]
    private AuthStateServiceBase Auth { get; set; } = null!;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        _hubStateSubscription = SubscribeToHubState();
    }

    private IDisposable SubscribeToHubState()
    {
        // Handle state changes
        void Handler(object? s, ConnectionState state)
        {
            _ = InvokeAsync(() => OnHubStateChanged(state));
        }

        Hub.StateChanged += Handler;

        // Check initial state ONLY when auth is ready. During SSR prerender,
        // auth isn't ready yet (MainLayout hasn't called MarkReady), so the
        // hub hasn't had a chance to connect. Checking the initial
        // Disconnected state during SSR would show a false "Connection Lost"
        // overlay before the circuit even has a chance to connect.
        if (Auth.IsAuthReady)
        {
            _ = InvokeAsync(() => OnHubStateChanged(Hub.State));
        }

        return new Subscription(() => Hub.StateChanged -= Handler);
    }

    private void OnHubStateChanged(ConnectionState state)
    {
        switch (state)
        {
            case ConnectionState.Reconnecting:
                ShowOverlay("Connection lost. Attempting to reconnect...", showCountdown: false, isReconnecting: true);
                break;

            case ConnectionState.Connecting:
                ShowOverlay("Connecting to game server...", showCountdown: false, isReconnecting: true);
                break;

            case ConnectionState.Failed:
                ShowOverlay("Connection failed. Retry in 5 seconds...", showCountdown: true, isReconnecting: false);
                StartAutoRetry(5000);
                break;

            case ConnectionState.Disconnected:
                if (!_isReconnecting)
                {
                    ShowOverlay("Connection lost. Retry in 5 seconds...", showCountdown: true, isReconnecting: false);
                    StartAutoRetry(5000);
                }
                break;

            case ConnectionState.Connected:
                if (_visible)
                {
                    HideOverlay();
                    ShowReconnectedToast();
                }
                break;

            case ConnectionState.Degraded:
                // Don't show overlay for degraded; footer handles it
                break;
        }
    }

    private void ShowOverlay(string message, bool showCountdown, bool isReconnecting)
    {
        _statusMessage = message;
        _showCountdown = showCountdown;
        _isReconnecting = isReconnecting;
        _visible = true;
        _isBusy = false;
        _countdownSeconds = 5;
        StateHasChanged();
    }

    private void HideOverlay()
    {
        _visible = false;
        _isReconnecting = false;
        _isBusy = false;
        _showCountdown = false;
        _retryCts?.Cancel();
        _retryCts?.Dispose();
        _retryCts = null;
        StateHasChanged();
    }

    private async void StartAutoRetry(int delayMs)
    {
        _retryCts?.Cancel();
        _retryCts?.Dispose();
        _retryCts = new CancellationTokenSource();
        var token = _retryCts.Token;

        try
        {
            // Countdown from 5 seconds (or use the actual delay/1000)
            var countdownTotal = Math.Max(1, delayMs / 1000);
            for (var i = countdownTotal; i > 0; i--)
            {
                if (token.IsCancellationRequested) return;
                _countdownSeconds = i;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(1000, token);
            }

            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(async () =>
                {
                    _isBusy = true;
                    _statusMessage = "Reconnecting...";
                    StateHasChanged();
                    await AttemptReconnectAsync();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Cancellation is expected when manually reconnecting or overlay is dismissed
        }
    }

    private async Task ReconnectNow()
    {
        _retryCts?.Cancel();
        _retryCts?.Dispose();
        _retryCts = null;

        _isBusy = true;
        _statusMessage = "Reconnecting...";
        _showCountdown = false;
        StateHasChanged();

        await AttemptReconnectAsync();
    }

    private async Task AttemptReconnectAsync()
    {
        try
        {
            // For Failed or Disconnected states, SignalR's automatic reconnect has
            // given up.  Re-establish the connection from scratch using the stored
            // server URL and access token.
            if (Hub.State is ConnectionState.Failed or ConnectionState.Disconnected)
            {
                var serverUrl = Configuration["Veldrath:ServerUrl"];
                if (string.IsNullOrWhiteSpace(serverUrl) || !Auth.IsLoggedIn || Auth.AccessToken is null)
                {
                    _statusMessage = "Cannot reconnect automatically. Please return to the menu.";
                    _isBusy = false;
                    _showCountdown = false;
                    StateHasChanged();
                    return;
                }

                await Hub.ConnectAsync(serverUrl, Auth.AccessToken);
                // State will transition to Connected via the handler — no further action needed.
                return;
            }

            // For Reconnecting state, SignalR handles it automatically.
            // We just wait for the state to change.
            _statusMessage = "Waiting for automatic reconnection...";
            _isBusy = false;
            StateHasChanged();
        }
        catch (Exception)
        {
            _statusMessage = "Reconnection failed. Please try again.";
            _isBusy = false;
            _showCountdown = true;
            _countdownSeconds = 5;
            StateHasChanged();
            StartAutoRetry(5000);
        }
    }

    private async void ShowReconnectedToast()
    {
        _showReconnectedToast = true;
        StateHasChanged();
        await Task.Delay(5000);
        _showReconnectedToast = false;
        await InvokeAsync(StateHasChanged);

        if (OnReconnected.HasDelegate)
        {
            await OnReconnected.InvokeAsync();
        }
    }

    private async Task ReturnToMenu()
    {
        _retryCts?.Cancel();
        _retryCts?.Dispose();
        _retryCts = null;

        if (OnReturnToMenu.HasDelegate)
        {
            await OnReturnToMenu.InvokeAsync();
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _hubStateSubscription?.Dispose();
        _retryCts?.Cancel();
        _retryCts?.Dispose();
    }

    /// <summary>
    /// Simple disposable that runs an action on dispose.
    /// </summary>
    private sealed class Subscription(Action onDispose) : IDisposable
    {
        /// <inheritdoc />
        public void Dispose() => onDispose();
    }
}
