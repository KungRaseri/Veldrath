@* Status bar displayed below the tilemap viewport, showing the current tile's type description. *@

<div class="tile-status-bar">
    <span class="tile-status-bar-icon" aria-hidden="true">📍</span>
    <span class="tile-status-bar-text">@Description</span>
</div>

@code {
    /// <summary>The human-readable description of the player's current tile (e.g. "Grass", "Path").</summary>
    [Parameter] public string Description { get; set; } = string.Empty;
}
