@* Reusable action button bar that shows context-sensitive buttons based on game state
    and a hotbar row with ability quick-slot buttons. *@
@using MudBlazor

<div class="action-bar-wrapper">
    @* Hotbar ability quick-slot buttons row *@
    @if (ShowHotbar)
    {
        <div class="hotbar">
            @foreach (var slot in HotbarSlots)
            {
                <button class="hotbar-slot @slot.CssClass"
                        @onclick="() => OnUseAbility.InvokeAsync(slot.AbilityId)"
                        disabled="@(slot.IsEmpty || !slot.IsAvailable)"
                        title="@(slot.Name ?? $"Slot {slot.SlotNumber}")">
                    <span class="hotbar-slot-key">@slot.KeyBind</span>
                    <span class="hotbar-slot-icon">
                        @if (slot.IsEmpty)
                        {
                            <span class="hotbar-slot-empty-icon">—</span>
                        }
                        else if (!slot.IsAvailable && slot.CooldownRemaining > 0)
                        {
                            <span class="hotbar-slot-cooldown">@slot.CooldownRemaining</span>
                        }
                        else
                        {
                            <span class="hotbar-slot-ability-name">@slot.Name?[..Math.Min(3, slot.Name?.Length ?? 0)]</span>
                        }
                    </span>
                </button>
            }
        </div>
    }

    @* Context-sensitive action buttons *@
    <div class="action-bar">
        @if (ShowAttack)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="OnAttack"
                       Disabled="@Disabled"
                       Size="Size.Small">
                Attack
            </MudButton>
        }
        @if (ShowDefend)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Info"
                       OnClick="OnDefend"
                       Disabled="@Disabled"
                       Size="Size.Small">
                Defend
            </MudButton>
        }
        @if (ShowFlee)
        {
            <MudButton Variant="Variant.Outlined"
                       OnClick="OnFlee"
                       Disabled="@Disabled"
                       Size="Size.Small">
                Flee
            </MudButton>
        }
        @if (ShowRespawn)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Warning"
                       OnClick="OnRespawn"
                       Disabled="@Disabled"
                       Size="Size.Small">
                Respawn
            </MudButton>
        }
    </div>
</div>

@code {
    /// <summary>Whether to show the hotbar ability quick-slot row.</summary>
    [Parameter] public bool ShowHotbar { get; set; } = true;

    /// <summary>The list of hotbar ability slots to display.</summary>
    [Parameter] public List<Veldrath.GameClient.Components.Models.HotbarAbility> HotbarSlots { get; set; } = [];

    /// <summary>Whether to show the Attack button.</summary>
    [Parameter] public bool ShowAttack { get; set; }

    /// <summary>Whether to show the Defend button.</summary>
    [Parameter] public bool ShowDefend { get; set; }

    /// <summary>Whether to show the Flee button.</summary>
    [Parameter] public bool ShowFlee { get; set; }

    /// <summary>Whether to show the Respawn button.</summary>
    [Parameter] public bool ShowRespawn { get; set; }

    /// <summary>Whether action buttons are disabled (e.g. during combat turn processing).</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Callback when the Attack button is clicked.</summary>
    [Parameter] public EventCallback OnAttack { get; set; }

    /// <summary>Callback when the Defend button is clicked.</summary>
    [Parameter] public EventCallback OnDefend { get; set; }

    /// <summary>Callback when the Flee button is clicked.</summary>
    [Parameter] public EventCallback OnFlee { get; set; }

    /// <summary>Callback when the Respawn button is clicked.</summary>
    [Parameter] public EventCallback OnRespawn { get; set; }

    /// <summary>
    /// Callback invoked when a hotbar ability quick-slot is clicked.
    /// The parameter is the <see cref="Veldrath.GameClient.Components.Models.HotbarAbility.AbilityId"/>.
    /// </summary>
    [Parameter] public EventCallback<string?> OnUseAbility { get; set; }
}
