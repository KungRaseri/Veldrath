@* Reusable panel/modal wrapper with a title, body content, and optional close button. *@

@if (Visible)
{
    <div class="game-panel-backdrop d-flex align-center justify-center" @onclick="HandleBackdropClick">
        <div class="game-panel d-flex flex-column" @onclick:stopPropagation="true">
            <div class="game-panel-header d-flex align-center justify-space-between">
                <span class="game-panel-title">@Title</span>
                @if (ShowClose)
                {
                    <button class="game-panel-close" @onclick="OnClose">✕</button>
                }
            </div>
            <div class="game-panel-body">
                @ChildContent
            </div>
        </div>
    </div>
}

@code {
    /// <summary>The panel title displayed in the header.</summary>
    [Parameter] public string Title { get; set; } = string.Empty;

    /// <summary>Whether the panel is visible.</summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>Whether to show the close button.</summary>
    [Parameter] public bool ShowClose { get; set; } = true;

    /// <summary>Callback invoked when the panel is closed.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>The body content of the panel.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private async Task HandleBackdropClick()
    {
        if (ShowClose)
        {
            await OnClose.InvokeAsync();
        }
    }
}
