@using Veldrath.GameClient.Core.Abstractions
@using MudBlazor
@inherits LayoutComponentBase
@inject IGameStateService GameState
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation

<MudDialogProvider />

<MudLayout>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>
@* Desktop bridge: loaded when running inside Avalonia WebView2 *@
@if (Navigation.BaseUri.StartsWith("http://localhost", StringComparison.OrdinalIgnoreCase))
{
    <script src="_content/Veldrath.GameClient.Components/bridge.js"></script>
}
