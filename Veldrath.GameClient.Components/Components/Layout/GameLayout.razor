@using Veldrath.GameClient.Core.Abstractions
@using MudBlazor
@inherits LayoutComponentBase
@inject IGameStateService GameState
@inject IGameHubConnectionService Hub
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation

<MudDialogProvider />

<div class="game-layout mud-d-flex flex-column overflow-hidden @(GameState.IsConnected ? "in-game" : "")">
    @Body
</div>

@* Reconnect overlay shown when connection is lost.
    OnReconnected triggers a layout re-render so child components (e.g. Game.razor)
    can detect the Connected state transition and reinitialize their session. *@
<ReconnectOverlay OnReturnToMenu="HandleReturnToMenu"
                  OnReconnected="HandleReconnected" />

@* Desktop bridge: loaded when running inside Avalonia WebView2 *@
@if (Navigation.BaseUri.StartsWith("http://localhost", StringComparison.OrdinalIgnoreCase))
{
    <script src="_content/Veldrath.GameClient.Components/bridge.js"></script>
}

@code {
    private async Task HandleReturnToMenu()
    {
        GameState.ApplySystemMessage("Returning to main menu...");
        Navigation.NavigateTo("/");
    }

    /// <summary>
    /// Called by <see cref="ReconnectOverlay"/> after a successful reconnection.
    /// Forces a layout re-render so child components can detect the transition
    /// and restore their game session state.
    /// </summary>
    private void HandleReconnected()
    {
        StateHasChanged();
    }
}
