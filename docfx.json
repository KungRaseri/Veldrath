{
  "metadata": [
    {
      "src": [
        { "files": ["Realm.Full.slnx"] }
      ],
      "dest": "api",
      "allowCompilationErrors": true,
      "noRestore": true,
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": ["api/**.yml"] }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "RealmEngine",
      "_appTitle": "RealmEngine",
      "_enableSearch": true,
      "_memberLayout": "separatePages",
      "_gitContribute": {
        "repo": "https://github.com/KungRaseri/RealmEngine",
        "branch": "main"
      }
    },
    "xref": [
      "https://learn.microsoft.com/en-us/dotnet/.xrefmap.json"
    ],
    "sitemap": {
      "baseUrl": "https://kungraseri.github.io/RealmEngine"
    }
  }
}
