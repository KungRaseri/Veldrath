<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <!-- SQLite in-memory for DbContext testing -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" />
    <!-- Transitive pin: SQLitePCLRaw.lib.e_sqlite3 2.1.11 (from bundle_e_sqlite3) has known heap-buffer-overflow (GHSA-2m69-gcr7-jv3q) -->
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" />
    <!-- Integration testing host -->
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <!-- Mocking for unit-level health check tests -->
    <PackageReference Include="Moq" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Veldrath.Server\Veldrath.Server.csproj" />
    <ProjectReference Include="..\Veldrath.Contracts\Veldrath.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Moq" />
    <Using Include="MediatR" />
    <Using Include="Veldrath.Contracts.Account" />
    <Using Include="Veldrath.Contracts.Admin" />
    <Using Include="Veldrath.Contracts.Auth" />
    <Using Include="Veldrath.Contracts.Characters" />
    <Using Include="Veldrath.Contracts.Editorial" />
    <Using Include="Veldrath.Contracts.Foundry" />
    <Using Include="Veldrath.Contracts.Players" />
    <Using Include="Veldrath.Contracts.Zones" />
  </ItemGroup>

</Project>
