# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# HTTPS dev certificate password
# Export your dev cert once with:
#   dotnet dev-certs https -ep "$env:USERPROFILE\.aspnet\https\realmunbound.pfx" -p "your_password_here"
#   dotnet dev-certs https --trust
CERT_PASSWORD=your_password_here
