# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── HTTPS dev certificate ──────────────────────────────────────────────────
# Export your dev cert once with:
#   dotnet dev-certs https -ep "$env:USERPROFILE\.aspnet\https\realmunbound.pfx" -p "your_password_here"
#   dotnet dev-certs https --trust
CERT_PASSWORD=your_password_here

# ── JWT signing key (docker / production) ─────────────────────────────────
# Must be at least 32 characters. Keep this secret.
# For local dev outside Docker, set via: dotnet user-secrets set "Jwt:Key" "..."
JWT_KEY=your_jwt_signing_key_at_least_32_chars_here

# ── Discord bot (RealmUnbound.Discord service) ─────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_DEV_GUILD_ID=123456789

# ── OAuth provider credentials (RealmUnbound.Server) ──────────────────────
# For local dev outside Docker, set these via dotnet user-secrets (see below).
# For Docker (docker-compose), these are injected into the server container.
#
# dotnet user-secrets --project RealmUnbound.Server set "OAuth:Discord:ClientId"     "..."
# dotnet user-secrets --project RealmUnbound.Server set "OAuth:Discord:ClientSecret" "..."
# dotnet user-secrets --project RealmUnbound.Server set "OAuth:Google:ClientId"      "..."
# dotnet user-secrets --project RealmUnbound.Server set "OAuth:Google:ClientSecret"  "..."
# dotnet user-secrets --project RealmUnbound.Server set "OAuth:Microsoft:ClientId"     "..."
# dotnet user-secrets --project RealmUnbound.Server set "OAuth:Microsoft:ClientSecret" "..."

# Discord — https://discord.com/developers/applications → OAuth2
OAUTH_DISCORD_CLIENT_ID=your_discord_oauth_client_id
OAUTH_DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret

# Google — https://console.cloud.google.com → APIs & Services → Credentials
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft — https://portal.azure.com → App registrations
OAUTH_MICROSOFT_CLIENT_ID=your_microsoft_client_id
OAUTH_MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret