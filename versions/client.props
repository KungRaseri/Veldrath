<Project>
  <!-- Veldrath.Client: Avalonia desktop client -->
  <PropertyGroup>
    <VersionMajor>0</VersionMajor>
    <VersionMinor>1</VersionMinor>
    <!--
      Oldest server version this client can work with.
      Only bump when the client requires a server feature that did not exist before.
      Never auto-track VersionMinor.
    -->
    <MinCompatibleServerVersion>0.1</MinCompatibleServerVersion>
    <!--
      Unconditional overrides so the MSBuild conditional fallbacks in root
      Directory.Build.props (which lock AssemblyVersion to "0.0.0" before
      this file is imported) are superseded with the correct component version.
    -->
    <Version>$(VersionMajor).$(VersionMinor).0</Version>
    <AssemblyVersion>$(VersionMajor).$(VersionMinor).0</AssemblyVersion>
    <FileVersion>$(VersionMajor).$(VersionMinor).0.0</FileVersion>
    <InformationalVersion>$(VersionMajor).$(VersionMinor).0-dev</InformationalVersion>
  </PropertyGroup>
</Project>
