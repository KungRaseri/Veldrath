{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Database": {
    "Provider": "sqlite"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=realmunbound-dev.db"
  },
  "Jwt": {
    "Key": "dev-secret-key-change-in-production-must-be-32-chars",
    "Issuer": "RealmUnbound.Server",
    "Audience": "RealmUnbound.Client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "RealmEngine": {
    "DataPath": "Data/Json"
  }
}
