<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Veldrath.Client"
             xmlns:fac="using:FluentAvalonia.Styling"
             x:Class="Veldrath.Client.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <fac:FluentAvaloniaTheme />
        <StyleInclude Source="avares://Veldrath.Client/Assets/Themes/GameTheme.axaml" />
    </Application.Styles>

</Application>
