<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Veldrath.Client.ViewModels"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Veldrath.Client.Views.ForgotPasswordView"
             x:DataType="vm:ForgotPasswordViewModel">

    <Grid RowDefinitions="*,Auto,*">

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Width="360"
                    Spacing="12">

            <TextBlock Text="Reset your password"
                       Classes="title-large"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <TextBlock Text="Enter your account email and we'll send you a reset link."
                       Classes="muted"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

            <!-- Success banner (shown after submit) -->
            <ui:InfoBar Title="Check your inbox"
                        Message="If an account exists for that email, a reset link has been sent."
                        Severity="Success"
                        IsOpen="{Binding EmailSent}"
                        IsClosable="False"
                        Margin="0,0,0,4" />

            <!-- Error feedback -->
            <ui:InfoBar Title="Something went wrong"
                        Message="{Binding ErrorMessage}"
                        Severity="Error"
                        IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        IsClosable="False"
                        Margin="0,0,0,4" />

            <!-- Email -->
            <TextBlock Text="Email" Classes="muted" />
            <TextBox Text="{Binding Email}"
                     Watermark="Enter your email"
                     IsEnabled="{Binding !EmailSent}"
                     Height="40" />

            <!-- Send button -->
            <Button Content="Send Reset Link"
                    Classes="accent"
                    Command="{Binding SendResetCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="44"
                    FontSize="16"
                    Margin="0,4,0,0" />

            <!-- Back -->
            <Button Content="Back to Login"
                    Classes="ghost"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="40"
                    FontSize="14" />

            <!-- Busy indicator -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsBusy}"
                         Height="4" />

        </StackPanel>

    </Grid>

</UserControl>
