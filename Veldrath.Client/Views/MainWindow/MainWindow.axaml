<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Veldrath.Client.ViewModels"
        xmlns:views="using:Veldrath.Client.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="Veldrath.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Veldrath"
        Width="1280" Height="720"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource GameBackground0Brush}"
        WindowState="{Binding WindowState}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- Full-screen page host with a collapsible server-status banner at the top -->
    <Grid RowDefinitions="Auto,*">

        <!-- Server offline banner — collapses to zero height when server is online -->
        <Border Grid.Row="0"
                Background="{DynamicResource GameDangerMutedBrush}"
                IsVisible="{Binding !IsServerOnline}"
                Padding="12,6">
            <TextBlock Text="{Binding ServerStatusMessage}"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource GameDangerBrush}"
                       FontSize="12"
                       FontWeight="SemiBold" />
        </Border>

        <!-- Active page -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />

    </Grid>

</Window>
