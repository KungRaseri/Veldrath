<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Veldrath.Client.ViewModels"
             xmlns:contracts="using:Veldrath.Contracts.Announcements"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Veldrath.Client.Views.MainMenuView"
             x:DataType="vm:MainMenuViewModel">

    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <ImageBrush Source="{DynamicResource UiBg1}" Stretch="UniformToFill" Opacity="0.4" />
        </Grid.Background>

        <!-- Row 0: Full-width title header -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="0,48,0,24">
            <TextBlock Text="{Binding Title}"
                       Classes="title-large"
                       FontSize="72"
                       LetterSpacing="6"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Subtitle}"
                       Classes="subtitle"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Row 1: 3-column layout -->
        <Grid Grid.Row="1" ColumnDefinitions="280,*,280">

        <!-- Left: News &amp; Updates panel -->
        <Border Grid.Column="0"
                VerticalAlignment="Center"
                Margin="20,0,0,0"
                Background="#1a1a2e"
                CornerRadius="8"
                Opacity="0.92">
            <StackPanel Spacing="0">

                <!-- Panel header -->
                <Border Background="#16213e"
                        CornerRadius="8,8,0,0"
                        Padding="14,10">
                    <TextBlock Text="News &amp; Updates"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#b0b0c8" />
                </Border>

                <!-- Announcement list / offline placeholder -->
                <ScrollViewer MaxHeight="380" Padding="14">
                    <StackPanel>

                        <!-- Announcement items (shown when server is online and has announcements) -->
                        <ItemsControl ItemsSource="{Binding Announcements}"
                                      IsVisible="{Binding HasAnnouncements}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="contracts:AnnouncementDto">
                                    <Border Margin="0,0,0,12"
                                            Padding="10"
                                            Background="#11112a"
                                            CornerRadius="4">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Background="#2a2a50"
                                                        CornerRadius="3"
                                                        Padding="5,2">
                                                    <TextBlock Text="{Binding Category}"
                                                               FontSize="10"
                                                               Foreground="#8888cc"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Foreground="#e0e0f0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Body}"
                                                       FontSize="11"
                                                       Foreground="#9090a8"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding PublishedAt, StringFormat='{}{0:MMM d, yyyy}'}"
                                                       FontSize="10"
                                                       Foreground="#505060" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Placeholder shown when offline or no announcements -->
                        <TextBlock Text="{Binding NewsPlaceholderText}"
                                   IsVisible="{Binding !HasAnnouncements}"
                                   FontSize="12"
                                   Foreground="#606070"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />

                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Centre: Buttons -->
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Width="280">

            <!-- Guest buttons: shown when NOT logged in -->
            <Button Content="Register"
                    Classes="accent"
                    Command="{Binding RegisterCommand}"
                    IsVisible="{Binding !IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <Button Content="Login"
                    Command="{Binding LoginCommand}"
                    IsVisible="{Binding !IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <!-- Authenticated buttons: shown when logged in -->
            <Button Content="Select Character"
                    Classes="accent"
                    Command="{Binding SelectCharacterCommand}"
                    IsVisible="{Binding IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <Button Content="Logout"
                    Classes="danger"
                    Command="{Binding LogoutCommand}"
                    IsVisible="{Binding IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <Button Content="Manage Account"
                    Classes="ghost"
                    Command="{Binding ManageAccountCommand}"
                    IsVisible="{Binding IsLoggedIn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="42"
                    FontSize="14" />

            <!-- Always visible -->
            <Button Content="Settings"
                    Classes="ghost"
                    Command="{Binding SettingsCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

            <Button Content="Exit"
                    Classes="danger"
                    Command="{Binding ExitCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"
                    FontSize="16" />

        </StackPanel>

        </Grid>
    </Grid>

</UserControl>
