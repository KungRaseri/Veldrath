<UserControl
    x:Class="Veldrath.Client.Views.GameCenterPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Veldrath.Client.Views"
    xmlns:vm="using:Veldrath.Client.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="800"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <Border Background="{DynamicResource GameBackground0Brush}">
        <Grid>
            <!-- Zone location panel (replaces tilemap control) -->
            <views:ZoneLocationPanelView
                DataContext="{Binding ZoneLocationPanel}"
                IsVisible="{Binding IsZoneViewActive}" />

            <!-- Region view — side panel handles the content -->
            <Border
                IsVisible="{Binding IsRegionViewActive}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <TextBlock
                    Text="Select a zone from the side panel to enter"
                    FontSize="16"
                    Foreground="{DynamicResource GameSubtleBrush}" />
            </Border>

            <!-- World view — side panel handles the content -->
            <Border
                IsVisible="{Binding IsWorldViewActive}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <TextBlock
                    Text="Select a region from the side panel to explore"
                    FontSize="16"
                    Foreground="{DynamicResource GameSubtleBrush}" />
            </Border>
        </Grid>
    </Border>

</UserControl>
