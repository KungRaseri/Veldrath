<UserControl
    x:Class="Veldrath.Client.Views.GameCenterPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Veldrath.Client.Views"
    xmlns:vm="using:Veldrath.Client.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="800"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <Border Background="{DynamicResource GameBackground0Brush}">
        <Grid>
            <!-- WebView2 hosted Blazor game UI (primary, when WebView2 available) -->
            <Border
                x:Name="WebViewContainer"
                IsVisible="{Binding IsWebViewActive}" />

            <!-- Zone location panel (native fallback or region/world placeholders) -->
            <views:ZoneLocationPanelView
                DataContext="{Binding ZoneLocationPanel}"
                IsVisible="{Binding IsFallbackActive}" />
        </Grid>
    </Border>

</UserControl>
