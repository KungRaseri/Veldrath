<UserControl
    x:Class="Veldrath.Client.Views.GameRegionPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Veldrath.Client.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="800"
    x:DataType="vm:GameViewModel"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">

            <!--  Region header  -->
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Text="{Binding RegionName}" />
                    <Border
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Background="{DynamicResource GameBackground3Brush}"
                        BorderBrush="{DynamicResource GameBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        IsVisible="{Binding RegionType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Classes="caption" Text="{Binding RegionType}" />
                    </Border>
                </StackPanel>
                <TextBlock Classes="muted" FontSize="13">
                    <Run Text="Levels " /><Run Text="{Binding RegionMinLevel}" /><Run Text="–" /><Run Text="{Binding RegionMaxLevel}" />
                </TextBlock>
                <TextBlock
                    Classes="muted"
                    FontStyle="Italic"
                    Text="{Binding RegionDescription}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="separator" />

            <TextBlock Classes="caption" Text="Zones" />
            <ItemsControl ItemsSource="{Binding RegionZones}">
                <ItemsControl.Styles>
                    <Style Selector="Border.active">
                        <Setter Property="BorderBrush" Value="{DynamicResource GameAccentBrush}" />
                        <Setter Property="Background" Value="{DynamicResource GameBackground3Brush}" />
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ZoneNodeViewModel">
                        <Border
                            MinWidth="160"
                            Margin="0,0,12,12"
                            Padding="14,10"
                            Background="{DynamicResource GameBackground2Brush}"
                            BorderBrush="{DynamicResource GameBorderBrush}"
                            BorderThickness="1"
                            Classes.active="{Binding IsCurrentZone}"
                            CornerRadius="6">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Classes="accent"
                                        FontSize="11"
                                        IsVisible="{Binding IsCurrentZone}"
                                        Text="★" />
                                </StackPanel>
                                <Border
                                    Padding="5,2"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource GameBackground4Brush}"
                                    CornerRadius="3">
                                    <TextBlock
                                        Classes="caption"
                                        FontSize="10"
                                        Text="{Binding Type}" />
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontSize="11">
                                        <Run Text="Lv." /><Run Text="{Binding MinLevel}" />
                                    </TextBlock>
                                    <TextBlock
                                        Classes="muted"
                                        FontSize="10"
                                        IsVisible="{Binding HasInn}"
                                        Text="Inn" />
                                    <TextBlock
                                        Classes="muted"
                                        FontSize="10"
                                        IsVisible="{Binding HasMerchant}"
                                        Text="Shop" />
                                </StackPanel>
                                <Button
                                    Height="26"
                                    Classes="ghost"
                                    Command="{Binding TravelCommand}"
                                    Content="Travel here"
                                    FontSize="11"
                                    IsVisible="{Binding CanTravel}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>
