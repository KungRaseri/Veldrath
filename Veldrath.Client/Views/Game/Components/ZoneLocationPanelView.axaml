<UserControl
    x:Class="Veldrath.Client.Views.ZoneLocationPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Veldrath.Client.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="600"
    x:DataType="vm:ZoneLocationPanelViewModel"
    mc:Ignorable="d">

    <Border Background="{DynamicResource GameBackground0Brush}" Padding="16">
        <ScrollViewer x:Name="RootScroll">
            <StackPanel Spacing="12">
                <!-- Location header -->
                <TextBlock
                    Text="{Binding ZoneName}"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="{DynamicResource GameAccentBrush}"
                    TextWrapping="Wrap" />

                <!-- Description -->
                <Border
                    Padding="12"
                    CornerRadius="6"
                    Background="{DynamicResource GamePanelBackdropBrush}">
                    <TextBlock
                        Text="{Binding LocationDescription}"
                        FontSize="15"
                        Foreground="{DynamicResource GameForegroundBrush}"
                        TextWrapping="Wrap" />
                </Border>

                <!-- Exits section -->
                <Border
                    Padding="12"
                    CornerRadius="6"
                    Background="{DynamicResource GamePanelBackdropBrush}"
                    IsVisible="{Binding HasExits}">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Exits"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource GameSubtleBrush}" />
                        <ItemsControl ItemsSource="{Binding Exits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Content="{Binding DisplayLabel}"
                                        Command="{Binding $parent[ScrollViewer].DataContext.MoveToExitCommand}"
                                        CommandParameter="{Binding .}"
                                        HorizontalAlignment="Stretch"
                                        Padding="8,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Entities section -->
                <Border
                    Padding="12"
                    CornerRadius="6"
                    Background="{DynamicResource GamePanelBackdropBrush}"
                    IsVisible="{Binding HasEntities}">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Entities"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource GameSubtleBrush}" />
                        <ItemsControl ItemsSource="{Binding Entities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LocationEntityItem">
                                    <Border
                                        Padding="8,6"
                                        CornerRadius="4"
                                        Background="{DynamicResource GameBackground1Brush}">
                                        <StackPanel Spacing="6">
                                            <!-- Entity name and type -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock
                                                    Text="{Binding Name}"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource GameForegroundBrush}" />
                                                <TextBlock
                                                    Text="{Binding EntityType, StringFormat='({0})'}"
                                                    Foreground="{DynamicResource GameSubtleBrush}" />
                                            </StackPanel>
                                            <!-- Contextual action buttons -->
                                            <ItemsControl ItemsSource="{Binding Actions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:EntityAction">
                                                        <Button
                                                            Content="{Binding DisplayLabel}"
                                                            Command="{Binding Command}"
                                                            CommandParameter="{Binding $parent[Border].DataContext}"
                                                            Padding="6,2"
                                                            FontSize="12"
                                                            MinWidth="56" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Points of Interest / Zone Locations section -->
                <Border
                    Padding="12"
                    CornerRadius="6"
                    Background="{DynamicResource GamePanelBackdropBrush}"
                    IsVisible="{Binding HasZoneLocations}">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Points of Interest"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource GameSubtleBrush}" />
                        <ItemsControl ItemsSource="{Binding ZoneLocations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ZoneLocationItemViewModel">
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        Padding="8,4"
                                        IsEnabled="{Binding CanNavigate}"
                                        Command="{Binding $parent[ScrollViewer].DataContext.NavigateToLocationCommand}"
                                        CommandParameter="{Binding .}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                Text="{Binding DisplayName}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource GameForegroundBrush}" />
                                            <TextBlock
                                                Text="{Binding TypeKey, StringFormat='({0})'}"
                                                Foreground="{DynamicResource GameSubtleBrush}" />
                                            <TextBlock
                                                Text="{Binding MinLevel, StringFormat='Lv {0}'}"
                                                Foreground="{DynamicResource GameAccentBrush}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Loading indicator: shown while data is being loaded -->
                <Border
                    Padding="12"
                    CornerRadius="6"
                    Background="{DynamicResource GamePanelBackdropBrush}"
                    IsVisible="{Binding HasNoData}">
                    <TextBlock
                        Text="{Binding LoadingStatus}"
                        FontSize="13"
                        Foreground="{DynamicResource GameSubtleBrush}"
                        TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>

</UserControl>
