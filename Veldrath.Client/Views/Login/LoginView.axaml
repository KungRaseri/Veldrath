<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Veldrath.Client.ViewModels"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Veldrath.Client.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Grid RowDefinitions="*,Auto,*">

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Width="360"
                    Spacing="12">

            <TextBlock Text="Welcome Back"
                       Classes="title-large"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24" />

            <!-- OAuth providers -->
            <Button Classes="accent"
                    Command="{Binding LoginExternalCommand}"
                    CommandParameter="discord"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="44"
                    FontSize="16">
                Sign in with Discord
            </Button>

            <Button Classes="ghost"
                    Command="{Binding LoginExternalCommand}"
                    CommandParameter="google"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="44"
                    FontSize="16">
                Sign in with Google
            </Button>

            <Button Classes="ghost"
                    Command="{Binding LoginExternalCommand}"
                    CommandParameter="microsoft"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="44"
                    FontSize="16">
                Sign in with Microsoft
            </Button>

            <!-- Divider -->
            <Grid ColumnDefinitions="*,Auto,*" Margin="0,8,0,8">
                <Separator Grid.Column="0" VerticalAlignment="Center" Opacity="0.3" />
                <TextBlock Grid.Column="1"
                           Text="or sign in with email"
                           Classes="muted"
                           FontSize="12"
                           Margin="8,0" />
                <Separator Grid.Column="2" VerticalAlignment="Center" Opacity="0.3" />
            </Grid>

            <!-- Email -->
            <TextBlock Text="Email" Classes="muted" />
            <TextBox Text="{Binding Email}"
                     Watermark="Enter your email"
                     Height="40" />

            <!-- Password -->
            <TextBlock Text="Password" Classes="muted" Margin="0,4,0,0" />
            <TextBox Text="{Binding Password}"
                     Watermark="Enter password"
                     PasswordChar="•"
                     Height="40" />

            <!-- Forgot password link -->
            <Button Classes="hyperlink"
                    Command="{Binding ForgotPasswordCommand}"
                    HorizontalAlignment="Right"
                    Padding="0"
                    Margin="0,2,0,0"
                    FontSize="12">
                Forgot your password?
            </Button>

            <!-- Remember my email -->
            <CheckBox Content="Remember my email"
                      IsChecked="{Binding RememberEmail}"
                      Margin="0,4,0,0" />

            <!-- Error feedback -->
            <ui:InfoBar Title="Login Failed"
                        Message="{Binding ErrorMessage}"
                        Severity="Error"
                        IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        IsClosable="False"
                        Margin="0,4,0,0" />

            <Expander Header="Details"
                      IsVisible="{Binding ErrorDetails, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      IsExpanded="False"
                      Margin="0,-4,0,0">
                <TextBlock Text="{Binding ErrorDetails}"
                           Classes="muted"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </Expander>

            <!-- Login -->
            <Button Content="Login"
                    Classes="accent"
                    Command="{Binding LoginCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="44"
                    FontSize="16"
                    Margin="0,4,0,0" />

            <!-- Back -->
            <Button Content="Back"
                    Classes="ghost"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="40"
                    FontSize="14" />

            <!-- Busy indicator -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsBusy}"
                         Height="4" />

        </StackPanel>

    </Grid>

</UserControl>
