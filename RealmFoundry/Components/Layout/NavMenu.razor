@implements IDisposable
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav
@inject IConfiguration Config

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All">Home</MudNavLink>
    <MudNavLink Href="content">Content</MudNavLink>
    <MudNavLink Href="languages">Languages</MudNavLink>
    <MudNavLink Href="submissions">Submissions</MudNavLink>

    <MudDivider Class="mud-my-2" />

    @if (AuthState.IsLoggedIn)
    {
        @if (AuthState.HasPermission("manage_content"))
        {
            <MudNavLink Href="editorial/patch-notes">Patch Notes</MudNavLink>
            <MudNavLink Href="editorial/lore">Lore</MudNavLink>
            <MudNavLink Href="editorial/announcements">Announcements</MudNavLink>
        }
        @if (AuthState.IsAdmin)
        {
            <MudNavLink Href="admin">Admin</MudNavLink>
        }
        @if (AuthState.IsModerator && !AuthState.IsAdmin)
        {
            <MudNavLink Href="mod">Moderation</MudNavLink>
        }
        @if (_unreadCount > 0)
        {
            <MudNavLink Href="notifications">
                Notifications
                <MudChip T="int" Size="Size.Small" Color="Color.Error" Class="mud-ml-2">@_unreadCount</MudChip>
            </MudNavLink>
        }
        <MudNavLink Href="@_accountProfileUrl">My Account</MudNavLink>

        <MudDivider Class="mud-my-2" />
        <MudButton Variant="Variant.Text"
                   FullWidth="true"
                   Color="Color.Error"
                   OnClick="LogOutAsync"
                   Class="mud-text-left">
            Sign out
        </MudButton>
    }
    else
    {
        <MudNavLink Href="login">Sign in</MudNavLink>
    }
</MudNavMenu>

@code {
    private int     _unreadCount;
    private string  _accountProfileUrl = "#";

    protected override void OnInitialized()
    {
        AuthState.OnChange += Refresh;
        var webBase = Config["Web:BaseUrl"]?.TrimEnd('/') ?? "";
        _accountProfileUrl = $"{webBase}/account/profile";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        StateHasChanged();
        if (AuthState.IsLoggedIn)
            await LoadNotificationCountAsync();
    }

    public void Dispose()
        => AuthState.OnChange -= Refresh;

    private void Refresh() => InvokeAsync(async () =>
    {
        StateHasChanged();
        if (AuthState.IsLoggedIn)
            await LoadNotificationCountAsync();
        else
            _unreadCount = 0;
    });

    private async Task LoadNotificationCountAsync()
    {
        try
        {
            var notifications = await Api.GetNotificationsAsync();
            _unreadCount = notifications.Count(n => !n.IsRead);
        }
        catch
        {
            _unreadCount = 0;
        }
        StateHasChanged();
    }

    private void LogOutAsync()
    {
        _unreadCount = 0;
        Nav.NavigateTo("/auth/sign-out", forceLoad: true);
    }
}
