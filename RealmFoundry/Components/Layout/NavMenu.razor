@implements IDisposable
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav
@inject IConfiguration Config

<nav class="nav-links">
    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
        Home
    </NavLink>
    <NavLink class="nav-item" href="content">
        Content
    </NavLink>
    <NavLink class="nav-item" href="languages">
        Languages
    </NavLink>
    <NavLink class="nav-item" href="submissions">
        Submissions
    </NavLink>

    <div class="nav-spacer"></div>

    @if (AuthState.IsLoggedIn)
    {
        @if (AuthState.HasPermission("manage_content"))
        {
            <NavLink class="nav-item" href="editorial/patch-notes">Patch Notes</NavLink>
            <NavLink class="nav-item" href="editorial/lore">Lore</NavLink>
            <NavLink class="nav-item" href="editorial/announcements">Announcements</NavLink>
        }
        @if (AuthState.IsAdmin)
        {
            <NavLink class="nav-item" href="admin">Admin</NavLink>
        }
        @if (AuthState.IsModerator && !AuthState.IsAdmin)
        {
            <NavLink class="nav-item" href="mod">Moderation</NavLink>
        }
        @if (_unreadCount > 0)
        {
            <NavLink class="nav-item nav-bell" href="notifications">
                🔔 <span class="badge badge-red">@_unreadCount</span>
            </NavLink>
        }
        <button class="nav-item nav-logout" @onclick="LogOutAsync">Sign out</button>
        <a class="nav-item nav-account" href="@_accountProfileUrl">My Account</a>
    }
    else
    {
        <NavLink class="nav-item" href="login">Sign in</NavLink>
    }
</nav>

@code {
    private int     _unreadCount;
    private string  _accountProfileUrl = "#";

    protected override void OnInitialized()
    {
        AuthState.OnChange += Refresh;
        var webBase = Config["Web:BaseUrl"]?.TrimEnd('/') ?? "";
        _accountProfileUrl = $"{webBase}/account/profile";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        // Force a re-render immediately so the nav shows the correct login state
        // regardless of whether the notification fetch below succeeds or fails.
        StateHasChanged();
        if (AuthState.IsLoggedIn)
            await LoadNotificationCountAsync();
    }

    public void Dispose()
        => AuthState.OnChange -= Refresh;

    private void Refresh() => InvokeAsync(async () =>
    {
        // Always update the nav first, then try to load the notification count.
        StateHasChanged();
        if (AuthState.IsLoggedIn)
            await LoadNotificationCountAsync();
        else
            _unreadCount = 0;
    });

    private async Task LoadNotificationCountAsync()
    {
        try
        {
            var notifications = await Api.GetNotificationsAsync();
            _unreadCount = notifications.Count(n => !n.IsRead);
        }
        catch
        {
            _unreadCount = 0;
        }
        StateHasChanged();
    }

    private void LogOutAsync()
    {
        // Navigate to the server-side /auth/sign-out endpoint with forceLoad=true.
        // The endpoint revokes the refresh token, deletes the rt cookie, then redirects
        // to /.  forceLoad tears down the Blazor circuit so no stale auth state lingers.
        _unreadCount = 0;
        Nav.NavigateTo("/auth/sign-out", forceLoad: true);
    }
}
