@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav

<div class="layout">
    <nav class="sidebar">
        <div class="brand">
            <a href="">RealmFoundry</a>
        </div>
        <NavMenu />
    </nav>
    <main class="content">
        <div class="top-bar">
            <span>Community Content for Veldrath</span>
        </div>
        <article class="page-body">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        Nav.LocationChanged += OnLocationChanged;
        await TryProactiveRefreshAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(TryProactiveRefreshAsync);

    private async Task TryProactiveRefreshAsync()
    {
        if (AuthState.IsLoggedIn && AuthState.TokenExpiresSoon)
            await AuthState.TryRefreshAsync();
    }

    /// <inheritdoc />
    public void Dispose()
        => Nav.LocationChanged -= OnLocationChanged;
}
