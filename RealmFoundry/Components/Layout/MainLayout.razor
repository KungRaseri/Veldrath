@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject RealmFoundryApiClient Api

<div class="layout">
    <nav class="sidebar">
        <div class="brand">
            <a href="">RealmFoundry</a>
        </div>
        <NavMenu />
    </nav>
    <main class="content">
        <div class="top-bar">
            <span>Community Content for Veldrath</span>
        </div>
        <article class="page-body">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private PersistingComponentStateSubscription _subscription;

    protected override async Task OnInitializedAsync()
    {
        var ctx = HttpContextAccessor.HttpContext;

        if (ctx is not null)
        {
            // SSR prerender pass — HttpContext is available.
            // Read the rt cookie directly from the request (same technique used by the
            // original PersistingAuthState, which the logs proved DID read the cookie
            // and successfully call the server). Use RenewJwtAsync so we get a fresh JWT
            // without rotating or writing back the refresh token — no cookie writes means
            // no "headers are read-only" exception after the await.
            // RegisterOnPersisting works here because MainLayout is inside
            // <Routes @rendermode="InteractiveServer">, making it part of the interactive
            // subtree rather than a sibling SSR-only component.
            var rt = ctx.Request.Cookies["rt"];
            if (!string.IsNullOrEmpty(rt))
            {
                var renewed = await Api.RenewJwtAsync(rt);
                if (renewed is not null)
                {
                    // Re-use the same rt value — the refresh token is unchanged.
                    var authResponse = new AuthResponse(
                        renewed.AccessToken, rt, renewed.AccessTokenExpiry,
                        renewed.AccountId, renewed.Username, renewed.Roles,
                        renewed.Permissions, renewed.IsCurator, renewed.SessionId);

                    await AuthState.SetTokensAsync(authResponse);

                    _subscription = ApplicationState.RegisterOnPersisting(() =>
                    {
                        ApplicationState.PersistAsJson("auth-state", authResponse);
                        return Task.CompletedTask;
                    });
                }
            }
            return;
        }

        // Circuit pass — HttpContext is null (WebSocket scope).
        // Restore from the JSON that was embedded in the prerendered HTML above.
        if (ApplicationState.TryTakeFromJson<AuthResponse>("auth-state", out var saved) && saved is not null)
            await AuthState.SetTokensAsync(saved);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(TryProactiveRefreshAsync);

    private async Task TryProactiveRefreshAsync()
    {
        if (AuthState.IsLoggedIn && AuthState.TokenExpiresSoon)
            await AuthState.TryRefreshAsync();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _subscription.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
    }
}
