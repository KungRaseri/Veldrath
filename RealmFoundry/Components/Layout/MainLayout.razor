@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject PersistentComponentState ApplicationState

<div class="layout">
    <nav class="sidebar">
        <div class="brand">
            <a href="">RealmFoundry</a>
        </div>
        <NavMenu />
    </nav>
    <main class="content">
        <div class="top-bar">
            <span>Community Content for Veldrath</span>
        </div>
        <article class="page-body">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    protected override void OnInitialized()
    {
        // Restore auth state from the JSON embedded in the prerendered HTML by
        // PersistingAuthState.RegisterOnPersisting. MainLayout is the parent of every
        // page component in the single InteractiveServer tree rooted at <Routes>, so
        // this is guaranteed to run before any page's OnInitializedAsync.
        // SetTokensAsync returns Task.CompletedTask so the discard is safe.
        if (ApplicationState.TryTakeFromJson<AuthResponse>("auth-state", out var saved) && saved is not null)
            _ = AuthState.SetTokensAsync(saved);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(TryProactiveRefreshAsync);

    private async Task TryProactiveRefreshAsync()
    {
        if (AuthState.IsLoggedIn && AuthState.TokenExpiresSoon)
            await AuthState.TryRefreshAsync();
    }

    /// <inheritdoc />
    public void Dispose()
        => Nav.LocationChanged -= OnLocationChanged;
}
