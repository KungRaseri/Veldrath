@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject RealmFoundryApiClient Api

<MudLayout>
    <MudAppBar Elevation="0" Class="mud-appbar-custom">
        <MudText Typo="Typo.h6" Style="font-family: var(--vds-font-heading); color: var(--vds-seal-light);">
            RealmFoundry</MudText>
            <MudSpacer />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Community Content for Veldrath</MudText>
        </MudAppBar>
        <div class="my-2"></div>
        <MudDrawer Open="true" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always" Elevation="0">
            <NavMenu />
        </MudDrawer>
        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <span class="dismiss">&#x2715;</span>
    </div>

@code {
    private PersistingComponentStateSubscription _subscription;

    protected override void OnInitialized()
        => AuthState.OnChange += OnAuthStateChanged;

    private void OnAuthStateChanged()
        => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        var ctx = HttpContextAccessor.HttpContext;

        if (ctx is not null)
        {
            var rt = ctx.Request.Cookies["rt"];
            if (!string.IsNullOrEmpty(rt))
            {
                try
                {
                    var renewed = await Api.RenewJwtAsync(rt);
                    if (renewed is not null)
                    {
                        var authResponse = new AuthResponse(
                            renewed.AccessToken, rt, renewed.AccessTokenExpiry,
                            renewed.AccountId, renewed.Username, renewed.Roles,
                            renewed.Permissions, renewed.IsCurator, renewed.SessionId);

                        await AuthState.SetTokensAsync(authResponse);

                        _subscription = ApplicationState.RegisterOnPersisting(() =>
                        {
                            ApplicationState.PersistAsJson("auth-state", authResponse);
                            return Task.CompletedTask;
                        });
                    }
                }
                catch
                {
                    // Server unreachable or network error during prerendering —
                    // proceed as unauthenticated so the circuit can still establish.
                }
            }

            if (!AuthState.IsAuthReady)
                AuthState.MarkReady();

            return;
        }

        if (ApplicationState.TryTakeFromJson<AuthResponse>("auth-state", out var saved) && saved is not null)
            await AuthState.SetTokensAsync(saved);

        if (!AuthState.IsAuthReady)
            AuthState.MarkReady();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(TryProactiveRefreshAsync);

    private async Task TryProactiveRefreshAsync()
    {
        if (AuthState.IsLoggedIn && AuthState.TokenExpiresSoon)
            await AuthState.TryRefreshAsync();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _subscription.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
    }
}
