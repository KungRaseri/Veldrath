@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState

<div class="layout">
    <nav class="sidebar">
        <div class="brand">
            <a href="">RealmFoundry</a>
        </div>
        <NavMenu />
    </nav>
    <main class="content">
        <div class="top-bar">
            <span>Community Content for Veldrath</span>
        </div>
        <article class="page-body">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private PersistingComponentStateSubscription _subscription;

    protected override void OnInitialized()
    {
        // Distinguish SSR-prerender pass (HttpContext is present) from circuit pass (null).
        //
        // SSR prerender: the cookie-refresh middleware has already stored the refreshed
        // AuthResponse in HttpContext.Items["auth-state"]. Apply it to the SSR-scoped
        // AuthStateService so the prerendered HTML renders logged-in, and register it
        // for persistence so the circuit can restore it via TryTakeFromJson.
        // RegisterOnPersisting is only effective inside an interactive component subtree
        // (this layout is inside <Routes @rendermode="InteractiveServer">), which is why
        // PersistingAuthState's previous call — from an SSR-only sibling — was a no-op.
        //
        // Circuit pass: HttpContext is null (WebSocket scope). Read the persisted JSON
        // that was embedded during SSR prerender and apply it before any page component
        // has a chance to check AuthState.IsLoggedIn.
        var ctx = HttpContextAccessor.HttpContext;
        if (ctx?.Items["auth-state"] is AuthResponse ssrAuth)
        {
            _ = AuthState.SetTokensAsync(ssrAuth);
            _subscription = ApplicationState.RegisterOnPersisting(() =>
            {
                ApplicationState.PersistAsJson("auth-state", ssrAuth);
                return Task.CompletedTask;
            });
            return;
        }

        if (ApplicationState.TryTakeFromJson<AuthResponse>("auth-state", out var saved) && saved is not null)
            _ = AuthState.SetTokensAsync(saved);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(TryProactiveRefreshAsync);

    private async Task TryProactiveRefreshAsync()
    {
        if (AuthState.IsLoggedIn && AuthState.TokenExpiresSoon)
            await AuthState.TryRefreshAsync();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _subscription.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
    }
}
