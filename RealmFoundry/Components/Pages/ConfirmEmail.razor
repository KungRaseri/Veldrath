@page "/confirm-email"
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav
@inject AuthStateService AuthState

<PageTitle>Confirm Email — RealmFoundry</PageTitle>

@if (_loading)
{
    <MudText Typo="Typo.body1">Confirming your email address…</MudText>
}
else if (_done)
{
    <MudAlert Severity="Severity.Success" Class="mt-8">
        Your email has been confirmed! <MudLink Href="/">Go to RealmFoundry</MudLink>
    </MudAlert>
}
else
{
    <MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="my-8">
        <MudPaper Elevation="0" Outlined="true" Class="pa-8">
            <MudAlert Severity="Severity.Error" Class="mb-4">@(_error ?? "Confirmation failed. The link may have expired.")</MudAlert>

            @if (AuthState.IsLoggedIn)
            {
                @if (_resendSent)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-4">A new confirmation email has been sent. Check your inbox.</MudAlert>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ResendAsync"
                               Disabled="@_resending">
                        @(_resending ? "Sending…" : "Resend confirmation email")
                    </MudButton>
                    @if (_resendError is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error" Class="mt-2">@_resendError</MudText>
                    }
                }
            }

            <MudLink Href="/login" Class="mt-4 d-block">Back to sign in</MudLink>
        </MudPaper>
    </MudContainer>
}

@code {
    [SupplyParameterFromQuery(Name = "userId")] private string? UserId { get; set; }
    [SupplyParameterFromQuery(Name = "token")]  private string? Token  { get; set; }

    private bool    _loading     = true;
    private bool    _done;
    private string? _error;

    private bool    _resending;
    private bool    _resendSent;
    private string? _resendError;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            _error   = "Invalid confirmation link — userId or token is missing.";
            _loading = false;
            return;
        }

        var (ok, error) = await Api.ConfirmEmailAsync(UserId, Token);
        _done    = ok;
        _error   = error;
        _loading = false;
    }

    private async Task ResendAsync()
    {
        _resending   = true;
        _resendError = null;
        try
        {
            var (ok, error) = await Api.ResendEmailConfirmationAsync();
            if (ok)
                _resendSent = true;
            else
                _resendError = error ?? "Could not resend confirmation email. Please try again.";
        }
        finally
        {
            _resending = false;
        }
    }
}
