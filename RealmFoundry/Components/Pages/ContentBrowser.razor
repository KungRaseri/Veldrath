@page "/content"
@using Veldrath.Contracts.Content

<PageTitle>Content — RealmFoundry</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Base Content</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
    Browse all canonical game content authored in RealmForge.
    Select a content type below to explore the full catalog.
</MudText>

<MudGrid Spacing="4">
    @foreach (var schema in ContentSchemaRegistry.All.Values.OrderBy(s => s.DisplayLabel))
    {
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="mb-1">@schema.DisplayLabel</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@schema.Description</MudText>
                <MudButton Variant="Variant.Filled" Size="Size.Small" Href="@($"/content/{schema.ContentType}")">Browse</MudButton>
            </MudPaper>
        </MudItem>
    }
</MudGrid>
