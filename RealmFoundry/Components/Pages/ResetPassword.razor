@page "/reset-password"
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password — RealmFoundry</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="my-8">
    <MudPaper Elevation="0" Outlined="true" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">Reset Password</MudText>

        @if (_done)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                Your password has been reset.
            </MudAlert>
            <MudLink Href="/login">Sign in</MudLink>
        }
        else if (_tokenMissing)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                This reset link is incomplete or has already been used. <MudLink Href="/forgot-password">Request a new one</MudLink>.
            </MudAlert>
        }
        else
        {
            <MudTextField @bind-Value="_password"
                          Label="New password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Margin="Margin.Dense"
                          Class="mb-3" />

            <MudTextField @bind-Value="_confirm"
                          Label="Confirm new password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Margin="Margin.Dense"
                          Class="mb-3" />

            @if (_error is not null)
            {
                <MudText Typo="Typo.body2" Color="Color.Error" Class="mb-3">@_error</MudText>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitAsync"
                       Disabled="@_submitting">
                @(_submitting ? "Resetting…" : "Set new password")
            </MudButton>
        }
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery] private string? Email { get; set; }
    [SupplyParameterFromQuery] private string? Token { get; set; }

    private string  _password  = string.Empty;
    private string  _confirm   = string.Empty;
    private bool    _submitting;
    private bool    _done;
    private bool    _tokenMissing;
    private string? _error;

    protected override void OnInitialized()
    {
        _tokenMissing = string.IsNullOrWhiteSpace(Token) || string.IsNullOrWhiteSpace(Email);
    }

    private async Task SubmitAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please enter a new password.";
            return;
        }

        if (_password != _confirm)
        {
            _error = "Passwords do not match.";
            return;
        }

        _submitting = true;
        try
        {
            var (ok, error) = await Api.ResetPasswordAsync(Email!, Token!, _password);
            if (ok)
                _done = true;
            else
                _error = error ?? "Reset failed. The link may have expired.";
        }
        finally
        {
            _submitting = false;
        }
    }
}
