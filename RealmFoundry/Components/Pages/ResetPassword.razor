@page "/reset-password"
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password — RealmFoundry</PageTitle>

<div class="auth-card">
    <h1>Reset Password</h1>

    @if (_done)
    {
        <p class="success">Your password has been reset. <a href="/login">Sign in</a></p>
    }
    else if (_tokenMissing)
    {
        <p class="error">This reset link is incomplete or has already been used. <a href="/forgot-password">Request a new one</a>.</p>
    }
    else
    {
        <label class="field-label">New password</label>
        <input type="password" class="field-input" @bind="_password" />

        <label class="field-label" style="margin-top:.75rem">Confirm new password</label>
        <input type="password" class="field-input" @bind="_confirm" />

        @if (_error is not null)
        {
            <p class="error">@_error</p>
        }

        <button class="btn" @onclick="SubmitAsync" disabled="@_submitting" style="margin-top:.75rem">
            @(_submitting ? "Resetting…" : "Set new password")
        </button>
    }
</div>

<style>
    .auth-card { max-width: 420px; margin: 4rem auto; padding: 2rem; border: 1px solid var(--border, #333); border-radius: 8px; }
    .field-label { display: block; font-size: .85rem; color: var(--muted, #888); margin-bottom: .35rem; }
    .field-input { width: 100%; padding: .4rem .6rem; border-radius: 4px;
        border: 1px solid var(--border, #333); background: var(--input-bg, #111);
        color: inherit; font-size: .95rem; box-sizing: border-box; }
    .success { color: #4caf50; font-size: .95rem; }
    .error { color: #f44336; font-size: .9rem; margin-top: .5rem; }
</style>

@code {
    [SupplyParameterFromQuery] private string? Email { get; set; }
    [SupplyParameterFromQuery] private string? Token { get; set; }

    private string  _password  = string.Empty;
    private string  _confirm   = string.Empty;
    private bool    _submitting;
    private bool    _done;
    private bool    _tokenMissing;
    private string? _error;

    protected override void OnInitialized()
    {
        _tokenMissing = string.IsNullOrWhiteSpace(Token) || string.IsNullOrWhiteSpace(Email);
    }

    private async Task SubmitAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please enter a new password.";
            return;
        }

        if (_password != _confirm)
        {
            _error = "Passwords do not match.";
            return;
        }

        _submitting = true;
        try
        {
            var (ok, error) = await Api.ResetPasswordAsync(Email!, Token!, _password);
            if (ok)
                _done = true;
            else
                _error = error ?? "Reset failed. The link may have expired.";
        }
        finally
        {
            _submitting = false;
        }
    }
}
