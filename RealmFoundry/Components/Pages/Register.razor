@page "/register"
@implements IDisposable
@inject NavigationManager Nav
@inject IConfiguration Config
@inject RealmFoundryApiClient Api
@inject AuthStateService AuthState

<PageTitle>Create Account — RealmFoundry</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="my-8">
    <MudPaper Elevation="0" Outlined="true" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">Create an Account</MudText>

        @if (_registered)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                <strong>Welcome!</strong> Your account has been created. Please check your email to confirm your address before signing in.
            </MudAlert>
            <MudLink Href="/login">Back to sign in</MudLink>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Register with your email to access RealmFoundry, or use a connected provider below.
            </MudText>

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            <MudForm>
                <MudTextField @bind-Value="_email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField @bind-Value="_username"
                              Label="Username"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField @bind-Value="_password"
                              Label="Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField @bind-Value="_confirmPassword"
                              Label="Confirm Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="DoRegisterAsync"
                           Disabled="@_submitting"
                           Class="mt-2">
                    @(_submitting ? "Creating account…" : "Create account")
                </MudButton>
            </MudForm>

            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-3">
                Already have an account? <MudLink Href="/login">Sign in</MudLink>
            </MudText>

            <div class="d-flex align-items-center gap-3 my-4" style="color: var(--mud-palette-text-secondary); font-size: 0.85rem;">
                <MudDivider Class="flex-1" />
                <span>or register with</span>
                <MudDivider Class="flex-1" />
            </div>

            <MudStack Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Href="@_discordUrl"
                           FullWidth="true"
                           Style="background-color: var(--vds-oauth-discord); color: #fff;">
                    Register with Discord
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Href="@_googleUrl"
                           FullWidth="true"
                           Style="background-color: var(--vds-oauth-google); color: #fff;">
                    Register with Google
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Href="@_msUrl"
                           FullWidth="true"
                           Style="background-color: var(--vds-oauth-microsoft); color: #fff;">
                    Register with Microsoft
                </MudButton>
            </MudStack>
        }
    </MudPaper>
</MudContainer>

@code {
    private string _email = string.Empty;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _submitting;
    private bool _registered;
    private string? _error;

    private string _discordUrl = "#";
    private string _googleUrl = "#";
    private string _msUrl = "#";

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;

        var serverUrl = (Config["Veldrath:PublicServerUrl"] ?? Config["Veldrath:ServerUrl"])?.TrimEnd('/') ?? "";
        var callbackBase = $"{serverUrl}/api/auth/session?redirectTo={Uri.EscapeDataString(Nav.BaseUri.TrimEnd('/') + "/")}";

        _discordUrl = $"{serverUrl}/api/auth/external/discord?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _googleUrl = $"{serverUrl}/api/auth/external/google?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _msUrl = $"{serverUrl}/api/auth/external/microsoft?returnUrl={Uri.EscapeDataString(callbackBase)}";
    }

    private void OnAuthStateChanged()
    {
        if (AuthState.IsAuthReady && AuthState.IsLoggedIn)
            Nav.NavigateTo("/", replace: true);
    }

    public void Dispose() => AuthState.OnChange -= OnAuthStateChanged;

    private async Task DoRegisterAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_username) ||
            string.IsNullOrWhiteSpace(_password) || string.IsNullOrWhiteSpace(_confirmPassword))
            return;

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _submitting = true;
        _error = null;
        try
        {
            var result = await Api.RegisterAsync(_email, _username, _password);
            if (result is not null)
                _registered = true;
            else
                _error = "Registration failed. The email or username may already be in use.";
        }
        catch (Exception)
        {
            _error = "An error occurred during registration. Please try again.";
        }
        finally
        {
            _submitting = false;
        }
    }
}
