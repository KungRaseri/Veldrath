@page "/editorial/announcements/new"
@page "/editorial/announcements/{Id:guid}"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav
@using Veldrath.Contracts.Editorial

<PageTitle>@(_isNew ? "New Announcement" : "Edit Announcement") — Editorial — RealmFoundry</PageTitle>

@if (!AuthState.HasPermission("manage_content"))
{
    <p>Access denied.</p>
}
else if (_loading)
{
    <MudText>Loading…</MudText>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudText Typo="Typo.h3">@(_isNew ? "New Announcement" : "Edit Announcement")</MudText>
        <MudButton Variant="Variant.Outlined" Href="/editorial/announcements">← Back</MudButton>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@(_error ? Severity.Error : Severity.Success)" Class="mud-mb-4">@_message</MudAlert>
    }

    @if (!_isNew)
    {
        <div class="d-flex align-items-center gap-2 mb-4">
            <MudButton Variant="Variant.Filled"
                       Color="@(_status == "Published" ? Color.Warning : Color.Primary)"
                       OnClick="TogglePublishAsync">
                @(_status == "Published" ? "Unpublish" : "Publish")
            </MudButton>
            <MudChip T="string" Size="Size.Small" Color="@(_status == "Published" ? Color.Success : null)">@_status</MudChip>
        </div>
    }

    <MudPaper Elevation="0" Outlined="true" Class="mud-pa-4 mud-mb-4">
        <MudTextField @bind-Value="_title"
                      T="string"
                      Label="Title"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="Scheduled maintenance on Friday…"
                      Class="mud-mb-4" />

        <MudTextField @bind-Value="_body"
                      T="string"
                      Label="Body (plain text, max 1000 chars)"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="6"
                      MaxLength="1000" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary mud-mt-1">@_body.Length / 1000</MudText>
    </MudPaper>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">@(_isNew ? "Create" : "Save Changes")</MudButton>
        <MudButton Variant="Variant.Outlined" Href="/editorial/announcements">Cancel</MudButton>
    </MudStack>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isNew;
    private bool _loading = true;
    private string? _message;
    private bool _error;

    private string _title  = "";
    private string _body   = "";
    private string _status = "Draft";

    protected override async Task OnInitializedAsync()
    {
        _isNew = Id is null;
        if (!_isNew)
        {
            var dto = await Api.GetAnnouncementAsync(Id!.Value);
            if (dto is not null)
            {
                _title  = dto.Title;
                _body   = dto.Body;
                _status = dto.Status;
            }
            else
            {
                _message = "Announcement not found.";
                _error   = true;
            }
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (_isNew)
        {
            var (dto, error) = await Api.CreateAnnouncementAsync(
                new CreateAnnouncementRequest(_title, _body));
            if (dto is not null)
                Nav.NavigateTo($"/editorial/announcements/{dto.Id}");
            else
            {
                _message = $"Create failed: {error}";
                _error   = true;
            }
        }
        else
        {
            var (dto, error) = await Api.UpdateAnnouncementAsync(
                Id!.Value,
                new UpdateAnnouncementRequest(_title, _body, _status));
            if (dto is not null)
            {
                _status  = dto.Status;
                _message = "Saved.";
                _error   = false;
            }
            else
            {
                _message = $"Save failed: {error}";
                _error   = true;
            }
        }
    }

    private async Task TogglePublishAsync()
    {
        var (dto, error) = await Api.PublishAnnouncementAsync(Id!.Value);
        if (dto is not null)
        {
            _status  = dto.Status;
            _message = _status == "Published" ? "Published." : "Unpublished.";
            _error   = false;
        }
        else
        {
            _message = $"Toggle failed: {error}";
            _error   = true;
        }
    }
}
