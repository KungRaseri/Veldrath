@page "/editorial/patch-notes/new"
@page "/editorial/patch-notes/{Id:guid}"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav
@using Veldrath.Contracts.Editorial

<PageTitle>@(_isNew ? "New Patch Note" : "Edit Patch Note") — Editorial — RealmFoundry</PageTitle>

@if (!AuthState.HasPermission("manage_content"))
{
    <p>Access denied.</p>
}
else if (_loading)
{
    <MudText>Loading…</MudText>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudText Typo="Typo.h3">@(_isNew ? "New Patch Note" : "Edit Patch Note")</MudText>
        <MudButton Variant="Variant.Outlined" Href="/editorial/patch-notes">← Back</MudButton>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@(_error ? Severity.Error : Severity.Success)" Class="mb-4">@_message</MudAlert>
    }

    @if (!_isNew)
    {
        <div class="d-flex align-items-center gap-2 mb-4">
            <MudButton Variant="Variant.Filled"
                       Color="@(_status == "Published" ? Color.Warning : Color.Primary)"
                       OnClick="TogglePublishAsync">
                @(_status == "Published" ? "Unpublish" : "Publish")
            </MudButton>
            <MudChip T="string" Size="Size.Small" Color="@(_status == "Published" ? Color.Success : null)">@_status</MudChip>
        </div>
    }

    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
        <div class="d-flex gap-3 mb-4">
            <MudTextField @bind-Value="_slug"
                          T="string"
                          Label="Slug"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Disabled="@(!_isNew)"
                          Placeholder="patch-1-2-0"
                          Style="flex: 1;" />

            <MudTextField @bind-Value="_version"
                          T="string"
                          Label="Version"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Placeholder="1.2.0"
                          Style="flex: 1;" />
        </div>

        <MudTextField @bind-Value="_title"
                      T="string"
                      Label="Title"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="Patch 1.2.0 — Balance Pass"
                      Class="mb-4" />

        <MudTextField @bind-Value="_summary"
                      T="string"
                      Label="Summary"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="Brief description for list views…"
                      Class="mb-4" />

        <MudTextField @bind-Value="_content"
                      T="string"
                      Label="Content (Markdown)"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="20" />
    </MudPaper>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">@(_isNew ? "Create" : "Save Changes")</MudButton>
        <MudButton Variant="Variant.Outlined" Href="/editorial/patch-notes">Cancel</MudButton>
    </MudStack>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isNew;
    private bool _loading = true;
    private string? _message;
    private bool _error;

    private string _slug    = "";
    private string _title   = "";
    private string _content = "";
    private string _summary = "";
    private string _version = "";
    private string _status  = "Draft";

    protected override async Task OnInitializedAsync()
    {
        _isNew = Id is null;
        if (!_isNew)
        {
            var dto = await Api.GetPatchNoteAsync(Id!.Value);
            if (dto is not null)
            {
                _slug    = dto.Slug;
                _title   = dto.Title;
                _content = dto.Content;
                _summary = dto.Summary;
                _version = dto.Version;
                _status  = dto.Status;
            }
            else
            {
                _message = "Patch note not found.";
                _error   = true;
            }
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (_isNew)
        {
            var (dto, error) = await Api.CreatePatchNoteAsync(
                new CreatePatchNoteRequest(_slug, _title, _content, _summary, _version));
            if (dto is not null)
                Nav.NavigateTo($"/editorial/patch-notes/{dto.Id}");
            else
            {
                _message = $"Create failed: {error}";
                _error   = true;
            }
        }
        else
        {
            var (dto, error) = await Api.UpdatePatchNoteAsync(
                Id!.Value,
                new UpdatePatchNoteRequest(_title, _content, _summary, _version, _status));
            if (dto is not null)
            {
                _status  = dto.Status;
                _message = "Saved.";
                _error   = false;
            }
            else
            {
                _message = $"Save failed: {error}";
                _error   = true;
            }
        }
    }

    private async Task TogglePublishAsync()
    {
        var (dto, error) = await Api.PublishPatchNoteAsync(Id!.Value);
        if (dto is not null)
        {
            _status  = dto.Status;
            _message = _status == "Published" ? "Published." : "Unpublished.";
            _error   = false;
        }
        else
        {
            _message = $"Toggle failed: {error}";
            _error   = true;
        }
    }
}
