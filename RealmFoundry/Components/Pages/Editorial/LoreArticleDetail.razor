@page "/editorial/lore/new"
@page "/editorial/lore/{Id:guid}"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav
@using Veldrath.Contracts.Editorial

<PageTitle>@(_isNew ? "New Lore Article" : "Edit Lore Article") — Editorial — RealmFoundry</PageTitle>

@if (!AuthState.HasPermission("manage_content"))
{
    <p>Access denied.</p>
}
else if (_loading)
{
    <MudText>Loading…</MudText>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudText Typo="Typo.h3">@(_isNew ? "New Lore Article" : "Edit Lore Article")</MudText>
        <MudButton Variant="Variant.Outlined" Href="/editorial/lore">← Back</MudButton>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@(_error ? Severity.Error : Severity.Success)" Class="mud-mb-4">@_message</MudAlert>
    }

    @if (!_isNew)
    {
        <div class="d-flex align-items-center gap-2 mb-4">
            <MudButton Variant="Variant.Filled"
                       Color="@(_status == "Published" ? Color.Warning : Color.Primary)"
                       OnClick="TogglePublishAsync">
                @(_status == "Published" ? "Unpublish" : "Publish")
            </MudButton>
            <MudChip T="string" Size="Size.Small" Color="@(_status == "Published" ? Color.Success : null)">@_status</MudChip>
        </div>
    }

    <MudPaper Elevation="0" Outlined="true" Class="mud-pa-4 mud-mb-4">
        <div class="d-flex gap-3 mb-4">
            <MudTextField @bind-Value="_slug"
                          T="string"
                          Label="Slug"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Disabled="@(!_isNew)"
                          Placeholder="the-sunken-empire"
                          Style="flex: 1;" />

            <MudTextField @bind-Value="_category"
                          T="string"
                          Label="Category"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Placeholder="History, Factions, Geography…"
                          Style="flex: 1;" />
        </div>

        <MudTextField @bind-Value="_title"
                      T="string"
                      Label="Title"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="The Sunken Empire"
                      Class="mud-mb-4" />

        <MudTextField @bind-Value="_summary"
                      T="string"
                      Label="Summary"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="Brief description for list views…"
                      Class="mud-mb-4" />

        <MudTextField @bind-Value="_content"
                      T="string"
                      Label="Content (Markdown)"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="20" />
    </MudPaper>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">@(_isNew ? "Create" : "Save Changes")</MudButton>
        <MudButton Variant="Variant.Outlined" Href="/editorial/lore">Cancel</MudButton>
    </MudStack>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isNew;
    private bool _loading = true;
    private string? _message;
    private bool _error;

    private string _slug     = "";
    private string _title    = "";
    private string _content  = "";
    private string _summary  = "";
    private string _category = "";
    private string _status   = "Draft";

    protected override async Task OnInitializedAsync()
    {
        _isNew = Id is null;
        if (!_isNew)
        {
            var dto = await Api.GetLoreArticleAsync(Id!.Value);
            if (dto is not null)
            {
                _slug     = dto.Slug;
                _title    = dto.Title;
                _content  = dto.Content;
                _summary  = dto.Summary;
                _category = dto.Category;
                _status   = dto.Status;
            }
            else
            {
                _message = "Lore article not found.";
                _error   = true;
            }
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (_isNew)
        {
            var (dto, error) = await Api.CreateLoreArticleAsync(
                new CreateLoreArticleRequest(_slug, _title, _content, _summary, _category));
            if (dto is not null)
                Nav.NavigateTo($"/editorial/lore/{dto.Id}");
            else
            {
                _message = $"Create failed: {error}";
                _error   = true;
            }
        }
        else
        {
            var (dto, error) = await Api.UpdateLoreArticleAsync(
                Id!.Value,
                new UpdateLoreArticleRequest(_title, _content, _summary, _category, _status));
            if (dto is not null)
            {
                _status  = dto.Status;
                _message = "Saved.";
                _error   = false;
            }
            else
            {
                _message = $"Save failed: {error}";
                _error   = true;
            }
        }
    }

    private async Task TogglePublishAsync()
    {
        var (dto, error) = await Api.PublishLoreArticleAsync(Id!.Value);
        if (dto is not null)
        {
            _status  = dto.Status;
            _message = _status == "Published" ? "Published." : "Unpublished.";
            _error   = false;
        }
        else
        {
            _message = $"Toggle failed: {error}";
            _error   = true;
        }
    }
}
