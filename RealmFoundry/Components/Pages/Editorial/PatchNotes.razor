@page "/editorial/patch-notes"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav
@using Veldrath.Contracts.Editorial
@using Veldrath.Contracts.Foundry

<PageTitle>Patch Notes — Editorial — RealmFoundry</PageTitle>

@if (!AuthState.HasPermission("manage_content"))
{
    <p>Access denied. The <strong>manage_content</strong> permission is required.</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudText Typo="Typo.h3">Patch Notes</MudText>
        <MudButton Variant="Variant.Filled" Href="/editorial/patch-notes/new">+ New Patch Note</MudButton>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@(_error ? Severity.Error : Severity.Success)" Class="mud-mb-4">@_message</MudAlert>
    }

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_result is null)
    {
        <MudAlert Severity="Severity.Error" Class="mud-mb-4">Failed to load patch notes.</MudAlert>
    }
    else
    {
        <MudTable Items="@_result.Items" Hover="true" Elevation="0" Outlined="true">
            <HeaderContent>
                <MudTh>Title</MudTh>
                <MudTh>Version</MudTh>
                <MudTh>Slug</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Published</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Title</MudTd>
                <MudTd Class="mud-text-secondary">@context.Version</MudTd>
                <MudTd Class="mud-text-secondary">@context.Slug</MudTd>
                <MudTd>
                    @if (context.Status == "Published")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Published</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small">Draft</MudChip>
                    }
                </MudTd>
                <MudTd Class="mud-text-secondary">@(context.PublishedAt?.ToLocalTime().ToString("d") ?? "—")</MudTd>
                <MudTd>
                    <div class="d-flex gap-1">
                        <MudButton Variant="Variant.Filled" Size="Size.Small" Href="@($"/editorial/patch-notes/{context.Id}")">Edit</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="() => DeleteAsync(context.Id, context.Title)">Delete</MudButton>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @if (_result.TotalCount > _result.PageSize)
        {
            <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPage" Disabled="@(_page <= 1)">← Prev</MudButton>
                <MudText Typo="Typo.body2">Page @_page of @((_result.TotalCount + _result.PageSize - 1) / _result.PageSize)</MudText>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPage" Disabled="@(_result.Items.Count < _result.PageSize)">Next →</MudButton>
            </div>
        }
    }
}

@code {
    private PagedResult<PatchNoteSummaryDto>? _result;
    private bool _loading = true;
    private string? _message;
    private bool _error;
    private int _page = 1;

    protected override async Task OnInitializedAsync()
        => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Api.GetAllPatchNotesAsync(_page);
        _loading = false;
    }

    private async Task DeleteAsync(Guid id, string title)
    {
        var (ok, error) = await Api.DeletePatchNoteAsync(id);
        if (ok)
        {
            _message = $"'{title}' deleted.";
            _error   = false;
            await LoadAsync();
        }
        else
        {
            _message = $"Delete failed: {error}";
            _error   = true;
        }
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }
}
