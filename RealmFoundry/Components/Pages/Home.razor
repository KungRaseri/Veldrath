@page "/"

<PageTitle>RealmFoundry — Community Content</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">RealmFoundry</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">Browse and contribute community-created content for Veldrath.</MudText>

<MudGrid Spacing="4">
    <MudItem xs="12" sm="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-6">
            <MudText Typo="Typo.h6" Class="mb-2">Browse</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Explore items and more created by the community.</MudText>
            <MudButton Variant="Variant.Filled" Href="submissions">View Submissions</MudButton>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-6">
            <MudText Typo="Typo.h6" Class="mb-2">Submit</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Propose your own content for inclusion in the game.</MudText>
            <MudButton Variant="Variant.Filled" Href="submissions/new">New Submission</MudButton>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-6">
            <MudText Typo="Typo.h6" Class="mb-2">Vote</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Support the community's best ideas.</MudText>
            <MudButton Variant="Variant.Filled" Href="submissions">Vote Now</MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>
