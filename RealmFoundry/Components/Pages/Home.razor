@page "/"

<PageTitle>RealmFoundry — Community Content</PageTitle>

<h1>RealmFoundry</h1>
<p class="lead">Browse and contribute community-created content for RealmUnbound.</p>

<div class="feature-cards">
    <div class="card">
        <h3>Browse</h3>
        <p>Explore items and more created by the community.</p>
        <a href="submissions" class="btn">View Submissions</a>
    </div>
    <div class="card">
        <h3>Submit</h3>
        <p>Propose your own content for inclusion in the game.</p>
        <a href="submissions/new" class="btn">New Submission</a>
    </div>
    <div class="card">
        <h3>Vote</h3>
        <p>Support the community's best ideas.</p>
        <a href="submissions" class="btn">Vote Now</a>
    </div>
</div>
