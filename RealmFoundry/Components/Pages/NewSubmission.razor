@page "/submissions/new"
@using Veldrath.Contracts.Content
@using System.Text.Json
@using System.Globalization
@inject RealmFoundryApiClient Api
@inject AuthStateService AuthState
@inject NavigationManager Nav

<PageTitle>New Submission — RealmFoundry</PageTitle>

@if (!AuthState.IsAuthReady)
{
    @* Auth check still running — render nothing to avoid flashing "must sign in". *@
}
else if (!AuthState.IsLoggedIn)
{
    <p>You must <a href="/login">sign in</a> to submit content.</p>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
        <MudText Typo="Typo.h4" Class="mb-6">New Submission</MudText>

        <MudSelect @bind-Value="_contentType"
                   @bind-Value:after="OnTypeChanged"
                   T="string"
                   Label="Content Type"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomCenter"
                   Class="mb-4">
            @foreach (var schema in ContentSchemaRegistry.All.Values.OrderBy(s => s.DisplayLabel))
            {
                <MudSelectItem Value="@schema.ContentType">@schema.DisplayLabel</MudSelectItem>
            }
        </MudSelect>
        @if (_schema is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4" Style="margin-top: -0.75rem;">@_schema.Description</MudText>
        }

        <MudTextField @bind-Value="_title"
                      Label="Title"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="Give your submission a short name"
                      MaxLength="200"
                      Class="mb-4" />

        <MudTextField @bind-Value="_description"
                      Label="Description"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="4"
                      Placeholder="Describe what this content adds, its lore context, balance reasoning, etc."
                      HelperText="Markdown, optional"
                      Class="mb-6" />

        @if (_schema is not null)
        {
            foreach (var group in _schema.Groups)
            {
                <MudText Typo="Typo.h6" Class="mb-3">@group.Label</MudText>

                foreach (var field in group.Fields)
                {
                    @if (field.FieldType == ContentFieldType.Boolean)
                    {
                        <MudCheckBox T="bool"
                                     Value="@GetBool(field.Name)"
                                     ValueChanged="@((bool v) => SetBool(field.Name, v))"
                                     Label="@($"{field.Label}{(field.Required ? " *" : "")}")"
                                     Class="mb-3" />
                        if (field.Hint is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: -0.75rem; margin-bottom: 1rem;">@field.Hint</MudText>
                        }
                    }
                    else if (field.FieldType == ContentFieldType.LongText)
                    {
                        <MudTextField Value="@GetString(field.Name)"
                                      ValueChanged="@((string v) => SetString(field.Name, v))"
                                      Label="@($"{field.Label}{(field.Required ? " *" : "")}")"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="4"
                                      Placeholder="@field.Hint"
                                      Class="mb-4" />
                    }
                    else if (field.FieldType == ContentFieldType.EnumString && field.EnumValues is not null)
                    {
                        <MudSelect Value="@GetString(field.Name)"
                                   ValueChanged="@((string v) => SetString(field.Name, v))"
                                   T="string"
                                   Label="@($"{field.Label}{(field.Required ? " *" : "")}")"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   AnchorOrigin="Origin.BottomCenter"
                                   Class="mb-4">
                            @foreach (var v in field.EnumValues.Where(v => v != ""))
                            {
                                <MudSelectItem Value="@v">@v</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (field.FieldType is ContentFieldType.Integer or ContentFieldType.Decimal)
                    {
                        <MudTextField Value="@GetString(field.Name)"
                                      ValueChanged="@((string v) => SetString(field.Name, v))"
                                      Label="@($"{field.Label}{(field.Required ? " *" : "")}")"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      InputType="InputType.Number"
                                      Placeholder="@field.Default"
                                      Class="mb-4" />
                    }
                    else
                    {
                        <MudTextField Value="@GetString(field.Name)"
                                      ValueChanged="@((string v) => SetString(field.Name, v))"
                                      Label="@($"{field.Label}{(field.Required ? " *" : "")}")"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="@(field.FieldType == ContentFieldType.Slug ? "e.g. my-content-slug" : field.Hint ?? "")"
                                      Class="mb-4" />
                    }

                    @if (field.Hint is not null && field.FieldType != ContentFieldType.LongText)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: -0.75rem; margin-bottom: 1rem;">@field.Hint</MudText>
                    }
                }
            }
        }

        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
        }

        <MudStack Row="true" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="@_submitting">
                @(_submitting ? "Submitting…" : "Submit")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Href="/submissions">Cancel</MudButton>
        </MudStack>
    </MudContainer>
}

@code {
    // Pre-populate from /submissions/new?type=weapon&ref=iron-sword (linked from ContentDetail)
    [SupplyParameterFromQuery(Name = "type")] public string? QueryType { get; set; }
    [SupplyParameterFromQuery(Name = "ref")]  public string? QueryRef  { get; set; }

    private string  _contentType = "";
    private string  _title       = "";
    private string  _description = "";
    private bool    _submitting;
    private string? _error;

    private ContentTypeSchema? _schema;

    // Flat key → string value store for all schema fields
    private readonly Dictionary<string, string> _values = new();

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(QueryType) && string.IsNullOrEmpty(_contentType))
        {
            _contentType = QueryType;
            _schema = ContentSchemaRegistry.Get(_contentType);

            // Pre-populate slug from ?ref= so the submitter can base their work on an existing entity
            if (!string.IsNullOrEmpty(QueryRef))
                _values["slug"] = QueryRef + "-variant";
        }
    }

    private void OnTypeChanged()
    {
        _schema = string.IsNullOrEmpty(_contentType)
            ? null
            : ContentSchemaRegistry.Get(_contentType);
        _values.Clear();
    }

    private string? GetString(string key)  => _values.TryGetValue(key, out var v) ? v : null;
    private bool    GetBool(string key)    => _values.TryGetValue(key, out var v) && v == "true";
    private void    SetString(string key, string? v) => _values[key] = v ?? "";
    private void    SetBool(string key, bool v)      => _values[key] = v ? "true" : "false";

    private async Task SubmitAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_contentType)) { _error = "Please select a content type."; return; }
        if (string.IsNullOrWhiteSpace(_title))       { _error = "Title is required.";            return; }

        var payload = BuildPayloadJson();

        _submitting = true;
        var (dto, error) = await Api.CreateSubmissionAsync(
            new(_contentType, _title.Trim(), payload,
                string.IsNullOrWhiteSpace(_description) ? null : _description.Trim()));

        _submitting = false;

        if (dto is not null)
            Nav.NavigateTo($"/submissions/{dto.Id}");
        else
            _error = $"Submission failed: {error}";
    }

    // Build a nested JSON object from the flat dot-path key/value store.
    private string BuildPayloadJson()
    {
        var root = new Dictionary<string, object?>();
        foreach (var (key, rawValue) in _values.Where(kv => !string.IsNullOrWhiteSpace(kv.Value)))
        {
            var parts = key.Split('.', 2);
            if (parts.Length == 1)
            {
                root[parts[0]] = ParseValue(rawValue);
            }
            else
            {
                if (!root.TryGetValue(parts[0], out var node) || node is not Dictionary<string, object?> dict)
                    root[parts[0]] = dict = new Dictionary<string, object?>();
                dict[parts[1]] = ParseValue(rawValue);
            }
        }
        return JsonSerializer.Serialize(root, new JsonSerializerOptions { WriteIndented = true });
    }

    private static object? ParseValue(string s) =>
        s == "true"  ? (object?)true  :
        s == "false" ? (object?)false :
        long.TryParse(s, out var l)                                                  ? l :
        double.TryParse(s, NumberStyles.Float, CultureInfo.InvariantCulture, out var d) ? d :
        (object?)s;
}
