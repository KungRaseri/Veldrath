@page "/admin/roles"
@inject AuthStateService AuthState

<PageTitle>Role Management — Admin — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied.</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudLink Href="/admin">← Back to Admin</MudLink>
    </div>
    <MudText Typo="Typo.h3" Class="mud-mb-2">Role Management</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mud-mb-4">
        Roles are seeded at server startup. The table below shows each role's default
        permission set. To adjust a specific player's roles or per-user permission
        overrides, use <MudLink Href="/admin/users">User Management</MudLink>.
    </MudText>

    <MudGrid Spacing="4">
        @foreach (var role in _roles)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Outlined="true" Class="mud-pa-4">
                    <MudText Typo="Typo.h6" Class="mud-mb-1">@role.Name</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mud-mb-3">@role.Description</MudText>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var p in role.Permissions)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@p</MudChip>
                        }
                        @if (role.Permissions.Length == 0)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">No default permissions.</MudText>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private static readonly RoleInfo[] _roles =
    [
        new("Admin",         "Full system access — all permissions granted.", [
            "ban_players","kick_players","warn_players","view_players","teleport_players",
            "give_items","run_events","manage_content","view_content","manage_roles",
            "manage_users","debug_access","send_announcements","review_submissions"
        ]),
        new("Moderator",     "Player-facing moderation: ban, kick, warn, view players.", [
            "ban_players","kick_players","warn_players","view_players","send_announcements"
        ]),
        new("Curator",       "Community content curation: review and approve/reject Foundry submissions.", [
            "review_submissions","view_content"
        ]),
        new("GameMaster",    "In-game powers: teleport, give items, run events, view players.", [
            "teleport_players","give_items","run_events","view_players","kick_players","send_announcements"
        ]),
        new("Developer",     "Debug and diagnostic access plus content read access.", [
            "debug_access","view_content","view_players"
        ]),
        new("ContentEditor", "Manage and view canonical game content in the database.", [
            "manage_content","view_content"
        ]),
    ];

    private sealed record RoleInfo(string Name, string Description, string[] Permissions);
}
