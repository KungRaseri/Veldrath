@page "/admin/users"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>User Management — Admin — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied.</p>
}
else
{
    <MudText Typo="Typo.h3" Class="mb-4">User Management</MudText>

    <div class="d-flex flex-wrap gap-3 mb-4 align-items-center">
        <MudTextField @bind-Value="_search"
                      T="string"
                      Placeholder="Search username or email…"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Style="min-width: 200px;"
                      OnKeyUp="OnSearchKeyUp" />
        <MudSelect Value="_filterRole"
                   ValueChanged="@(async (string v) => { _filterRole = v; await OnFilterChanged(); })"
                   T="string"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomCenter"
                   Clearable="true"
                   Placeholder="All Roles"
                   Style="min-width: 150px;">
            <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
            <MudSelectItem Value="@("Moderator")">Moderator</MudSelectItem>
            <MudSelectItem Value="@("Player")">Player</MudSelectItem>
        </MudSelect>
        <MudSelect Value="_filterStatus"
                   ValueChanged="@(async (string v) => { _filterStatus = v; await OnFilterChanged(); })"
                   T="string"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomCenter"
                   Clearable="true"
                   Placeholder="All Status"
                   Style="min-width: 150px;">
            <MudSelectItem Value="@("active")">Active</MudSelectItem>
            <MudSelectItem Value="@("banned")">Banned</MudSelectItem>
            <MudSelectItem Value="@("muted")">Muted</MudSelectItem>
        </MudSelect>
        <MudSelect Value="_sort"
                   ValueChanged="@(async (string v) => { _sort = v; await OnFilterChanged(); })"
                   T="string"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomCenter"
                   Clearable="true"
                   Placeholder="Sort: Default"
                   Style="min-width: 150px;">
            <MudSelectItem Value="@("username")">Username</MudSelectItem>
            <MudSelectItem Value="@("lastseen")">Last Seen</MudSelectItem>
            <MudSelectItem Value="@("warncount")">Warn Count</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="LoadUsersAsync">Search</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/admin">← Back</MudButton>
    </div>

    @if (!string.IsNullOrEmpty(_actionMessage))
    {
        <MudAlert Severity="@(_actionError ? Severity.Error : Severity.Success)" Class="mb-4">@_actionMessage</MudAlert>
    }

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_users is null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    }
    else
    {
        <MudTable Items="@_users.Items" Hover="true" Elevation="0" Outlined="true">
            <HeaderContent>
                <MudTh>Username</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Roles</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Warns</MudTh>
                <MudTh>Last Seen</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Username</MudTd>
                <MudTd Class="mud-text-secondary">@context.Email</MudTd>
                <MudTd>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var r in context.Roles)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@r</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd>
                    @if (context.IsBanned)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Banned</MudChip>
                    }
                    else if (context.IsMuted)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Muted</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
                    }
                </MudTd>
                <MudTd Class="@(context.WarnCount > 0 ? "mud-warning-text" : "mud-text-secondary")">
                    <MudText Typo="Typo.body2" Color="@(context.WarnCount > 0 ? Color.Warning : Color.Inherit)">@context.WarnCount</MudText>
                </MudTd>
                <MudTd Class="mud-text-secondary">@(context.LastSeenAt?.ToLocalTime().ToString("g") ?? "Never")</MudTd>
                <MudTd>
                    <div class="d-flex gap-1 flex-wrap">
                        <MudButton Variant="Variant.Filled" Size="Size.Small" Href="@($"/admin/users/{context.Id}")">Manage</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="() => QuickWarnAsync(context.Id, context.Username)">Warn</MudButton>
                        @if (context.IsMuted)
                        {
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="() => QuickUnmuteAsync(context.Id, context.Username)">Unmute</MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="() => QuickMuteAsync(context.Id, context.Username)">Mute</MudButton>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPageAsync" Disabled="@(_page <= 1)">← Prev</MudButton>
            <MudText Typo="Typo.body2">Page @_page of @TotalPages</MudText>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPageAsync" Disabled="@(_page >= TotalPages)">Next →</MudButton>
        </div>
    }
}

@code {
    private string?              _search;
    private string?              _filterRole;
    private string?              _filterStatus;
    private string?              _sort;
    private bool                 _loading;
    private string?              _error;
    private string?              _actionMessage;
    private bool                 _actionError;
    private AdminUserListResponse? _users;
    private int _page     = 1;
    private int _pageSize = 25;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_users?.Total ?? 0 / (double)_pageSize));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        if (AuthState.IsAdmin)
            await LoadUsersAsync();
        StateHasChanged();
    }

    private async Task LoadUsersAsync()
    {
        _loading       = true;
        _error         = null;
        _actionMessage = null;
        StateHasChanged();

        _users = await Api.GetUsersAsync(_search, _filterRole, _filterStatus, _sort, _page, _pageSize);
        if (_users is null) _error = "Failed to load users.";

        _loading = false;
        StateHasChanged();
    }

    private async Task OnFilterChanged()
    {
        _page = 1;
        await LoadUsersAsync();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadUsersAsync(); }
    }

    private async Task PrevPageAsync() { if (_page > 1) { _page--; await LoadUsersAsync(); } }
    private async Task NextPageAsync() { _page++; await LoadUsersAsync(); }

    private async Task QuickWarnAsync(Guid accountId, string username)
    {
        var (ok, err) = await Api.WarnPlayerAsync(new WarnPlayerRequest(accountId, "Warned via user list."));
        SetActionResult(ok, err, $"{username} warned.");
        if (ok) await LoadUsersAsync();
    }

    private async Task QuickMuteAsync(Guid accountId, string username)
    {
        var (ok, err) = await Api.MutePlayerAsync(new MutePlayerRequest(accountId, "Muted via user list.", null));
        SetActionResult(ok, err, $"{username} muted.");
        if (ok) await LoadUsersAsync();
    }

    private async Task QuickUnmuteAsync(Guid accountId, string username)
    {
        var (ok, err) = await Api.UnmutePlayerAsync(accountId);
        SetActionResult(ok, err, $"{username} unmuted.");
        if (ok) await LoadUsersAsync();
    }

    private void SetActionResult(bool ok, string? err, string successMsg)
    {
        _actionError   = !ok;
        _actionMessage = ok ? successMsg : (err ?? "Action failed.");
        StateHasChanged();
    }
}
