@page "/admin/audit"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api

<PageTitle>Audit Log — Admin — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied.</p>
}
else
{
    <MudText Typo="Typo.h3" Class="mb-4">Audit Log</MudText>

    <div class="d-flex flex-wrap gap-3 mb-4 align-items-center">
        <MudTextField @bind-Value="_targetIdRaw"
                      T="string"
                      Placeholder="Target Account ID (GUID)…"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Style="width: 260px;" />
        <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="ApplyFilterAsync">Filter</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="ClearFilterAsync">Clear</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/admin">← Back</MudButton>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@(_result?.Total ?? 0) total entries</MudText>
    </div>

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_result is null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">Failed to load audit log.</MudAlert>
    }
    else if (_result.Items.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No entries found.</MudText>
    }
    else
    {
        <MudTable Items="@_result.Items" Hover="true" Elevation="0" Outlined="true">
            <HeaderContent>
                <MudTh>When</MudTh>
                <MudTh>Actor</MudTh>
                <MudTh>Action</MudTh>
                <MudTh>Target</MudTh>
                <MudTh>Details</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Class="mud-secondary-text" Style="white-space: nowrap;">@context.OccurredAt.ToLocalTime().ToString("g")</MudTd>
                <MudTd>@context.ActorUsername</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.Action</MudChip>
                </MudTd>
                <MudTd Class="mud-secondary-text">
                    @if (context.TargetAccountId.HasValue)
                    {
                        <MudLink Href="@($"/admin/users/{context.TargetAccountId}")">@(context.TargetUsername ?? context.TargetAccountId.ToString())</MudLink>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </MudTd>
                <MudTd Class="mud-secondary-text" Style="max-width: 320px; overflow-wrap: break-word;">@(context.Details ?? "—")</MudTd>
            </RowTemplate>
        </MudTable>

        <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPageAsync" Disabled="@(_page <= 1)">← Prev</MudButton>
            <MudText Typo="Typo.body2">Page @_page of @TotalPages</MudText>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPageAsync" Disabled="@(_page >= TotalPages)">Next →</MudButton>
        </div>
    }
}

@code {
    [SupplyParameterFromQuery] public string? TargetId { get; set; }

    private string? _targetIdRaw;
    private bool    _loading;
    private int     _page     = 1;
    private int     _pageSize = 50;
    private PagedAdminResult<AuditEntryDto>? _result;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_result?.Total ?? 0 / (double)_pageSize));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        if (AuthState.IsAdmin)
        {
            if (!string.IsNullOrEmpty(TargetId)) _targetIdRaw = TargetId;
            await LoadAsync();
        }
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        Guid? targetId = Guid.TryParse(_targetIdRaw, out var g) ? g : null;
        _result  = await Api.GetAuditLogAsync(_page, _pageSize, targetId);
        _loading = false;
        StateHasChanged();
    }

    private async Task ApplyFilterAsync() { _page = 1; await LoadAsync(); }
    private async Task ClearFilterAsync()  { _targetIdRaw = null; _page = 1; await LoadAsync(); }
    private async Task PrevPageAsync() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPageAsync() { _page++; await LoadAsync(); }
}
