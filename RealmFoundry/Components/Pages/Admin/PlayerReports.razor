@page "/admin/reports"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api

<PageTitle>Player Reports — Admin — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied.</p>
}
else
{
    <MudText Typo="Typo.h3" Class="mb-4">Player Reports</MudText>

    <div class="d-flex flex-wrap gap-3 mb-4 align-items-center">
        <MudSelect Value="_showResolved"
                   ValueChanged="@(async (string v) => { _showResolved = v; await OnFilterChangedAsync(); })"
                   T="string"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomCenter"
                   Clearable="true"
                   Placeholder="All Reports"
                   Style="min-width: 180px;">
            <MudSelectItem Value="@("false")">Open Only</MudSelectItem>
            <MudSelectItem Value="@("true")">Resolved Only</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/admin">← Back</MudButton>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@(_result?.Total ?? 0) total</MudText>
    </div>

    @if (!string.IsNullOrEmpty(_actionMessage))
    {
        <MudAlert Severity="@(_actionError ? Severity.Error : Severity.Success)" Class="mb-4">@_actionMessage</MudAlert>
    }

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_result is null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">Failed to load reports.</MudAlert>
    }
    else if (_result.Items.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">No reports found.</MudText>
    }
    else
    {
        <MudTable Items="@_result.Items" Hover="true" Elevation="0" Outlined="true">
            <HeaderContent>
                <MudTh>Submitted</MudTh>
                <MudTh>Reporter</MudTh>
                <MudTh>Target</MudTh>
                <MudTh>Reason</MudTh>
                <MudTh>Status</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Class="mud-text-secondary" Style="white-space: nowrap;">@context.SubmittedAt.ToLocalTime().ToString("g")</MudTd>
                <MudTd>@context.ReporterName</MudTd>
                <MudTd>@context.TargetName</MudTd>
                <MudTd Style="max-width: 360px; overflow-wrap: break-word;">@context.Reason</MudTd>
                <MudTd>
                    @if (context.IsResolved)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Resolved</MudChip>
                        @if (context.ResolvedAt.HasValue)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1" Inline="true">@context.ResolvedAt.Value.ToLocalTime().ToString("g")</MudText>
                        }
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Open</MudChip>
                    }
                </MudTd>
                <MudTd>
                    @if (!context.IsResolved)
                    {
                        <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="() => ResolveAsync(context.Id)">Resolve</MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPageAsync" Disabled="@(_page <= 1)">← Prev</MudButton>
            <MudText Typo="Typo.body2">Page @_page of @TotalPages</MudText>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPageAsync" Disabled="@(_page >= TotalPages)">Next →</MudButton>
        </div>
    }
}

@code {
    private string? _showResolved;
    private bool    _loading;
    private string? _actionMessage;
    private bool    _actionError;
    private int     _page     = 1;
    private int     _pageSize = 50;
    private PagedAdminResult<PlayerReportDto>? _result;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_result?.Total ?? 0 / (double)_pageSize));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        if (AuthState.IsAdmin) await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _loading       = true;
        _actionMessage = null;
        StateHasChanged();
        bool? resolved = _showResolved switch
        {
            "true"  => true,
            "false" => false,
            _       => null,
        };
        _result  = await Api.GetReportsAsync(_page, _pageSize, resolved);
        _loading = false;
        StateHasChanged();
    }

    private async Task OnFilterChangedAsync() { _page = 1; await LoadAsync(); }
    private async Task PrevPageAsync() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPageAsync() { _page++; await LoadAsync(); }

    private async Task ResolveAsync(Guid id)
    {
        var (ok, err) = await Api.ResolveReportAsync(id);
        _actionError   = !ok;
        _actionMessage = ok ? "Report resolved." : (err ?? "Failed to resolve report.");
        if (ok) await LoadAsync();
        else StateHasChanged();
    }
}
