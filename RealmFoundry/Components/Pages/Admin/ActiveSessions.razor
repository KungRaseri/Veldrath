@page "/admin/sessions"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api

<PageTitle>Active Sessions — Admin — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied.</p>
}
else
{
    <MudText Typo="Typo.h3" Class="mb-4">Active Sessions</MudText>

    <div class="d-flex flex-wrap gap-3 mb-4 align-items-center">
        <MudTextField @bind-Value="_regionId"
                      T="string"
                      Placeholder="Region ID…"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Style="width: 160px;" />
        <MudTextField @bind-Value="_zoneId"
                      T="string"
                      Placeholder="Zone ID…"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Style="width: 160px;" />
        <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="LoadAsync">Filter</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="ClearFiltersAsync">Clear</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/admin">← Back</MudButton>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@(_sessions?.Count ?? 0) player(s) online</MudText>
    </div>

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_sessions is null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">Failed to load sessions.</MudAlert>
    }
    else if (_sessions.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No active sessions match the current filter.</MudText>
    }
    else
    {
        <MudTable Items="@_sessions" Hover="true" Elevation="0" Outlined="true">
            <HeaderContent>
                <MudTh>Character</MudTh>
                <MudTh>Account</MudTh>
                <MudTh>Region</MudTh>
                <MudTh>Zone</MudTh>
                <MudTh>Since</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.CharacterName</MudTd>
                <MudTd Class="mud-text-secondary">@context.AccountUsername</MudTd>
                <MudTd Class="mud-text-secondary">@context.RegionId</MudTd>
                <MudTd Class="mud-text-secondary">@(context.ZoneId ?? "—")</MudTd>
                <MudTd Class="mud-text-secondary">@context.EnteredAt.ToLocalTime().ToString("g")</MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Href="@($"/admin/users/{context.AccountId}")">Manage Account</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private string? _regionId;
    private string? _zoneId;
    private bool    _loading;
    private IReadOnlyList<ActiveSessionDto>? _sessions;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        if (AuthState.IsAdmin) await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        _sessions = await Api.GetSessionsAsync(
            string.IsNullOrWhiteSpace(_regionId) ? null : _regionId,
            string.IsNullOrWhiteSpace(_zoneId)   ? null : _zoneId);
        _loading = false;
        StateHasChanged();
    }

    private async Task ClearFiltersAsync()
    {
        _regionId = null;
        _zoneId   = null;
        await LoadAsync();
    }
}
