@page "/admin/server"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api

<PageTitle>Server Commands — Admin — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied.</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudLink Href="/admin">← Back to Admin</MudLink>
    </div>
    <MudText Typo="Typo.h3" Class="mb-4">Server Commands</MudText>

    @* ── Broadcast Announcement ────────────────────────────────── *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="max-width: 540px;">
        <MudText Typo="Typo.h6" Class="mb-2">Broadcast Announcement</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
            Sends a server-wide announcement to every connected player via SignalR.
        </MudText>

        <MudTextField @bind-Value="_message"
                      T="string"
                      Label="Message"
                      Variant="Variant.Outlined"
                      Lines="3"
                      Required="true"
                      Placeholder="Enter announcement text…"
                      Class="mb-3" />

        <MudSelect @bind-Value="_severity"
                   T="string"
                   Label="Severity"
                   Variant="Variant.Outlined"
                   Class="mb-4">
            <MudSelectItem Value="@("info")">Info (blue)</MudSelectItem>
            <MudSelectItem Value="@("warning")">Warning (yellow)</MudSelectItem>
            <MudSelectItem Value="@("danger")">Danger (red)</MudSelectItem>
        </MudSelect>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SendAsync"
                   Disabled="@(string.IsNullOrWhiteSpace(_message) || _sending)">
            @(_sending ? "Sending…" : "Send Announcement")
        </MudButton>
    </MudPaper>

    @if (!string.IsNullOrEmpty(_resultMessage))
    {
        <MudAlert Severity="@(_resultOk ? Severity.Success : Severity.Error)" Class="mt-4">@_resultMessage</MudAlert>
    }
}

@code {
    private string _message  = string.Empty;
    private string _severity = "info";
    private bool   _sending;
    private string? _resultMessage;
    private bool    _resultOk;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        StateHasChanged();
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_message)) return;
        _sending = true;
        StateHasChanged();

        var (ok, err) = await Api.BroadcastAnnouncementAsync(new BroadcastAnnouncementRequest(_message.Trim(), _severity));
        var result = (Success: ok, Message: err ?? (ok ? "Announcement sent." : "Failed to send."));
        _resultOk      = result.Success;
        _resultMessage = result.Message;

        if (_resultOk) _message = string.Empty;
        _sending = false;
        StateHasChanged();
    }
}
