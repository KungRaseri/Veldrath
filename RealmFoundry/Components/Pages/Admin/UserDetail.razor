@page "/admin/users/{Id:guid}"
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>User Detail — Admin — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied.</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudLink Href="/admin/users">← Back to User Management</MudLink>
    </div>

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_detail is null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h3" Class="mb-1">@_detail.Username</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
            @_detail.Email &nbsp;|&nbsp; Joined @_detail.CreatedAt.ToLocalTime().ToString("d") &nbsp;|&nbsp; Last seen @(_detail.LastSeenAt?.ToLocalTime().ToString("g") ?? "never")
        </MudText>

        <MudGrid Spacing="4">
            @* ── Roles ─────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Roles</MudText>
                    @foreach (var role in _allRoles)
                    {
                        var has = _detail.Roles.Contains(role);
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <MudChip T="string" Size="Size.Small" Color="@(has ? Color.Primary : Color.Default)" Variant="@(has ? Variant.Filled : Variant.Outlined)">@role</MudChip>
                            @if (has)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="() => RevokeRoleAsync(role)">Remove</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="() => AssignRoleAsync(role)">Add</MudButton>
                            }
                        </div>
                    }
                </MudPaper>
            </MudItem>

            @* ── Per-user permissions ──────────────── *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-1">Extra Permissions</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">Override grants not inherited from any role.</MudText>
                    @foreach (var perm in _allPermissions)
                    {
                        var roleHas = _detail.EffectivePermissions.Contains(perm) && !_detail.UserPermissions.Contains(perm);
                        var userHas = _detail.UserPermissions.Contains(perm);
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(userHas ? Color.Success : roleHas ? Color.Default : Color.Default)"
                                     Variant="@(userHas || roleHas ? Variant.Filled : Variant.Outlined)">
                                @perm @(roleHas ? " (role)" : "")
                            </MudChip>
                            @if (userHas)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="() => RevokePermAsync(perm)">Revoke</MudButton>
                            }
                            else if (!roleHas)
                            {
                                <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="() => GrantPermAsync(perm)">Grant</MudButton>
                            }
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ── Ban / Unban ───────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mt-4">
            <MudText Typo="Typo.h6" Class="mb-3">Moderation</MudText>

            @* Warnings *@
            <MudText Typo="Typo.subtitle2" Class="mb-2">
                Warnings
                <MudChip T="string" Size="Size.Small" Color="@(_detail.WarnCount > 0 ? Color.Warning : Color.Default)" Class="ml-2">@_detail.WarnCount</MudChip>
            </MudText>
            <div class="d-flex gap-2 align-items-center mb-3">
                <MudTextField @bind-Value="_warnReason"
                              T="string"
                              Placeholder="Warning reason…"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="flex: 1;" />
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="WarnAsync">Issue Warning</MudButton>
            </div>

            @* Mute *@
            <MudDivider Class="mb-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Chat Mute</MudText>
            @if (_detail.IsMuted)
            {
                <div class="mb-2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Muted</MudChip>
                    @if (_detail.MutedUntil.HasValue)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1" Inline="true"> until @_detail.MutedUntil.Value.ToLocalTime().ToString("g")</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1" Inline="true"> (permanent)</MudText>
                    }
                    @if (!string.IsNullOrEmpty(_detail.MuteReason))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1" Inline="true"> — @_detail.MuteReason</MudText>
                    }
                </div>
                <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="UnmuteAsync">Lift Mute</MudButton>
            }
            else
            {
                <MudTextField @bind-Value="_muteReason"
                              T="string"
                              Label="Mute Reason"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-2" />
                <MudTextField @bind-Value="_muteDuration"
                              T="int?"
                              Label="Duration (minutes, blank = permanent)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="MuteAsync">Mute Player</MudButton>
            }

            @* Ban *@
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Ban</MudText>
            @if (_detail.IsBanned)
            {
                <div class="mb-2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Banned</MudChip>
                    @if (_detail.BannedUntil.HasValue)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1" Inline="true"> until @_detail.BannedUntil.Value.ToLocalTime().ToString("g")</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1" Inline="true"> (permanent)</MudText>
                    }
                    @if (!string.IsNullOrEmpty(_detail.BanReason))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1" Inline="true"> — @_detail.BanReason</MudText>
                    }
                </div>
                <MudButton Variant="Variant.Filled" OnClick="UnbanAsync">Unban Player</MudButton>
            }
            else
            {
                <MudTextField @bind-Value="_banReason"
                              T="string"
                              Label="Ban Reason *"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              Class="mb-2" />
                <MudTextField @bind-Value="_banDuration"
                              T="int?"
                              Label="Duration (minutes, blank = permanent)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <div class="d-flex gap-2 mb-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="BanAsync" Disabled="@string.IsNullOrWhiteSpace(_banReason)">Ban Player</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="KickAsync">Kick Player</MudButton>
                </div>
                <MudTextField @bind-Value="_kickReason"
                              T="string"
                              Label="Kick Reason"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            }

            <MudDivider Class="my-3" />
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="@($"/admin/audit?targetId={Id}")">View Audit Log</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/admin/reports">Player Reports</MudButton>
            </div>
        </MudPaper>

        @if (!string.IsNullOrEmpty(_actionMessage))
        {
            <MudAlert Severity="@(_actionOk ? Severity.Success : Severity.Error)" Class="mt-4">@_actionMessage</MudAlert>
        }
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PlayerDetailDto? _detail;
    private bool             _loading = true;
    private string?          _error;
    private string?          _actionMessage;
    private bool             _actionOk;


    private string? _banReason;
    private int?    _banDuration;
    private string? _kickReason;
    private string? _warnReason;
    private string? _muteReason;
    private int?    _muteDuration;

    private static readonly string[] _allRoles =
        ["Admin", "Moderator", "Curator", "GameMaster", "Developer", "ContentEditor"];

    private static readonly string[] _allPermissions =
    [
        "ban_players", "kick_players", "warn_players", "view_players",
        "teleport_players", "give_items", "run_events", "manage_content",
        "view_content", "manage_roles", "manage_users", "debug_access",
        "send_announcements", "review_submissions"
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitialiseAsync();
        if (AuthState.IsAdmin) await RefreshAsync();
        StateHasChanged();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        _detail  = null;
        StateHasChanged();
        _detail  = await Api.GetUserAsync(Id);
        if (_detail is null) _error = "User not found.";
        _loading = false;
        StateHasChanged();
    }

    private async Task AssignRoleAsync(string role)
    {
        var (ok, err) = await Api.AssignRoleAsync(Id, role);
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private async Task RevokeRoleAsync(string role)
    {
        var (ok, err) = await Api.RevokeRoleAsync(Id, role);
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private async Task GrantPermAsync(string perm)
    {
        var (ok, err) = await Api.GrantPermissionAsync(Id, perm);
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private async Task RevokePermAsync(string perm)
    {
        var (ok, err) = await Api.RevokePermissionAsync(Id, perm);
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private async Task WarnAsync()
    {
        var (ok, err) = await Api.WarnPlayerAsync(new WarnPlayerRequest(Id, _warnReason ?? "Warned by admin."));
        ShowResult(ok, err);
        _warnReason = null;
        if (ok) await RefreshAsync();
    }

    private async Task MuteAsync()
    {
        var (ok, err) = await Api.MutePlayerAsync(new MutePlayerRequest(Id, _muteReason, _muteDuration));
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private async Task UnmuteAsync()
    {
        var (ok, err) = await Api.UnmutePlayerAsync(Id);
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private async Task KickAsync()
    {
        var (ok, err) = await Api.KickPlayerAsync(new KickPlayerRequest(Id, _kickReason));
        ShowResult(ok, err);
    }

    private async Task BanAsync()
    {
        if (string.IsNullOrWhiteSpace(_banReason)) return;
        var (ok, err) = await Api.BanPlayerAsync(new BanPlayerRequest(Id, _banReason, _banDuration));
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private async Task UnbanAsync()
    {
        var (ok, err) = await Api.UnbanPlayerAsync(Id);
        ShowResult(ok, err);
        if (ok) await RefreshAsync();
    }

    private void ShowResult(bool ok, string? err)
    {
        _actionOk      = ok;
        _actionMessage = ok ? "Action applied successfully." : (err ?? "Operation failed.");
        StateHasChanged();
    }
}
