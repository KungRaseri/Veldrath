@page "/admin/status"
@using Veldrath.Contracts.Admin
@using Veldrath.Contracts.Account
@inject RealmFoundryApiClient Api
@inject AuthStateService AuthState

<PageTitle>Server Status — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied. You need the <strong>Admin</strong> role to view this page.</p>
}
else if (_loading)
{
    <MudText>Loading…</MudText>
}
else if (_status is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">Could not retrieve server status.</MudAlert>
}
else
{
    <MudText Typo="Typo.h3" Class="mb-4">Server Status</MudText>

    <div class="d-flex flex-wrap gap-4 mb-4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="min-width: 160px;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: .06em;">Connected Players</MudText>
            <MudText Typo="Typo.h4" Class="mt-1">@_status.ConnectedPlayers</MudText>
        </MudPaper>
        <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="min-width: 160px;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: .06em;">Registered Accounts</MudText>
            <MudText Typo="Typo.h4" Class="mt-1">@_status.RegisteredAccounts</MudText>
        </MudPaper>
        <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="min-width: 160px;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: .06em;">Total Characters</MudText>
            <MudText Typo="Typo.h4" Class="mt-1">@_status.TotalCharacters</MudText>
        </MudPaper>
        <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="min-width: 160px;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: .06em;">Uptime</MudText>
            <MudText Typo="Typo.h4" Class="mt-1">@FormatUptime(_status.ServerStartedAt)</MudText>
        </MudPaper>
        <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="min-width: 160px;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: .06em;">Started At</MudText>
            <MudText Typo="Typo.h4" Class="mt-1">@_status.ServerStartedAt.ToLocalTime().ToString("g")</MudText>
        </MudPaper>
    </div>

    @if (_status.ZonePopulations.Count > 0)
    {
        <MudText Typo="Typo.h5" Class="mb-2">Zone Population</MudText>
        <MudTable Items="@_status.ZonePopulations.OrderByDescending(z => z.PlayerCount).ToList()"
                  Hover="true" Elevation="0" Outlined="true" Class="mb-4">
            <HeaderContent>
                <MudTh>Zone</MudTh>
                <MudTh>Zone ID</MudTh>
                <MudTh>Players</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ZoneName</MudTd>
                <MudTd Class="mud-text-secondary">@context.ZoneId</MudTd>
                <MudTd>@context.PlayerCount</MudTd>
            </RowTemplate>
        </MudTable>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">No active zones.</MudText>
    }

    @if (_status.HealthChecks is { Count: > 0 })
    {
        <MudText Typo="Typo.h5" Class="mb-2">Health Checks</MudText>
        <MudTable Items="@_status.HealthChecks"
                  Hover="true" Elevation="0" Outlined="true" Class="mb-4">
            <HeaderContent>
                <MudTh>Check</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Details</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@HealthChipColor(context.Status)">@context.Status</MudChip>
                </MudTd>
                <MudTd Class="mud-text-secondary">@(context.Description ?? "—")</MudTd>
            </RowTemplate>
        </MudTable>
    }

    <div class="mt-4">
        <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="RefreshAsync">Refresh</MudButton>
    </div>
}

@code {
    private ServerStatusDto? _status;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task RefreshAsync()
    {
        _loading = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _status  = await Api.GetServerStatusAsync();
        _loading = false;
    }

    private static string FormatUptime(DateTimeOffset since)
    {
        var span = DateTimeOffset.UtcNow - since;
        if (span.TotalDays >= 1)  return $"{(int)span.TotalDays}d {span.Hours}h {span.Minutes}m";
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h {span.Minutes}m";
        return $"{span.Minutes}m";
    }

    private static Color HealthChipColor(string status) => status switch
    {
        "Healthy"   => Color.Success,
        "Degraded"  => Color.Warning,
        _           => Color.Error,
    };
}
