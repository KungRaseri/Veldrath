@page "/admin"
@inject AuthStateService AuthState
@inject NavigationManager Nav

<PageTitle>Admin Dashboard — RealmFoundry</PageTitle>

@if (!AuthState.IsAdmin)
{
    <p>Access denied. You need the <strong>Admin</strong> role to view this page.</p>
}
else
{
    <MudText Typo="Typo.h3" Class="mb-4">Admin Dashboard</MudText>

    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">User Management</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">View accounts, assign roles, grant or revoke per-user permissions, kick and ban players.</MudText>
                <MudButton Variant="Variant.Filled" Href="/admin/users">Manage Users</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Roles & Permissions</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Review the permission set for each role.</MudText>
                <MudButton Variant="Variant.Filled" Href="/admin/roles">View Roles</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Server Commands</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Broadcast server-wide announcements to all connected players.</MudText>
                <MudButton Variant="Variant.Filled" Href="/admin/server">Server Commands</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Active Sessions</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">View all players currently online, filterable by region and zone.</MudText>
                <MudButton Variant="Variant.Filled" Href="/admin/sessions">View Sessions</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Audit Log</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Review admin actions taken across all accounts with a full timestamped trail.</MudText>
                <MudButton Variant="Variant.Filled" Href="/admin/audit">View Audit Log</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Player Reports</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Manage reports submitted by players against other players. Resolve open reports.</MudText>
                <MudButton Variant="Variant.Filled" Href="/admin/reports">View Reports</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Server Status</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Live player count, uptime, and per-zone population overview.</MudText>
                <MudButton Variant="Variant.Filled" Href="/admin/status">View Status</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
