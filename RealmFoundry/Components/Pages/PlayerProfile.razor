@page "/players/{Id:guid}"
@using Veldrath.Contracts.Players
@inject RealmFoundryApiClient Api

<PageTitle>Player Profile — RealmFoundry</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="my-8">
    @if (_loading)
    {
        <MudText>Loading profile…</MudText>
    }
    else if (_profile is null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">Player not found.</MudAlert>
        <MudLink Href="/">← Back to Home</MudLink>
    }
    else
    {
        <MudPaper Elevation="0" Outlined="true" Class="pa-6">
            <MudText Typo="Typo.h4" Class="mb-4">@_profile.Username</MudText>

            <MudStack Spacing="3">
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Account ID</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_profile.AccountId</MudText>
                </div>

                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Registered</MudText>
                    <MudText Typo="Typo.body2">@_profile.RegisteredAt.ToLocalTime().ToString("d")</MudText>
                </div>

                @if (_profile.Level > 0)
                {
                    <MudDivider />

                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Level</MudText>
                        <MudText Typo="Typo.body2">@_profile.Level</MudText>
                    </div>

                    @if (_profile.CharacterClass is not null)
                    {
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Class</MudText>
                            <MudText Typo="Typo.body2">@_profile.CharacterClass</MudText>
                        </div>
                    }

                    @if (_profile.Species is not null)
                    {
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Species</MudText>
                            <MudText Typo="Typo.body2">@_profile.Species</MudText>
                        </div>
                    }

                    @if (_profile.CurrentZone is not null)
                    {
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Current Zone</MudText>
                            <MudText Typo="Typo.body2">@_profile.CurrentZone</MudText>
                        </div>
                    }
                }
                else
                {
                    <MudDivider />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">This player has no active characters.</MudText>
                }
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    /// <summary>Account ID supplied via the route.</summary>
    [Parameter]
    public Guid Id { get; set; }

    private PlayerProfileDto? _profile;
    private bool _loading = true;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _profile = await Api.GetPlayerProfileAsync(Id);
        _loading = false;
    }
}
