@page "/languages"
@using Veldrath.Contracts.Content
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>Languages — RealmFoundry</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mud-my-8">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6">
        <div class="d-flex align-items-center justify-space-between mb-4">
            <div>
                <MudText Typo="Typo.h4" Class="mb-2">Languages</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Explore constructed and natural languages of Veldrath.
                    Each language defines phonology, morphology, a root dictionary, and register rules
                    — the building blocks for procedural name generation across species and locations.
                </MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/languages/new">
                Build a Language
            </MudButton>
        </div>

        <MudTextField @bind-Value="_search"
                      @bind-Value:after="OnSearchChanged"
                      Placeholder="Search languages…"
                      Variant="Variant.Outlined"
                      Immediate="true"
                      Class="mb-4"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" />

        @if (_loading)
        {
            <div class="d-flex justify-center my-6">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            </div>
        }
        else if (_items.Count == 0)
        {
            <MudPaper Elevation="0" Class="pa-4 text-center">
                <MudText Typo="Typo.body1">No languages have been submitted yet.</MudText>
                <MudLink Href="/languages/new">Be the first — build a language.</MudLink>
            </MudPaper>
        }
        else
        {
            <MudGrid>
                @foreach (var lang in _items)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <a href="/content/language/@lang.Slug" style="text-decoration:none;">
                            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                                <MudText Typo="Typo.body1" Style="font-weight:600;">@(lang.DisplayName ?? lang.Slug)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@lang.TypeKey</MudText>
                            </MudPaper>
                        </a>
                    </MudItem>
                }
            </MudGrid>

            @if (_totalCount > _pageSize)
            {
                <div class="d-flex align-items-center justify-center gap-3 mt-4">
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               OnClick="PrevPage"
                               Disabled="@(_page <= 1)">
                        ← Prev
                    </MudButton>
                    <MudText Typo="Typo.body2">@_page / @TotalPages</MudText>
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               OnClick="Next"
                               Disabled="@(_page >= TotalPages)">
                        Next →
                    </MudButton>
                </div>
            }
        }
    </MudPaper>
</MudContainer>

@code {
    private List<ContentSummaryDto> _items = [];
    private int _totalCount;
    private int _page     = 1;
    private int _pageSize = 24;
    private string _search = string.Empty;
    private bool _loading  = true;

    private int TotalPages => (int)Math.Ceiling(_totalCount / (double)_pageSize);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnSearchChanged()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task Next()     { _page++; await LoadAsync(); }

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await Api.BrowseContentAsync("language", _search, _page, _pageSize);
        _items      = [.. result.Items];
        _totalCount = result.TotalCount;
        _loading    = false;
    }
}
