@page "/forgot-password"
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>Forgot Password — RealmFoundry</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="my-8">
    <MudPaper Elevation="0" Outlined="true" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">Forgot Password</MudText>

        @if (_sent)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                If an account with that email exists, we've sent a password-reset link. Check your inbox.
            </MudAlert>
            <MudLink Href="/login">Back to sign in</MudLink>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                Enter your account email and we'll send you a reset link.
            </MudText>

            <MudTextField @bind-Value="_email"
                          Label="Email address"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Margin="Margin.Dense"
                          Class="mb-3" />

            @if (_error is not null)
            {
                <MudText Typo="Typo.body2" Color="Color.Error" Class="mb-3">@_error</MudText>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitAsync"
                       Disabled="@_submitting">
                @(_submitting ? "Sending…" : "Send reset link")
            </MudButton>

            <MudLink Href="/login" Class="mt-4 d-block">Back to sign in</MudLink>
        }
    </MudPaper>
</MudContainer>

@code {
    private string  _email     = string.Empty;
    private bool    _submitting;
    private bool    _sent;
    private string? _error;

    private async Task SubmitAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = "Please enter your email address.";
            return;
        }

        _submitting = true;
        try
        {
            await Api.ForgotPasswordAsync(_email);
            _sent = true;
        }
        finally
        {
            _submitting = false;
        }
    }
}
