@page "/submissions"
@using RealmUnbound.Contracts.Content
@inject RealmFoundryApiClient Api
@rendermode InteractiveServer

<PageTitle>Submissions — RealmFoundry</PageTitle>

<div class="page-header">
    <h1>Submissions</h1>
    <a href="submissions/new" class="btn">+ New Submission</a>
</div>

<div class="filters">
    <input @bind="_searchFilter" @bind:event="oninput" placeholder="Search by title…" />
    <select @bind="_statusFilter">
        <option value="">All statuses</option>
        <option value="Pending">Pending</option>
        <option value="Approved">Approved</option>
        <option value="Curated">Curated</option>
        <option value="Rejected">Rejected</option>
    </select>
    <select @bind="_typeFilter">
        <option value="">All types</option>
        @foreach (var schema in ContentSchemaRegistry.All.Values.OrderBy(s => s.DisplayLabel))
        {
            <option value="@schema.ContentType">@schema.DisplayLabel</option>
        }
    </select>
    <button class="btn" @onclick="SearchAsync">Search</button>
</div>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_result.Items.Count == 0)
{
    <p class="muted">No submissions found.</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Status</th>
                <th>By</th>
                <th>Score</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in _result.Items)
            {
                <tr>
                    <td><a href="submissions/@s.Id">@s.Title</a></td>
                    <td>@s.ContentType</td>
                    <td><span class="badge @BadgeClass(s.Status)">@s.Status</span></td>
                    <td>@s.SubmitterName</td>
                    <td>@s.VoteScore</td>
                    <td>@s.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="pagination">
        <button class="btn btn-sm" @onclick="PrevPageAsync" disabled="@(_page <= 1)">&#x2190; Prev</button>
        <span>Page @_page of @TotalPages</span>
        <button class="btn btn-sm" @onclick="NextPageAsync" disabled="@(_page >= TotalPages)">Next &#x2192;</button>
    </div>
}

@code {
    private string? _searchFilter;
    private string? _statusFilter;
    private string? _typeFilter;
    private bool    _loading = true;
    private int     _page    = 1;
    private const int PageSize = 20;

    private PagedResult<FoundrySubmissionSummaryDto> _result = new([], 0, 1, PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_result.TotalCount / (double)PageSize));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task SearchAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task PrevPageAsync() { _page--; await LoadAsync(); }
    private async Task NextPageAsync() { _page++; await LoadAsync(); }

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Api.GetSubmissionsAsync(_statusFilter, _typeFilter, _searchFilter, _page, PageSize);
        _loading = false;
    }

    private static string BadgeClass(string status) => status switch
    {
        "Approved" or "Curated" => "badge-green",
        "Rejected"              => "badge-red",
        _                       => "badge-grey",
    };
}
