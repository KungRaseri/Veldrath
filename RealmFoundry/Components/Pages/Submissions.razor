@page "/submissions"
@using Veldrath.Contracts.Content
@inject RealmFoundryApiClient Api

<PageTitle>Submissions — RealmFoundry</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <MudText Typo="Typo.h4" Class="mb-0">Submissions</MudText>
    <MudButton Variant="Variant.Filled" Href="submissions/new">+ New Submission</MudButton>
</div>

<div class="d-flex flex-wrap gap-3 mb-4">
    <MudTextField @bind-Value="_searchFilter"
                  Placeholder="Search by title…"
                  Immediate="true"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Style="min-width: 200px;" />
    <MudSelect @bind-Value="_statusFilter"
               T="string"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               AnchorOrigin="Origin.BottomCenter"
               Clearable="true"
               Placeholder="All statuses"
               Style="min-width: 180px;">
        <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
        <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
        <MudSelectItem Value="@("Curated")">Curated</MudSelectItem>
        <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
    </MudSelect>
    <MudSelect @bind-Value="_typeFilter"
               T="string"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               AnchorOrigin="Origin.BottomCenter"
               Clearable="true"
               Placeholder="All types"
               Style="min-width: 180px;">
        @foreach (var schema in ContentSchemaRegistry.All.Values.OrderBy(s => s.DisplayLabel))
        {
            <MudSelectItem Value="@schema.ContentType">@schema.DisplayLabel</MudSelectItem>
        }
    </MudSelect>
    <MudButton Variant="Variant.Filled" OnClick="SearchAsync" Size="Size.Small">Search</MudButton>
</div>

@if (_loading)
{
    <MudText>Loading…</MudText>
}
else if (_result.Items.Count == 0)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary">No submissions found.</MudText>
}
else
{
    <MudTable Items="@_result.Items" Hover="true" Elevation="0" Outlined="true">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>By</MudTh>
            <MudTh>Score</MudTh>
            <MudTh>Date</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudLink Href="@($"submissions/{context.Id}")">@context.Title</MudLink></MudTd>
            <MudTd>@context.ContentType</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@ChipColor(context.Status)">@context.Status</MudChip></MudTd>
            <MudTd>@context.SubmitterName</MudTd>
            <MudTd>@context.VoteScore</MudTd>
            <MudTd>@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
        </RowTemplate>
    </MudTable>

    <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPageAsync" Disabled="@(_page <= 1)">← Prev</MudButton>
        <MudText Typo="Typo.body2">Page @_page of @TotalPages</MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPageAsync" Disabled="@(_page >= TotalPages)">Next →</MudButton>
    </div>
}

@code {
    private string? _searchFilter;
    private string? _statusFilter;
    private string? _typeFilter;
    private bool    _loading = true;
    private int     _page    = 1;
    private const int PageSize = 20;

    private PagedResult<FoundrySubmissionSummaryDto> _result = new([], 0, 1, PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_result.TotalCount / (double)PageSize));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task SearchAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task PrevPageAsync() { _page--; await LoadAsync(); }
    private async Task NextPageAsync() { _page++; await LoadAsync(); }

    private async Task LoadAsync()
    {
        _loading = true;
        _result  = await Api.GetSubmissionsAsync(_statusFilter, _typeFilter, _searchFilter, _page, PageSize);
        _loading = false;
    }

    private static Color ChipColor(string status) => status switch
    {
        "Approved" or "Curated" => Color.Success,
        "Rejected"              => Color.Error,
        _                       => Color.Default,
    };
}
