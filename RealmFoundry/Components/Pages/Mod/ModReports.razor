@page "/mod/reports"
@using Veldrath.Contracts.Admin
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api

<PageTitle>Player Reports — Moderation — RealmFoundry</PageTitle>

@if (!AuthState.IsModerator)
{
    <p>Access denied. You need the <strong>Moderator</strong> role to view this page.</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <MudText Typo="Typo.h3" Class="mb-0">Player Reports</MudText>
        <MudSelect Value="_showResolved"
                   ValueChanged="@(async (string v) => { _showResolved = v; await OnFilterChangedAsync(); })"
                   T="string"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomCenter"
                   Clearable="true"
                   Placeholder="All Reports"
                   Style="min-width: 150px;">
            <MudSelectItem Value="@("false")">Open Only</MudSelectItem>
            <MudSelectItem Value="@("true")">Resolved Only</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/mod">← Back</MudButton>
        @if (_result is not null)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@_result.Total total</MudText>
        }
    </div>

    @if (!string.IsNullOrEmpty(_actionMessage))
    {
        <MudAlert Severity="@(_actionError ? Severity.Error : Severity.Success)" Class="mud-mb-4">@_actionMessage</MudAlert>
    }

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_result is null)
    {
        <MudAlert Severity="Severity.Error" Class="mud-mb-4">Failed to load reports.</MudAlert>
    }
    else if (_result.Items.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">No reports found.</MudText>
    }
    else
    {
        <MudTable Items="@_result.Items" Hover="true" Elevation="0" Outlined="true">
            <HeaderContent>
                <MudTh>Submitted</MudTh>
                <MudTh>Reporter</MudTh>
                <MudTh>Target</MudTh>
                <MudTh>Reason</MudTh>
                <MudTh>Status</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Class="mud-text-secondary" Style="white-space: nowrap;">@context.SubmittedAt.ToLocalTime().ToString("g")</MudTd>
                <MudTd>@context.ReporterName</MudTd>
                <MudTd>@context.TargetName</MudTd>
                <MudTd>@context.Reason</MudTd>
                <MudTd>
                    @if (context.IsResolved)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Resolved</MudChip>
                        @if (context.ResolvedAt.HasValue)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-inline"> @context.ResolvedAt.Value.ToLocalTime().ToString("g")</MudText>
                        }
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Open</MudChip>
                    }
                </MudTd>
                <MudTd>
                    @if (!context.IsResolved)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="() => ResolveAsync(context.Id)">Resolve</MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>

        @if (_result.Total > _result.PageSize)
        {
            <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPageAsync" Disabled="@(_page <= 1)">← Prev</MudButton>
                <MudText Typo="Typo.body2">Page @_page of @((int)Math.Ceiling(_result.Total / (double)_result.PageSize))</MudText>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPageAsync" Disabled="@(_page * _result.PageSize >= _result.Total)">Next →</MudButton>
            </div>
        }
    }
}

@code {
    private PagedAdminResult<PlayerReportDto>? _result;
    private bool    _loading      = true;
    private int     _page         = 1;
    private string? _showResolved;
    private string? _actionMessage;
    private bool    _actionError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnFilterChangedAsync() { _page = 1; await LoadAsync(); }

    private async Task LoadAsync()
    {
        _loading = true;
        bool? resolved = _showResolved switch
        {
            "true"  => true,
            "false" => false,
            _       => null,
        };
        _result  = await Api.GetModReportsAsync(page: _page, resolved: resolved);
        _loading = false;
    }

    private async Task ResolveAsync(Guid id)
    {
        var (ok, err) = await Api.ResolveModReportAsync(id);
        _actionError   = !ok;
        _actionMessage = ok ? "Report resolved." : (err ?? "Could not resolve report.");
        if (ok) await LoadAsync();
    }

    private async Task PrevPageAsync() { _page--; await LoadAsync(); }
    private async Task NextPageAsync() { _page++; await LoadAsync(); }
}
