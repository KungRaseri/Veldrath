@page "/mod"
@inject AuthStateService AuthState

<PageTitle>Moderation — RealmFoundry</PageTitle>

@if (!AuthState.IsModerator)
{
    <p>Access denied. You need the <strong>Moderator</strong> role to view this page.</p>
}
else
{
    <MudText Typo="Typo.h3" Class="mud-mb-4">Moderation Dashboard</MudText>

    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="mud-pa-4">
                <MudText Typo="Typo.h6" Class="mud-mb-2">Player Search</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mud-mb-3">Look up player accounts, view history, and apply kick, warn, mute, or ban actions.</MudText>
                <MudButton Variant="Variant.Filled" Href="/mod/users">Search Players</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="0" Outlined="true" Class="mud-pa-4">
                <MudText Typo="Typo.h6" Class="mud-mb-2">Player Reports</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mud-mb-3">Review open player-submitted reports and mark them resolved.</MudText>
                <MudButton Variant="Variant.Filled" Href="/mod/reports">View Reports</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
