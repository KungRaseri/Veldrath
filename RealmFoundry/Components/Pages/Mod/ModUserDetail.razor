@page "/mod/users/{Id:guid}"
@using Veldrath.Contracts.Admin
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_user?.Username ?? "Player") — Moderation — RealmFoundry</PageTitle>

@if (!AuthState.IsModerator)
{
    <p>Access denied. You need the <strong>Moderator</strong> role to view this page.</p>
}
else if (_loading)
{
    <MudText>Loading…</MudText>
}
else if (_user is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">Player not found. <MudLink Href="/mod/users">← Back</MudLink></MudAlert>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <MudText Typo="Typo.h3" Class="mb-0">@_user.Username</MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/mod/users">← Back</MudButton>
    </div>

    @if (!string.IsNullOrEmpty(_actionMessage))
    {
        <MudAlert Severity="@(_actionError ? Severity.Error : Severity.Success)" Class="mb-4">@_actionMessage</MudAlert>
    }

    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Account ID</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_user.Id</MudText>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Roles</MudText>
            <MudText Typo="Typo.body2">@string.Join(", ", _user.Roles)</MudText>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Warnings</MudText>
            <MudText Typo="Typo.body2">@_user.WarnCount</MudText>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Status</MudText>
            <div>
                @if (_user.IsBanned)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Banned</MudChip>
                    @if (_user.BannedUntil.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-inline"> until @_user.BannedUntil.Value.ToLocalTime().ToString("g")</MudText>
                    }
                    @if (_user.BanReason is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-inline"> — @_user.BanReason</MudText>
                    }
                }
                else if (_user.IsMuted)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Muted</MudChip>
                    @if (_user.MutedUntil.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-inline"> until @_user.MutedUntil.Value.ToLocalTime().ToString("g")</MudText>
                    }
                    @if (_user.MuteReason is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-inline"> — @_user.MuteReason</MudText>
                    }
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
                }
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Last Seen</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@(_user.LastSeenAt?.ToLocalTime().ToString("g") ?? "—")</MudText>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Created</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_user.CreatedAt.ToLocalTime().ToString("g")</MudText>
        </div>
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mb-3">Actions</MudText>

    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="() => KickAsync()">Kick</MudButton>
    </div>

    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <MudTextField @bind-Value="_warnReason"
                      T="string"
                      Placeholder="Warn reason…"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Style="min-width: 250px;" />
        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="WarnAsync" Disabled="@string.IsNullOrWhiteSpace(_warnReason)">Warn</MudButton>
    </div>

    @if (!_user.IsMuted)
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <MudTextField @bind-Value="_muteReason"
                          T="string"
                          Placeholder="Mute reason…"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="min-width: 250px;" />
            <MudTextField @bind-Value="_muteDurationText"
                          T="string"
                          Placeholder="Minutes (blank = permanent)"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="width: 200px;" />
            <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="MuteAsync" Disabled="@string.IsNullOrWhiteSpace(_muteReason)">Mute</MudButton>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="UnmuteAsync">Unmute</MudButton>
        </div>
    }

    @if (!_user.IsBanned)
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <MudTextField @bind-Value="_banReason"
                          T="string"
                          Placeholder="Ban reason…"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="min-width: 250px;" />
            <MudTextField @bind-Value="_banDurationText"
                          T="string"
                          Placeholder="Minutes (blank = permanent)"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="width: 200px;" />
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="BanAsync" Disabled="@string.IsNullOrWhiteSpace(_banReason)">Ban</MudButton>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="UnbanAsync">Unban</MudButton>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PlayerDetailDto? _user;
    private bool    _loading      = true;
    private string? _actionMessage;
    private bool    _actionError;

    private string? _warnReason;
    private string? _muteReason;
    private string? _muteDurationText;
    private string? _banReason;
    private string? _banDurationText;

    protected override async Task OnInitializedAsync()
    {
        _user    = await Api.GetModUserAsync(Id);
        _loading = false;
    }

    private async Task KickAsync()
    {
        var (ok, err) = await Api.KickPlayerAsync(new KickPlayerRequest(Id));
        SetMessage(ok, err, "Player kicked.");
    }

    private async Task WarnAsync()
    {
        var (ok, err) = await Api.WarnPlayerAsync(new WarnPlayerRequest(Id, _warnReason!));
        SetMessage(ok, err, "Warning issued.");
        if (ok) { _warnReason = null; await RefreshAsync(); }
    }

    private async Task MuteAsync()
    {
        int? duration = int.TryParse(_muteDurationText, out var d) ? d : null;
        var (ok, err) = await Api.MutePlayerAsync(new MutePlayerRequest(Id, _muteReason!, duration));
        SetMessage(ok, err, "Player muted.");
        if (ok) { _muteReason = null; _muteDurationText = null; await RefreshAsync(); }
    }

    private async Task UnmuteAsync()
    {
        var (ok, err) = await Api.UnmutePlayerAsync(Id);
        SetMessage(ok, err, "Player unmuted.");
        if (ok) await RefreshAsync();
    }

    private async Task BanAsync()
    {
        int? duration = int.TryParse(_banDurationText, out var d) ? d : null;
        var (ok, err) = await Api.BanPlayerAsync(new BanPlayerRequest(Id, _banReason!, duration));
        SetMessage(ok, err, "Player banned.");
        if (ok) { _banReason = null; _banDurationText = null; await RefreshAsync(); }
    }

    private async Task UnbanAsync()
    {
        var (ok, err) = await Api.UnbanPlayerAsync(Id);
        SetMessage(ok, err, "Player unbanned.");
        if (ok) await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _user = await Api.GetModUserAsync(Id);
        StateHasChanged();
    }

    private void SetMessage(bool ok, string? err, string successMsg)
    {
        _actionError   = !ok;
        _actionMessage = ok ? successMsg : (err ?? "Action failed.");
    }
}
