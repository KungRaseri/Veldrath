@page "/mod/users"
@using Veldrath.Contracts.Admin
@inject AuthStateService AuthState
@inject RealmFoundryApiClient Api
@inject NavigationManager Nav

<PageTitle>Player Search — Moderation — RealmFoundry</PageTitle>

@if (!AuthState.IsModerator)
{
    <p>Access denied. You need the <strong>Moderator</strong> role to view this page.</p>
}
else
{
    <div class="d-flex flex-wrap gap-3 mb-4 align-items-center">
        <MudTextField @bind-Value="_search"
                      T="string"
                      Placeholder="Search username…"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Style="min-width: 200px;"
                      OnKeyUp="OnSearchKeyUp" />
        <MudSelect Value="_filterStatus"
                   ValueChanged="@(async (string v) => { _filterStatus = v; await OnFilterChangedAsync(); })"
                   T="string"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomCenter"
                   Clearable="true"
                   Placeholder="All Status"
                   Style="min-width: 150px;">
            <MudSelectItem Value="@("active")">Active</MudSelectItem>
            <MudSelectItem Value="@("banned")">Banned</MudSelectItem>
            <MudSelectItem Value="@("muted")">Muted</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="LoadUsersAsync">Search</MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/mod">← Back</MudButton>
    </div>

    @if (_loading)
    {
        <MudText>Loading…</MudText>
    }
    else if (_result is null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">Failed to load users.</MudAlert>
    }
    else if (_result.Items.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No players found.</MudText>
    }
    else
    {
        <MudTable Items="@_result.Items" Hover="true" Elevation="0" Outlined="true">
            <HeaderContent>
                <MudTh>Username</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Warnings</MudTh>
                <MudTh>Last Seen</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Username</MudTd>
                <MudTd>
                    @if (context.IsBanned)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Banned</MudChip>
                    }
                    else if (context.IsMuted)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Muted</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
                    }
                </MudTd>
                <MudTd>@context.WarnCount</MudTd>
                <MudTd Class="mud-secondary-text" Style="white-space: nowrap;">@(context.LastSeenAt?.ToLocalTime().ToString("g") ?? "—")</MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Href="@($"/mod/users/{context.Id}")">View</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @if (_result.Total > _result.PageSize)
        {
            <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPageAsync" Disabled="@(_page <= 1)">← Prev</MudButton>
                <MudText Typo="Typo.body2">Page @_page of @((int)Math.Ceiling(_result.Total / (double)_result.PageSize))</MudText>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPageAsync" Disabled="@(_page * _result.PageSize >= _result.Total)">Next →</MudButton>
            </div>
        }
    }
}

@code {
    private AdminUserListResponse? _result;
    private bool    _loading      = true;
    private string? _search;
    private string? _filterStatus;
    private int     _page         = 1;

    protected override async Task OnInitializedAsync() => await LoadUsersAsync();

    private async Task OnFilterChangedAsync() { _page = 1; await LoadUsersAsync(); }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadUsersAsync(); }
    }

    private async Task LoadUsersAsync()
    {
        _loading = true;
        _result  = await Api.GetModUsersAsync(search: _search, status: _filterStatus, page: _page);
        _loading = false;
    }

    private async Task PrevPageAsync() { _page--; await LoadUsersAsync(); }
    private async Task NextPageAsync() { _page++; await LoadUsersAsync(); }
}
