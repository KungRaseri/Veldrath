@page "/notifications"
@using Veldrath.Contracts.Foundry
@inject RealmFoundryApiClient Api
@inject AuthStateService AuthState

<PageTitle>Notifications — RealmFoundry</PageTitle>

@if (!AuthState.IsAuthReady)
{
    @* Auth check still running — render nothing to avoid flashing "must sign in". *@
}
else if (!AuthState.IsLoggedIn)
{
    <p>You must <a href="/login">sign in</a> to view your notifications.</p>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mud-my-8">
        <div class="d-flex align-items-center gap-3 mb-4">
            <MudText Typo="Typo.h4" Class="mud-mb-0">Notifications</MudText>
            @if (_notifications.Any(n => !n.IsRead))
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="MarkAllReadAsync">Mark all as read</MudButton>
            }
        </div>

        @if (_loading)
        {
            <MudText>Loading…</MudText>
        }
        else if (_notifications.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">No notifications yet.</MudText>
        }
        else
        {
            <MudStack Spacing="2">
                @foreach (var n in _notifications)
                {
                    <MudPaper Elevation="0" Outlined="true" Class="@($"mud-pa-3 {(n.IsRead ? "" : "mud-paper-border-left-primary")}")" @key="n.Id">
                        <div class="d-flex align-items-start justify-space-between gap-3">
                            <div class="d-flex flex-column gap-1">
                                <MudLink Href="@($"/submissions/{n.SubmissionId}")">@n.SubmissionTitle</MudLink>
                                <MudText Typo="Typo.body2">@n.Message</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@n.CreatedAt.ToLocalTime().ToString("g")</MudText>
                            </div>
                            @if (!n.IsRead)
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="() => MarkReadAsync(n.Id)">Dismiss</MudButton>
                            }
                        </div>
                    </MudPaper>
                }
            </MudStack>
        }
    </MudContainer>
}

@code {
    private List<FoundryNotificationDto> _notifications = [];
    private bool _loading = true;
    private bool _dataLoaded;

    protected override void OnInitialized()
    {
        // If auth is not yet ready the OnAfterRenderAsync path will pick up the load
        // once MainLayout signals IsAuthReady. Set _loading=false now so the spinner
        // doesn't show while the auth check is still running.
        if (!AuthState.IsAuthReady)
            _loading = false;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthReady || !AuthState.IsLoggedIn) { _loading = false; return; }
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (AuthState.IsLoggedIn && !_dataLoaded)
        {
            _loading = true;
            await LoadDataAsync();
            StateHasChanged();
        }
    }

    private async Task LoadDataAsync()
    {
        _dataLoaded = true;
        _notifications = (await Api.GetNotificationsAsync()).ToList();
        _loading = false;
    }

    private async Task MarkReadAsync(Guid id)
    {
        await Api.MarkNotificationReadAsync(id);
        var idx = _notifications.FindIndex(n => n.Id == id);
        if (idx >= 0)
            _notifications[idx] = _notifications[idx] with { IsRead = true };
    }

    private async Task MarkAllReadAsync()
    {
        var unread = _notifications.Where(n => !n.IsRead).ToList();
        foreach (var n in unread)
            await MarkReadAsync(n.Id);
    }
}
