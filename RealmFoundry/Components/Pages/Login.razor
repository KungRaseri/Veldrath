@page "/login"
@inject NavigationManager Nav
@inject IConfiguration Config

<PageTitle>Sign In — RealmFoundry</PageTitle>

<div class="auth-card">
    <h1>Sign In</h1>

    @if (PendingLinkParam is not null)
    {
        <div class="alert alert-info">
            <strong>One more step!</strong> We've sent a confirmation link to your email address.
            Click it to finish linking your account with this provider, then sign in again.
        </div>
    }
    @if (ErrorParam is not null)
    {
        <div class="alert alert-error">
            <strong>Sign-in failed.</strong> Something went wrong during authentication. Please try again.
        </div>
    }

    <p class="lead">Choose a provider to log into RealmFoundry.</p>

    <div class="oauth-buttons">
        <a class="btn btn-discord" href="@_discordUrl">
            Sign in with Discord
        </a>
        <a class="btn btn-google" href="@_googleUrl">
            Sign in with Google
        </a>
        <a class="btn btn-microsoft" href="@_msUrl">
            Sign in with Microsoft
        </a>
    </div>

    <p style="margin-top:1.5rem;text-align:center;font-size:.9rem">
        <a href="/forgot-password">Forgot your password?</a>
    </p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "pending_link")] private string? PendingLinkParam { get; set; }
    [SupplyParameterFromQuery(Name = "error")]        private string? ErrorParam        { get; set; }

    private string _discordUrl   = "#";
    private string _googleUrl    = "#";
    private string _msUrl        = "#";

    protected override void OnInitialized()
    {
        // PublicServerUrl is the browser-reachable address; ServerUrl may be an internal Docker hostname.
        var serverUrl = (Config["Veldrath:PublicServerUrl"] ?? Config["Veldrath:ServerUrl"])?.TrimEnd('/') ?? "";
        // The server will append ?code=&aid= to this URL after a successful OAuth exchange.
        // The /auth/start-session endpoint reads those params, sets the rt HttpOnly cookie,
        // and redirects to / so the next SSR pass can restore auth via PersistingAuthState.
        var callbackBase = Nav.BaseUri.TrimEnd('/') + "/auth/start-session";

        _discordUrl   = $"{serverUrl}/api/auth/external/discord?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _googleUrl    = $"{serverUrl}/api/auth/external/google?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _msUrl        = $"{serverUrl}/api/auth/external/microsoft?returnUrl={Uri.EscapeDataString(callbackBase)}";
    }
}
