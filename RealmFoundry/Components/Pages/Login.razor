@page "/login"
@inject NavigationManager Nav
@inject IConfiguration Config

<PageTitle>Sign In — RealmFoundry</PageTitle>

<div class="auth-card">
    <h1>Sign In</h1>
    <p class="lead">Choose a provider to log into RealmFoundry.</p>

    <div class="oauth-buttons">
        <a class="btn btn-discord" href="@_discordUrl">
            Sign in with Discord
        </a>
        <a class="btn btn-google" href="@_googleUrl">
            Sign in with Google
        </a>
        <a class="btn btn-microsoft" href="@_msUrl">
            Sign in with Microsoft
        </a>
    </div>
</div>

@code {
    private string _discordUrl   = "#";
    private string _googleUrl    = "#";
    private string _msUrl        = "#";

    protected override void OnInitialized()
    {
        // PublicServerUrl is the browser-reachable address; ServerUrl may be an internal Docker hostname.
        var serverUrl = (Config["RealmUnbound:PublicServerUrl"] ?? Config["RealmUnbound:ServerUrl"])?.TrimEnd('/') ?? "";
        // The return URL is this Blazor app's /auth/callback route where we'll
        // receive the JWT from the server's redirect and update AuthStateService.
        var callbackBase = Nav.BaseUri.TrimEnd('/') + "/auth/callback";

        _discordUrl   = $"{serverUrl}/api/auth/external/discord?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _googleUrl    = $"{serverUrl}/api/auth/external/google?returnUrl={Uri.EscapeDataString(callbackBase)}";
        _msUrl        = $"{serverUrl}/api/auth/external/microsoft?returnUrl={Uri.EscapeDataString(callbackBase)}";
    }
}
