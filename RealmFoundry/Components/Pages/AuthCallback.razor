@page "/auth/callback"
@using System.Text.Json
@using System.Text.Encodings.Web

<PageTitle>Signing in… — RealmFoundry</PageTitle>

@if (_payload is not null)
{
    <p>Signing you in…</p>
    @* Inline script runs immediately on page load — before blazor.web.js even initialises.
       JavaScriptEncoder.Default renders <, >, &, ' as Unicode escapes so the JSON blob is
       safe to embed inside a <script> tag without any risk of script injection. *@
    <script>
        (function () {
            try {
                var d = @((MarkupString)_payload);
                sessionStorage.setItem('rf_access',       d.a);
                sessionStorage.setItem('rf_refresh',      d.r);
                sessionStorage.setItem('rf_username',     d.u);
                sessionStorage.setItem('rf_account_id',   d.i);
                sessionStorage.setItem('rf_is_curator',   d.c ? 'true' : 'false');
                sessionStorage.setItem('rf_token_expiry', d.e);
            } catch (_) { /* storage quota or unavailable */ }
            window.location.replace('/');
        })();
    </script>
}
else
{
    <p class="error">Login failed: @_error. <a href="/login">Try again</a>.</p>
}

@code {
    // SupplyParameterFromQuery works in static SSR — the router binds these
    // directly from the OAuth redirect query string during the SSR pass.
    [SupplyParameterFromQuery] private string? Jwt     { get; set; }
    [SupplyParameterFromQuery] private string? Refresh { get; set; }
    [SupplyParameterFromQuery] private string? Expires { get; set; }

    private string? _payload;
    private string  _error = "Login failed.";

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Jwt))
        {
            _error = "No token received.";
            return;
        }

        var parts = Jwt.Split('.');
        if (parts.Length != 3)
        {
            _error = "Invalid token format.";
            return;
        }

        Dictionary<string, JsonElement>? claims;
        try
        {
            var b64   = parts[1].Replace('-', '+').Replace('_', '/');
            b64       = b64.PadRight(b64.Length + (4 - b64.Length % 4) % 4, '=');
            claims    = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(Convert.FromBase64String(b64));
        }
        catch
        {
            _error = "Could not read token payload.";
            return;
        }

        if (claims is null) { _error = "Empty token payload."; return; }

        var username = (claims.TryGetValue("unique_name", out var un) ? un.GetString() : null)
            ?? (claims.TryGetValue("name", out var n) ? n.GetString() : null)
            ?? "unknown";

        if (!claims.TryGetValue("sub", out var subEl) || !Guid.TryParse(subEl.GetString(), out var accountId))
        {
            _error = "Invalid account claim.";
            return;
        }

        var isCurator = claims.TryGetValue("role", out var roleEl)
            && roleEl.ValueKind == JsonValueKind.String
            && roleEl.GetString() == "Curator";

        var expiry = long.TryParse(Expires, out var unix)
            ? DateTimeOffset.FromUnixTimeSeconds(unix).ToString("O")
            : DateTimeOffset.UtcNow.AddMinutes(15).ToString("O");

        // JavaScriptEncoder.Default escapes <, >, &, ' and " as \uXXXX — safe to embed in <script>.
        _payload = JsonSerializer.Serialize(new
        {
            a = Jwt,
            r = Refresh ?? "",
            u = username,
            i = accountId.ToString(),
            c = isCurator,
            e = expiry
        }, new JsonSerializerOptions { Encoder = JavaScriptEncoder.Default });
    }
}
