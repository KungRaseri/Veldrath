@* No @page directive — used as a child component in App.razor. *@
@* SSR-only component (no @rendermode). Runs once during the HTTP request's SSR pass: *@
@*   - reads the refreshed AuthResponse placed in HttpContext.Items by the cookie *@
@*     refresh middleware                                                           *@
@*   - applies it to the SSR-scoped AuthStateService so the prerendered HTML       *@
@*     already shows the logged-in nav (no flash)                                  *@
@*   - embeds it via PersistentComponentState so the interactive circuit can read  *@
@*     it in MainLayout.OnInitialized, which runs before any page component        *@
@implements IDisposable

@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject AuthStateService AuthState

@* Renders nothing — purely performs auth bootstrapping. *@

@code {
    private PersistingComponentStateSubscription _subscription;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        // ── SSR pass only ────────────────────────────────────────────────────
        // CookieRefreshMiddleware (Program.cs) has already rotated the rt cookie
        // and stored the refreshed AuthResponse in HttpContext.Items before Blazor
        // rendered. Reading from Items avoids any async work here — writing cookies
        // after an await causes "Headers are read-only, response has already started."
        // This component has no @rendermode so it never runs in the Blazor circuit;
        // auth state restoration in the circuit is handled by MainLayout.OnInitialized.
        var ctx = HttpContextAccessor.HttpContext;
        if (ctx?.Items["auth-state"] is not AuthResponse refreshed) return;

        // Apply to the SSR-scoped AuthStateService so the prerendered HTML renders
        // with the correct logged-in state rather than flashing "Sign in".
        await AuthState.SetTokensAsync(refreshed);

        // Embed the AuthResponse in the prerendered HTML so MainLayout can restore
        // it via TryTakeFromJson during the circuit's OnInitialized, which is
        // guaranteed to run before any page component initialises.
        _subscription = ApplicationState.RegisterOnPersisting(() =>
        {
            ApplicationState.PersistAsJson("auth-state", refreshed);
            return Task.CompletedTask;
        });
    }

    /// <inheritdoc />
    public void Dispose() => _subscription.Dispose();
}
