{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/RealmEngine.slnx",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "build-realmforge",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/RealmForge/RealmForge.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "run-realmforge",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/RealmForge/RealmForge.csproj"
			],
			"problemMatcher": "$msCompile",
			"dependsOn": "build-realmforge",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "watch-realmforge",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"run",
				"--project",
				"${workspaceFolder}/RealmForge/RealmForge.csproj",
				"--non-interactive"
			],
			"problemMatcher": "$msCompile",
			"isBackground": true,
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": false
			},
			"options": {
				"env": {
					"DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
				}
			}
		},
		{
			"label": "test",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/Realm.Full.slnx",
				"--filter",
				"Category!=UI",
				"--verbosity",
				"normal"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-shared",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmEngine.Shared.Tests/RealmEngine.Shared.Tests.csproj"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-core",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmEngine.Core.Tests/RealmEngine.Core.Tests.csproj"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-data",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmEngine.Data.Tests/RealmEngine.Data.Tests.csproj"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmforge-unit",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmForge.Tests/RealmForge.Tests.csproj",
				"--filter",
				"Category=ViewModel"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmforge-ui",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmForge.Tests/RealmForge.Tests.csproj",
				"--filter",
				"Category=UI"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmforge-integration",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmForge.Tests/RealmForge.Tests.csproj",
				"--filter",
				"Category=Integration"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmforge-all",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmForge.Tests/RealmForge.Tests.csproj"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-with-coverage",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/Realm.Full.slnx",
				"--filter",
				"Category!=UI",
				"--collect",
				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "generate-coverage-report",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/generate-coverage-report.ps1"
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "test-coverage",
			"dependsOn": [
				"test-with-coverage",
				"generate-coverage-report"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "clean",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"clean",
				"${workspaceFolder}/RealmEngine.slnx"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "rebuild",
			"dependsOn": [
				"clean",
				"build"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "build-package",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/build-game-package.ps1",
				"-Configuration",
				"Debug"
			],
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "build-package-release",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/build-game-package.ps1",
				"-Configuration",
				"Release"
			],
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "generate-version",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/generate-version.ps1",
				"-OutputFormat",
				"string"
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "deploy-to-godot",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/deploy-to-godot.ps1",
				"-GodotProjectPath",
				"${input:godotProjectPath}",
				"-PackagePath",
				"package"
			],
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "package-and-deploy",
			"dependsOn": [
				"build-package",
				"deploy-to-godot"
			],
			"dependsOrder": "sequence",
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},

		// ── RealmUnbound ─────────────────────────────────────────────────────────
		{
			"label": "build-realmunbound-server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/RealmUnbound.Server/RealmUnbound.Server.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "build-realmunbound-client",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/RealmUnbound.Client/RealmUnbound.Client.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "run-realmunbound-server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/RealmUnbound.Server/RealmUnbound.Server.csproj",
				"--no-build"
			],
			"isBackground": true,
			"dependsOn": "build-realmunbound-server",
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "RealmUnbound\\.Server starting",
					"endsPattern": "Now listening on:"
				}
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "run-realmunbound-client",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/RealmUnbound.Client/RealmUnbound.Client.csproj",
				"--no-build"
			],
			"dependsOn": "build-realmunbound-client",
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "test-realmunbound-server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmUnbound.Server.Tests/RealmUnbound.Server.Tests.csproj",
				"--verbosity",
				"normal"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmunbound-client",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmUnbound.Client.Tests/RealmUnbound.Client.Tests.csproj",
				"--verbosity",
				"normal"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmunbound-all",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmUnbound.slnx",
				"--verbosity",
				"normal"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},

		// ── Docker ───────────────────────────────────────────────────────────────
		{
			"label": "docker-compose-up",
			"type": "shell",
			"command": "docker",
			"args": ["compose", "up", "--build", "-d"],
			"options": { "cwd": "${workspaceFolder}" },
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "docker-compose-up-db",
			"type": "shell",
			"command": "docker",
			"args": ["compose", "up", "postgres", "-d"],
			"options": { "cwd": "${workspaceFolder}" },
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"clear": false
			}
		},
		{
			"label": "docker-compose-down",
			"type": "shell",
			"command": "docker",
			"args": ["compose", "down"],
			"options": { "cwd": "${workspaceFolder}" },
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"clear": false
			}
		}
	],
	"inputs": [
		{
			"id": "godotProjectPath",
			"type": "promptString",
			"description": "Enter the path to your Godot project directory",
			"default": "C:\\path\\to\\your\\godot\\project"
		}
	]
}