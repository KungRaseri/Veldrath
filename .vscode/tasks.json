			}
		},
		{
			"label": "test-realmforge-all",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmForge.Tests/RealmForge.Tests.csproj",
				"--collect",
				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-with-coverage",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/Realm.Full.slnx",
				"--filter",
				"Category!=UI",
				"--collect",
				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "generate-coverage-report",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/generate-coverage-report.ps1"
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "test-coverage",
			"dependsOn": [
				"test-with-coverage",
				"generate-coverage-report"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "clean",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"clean",
				"${workspaceFolder}/Realm.Full.slnx"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "rebuild",
			"dependsOn": [
				"clean",
				"build"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "generate-version",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/generate-version.ps1",
				"-OutputFormat",
				"string"
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "download-assets",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-File",
				"${workspaceFolder}/scripts/download-assets.ps1"
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"clear": true
			}
		},
		// ── RealmUnbound ─────────────────────────────────────────────────────────
		{
			"label": "build-realmunbound-server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/RealmUnbound.Server/RealmUnbound.Server.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "build-realmunbound-client",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/RealmUnbound.Client/RealmUnbound.Client.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "run-realmunbound-server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/RealmUnbound.Server/RealmUnbound.Server.csproj",
				"--no-build"
			],
			"isBackground": true,
			"dependsOn": "build-realmunbound-server",
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "RealmUnbound\\.Server starting",
					"endsPattern": "Now listening on:"
				}
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "run-realmunbound-client",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/RealmUnbound.Client/RealmUnbound.Client.csproj",
				"--no-build"
			],
			"dependsOn": "build-realmunbound-client",
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "test-realmunbound-server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmUnbound.Server.Tests/RealmUnbound.Server.Tests.csproj",
				"--verbosity",
				"normal",
				"--collect",
				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmunbound-client",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmUnbound.Client.Tests/RealmUnbound.Client.Tests.csproj",
				"--filter",
				"Category!=UI",
				"--verbosity",
				"normal",
				"--collect",
				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-realmunbound-all",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/RealmUnbound.slnx",
				"--filter",
				"Category!=UI",
				"--verbosity",
				"normal",
				"--collect",
				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
