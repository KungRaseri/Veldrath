{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/Realm.Full.slnx",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "build-realmforge",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/RealmForge/RealmForge.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "run-realmforge",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/RealmForge/RealmForge.csproj"
			],
			"problemMatcher": "$msCompile",
			"dependsOn": "build-realmforge",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "watch-realmforge",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"run",
				"--project",
				"${workspaceFolder}/RealmForge/RealmForge.csproj",
				"--non-interactive"
			],
			"problemMatcher": "$msCompile",
			"isBackground": true,
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"clear": false
			},
			"options": {
				"env": {
					"DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
				}
			}
		},
		{
			"label": "test",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/Realm.Full.slnx",
				"--filter",
				"Category!=UI",
				"--verbosity",
				"normal",
				"--collect",
				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "test-shared",
			"type": "shell",
			"command": "dotnet",
