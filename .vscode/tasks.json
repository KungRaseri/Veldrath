				"XPlat Code Coverage",
				"--settings",
				"coverage.runsettings",
				"--results-directory",
				"${workspaceFolder}/coverage-results"
			],
			"problemMatcher": "$msCompile",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
