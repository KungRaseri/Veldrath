{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "RealmForge (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-realmforge",
            "program": "${workspaceFolder}/RealmForge/bin/Debug/net10.0-windows10.0.19041.0/RealmForge.dll",
            "args": [],
            "cwd": "${workspaceFolder}/RealmForge",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Test: RealmEngine.Shared.Tests",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "test-shared",
            "program": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/RealmEngine.Shared.Tests/RealmEngine.Shared.Tests.csproj",
                "--no-build"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Test: RealmEngine.Core.Tests",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "test-core",
            "program": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/RealmEngine.Core.Tests/RealmEngine.Core.Tests.csproj",
                "--no-build"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Test: RealmEngine.Data.Tests",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "test-data",
            "program": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/RealmEngine.Data.Tests/RealmEngine.Data.Tests.csproj",
                "--no-build"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Test: All Tests",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/RealmEngine.slnx",
                "--filter",
                "Category!=UI",
                "--no-build"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        },

        // ── RealmUnbound ─────────────────────────────────────────────────────────
        {
            "name": "RealmUnbound Server (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-realmunbound-server",
            "program": "${workspaceFolder}/RealmUnbound.Server/bin/Debug/net10.0/RealmUnbound.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/RealmUnbound.Server",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "RealmUnbound Client (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-realmunbound-client",
            "program": "${workspaceFolder}/RealmUnbound.Client/bin/Debug/net10.0/RealmUnbound.Client.exe",
            "args": [],
            "cwd": "${workspaceFolder}/RealmUnbound.Client",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Test: RealmUnbound.Server.Tests",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "test-realmunbound-server",
            "program": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/RealmUnbound.Server.Tests/RealmUnbound.Server.Tests.csproj",
                "--no-build"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        }
    ],

    "compounds": [
        {
            "name": "RealmUnbound (Full Stack)",
            "configurations": ["RealmUnbound Server (Debug)", "RealmUnbound Client (Debug)"],
            "stopAll": true
        }
    ]
}